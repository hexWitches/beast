@base <https://w3id.org/beast/ontology> .
@prefix : <https://w3id.org/beast/ontology#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix schema: <https://schema.org/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix creon: <http://www.ontologydesignpatterns.org/ont/creativity/creon.owl#> .
@prefix cito: <http://purl.org/spar/cito/> .

<https://w3id.org/beast/ontology> rdf:type owl:Ontology ;
    dcterms:title "BEAST Ontology"@en ;
    dcterms:description "An ontology for the description of bestiaries and creatures, their historical terminology, biological components, and symbolic implications."@en ;
    dcterms:creator "Maria Juliana Gamboa Nivia",
        "Miriana Pinto",
        "Sara Roggiani",
        "Alice Spadavecchia" ;
    dcterms:created "2026-05-01"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:publisher <https://github.com/hexWitches> ;
    schema:codeRepository <https://github.com/hexWitches/beast> ;
    vann:preferredNamespacePrefix "beast" ;
    dcterms:bibliographicCitation "Durand, G. (1972). Le Strutture Antropologiche dell'Immaginario: introduzione all'archetipologia generale" ;
    rdfs:comment "The BEAST ontology is structured into three interconnected modules: the Provenance Module documents the textual sources, interpretations and linguistic evolution of creature terminology; the Biological Module defines the morphological and behavioral traits of both real and imaginary beings appearing within bestiaries; the Symbolic Module provides a multidimensional framework for the analysis of creatures across art and literature. By integrating Gilbert Durand's anthropological structures of the imaginary with the study of creative sources, this module interprets creatures not just as biological entitites, but as cultural and archetypal figures transforming biological reality into symbolic reality."@en .

# ===== BEAST ONTOLOGY ================
# ===== CLASSES ================
:Module rdf:type owl:Class ;
    rdfs:label "Module" ;
    rdfs:comment "Top level class for organizing the ontology architecture into three distinct layers (Provenance, Biological, Symbolic)."@en .

# ===== MODULE 1 - PROVENANCE AND IDENTITY LAYER ================
# ===== CLASSES ================
:Nomenclature rdf:type owl:Class ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Nomenclature"@en ;
    rdfs:comment "The precise linguistic term used within a Source to label an creature. Nomenclature functions at two levels of granularity: it can be assigned to a broad species (e.g. linking the class Creature to the standard term Lion), or it can be assigned directly to a source-specific Interpretation to capture contextual, poetic, or stylistic word choices used by a particular creator (e.g., labeling a specific textual variant as a Monster)."@en .

:Etymology rdf:type owl:Class ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Etymology"@en ;
    rdfs:comment "The etymology of a Nomenclature denoting creatures."@en .

:Language rdf:type owl:Class ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Language"@en ;
    rdfs:comment "The specific human language of origin for a given term (e.g. Latin, Ancient Greek)."@en .

:Interpretation rdf:type owl:Class ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Interpretation"@en ;
    rdfs:comment "A specific conceptualization, reading, or artistic depiction of a creature as conceived by a particular creator within a specific Source. It distinguishes the universal concept of a Creature from its specific variations, allowing researchers to document how a single beast's anatomy, behavior, or allegorical meaning mutates when handled by different authors, artists, or historical periods."@en .

:Source rdf:type owl:Class ;
    rdfs:subClassOf schema:CreativeWork ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Source"@en ;
    rdfs:comment "A primary text, manuscript, or artifact where a creature is described or depicted."@en .

:Creature rdf:type owl:Class ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Creature"@en ;
    rdfs:comment "Any living entity, whether based in biological reality or imagination, described within a Source. It serves as the central node tying together all historical, biological and symbolic variations."@en .

:Bestiary rdf:type owl:Class ;
    rdfs:subClassOf :Source ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Bestiary"@en ;
    rdfs:comment "A specific type of compendium cataloging various animals and imaginary creatures."@en .

:BestiaryType rdf:type owl:Class ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Bestiary Type"@en ;
    rdfs:comment "The thematic or functional classification of a bestiary."@en .

:LiteraryWork rdf:type owl:Class ;
    rdfs:subClassOf :Source ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Literary work"@en ;
    rdfs:comment "A written source text, such as a poem or novel, in which a creature is described, cited, or appears."@en .

:VisualArtwork rdf:type owl:Class ;
    rdfs:subClassOf creon:CreativeProduct ;
    rdfs:subClassOf :Source ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Visual artwork"@en ;
    rdfs:comment "A visual representation, such as an illumination, painting, or sculpture, depicting a creature."@en .

:CinematicWork rdf:type owl:Class ;
    rdfs:subClassOf creon:CreativeProduct ;
    rdfs:subClassOf :Source ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "CinematicWork"@en ;
    rdfs:comment "A cinematographic work serving as a modern source for creature depictions."@en .

[] rdf:type owl:AllDisjointClasses ;
    owl:members (:Source :Creature :Interpretation) .

# ===== OBJECT PROPERTIES ================
:hasEtymology rdf:type owl:ObjectProperty ;
    rdfs:domain :Nomenclature ;
    rdfs:range :Etymology ;
    owl:inverseOf :isEtymologyOf ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "has etymology"@en ;
    rdfs:comment "Links a specific linguistic term to the documented history of its origin."@en .

:isEtymologyOf rdf:type owl:ObjectProperty ;
    rdfs:domain :Etymology ;
    rdfs:range :Nomenclature ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "is etymology of"@en ;
    rdfs:comment "Links an etymological origin back to the modern or targeted term it resulted in."@en .

:derivesFromLanguage rdf:type owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain :Etymology ;
    rdfs:range :Language ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "derives from language"@en ;
    rdfs:comment "Identifies the source language from which an etymological root originates."@en .

:ofCreature rdf:type owl:ObjectProperty ;
    rdfs:domain :Interpretation ;
    rdfs:range :Creature ;
    rdfs:isDefinedBy :ProvenanceModule ;
    owl:inverseOf :hasInterpretation ;
    rdfs:label "of creature"@en ;
    rdfs:comment "The property linking an interpretation with a creature."@en .

:hasInterpretation rdf:type owl:ObjectProperty ;
    rdfs:domain :Creature ;
    rdfs:range :Interpretation ;
    rdfs:label "has interpretation"@en ;
    rdfs:comment "Links a universal creature concept to its specific occurrences in a Source."@en .

:appearsIn rdf:type owl:ObjectProperty ;
    rdfs:domain :Interpretation ;
    rdfs:range :Source ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "appears in"@en ;
    rdfs:comment "Links a creature occurrence to the specific Source where it is mentioned."@en .

:hasBestiaryType rdf:type owl:ObjectProperty ;
    rdfs:domain :Bestiary ;
    rdfs:range :BestiaryType ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "has genre"@en ;
    rdfs:comment "Defines the primary intent or literary genre of the bestiary"@en .

:cites rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf cito:cites ;
    rdfs:domain :Source ;
    rdfs:range :Source ;
    rdfs:label "cites"@en ;
    rdfs:comment "Indicates an explicit intertextual relationship where one primary Source directly mentions, quotes, copies, or references an earlier primary Source."@en .

:hasNomenclature rdf:type owl:ObjectProperty ;
    rdfs:domain [ rdf:type owl:Class ;
                    owl:unionOf (:Creature :Interpretation) ] ;
    rdfs:range :Nomenclature ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "uses nomenclature"@en ;
    rdfs:comment "Links a general Creature or a specific Interpretation to the precise linguistic term used to identify it."@en .

:wasInfluencedBy rdf:type owl:ObjectProperty, owl:TransitiveProperty ;      # transitive property means that if A was influenced by B, and B by C, then A was influenced by C
    rdfs:subPropertyOf prov:wasInfluencedBy ;
    rdfs:domain :Source ;
    rdfs:range :Source ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "was influenced by"@en ;
    rdfs:comment "Indicates that a Source drew thematic, stylistic, or conceptual inspiration from an earlier work, even without a direct citation."@en .

# ===== DATA PROPERTIES ================
:hasRootTerm rdf:type owl:DatatypeProperty ;
    rdfs:domain :Etymology ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "has root term"@en ;
    rdfs:comment "The literal string representation of the original word."@en .

:hasMeaning rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf owl:topDataProperty ;
    rdfs:domain [ rdf:type owl:Class ;
                    owl:unionOf (:Etymology :Interpretation :Archetype)] ;
    rdfs:range xsd:string ;
    rdfs:label "has meaning"@en ;
    rdfs:comment "The literal string translation or definition of the root term."@en .

# ===== MODULE 2 - BIOLOGICAL AND STRUCTURAL LAYER ================
# ===== CLASSES ================
:ImaginaryBeing rdf:type owl:Class ;
    rdfs:subClassOf :Creature ;
    rdfs:isDefinedBy :BiologicalModule ;
    owl:disjointWith :RealAnimal ;
    rdfs:label "Imaginary being"@en ;
    rdfs:comment "A creature that does not exist in the natural world, originating from folklore, myth, or literary invention."@en .

:CompositeCreature rdf:type owl:Class ;
    rdfs:subClassOf :ImaginaryBeing ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Composite creature"@en ;
    rdfs:comment "A creature composed of disparate parts, whether those parts are from different animals or distinct materials."@en .

:HybridCreature rdf:type owl:Class ;
    rdfs:subClassOf :CompositeCreature ,
        [
            rdf:type owl:Restriction ;
            owl:onProperty :hasPartDerivedFrom ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass :RealAnimal
        ] ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Hybrid creature"@en ;
    rdfs:comment "A specific type of imaginary being composed of anatomical parts from two or more distinct real animals."@en .

:RealAnimal rdf:type owl:Class ;
    rdfs:subClassOf :Creature ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Real animal"@en ;
    rdfs:comment "A scientifically recognized biological animal that exists or existed in the natural world."@en .

:Plant rdf:type owl:Class ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Plant"@en ;
    rdfs:comment "A living organism belonging to the botanical kingdom, often serving as a biological component in composite creatures (e.g. roots or branches)."@en .

:InanimateElement rdf:type owl:Class ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Inanimate element"@en ;
    rdfs:comment "Non-living matter or material (e.g. stone and metal) that forms part of a creature's physical anatomy."@en .

:AnatomicalPart rdf:type owl:Class ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Anatomical part"@en ;
    rdfs:comment "An anatomical component of a creature's body, such as a head, limb or tail."@en .

:Ability rdf:type owl:Class ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Ability"@en ;
    rdfs:comment "A specific behavior, movement, or activity performed by a creature."@en .

:Habitat rdf:type owl:Class ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Habitat"@en ;
    rdfs:comment "The natural or mythological environment in which a creature lives or is commonly found."@en .

:RealWorldPlace rdf:type owl:Class ;
    rdfs:subClassOf :Habitat ;
    owl:disjointWith :ImaginaryPlace ;
    rdfs:label "Real-world place"@en ;
    rdfs:comment "A geographic or ecological habitat that exists in the physical world. Class influenced by J. L. Borges' distinction bewteen biological reality and the imaginary spaces."@en .

:ImaginaryPlace rdf:type owl:Class ;
    rdfs:subClassOf :Habitat ;
    rdfs:label "Imaginary place"@en ;
    rdfs:comment "A conceptual, magical, or purely literary space (e.g. the Garden of Eden or Hades). As noted by Borges, these spaces follow the laws of imagination rather than biology."@en .

:Anomaly rdf:type owl:Class ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Anomaly"@en ;
    rdfs:comment "A physical deformity or monstrous irregularity exhibited by a creature, distinguishing it from standard anatomy."@en .

:Diet rdf:type owl:Class ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Diet"@en ;
    rdfs:comment "The standard food consumption habits of a creature."@en .

[] rdf:type owl:AllDisjointClasses ;
    owl:members (:RealAnimal :Plant :InanimateElement) .

# ===== OBJECT PROPERTIES ================
:hasAbility rdf:type owl:ObjectProperty ;
    rdfs:domain :Creature ;
    rdfs:range :Ability ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has ability"@en ;
    rdfs:comment "Links a creature to a specific behavior or physical action it is known for."@en .

:hasAnatomicalPart rdf:type owl:ObjectProperty ;
    rdfs:domain :Creature ;
    rdfs:range :AnatomicalPart ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has anatomical part"@en ;
    rdfs:comment "Connects a creature to a specific structural or morphological component of its body."@en .

:hasPartDerivedFrom rdf:type owl:ObjectProperty ;
    rdfs:domain :CompositeCreature ;
    rdfs:range [ rdf:type owl:Class ;
            owl:unionOf (:RealAnimal :Plant :InanimateElement) ] ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has part of"@en ;
    rdfs:comment "Indicates that a composite creature possesses anatomical or morphological features derived from a specific real animal, a plant or an inanimate element."@en .

:hasHeadOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasPartDerivedFrom ;
    rdfs:range :RealAnimal ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has head of"@en ;
    rdfs:comment "Specifies the head structure of a creature."@en .

:hasLimbsOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasPartDerivedFrom ;
    rdfs:range :RealAnimal ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has limbs of"@en ;
    rdfs:comment "Specifies the limbs (arms, legs, wings) of a creature."@en .

:hasBodyOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasPartDerivedFrom ;
    rdfs:range :RealAnimal ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has body of"@en ;
    rdfs:comment "Specifies the main torso or body structure of a creature."@en .

:hasTailOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasPartDerivedFrom ;
    rdfs:range :RealAnimal ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has tail of"@en ;
    rdfs:comment "Specifies the tail structure of a creature."@en .

:hasHabitat rdf:type owl:ObjectProperty ;
    rdfs:domain :Creature ;
    rdfs:range :Habitat ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has habitat"@en ;
    rdfs:comment "Connects a creature to the environment it natively inhabits."@en .

:hasDeformity rdf:type owl:ObjectProperty ;
    rdfs:domain :RealAnimal ;
    rdfs:range :Anomaly ;
    rdfs:label "has deformity"@en ;
    rdfs:comment "Indicates that a creature suffers from or exhibits a specific anomaly."@en .

:affectsPart rdf:type owl:ObjectProperty ;
    rdfs:domain :Anomaly ;
    rdfs:range :AnatomicalPart ;
    rdfs:label "affects part" ;
    rdfs:comment "Indicates the anatomical structure altered, deformed, duplicated, absent, or otherwise modified by an anomaly."@en .

:hasDiet rdf:type owl:ObjectProperty ,
                    owl:FunctionalProperty ;
    rdfs:domain :Creature ;
    rdfs:range :Diet ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has diet"@en ;
    rdfs:comment "Specifies the feeding classification (e.g. carnivorous) of the creature."@en .

# ===== MODULE 3 - SYMBOLIC AND ANALYSIS LAYER ================
# ===== CLASSES ================
:Archetype rdf:type owl:Class , 
                    skos:Concept ;
    rdfs:label "Archetype"@en ;
    rdfs:comment "A universal, primordial pattern or character prototype residing in the collective human imagination. Within the ontology, the class serves as the ultimate analytical anchor that bridges the historical world with the symbolic world, linking a source-bound Interpretation of a Creature directly to its deeper allegorical, spiritual, or psychological meaning."@en .

# DURAND SCHEME
:DurandImaginary rdf:type skos:ConceptScheme ;
    dcterms:title "Durand's structures of the Imaginary"@en ;
    skos:hasTopConcept :Regime , :ImaginaryStructure ;
    prov:wasDerivedFrom "Durand, G. (1972). Le Strutture Antropologiche dell'Immaginario: introduzione all'archetipologia generale" ;
    rdfs:comment "A conceptual scheme providing a framework for the symbolic and anthropological analysis of creatures within bestiaries. It acts as the theoretical pivot of the Symbolic Module, allowing for the classification of beasts and their attributes based on their relationship with human anxiety regarding time and death. By applying Gilbert Durand's regimes and structures defined in 'Les Structures Anthropologiques de l'Imaginaire', 'beast' can map how physical biological traits - such as wings - serve as archetypal responses to mortality, transforming the creature from a mere biological entity into a profound cultural symbol."@en .

:Regime rdf:type owl:Class ,
                skos:Concept ;
    skos:inScheme :DurandImaginary ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "Regime"@en ;
    rdfs:comment "The fundamental high-level classification of Durand, organized around sensory-motor dominants (postural, digestive, cyclic). Regimes act as organizational systems of the imagination, condensing multiple symbolic meanings into a coherent structure."@en .

:NocturnalRegime rdf:type owl:Class , 
                        skos:Concept ;
    skos:inScheme :DurandImaginary ;
    skos:broader :Regime ;
    rdfs:isDefinedBy :SymbolicModule ;
    owl:disjointWith :DiurnalRegime ;
    rdfs:label "Nocturnal Regime"@en ;
    rdfs:comment "The Nocturnal Regime represents an attitude of reconciliation in front of the fleeting nature of time, incorporating symbols of transformation and cyclicality. The symbols belonging to the nocturnal regime exorcise fear by transforming images into reassuring figures.
    Unlike the diurnal regime, the antidote to the passing of time is not sought on a superhuman or transcendent level, but rather in reassuring intimacy or in the rhytmic constants that govern natural phenomena. The nocturnal regime is divided into synthetic structures and mystical structures."@en .

:DiurnalRegime rdf:type owl:Class ,
                        skos:Concept ;
    skos:inScheme :DurandImaginary ;
    skos:broader :Regime ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "Diurnal Regime"@en ;
    rdfs:comment "The Diurnal Regime is characterized by the battle against death and time. It is governed by antithesis, encompassing axiomatic images that give rise to two polarized facets: a background of darkness against which the victorious splendor of light is contrasted, and antithetical reconquest of negative values. It embodies the sharp logic of the sword and heroic battles against the passage of time.
    This regime is built upon schizomorphic structures, defined by separation, fall, antithesis, and scission. It is a multifaceted regime that includes theriomorphic, nyctomorphic, catamorphic, ascensional, spectacular, and diaretic symbols. Together, these symbols express both the profound anxiety in front of time and death and the heroic drive to transcend or overcome these forces."@en .

:ImaginaryStructure rdf:type owl:Class ,
                            skos:Concept ;
    skos:inScheme :DurandImaginary ;
    rdfs:label "Imaginary Structure"@en ;
    rdfs:comment "The structural framework of the imaginary as defined by Gilbert Durand in 'Les Structures Anthropologiques de l'Imaginaire', acting as the mediating layer between biological reflexes and symbolic expression. It represents the archetypal logic that organizes a creature's physical and behavioral attributes into a coherent symbolic system. It provides the protocol through which raw sensory data - such as a beast's fangs, its flight, or its habitat - is transformed into a structured symbolic response (Schizomorphic, Mystical, or Synthetic) to the existential anxiety of time and death."@en .

:SchizomorphicStructure rdf:type owl:Class ;
    rdfs:subClassOf :ImaginaryStructure ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :isGovernedBy ;
          owl:someValuesFrom :DiurnalRegime ] ;
    skos:inScheme :DurandImaginary ;
    skos:broader :ImaginaryStructure ;
    rdfs:label "Schizomorphic Structure (or Heroic)"@en ;
    rdfs:comment "The Schizomorphic Structure represents the mode of the imaginary governed by the Diurnal Regime. It functions through the principles of antithesis and verticality as a defensive response to the anxiety of time. It operates via 'diaresis' – the act of cutting, dividing, and establishing absolute distinctions to maintain the separation between light and dark, height and depth. This structure organizes symbols into two polarized groups: the 'symbols of the antithesis' (teriomorphic, nyctomorphic, and catamorphic), which represent the terror of the abyss and devouring time; and the 'symbols of transcendence' (ascensional, spectacular, and diaretic), which provide the tools for the heroic reconquest through verticality, solar vision, and the purifying sword."@en .

:SyntheticStructure rdf:type owl:Class ;
    rdfs:subClassOf :ImaginaryStructure ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :isGovernedBy ;
          owl:someValuesFrom :NocturnalRegime ] ;
    skos:inScheme :DurandImaginary ;
    skos:broader :ImaginaryStructure ;
    rdfs:label "Synthetic Structure (or Dramatic)"@en ;
    rdfs:comment "Synthetic structure operates by bringing contradictions into dialogue and includes cyclical symbols. It treats time as a series of phases, where night is a necessary prelude to dawn and death is a prelude to rebirth. It transforms the fall into a slow, controlled descent, allowing for the acceptance of change and progress through the succession of opposites."@en .

:MysticalStructure rdf:type owl:Class ;
    rdfs:subClassOf :ImaginaryStructure ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :isGovernedBy ;
          owl:someValuesFrom :NocturnalRegime ] ;
    skos:inScheme :DurandImaginary ;
    skos:broader :ImaginaryStructure ;
    rdfs:label "Mystical Structure (or Antiphrastic)"@en ;
    rdfs:comment "Mystical structures include symbols of intimacy and calm, the search for light within darkness. The principles underlying mystical structures are analogy and similarity. Instead of battling against time, one enters into union with it. The mind takes images of terror and rewrites them positively, transforming them into refuge and protected space. Within this logic, opposites can coexist. In mystical structures one finds doubling and adherence rather than antithesis. It functions through inversion, doubling, and adherence, turning the devouring mouth of the diurnal regime into a protective container."@en .

:TeriomorphicSymbol rdf:type owl:Class ;
    rdfs:subClassOf :SchizomorphicStructure ;
    skos:inScheme :DurandImaginary ;
    skos:broader :SchizomorphicStructure ;
    rdfs:label "Teriomorphic Symbol"@en ;
    rdfs:comment "Teriomorphic symbol represents the terrifying aspect of animals, embodying biting, devouring, and feral chaos. As 'enemy symbol' of anxiety and darkness, it is linked to the restlessness caused by rapid, undisciplined movement. It captures the chaos of fleeing from 'devouring time' and the archetype of the predatory jaws ready to strike."@en .

:NyctomorphicSymbol rdf:type owl:Class ;
    rdfs:subClassOf :SchizomorphicStructure ;
    skos:inScheme :DurandImaginary ;
    skos:broader :SchizomorphicStructure ;
    rdfs:label "Nyctomorphic Symbol"@en ;
    rdfs:comment "Nyctomorphic symbol encapsulates the temporal symbolism of darkness, blindness, and shadows. Linked to the voracity of the night, it often incorporates the element of water - viewed here not as a source of life, but as an elusive, dark surface that doubles the abyss and reflects the formless terror of the unknown."@en .

:CatamorphicSymbol rdf:type owl:Class ;
    rdfs:subClassOf :SchizomorphicStructure ;
    skos:inScheme :DurandImaginary ;
    skos:broader :SchizomorphicStructure ;
    rdfs:label "Catamorphic Symbol"@en ;
    rdfs:comment "Catamorphic symbol embodies falling, gravity, and the physical degradation of flesh. These dynamic images of transience represent the dazzling acceleration of time during a downward plunge. Catamorphic symbol captures the existential anxiety of the fall, where movement signifies the inescapable and rapid passage of time toward death."@en .

:AscensionalSymbol rdf:type owl:Class ;
    rdfs:subClassOf :SchizomorphicStructure ;
    skos:inScheme :DurandImaginary ;
    skos:broader :SchizomorphicStructure ;
    rdfs:label "Ascensional Symbol"@en ;
    rdfs:comment "Ascensional symbol embodies heroic symbols of elevation, verticality, and transcendence. It represents the upward movement to escape the degradation of time and the symbolic refusal of death. In this structure, height is synonymous with the pure and the divine; the wing is the ascensional instrument that contradicts gravity. These symbols manifest a quest to regain lost power through movement toward metaphysical spaces (e.g., mountains), dazzling imagery (arrows, wings), and virile archetypes of celestial royalty and the warrior."@en .

:SpectacularSymbol rdf:type owl:Class ;
    rdfs:subClassOf :SchizomorphicStructure ;
    skos:inScheme :DurandImaginary ;
    skos:broader :SchizomorphicStructure ;
    rdfs:label "Spectacular Symbol"@en ;
    rdfs:comment "Spectacular symbol relates to intense light, vision, and the heroic gaze. Standing in direct opposition to darkness, it emphasizes the triumph of clarity and the 'solar power' that makes the world intelligible and thus controllable. Sight is the supreme sense of the hero, as clear vision allows for the differentiation of things and the definition of clear boundaries. In this context, light functions as a sword, cutting through obscurity to define reality."@en .

:DiareticSymbol rdf:type owl:Class ;
    rdfs:subClassOf :SchizomorphicStructure ;
    skos:inScheme :DurandImaginary ;
    skos:broader :SchizomorphicStructure ;
    rdfs:label "Diaretic Symbol"@en ;
    rdfs:comment "Diaretic symbol embodies figures of cutting, weapons, and purification, derived from the Greek term 'diairesis' (division). They represent the human need for analysis, categorization, and absolute separation to overcome natural chaos. The hero's weapon is a dual symbol of power and purity; by cutting through confusion and separating the real from the imaginary, or good from evil, the hero gains mastery over the world. In this structure, the act of separation is the primary source of intellectual and spiritual power."@en .

:CyclicalSymbol rdf:type owl:Class ;
    rdfs:subClassOf :SyntheticStructure ;
    skos:inScheme :DurandImaginary ;
    skos:broader :SyntheticStructure ;
    rdfs:label "Cyclical Symbol"@en ;
    rdfs:comment "Cyclical symbol represents the archetype of the Eternal Return and time as a series of phases. Using the moon as a primary model - being the first to die and the first to be reborn - these symbols suggest that time is a series of phases where opposites (life/death, light/dark) coexist. This 'lunar optimism' does not negate death but reintegrates it as an essential stage of an incessant, evolving movement where every sunset is a prelude to a new dawn. The repetition of opposites is also linked to evolution: it is not merely a continuous repetition of the same events. Things that change may also evolve or move forward; they may progress."@en .

:InversionSymbol rdf:type owl:Class ;
    rdfs:subClassOf :MysticalStructure ;
    skos:inScheme :DurandImaginary ;
    skos:broader :MysticalStructure ;
    rdfs:label "Inversion Symbol"@en ;
    rdfs:comment "Inversion symbol exorcises the fear of time by turning negative images into positive ones. Through an involutive process, the devouring mouth of the Diurnal Regime is transmuted into a protective nest. Instead of a heroic battle against darkness, there is a mystical union with it. This defensive mechanism employs doubling and reassuring symbols of intimacy to transform a dangerous fall into a controlled descent into the secrets of becoming."@en .

:IntimacySymbol rdf:type owl:Class ;
    rdfs:subClassOf :MysticalStructure ;
    skos:inScheme :DurandImaginary ;
    skos:broader :MysticalStructure ;
    rdfs:label "Intimacy Symbol"@en ;
    rdfs:comment "Intimacy symbol represents the center, the home, and the magical cradle. This symbol reduces the vast, terrifyng world into a controllable, safe microcosm - such as a shell, a tomb seen as a place of rest, or a secret dwelling. It marks an inversion toward interiority and the soul, where the essence of the creature is protected within a restful and familiar space. It embodies the transition from the fear of being 'swallowed' to the comfort of being 'contained'."@en .

# ALCHEMICAL SCHEME
:AlchemicalMagnumOpus rdf:type skos:ConceptScheme ;
    dcterms:title "Alchemical Magnum Opus Scheme"@en ;
    skos:hasTopConcept :Nigredo .

:Nigredo rdf:type owl:Class , skos:Concept ;
    rdfs:isDefinedBy :SymbolicModule ;
    skos:inScheme :AlchemicalMagnumOpus ;
    skos:prefLabel "Nigredo"@en ;
    rdfs:comment "The initial stage involving decomposition, rotting, or reduction of the material to its prima materia. It represents breaking down the ego or purifying raw, chaotic material."@en .

:Albedo rdf:type owl:Class , skos:Concept ;
    rdfs:isDefinedBy :SymbolicModule ;
    skos:inScheme :AlchemicalMagnumOpus ;
    skos:prefLabel "Albedo"@en ;
    rdfs:comment "The purification phase, where the material is washed to remove impurities, representing the cleansing of the spirit."@en .

:Citrinitas rdf:type owl:Class , skos:Concept ;
    rdfs:isDefinedBy :SymbolicModule ;
    skos:inScheme :AlchemicalMagnumOpus ;
    skos:prefLabel "Citrinitas"@en ;
    rdfs:comment "The transmutation of the silver into gold, or the dawning of solar light. In later traditions (after the 15th century), this stage was often merged into Rubedo."@en .

:Rubedo rdf:type owl:Class , skos:Concept ;
    rdfs:isDefinedBy :SymbolicModule ;
    skos:inScheme :AlchemicalMagnumOpus ;
    skos:prefLabel "Rubedo"@en ;
    rdfs:comment " The final stage, often representing the final realization, the union of opposing forces (like spirit and matter), and the creation of the Philosopher's Stone."@en .

# ===== OBJECT PROPERTIES ================
:symbolizes rdf:type owl:ObjectProperty ;
    rdfs:domain [ rdf:type owl:Class ; 
                  owl:unionOf (:Interpretation :AnatomicalPart :Ability) ] ;
    rdfs:range [ rdf:type owl:Class ; 
                  owl:unionOf (:ImaginaryStructure :Archetype skos:Concept) ] ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "symbolizes"@en ;
    rdfs:comment "The primary semantic bridge connecting the biological domain to the symbolic domain. It asserts that a specific physical attribute (AnatomicalPart), a behavior (Ability), or a source-specific manifestation (Interpretation) serves as a vehicle for a broader conceptual meaning (Archetype, Structure, etc.)."@en .

:embodiesArchetype rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :symbolizes ;
    rdfs:range :Archetype ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "embodies archetype"@en ;
    rdfs:comment "Indicates that a creature serves as a manifestation of a universal archetype."@en .

:belongsToImaginaryStructure rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :symbolizes ;
    rdfs:range :ImaginaryStructure ;
    rdfs:label "belongs to imaginary structure"@en ;
    rdfs:comment "Specifically links a creature or its parts to Durand's structures of the imaginary."@en .

:isGovernedBy rdf:type owl:ObjectProperty ;
    rdfs:domain :ImaginaryStructure ;
    rdfs:range :Regime ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "is governed by"@en ;
    rdfs:comment "Links one of Durand's Imaginary Structures to its overarching Regime (Diurnal or Nocturnal)."@en .

:indicatesAlchemicalStage rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :symbolizes ;
    rdfs:domain [ rdf:type owl:Class ; 
                  owl:unionOf (:Creature :AnatomicalPart :Ability) ] ;
    rdfs:range [ rdf:type owl:Class ; 
                  owl:unionOf (:Nigredo :Albedo :Citrinitas :Rubedo) ] ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "indicates alchemical stage"@en ;
    rdfs:comment "Links a creature, part, or action to a specific phase of the alchemical Magnum Opus."@en .

:followsStage rdf:type owl:ObjectProperty , owl:TransitiveProperty ;
    rdfs:domain skos:Concept ;
    rdfs:range skos:Concept ;
    rdfs:label "follows stage"@en ;
    rdfs:comment "Represents the chronological sequence of the alchemical work."@en .

# ===== DATA PROPERTIES ================
:hasDivergence rdf:type owl:DatatypeProperty ;
    rdfs:domain :Interpretation ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "has divergence"@en ;
    rdfs:comment "Links a specific Interpretation to a textual description of how it deviates from the creature's traditional representation, whether anatomically, behaviorally, or symbolically."@en .

:hasAnatomicalDivergence rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :hasDivergence ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "has anatomical divergence"@en ;
    rdfs:comment "Specifies a divergence related to the physical structure or appearance of the creature (e.g. giving wings to a traditionally wingless beast)."@en .

:hasAbilityDivergence rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :hasDivergence ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "has ability divergence"@en ;
    rdfs:comment "Specifies a divergence related to the creature's actions, powers, or behavioral traits (e.g. a fire-breathing creature that instead breathes ice)."@en .

:hasSymbolicDivergence rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :hasDivergence ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "has symbolic divergence"@en ;
    rdfs:comment "Specifies a divergence in the allegorical, moral, or cultural meaning assigned to the creature compared to its standard archetype."@en .


# ===== INDIVIDUALS - Controlled Vocabulary ================
:ProvenanceModule rdf:type owl:NamedIndividual,
                        :Module ;
    rdfs:label "Provenance module (the Anchor)" ;
    rdfs:comment "The Provenance Module documents the historical and textual footprint of a creature, distinguishing between the universal, abstract concept of a beast (Creature) and its specific manifestations (Interpretation) across various primary Sources. Furthermore, it tracks the diachronic evolution of the terminology used to name these entities, capturing etymologies and root languages."@en .

:BiologicalModule rdf:type owl:NamedIndividual ,
                        :Module ;
    rdfs:label "Biological module" ;
    rdfs:comment "The Biological Module is dedicated to the physical and behavioral traits of creatures - whether real or imaginary - as formalized in Bestiaries or other Sources. It catalogs anatomy, habitats, and diets, serving as the primary 'sensory data' that is later transformed into symbolic meaning within the artistic and literary tradition."@en .
    
:SymbolicModule rdf:type owl:NamedIndividual ,
                        :Module ;
    rdfs:label "Symbolic module" ;
    rdfs:comment "The Symbolic Module represents the analytical and allegorical layer of the ontology, where art, literature, and anthropology converge. It maps how creatures are represented in primary sources - from ancient imagery and medieval manuscripts to contemporary artworks - to decode the symbolic and archetypal logic behind their artistic creation."@en .

:Omnivorous rdf:type owl:NamedIndividual,
                    :Diet ;
    rdfs:label "Omnivorous"@en ;
    rdfs:comment "A diet consisting of both animal and plant matter."@en .

:Herbivorous rdf:type owl:NamedIndividual,
                    :Diet ;
    rdfs:label "Herbivorous"@en ;
    rdfs:comment "A diet consisting primarily of plant matter."@en .

:Carnivorous rdf:type owl:NamedIndividual,
                    :Diet ;
    rdfs:label "Carnivorous"@en ;
    rdfs:comment "A diet consisting primarily of animal meat."@en .

:Scavenger rdf:type owl:NamedIndividual,
                    :Diet ;
    rdfs:label "Scavenger"@en ;
    rdfs:comment "Creatures that eat dead organic matter."@en .

:Hematophagous rdf:type owl:NamedIndividual,
                    :Carnivorous ;
    rdfs:label "Hematophagous"@en ;
    rdfs:comment "Blood-drinkers."@en .

:Lithophagous rdf:type owl:NamedIndividual,
                    :Diet ;
    rdfs:label "Lithophagous"@en ;
    rdfs:comment "Stone-eaters."@en .

:Elemental rdf:type owl:NamedIndividual,
                    :Diet ;
    rdfs:label "Elemental"@en ;
    rdfs:comment "Creatures that eat things like fire, air, or even human souls."@en .

:Terrestrial rdf:type owl:NamedIndividual,
                    :RealWorldPlace ;
    rdfs:label "Terrestrial"@en ;
    rdfs:comment "A physical habitat primarily located on solid ground or within the earth."@en .

:Aerial rdf:type owl:NamedIndividual,
                    :RealWorldPlace ;
    rdfs:label "Aerial"@en ;
    rdfs:comment "A physical habitat located in the sky, clouds, or upper atmosphere."@en .

:Aquatic rdf:type owl:NamedIndividual,
                    :RealWorldPlace ;
    rdfs:label "Aquatic"@en ;
    rdfs:comment "A physical habitat located in or around bodies of water, such as oceans, rivers, or lakes."@en .

:ScientificTaxonomy rdf:type owl:NamedIndividual, :BestiaryType ;
    rdfs:label "Scientific Taxonomy" ;
    rdfs:comment "A genre focused on the scientific categorization and biological documentation of animals (e.g. Aldrovandi)."@en .

:LiteraryMetafiction rdf:type owl:NamedIndividual, :BestiaryType ;
    rdfs:label "Literary Metafiction" ;
    rdfs:comment "A post-modern or highly stylized genre where the bestiary is used as a narrative or literary device (e.g. Borges)."@en .

:MoralAllegory rdf:type owl:NamedIndividual, :BestiaryType ;
    rdfs:label "Moral Allegory" ;
    rdfs:comment "The traditional medieval genre where creatures are described primarily for Christian theological or moral lessons."@en .

[] rdf:type owl:AllDifferent ;
    owl:distinctMembers (
        :ScientificTaxonomy
        :LiteraryMetafiction
        :MoralAllegory
    ) .

[] rdf:type owl:AllDifferent ;
    owl:distinctMembers (
        :Omnivorous
        :Carnivorous
        :Herbivorous
        :Scavenger
        :Hematophagous
        :Lithophagous
        :Elemental
    ) .