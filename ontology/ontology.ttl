@base <https://w3id.org/beast/ontology> .
@prefix : <https://w3id.org/beast/ontology#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix schema: <https://schema.org/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix cito: <http://purl.org/spar/cito/> .
@prefix fabio: <http://purl.org/spar/fabio/> .

<https://w3id.org/beast/ontology> rdf:type owl:Ontology ;
    dcterms:title "BEAST Ontology"@en ;
    dcterms:description "An ontology for the description of creatures, their provenance, biological components and symbolic meanings."@en ;
    dcterms:creator "Maria Juliana Gamboa Nivia",
        "Miriana Pinto",
        "Sara Roggiani",
        "Alice Spadavecchia" ;
    dcterms:created "2026-05-01"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:publisher <https://github.com/hexWitches> ;
    schema:codeRepository <https://github.com/hexWitches/beast> ;
    vann:preferredNamespacePrefix "beast" ;
    dcterms:bibliographicCitation "Gamboa Nivia, M.J., Pinto, M., Roggiani, S., Spadavecchia, A. (2026). BEAST Ontology. https://w3id.org/beast/ontology"@en ;
    dcterms:references "Durand, G. (1972). Le Strutture Antropologiche dell'Immaginario: introduzione all'archetipologia generale" ;
    owl:imports <http://www.w3.org/2004/02/skos/core#> ,
        <http://www.w3.org/ns/prov-o#> ,
        <http://purl.org/spar/cito> ,
        <http://purl.org/spar/fabio> ;
    rdfs:comment "The BEAST ontology is structured into three interconnected modules. The Provenance Module documents the historical and textual footprint of creatures, distinguishing between the universal concept of a beast (Creature) and its source-specific manifestations (Interpretation) across bestiaries, literary works, visual artworks, and cinematic works; it also tracks the diachronic evolution of creature terminology through Nomenclature and Etymology. The Biological Module defines the morphological and behavioural traits of both real and imaginary beings: it catalogs anatomical composition, habitats, diets, and abilities, and documents anomalies in real animals through a structured vocabulary of absence, duplication, and modification. The Symbolic Module provides a multidimensional framework for the analysis of creatures as cultural and archetypal figures. It integrates two analytical layers: Gilbert Durand's anthropological structures of the imaginary (DurandImaginary scheme) and an archetype and narrative function layer that distinguishes the universal psychological patterns creatures embody from the contextual roles they perform in specific sources. Together the three modules enable the ontology to trace a creature from its historical attestation in a primary text, through its biological description, to its deepest symbolic resonance in the collective imagination."@en .

# ===== BEAST ONTOLOGY ================
# ===== CLASSES ================
:Module rdf:type owl:Class ;
    rdfs:label "Module"@en ;
    rdfs:comment "Top level class for organizing the ontology architecture into three distinct layers (Provenance, Biological, Symbolic)."@en .

# ===== MODULE 1 - PROVENANCE AND IDENTITY LAYER ================
# ===== CLASSES ================
:Creature rdf:type owl:Class ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Creature"@en ;
    rdfs:comment "Any living entity, whether based in biological reality or imagination, described within a Source. It serves as the central node tying together all historical, biological and symbolic variations."@en .

:Interpretation rdf:type owl:Class ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Interpretation"@en ;
    rdfs:comment "A specific conceptualization, reading, or artistic depiction of a creature as conceived by a particular creator within a specific Source. It distinguishes the universal concept of a Creature from its specific variations, allowing researchers to document how a single beast's anatomy, behavior, or allegorical meaning mutates when handled by different authors, artists, or historical periods."@en .

:Source rdf:type owl:Class ;
    rdfs:subClassOf schema:CreativeWork ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Source"@en ;
    rdfs:comment "A primary text, manuscript, or artifact where a creature is described or depicted."@en .

:Tradition rdf:type owl:Class ;
    rdfs:subClassOf :Source ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Tradition"@en ;
    rdfs:comment "A cultural, mythological, or folkloric tradition functioning as the origin context for a creature, predating or existing independently of any identifiable written source."@en .

:Bestiary rdf:type owl:Class ;
    rdfs:subClassOf :Source ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Bestiary"@en ;
    rdfs:comment "A specific type of compendium cataloging various animals and imaginary creatures."@en .

:BestiaryType rdf:type owl:Class ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Bestiary Type"@en ;
    rdfs:comment "The thematic or functional classification of a bestiary."@en .

:LiteraryWork rdf:type owl:Class ;
    rdfs:subClassOf :Source ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Literary work"@en ;
    rdfs:comment "A written source text, such as a poem or novel, in which a creature is described, cited, or appears."@en .

:VisualArtwork rdf:type owl:Class ;
    rdfs:subClassOf :Source ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Visual artwork"@en ;
    rdfs:comment "A visual representation, such as an illumination, painting, or sculpture, depicting a creature."@en .

:CinematicWork rdf:type owl:Class ;
    rdfs:subClassOf :Source ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "CinematicWork"@en ;
    rdfs:comment "A cinematographic work serving as a modern source for creature depictions."@en .

:Etymology rdf:type owl:Class ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Etymology"@en ;
    rdfs:comment "The documented linguistic origin of the name used to identify a Creature, capturing its root term, source language, and original meaning."@en .

:Citation rdf:type owl:Class ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Citation"@en ;
    rdfs:comment "A structured reference to a specific passage within a Source that documents a creature's appearance in a particular Interpretation, capturing both the precise textual location and the quoted or paraphrased content."@en .

# ===== OBJECT PROPERTIES ================
:ofCreature rdf:type owl:ObjectProperty ;
    rdfs:domain :Interpretation ;
    rdfs:range :Creature ;
    rdfs:isDefinedBy :ProvenanceModule ;
    owl:inverseOf :hasInterpretation ;
    rdfs:label "of creature"@en ;
    rdfs:comment "The property linking an interpretation with a creature."@en .

:hasInterpretation rdf:type owl:ObjectProperty ;
    rdfs:domain :Creature ;
    rdfs:range :Interpretation ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "has interpretation"@en ;
    rdfs:comment "Links a universal creature concept to its specific occurrences in a Source."@en .

:appearsIn rdf:type owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain :Interpretation ;
    rdfs:range :Source ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "appears in"@en ;
    rdfs:comment "Links an Interpretation to the specific Source where it is mentioned."@en .

:containsInterpretation rdf:type owl:ObjectProperty ;
    rdfs:domain :Source ;
    rdfs:range :Interpretation ;
    rdfs:isDefinedBy :ProvenanceModule ;
    owl:inverseOf :appearsIn ;
    rdfs:label "contains interpretation"@en ;
    rdfs:comment "Links a Source to the interpretations of creatures that appear within it."@en .

:hasBestiaryType rdf:type owl:ObjectProperty ;
    rdfs:domain :Bestiary ;
    rdfs:range :BestiaryType ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "has genre"@en ;
    rdfs:comment "Defines the primary intent or literary genre of the bestiary"@en .

:cites rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf cito:cites ;
    rdfs:domain :Source ;
    rdfs:range :Source ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "cites"@en ;
    rdfs:comment "Indicates an explicit intertextual relationship where one primary Source directly mentions, quotes, copies, or references an earlier primary Source."@en .

:wasInfluencedBy rdf:type owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:subPropertyOf prov:wasInfluencedBy ;
    rdfs:domain :Source ;
    rdfs:range :Source ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "was influenced by"@en ;
    rdfs:comment "Indicates that a Source drew thematic, stylistic, or conceptual inspiration from an earlier work, even without a direct citation."@en .

:hasEtymology rdf:type owl:ObjectProperty ;
    rdfs:domain :Creature ;
    rdfs:range :Etymology ;
    owl:inverseOf :isEtymologyOf ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "has etymology"@en ;
    rdfs:comment "Links a Creature directly to the documented history of its name's linguistic origin."@en .

:isEtymologyOf rdf:type owl:ObjectProperty ;
    rdfs:domain :Etymology ;
    rdfs:range :Creature ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "is etymology of"@en ;
    rdfs:comment "Links an etymological origin back to the modern or targeted term it resulted in."@en .

:hasOriginContext rdf:type owl:ObjectProperty ;
    rdfs:domain [ rdf:type owl:Class ;
                owl:unionOf (:Creature :ImaginaryPlace) ] ;
    rdfs:range :Source ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "has origin context"@en ;
    rdfs:comment "Links a creature or an imaginary place to their earliest known or most culturally foundational source, whether a specific written text or a broader mythological tradition. This property acknowledges that for many creatures a single primary source cannot always be identified."@en .

:isTextualReferenceOf rdf:type owl:ObjectProperty ;
    rdfs:domain :Citation ;
    rdfs:range :Interpretation ;
    owl:inverseOf :hasTextualReference ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:comment "The inverse of :hasTextualReference. Links a Citation back to the Interpretation it documents, allowing navigation from a specific passage in a Source to the interpretive claim it supports. This inverse direction is useful for querying which interpretations are grounded in a particular passage — for example, retrieving all creature readings that depend on a single chapter of a bestiary."@en .

:hasTextualReference rdf:type owl:ObjectProperty ;
    rdfs:domain :Interpretation ;
    rdfs:range :Citation ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "has textual reference"@en ;
    rdfs:comment "Links a source-specific Interpretation to a Citation node that captures the precise textual or visual evidence on which that interpretation rests. Where :appearsIn links an Interpretation directly to a Source at the document level, :hasTextualReference provides the finer-grained link to the exact passage and location within that Source."@en .

:extractedFrom rdf:type owl:ObjectProperty ;
    rdfs:domain :Citation ;
    rdfs:range :Source ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "extracted from"@en ;
    rdfs:comment "Links a Citation to the Source from which its passage was drawn. Where :hasTextualReference connects an Interpretation to a Citation, :extractedFrom connects that Citation upward to the Source document — completing the three-level provenance chain: Interpretation → Citation → Source. This property allows the ontology to answer questions such as 'which Sources contain direct textual evidence for this creature' by traversing the chain rather than asserting a direct link between Interpretation and Source."@en .
    
# ===== DATA PROPERTIES ================
:hasRootTerm rdf:type owl:DatatypeProperty ;
    rdfs:domain :Etymology ;
    rdfs:range rdfs:Literal ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "has root term"@en ;
    rdfs:comment "The literal string representation of the original word."@en .

:hasMeaning rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf owl:topDataProperty ;
    rdfs:domain [ rdf:type owl:Class ;
                    owl:unionOf (:Etymology :Interpretation :Archetype :NarrativeFunction)] ;
    rdfs:range rdfs:Literal ;
    rdfs:label "has meaning"@en ;
    rdfs:comment "The literal string translation or definition of a term, concept, or archetypal figure."@en .

:hasPassageText rdf:type owl:DatatypeProperty ;
    rdfs:domain :Citation ;
    rdfs:range rdfs:Literal ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "has passage text"@en ;
    rdfs:comment "The transcribed text of the passage extracted from a Source in which a creature is described, named, or depicted. Stored as a plain literal, this property preserves the exact wording of the primary source evidence that grounds a given Interpretation, enabling philological comparison across different textual witnesses of the same creature."@en .

:hasSequenceIdentifier rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf fabio:hasSequenceIdentifier ;
    rdfs:domain :Citation ;
    rdfs:range rdfs:Literal ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "has sequence identifier"@en ;
    rdfs:comment "The specific locator identifying the position of a Citation within its Source — such as a page number, folio reference, chapter, canto, stanza, or verse. Declared as a subproperty of fabio:hasSequenceIdentifier, aligning the ontology with the FRBR-aligned bibliographic vocabulary. This property allows precise scholarly referencing and enables the comparison of how different editions or translations of the same work locate their creature passages differently."@en .

:hasPersonalName rdf:type owl:DatatypeProperty ;
    rdfs:domain :Interpretation ;
    rdfs:range rdfs:Literal ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "has personal name"@en ;
    rdfs:comment "Records the proper name given to a creature in a specific interpretation, distinguishing a named individual from the generic species to which it belongs. It applies at the level of the interpretation, since a personal name is typically conferred by a particular source rather than shared across all manifestations of the creature."@en .

:hasAlternativeName rdf:type owl:DatatypeProperty ;
    rdfs:domain :Creature ;
    rdfs:range rdfs:Literal ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "has alternative name"@en ;
    rdfs:comment "An alternative proper name or alias by which a creature is known across different sources or traditions, distinct from its canonical label and source-specific terminology."@en .

# ===== MODULE 2 - BIOLOGICAL AND STRUCTURAL LAYER ================
# ===== CLASSES ================
:ImaginaryBeing rdf:type owl:Class ;
    rdfs:subClassOf :Creature ;
    rdfs:isDefinedBy :BiologicalModule ;
    owl:disjointWith :RealAnimal ;
    rdfs:label "Imaginary being"@en ;
    rdfs:comment "A creature that does not exist in the natural world, originating from folklore, myth, or literary invention."@en .

:CompositeCreature rdf:type owl:Class ;
    rdfs:subClassOf :ImaginaryBeing ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Composite creature"@en ;
    rdfs:comment "A creature composed of disparate parts, whether those parts are from different animals or distinct materials."@en .

:HybridCreature rdf:type owl:Class ;
    rdfs:subClassOf :CompositeCreature ,
        [
            rdf:type owl:Restriction ;
            owl:onProperty :hasPartDerivedFrom ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass :RealAnimal
        ] ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Hybrid creature"@en ;
    rdfs:comment "A specific type of imaginary being composed of anatomical parts from two or more distinct real animals."@en .

:RealAnimal rdf:type owl:Class ;
    rdfs:subClassOf :Creature ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Real animal"@en ;
    rdfs:comment "A scientifically recognized biological animal that exists or existed in the natural world."@en .

:Plant rdf:type owl:Class ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Plant"@en ;
    rdfs:comment "A living organism belonging to the botanical kingdom, often serving as a biological component in composite creatures (e.g. roots or branches)."@en .

:InanimateElement rdf:type owl:Class ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Inanimate element"@en ;
    rdfs:comment "Non-living matter or material (e.g. stone and metal) that forms part of a creature's physical anatomy."@en .

:AnatomicalPart rdf:type owl:Class ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Anatomical part"@en ;
    rdfs:comment "An anatomical component of a creature's body, such as a head, limb or tail."@en .

:Ability rdf:type owl:Class ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Ability"@en ;
    rdfs:comment "A specific behavior, movement, or activity performed by a creature."@en .

:Habitat rdf:type owl:Class ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Habitat"@en ;
    rdfs:comment "The natural or mythological environment in which a creature lives or is commonly found."@en .

:RealWorldPlace rdf:type owl:Class ;
    rdfs:subClassOf :Habitat ;
    owl:disjointWith :ImaginaryPlace ;
    rdfs:label "Real-world place"@en ;
    rdfs:comment "A geographic or ecological habitat that exists in the physical world. Class influenced by J. L. Borges' distinction between biological reality and the imaginary spaces."@en .

:ImaginaryPlace rdf:type owl:Class ;
    rdfs:subClassOf :Habitat ;
    rdfs:label "Imaginary place"@en ;
    rdfs:comment "A conceptual, magical, or purely literary space (e.g. the Garden of Eden or Hades). As noted by Borges, these spaces follow the laws of imagination rather than biology."@en .

:Diet rdf:type owl:Class ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Diet"@en ;
    rdfs:comment "The standard food consumption habits of a creature."@en .

# ===== OBJECT PROPERTIES ================
:hasAbility rdf:type owl:ObjectProperty ;
    rdfs:domain :Creature ;
    rdfs:range :Ability ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has ability"@en ;
    rdfs:comment "Links a creature to a specific behavior or physical action it is known for."@en .

:hasPart rdf:type owl:ObjectProperty ;
    rdfs:domain :ImaginaryBeing ;
    rdfs:range :AnatomicalPart ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has part"@en ;
    rdfs:comment "Links an ImaginaryBeing to a specific AnatomicalPart that constitutes its body, without asserting the biological origin of that part. Where :hasPartDerivedFrom links a CompositeCreature to the real animal or material from which a part originates, :hasPart simply records which anatomical components are present — useful for imaginary beings whose parts have no clear real-world derivation or whose source is not documented in the available sources."@en .

:hasAnomaly rdf:type owl:ObjectProperty ;
    rdfs:domain :RealAnimal ;
    rdfs:range :AnatomicalPart ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has anomaly"@en ;
    rdfs:comment "Links a RealAnimal to an AnatomicalPart that exhibits a monstrous or pathological irregularity in a specific Source. For cases where the nature of the anomaly itself needs to be documented (e.g. whether it is a duplication, absence, or modification), use the subproperties :hasDuplicationOf, :hasAbsenceOf, and :hasModificationOf."@en .

:hasAbsenceOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasAnomaly ;
    rdfs:domain :RealAnimal ;
    rdfs:range :AnatomicalPart ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has absence of"@en ;
    rdfs:comment "Indicates that a real animal, in a given Source or Interpretation, is missing an anatomical part that would normally be expected for its species. Records cases where the absence itself constitutes the anomaly — e.g. a serpent without a tongue, a bird without wings, or a humanoid creature lacking a face. Subproperty of :hasAnomaly."@en .

:hasDuplicationOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasAnomaly ;
    rdfs:domain :RealAnimal ;
    rdfs:range :AnatomicalPart ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has duplication of"@en ;
    rdfs:comment "Indicates that a real animal, in a given Source or Interpretation, possesses a duplicated or multiplied instance of an anatomical part — e.g. a two-headed calf, a creature with six limbs, or an animal with a forked tail where one is canonical. Subproperty of :hasAnomaly."@en .

:hasModificationOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasAnomaly ;
    rdfs:domain :RealAnimal ;
    rdfs:range :AnatomicalPart ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has modification of"@en ;
    rdfs:comment "Indicates that a real animal, in a given Source or Interpretation, exhibits an anatomical part in an altered or aberrant form — neither simply absent nor duplicated, but substantially changed in shape, size, material, or function. Examples include reversed feet, crystalline horns, or scales in place of fur. Subproperty of :hasAnomaly."@en .

:hasPartDerivedFrom rdf:type owl:ObjectProperty ;
    rdfs:domain :CompositeCreature ;
    rdfs:range [ rdf:type owl:Class ;
            owl:unionOf (:RealAnimal :Plant :InanimateElement) ] ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has part of"@en ;
    rdfs:comment "Indicates that a composite creature possesses anatomical or morphological features derived from a specific real animal, a plant or an inanimate element."@en .

:hasHeadOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasPartDerivedFrom ;
    rdfs:domain :CompositeCreature ;
    rdfs:range [ rdf:type owl:Class ;
            owl:unionOf (:RealAnimal :Plant :InanimateElement) ] ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has head of"@en ;
    rdfs:comment "Specifies the head structure of a creature."@en .

:hasBodyOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasPartDerivedFrom ;
    rdfs:domain :CompositeCreature ;
    rdfs:range [ rdf:type owl:Class ;
            owl:unionOf (:RealAnimal :Plant :InanimateElement) ] ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has body of"@en ;
    rdfs:comment "Specifies the main torso or body structure of a creature. May be asserted directly for creatures with a single undivided body source, or indirectly through its subproperties hasUpperBodyOf and hasLowerBodyOf for creatures whose body is split into distinct segments."@en .

:hasUpperBodyOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasBodyOf ;
    rdfs:domain :CompositeCreature ;
    rdfs:range [ rdf:type owl:Class ;
            owl:unionOf (:RealAnimal :Plant :InanimateElement) ] ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has upper body of"@en ;
    rdfs:comment "Specifies the upper body, torso, or anterior segment of a creature characterized by a segmented body structure."@en .

:hasLowerBodyOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasBodyOf ;
    rdfs:domain :CompositeCreature ;
    rdfs:range [ rdf:type owl:Class ;
            owl:unionOf (:RealAnimal :Plant :InanimateElement) ] ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has lower body of"@en ;
    rdfs:comment "Specifies the lower body, hindquarters, or posterior segment of a creature characterized by a segmented body structure."@en .

:hasTailOf rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasPartDerivedFrom ;
    rdfs:domain :CompositeCreature ;
    rdfs:range [ rdf:type owl:Class ;
            owl:unionOf (:RealAnimal :Plant :InanimateElement) ] ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has tail of"@en ;
    rdfs:comment "Specifies the tail structure of a creature."@en .

:hasHabitat rdf:type owl:ObjectProperty ;
    rdfs:domain :Creature ;
    rdfs:range :Habitat ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has habitat"@en ;
    rdfs:comment "Connects a creature to the environment it natively inhabits."@en .

:habitatCategory rdf:type owl:ObjectProperty ;
    rdfs:domain :Habitat ;
    rdfs:range :Habitat ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "habitat category"@en ;
    rdfs:comment "Assigns a specific habitat to its broader environmental class, grouping particular places under a general category (such as Aquatic). It provides the higher-level classification through which individual habitats are organised."@en .

:hasDiet rdf:type owl:ObjectProperty ,
                    owl:FunctionalProperty ;
    rdfs:domain :Creature ;
    rdfs:range :Diet ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has diet"@en ;
    rdfs:comment "Specifies the feeding classification (e.g. carnivorous) of the creature."@en .

:dietCategory rdf:type owl:ObjectProperty ;
    rdfs:domain :Diet ;
    rdfs:range :Diet ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "diet category"@en ;
    rdfs:comment "Assigns a specific diet to its broader dietary class, grouping particular diets under a general category (such as Carnivorous). It provides the higher-level classification through which fine-grained diets are organised."@en .

:isOfSpecies rdf:type owl:ObjectProperty ;
    rdfs:domain :RealAnimal ;
    rdfs:range :RealAnimal ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "is of species"@en ;
    rdfs:comment "Links a real animal individual to the base biological species it belongs to, used particularly for creatures that exhibit anomalies or deformities but remain fundamentally members of a recognizable species."@en .

# ===== DATA PROPERTIES ===============
:hasDistinctiveTrait rdf:type owl: ;
    rdfs:domain [ rdf:type owl:Class ;
                owl:unionOf (:Creature :Interpretation) ] ;
    rdfs:range rdfs:Literal ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "has distinctive trait"@en ;
    rdfs:comment "Records a short, characterizing description of the most defining features of a creature. It captures a headline characterization rather than the structured anatomical, dietary, or symbolic data modelled elsewhere."@en .

# ===== MODULE 3 - SYMBOLIC AND ANALYSIS LAYER ================
# ===== CLASSES ================
:Archetype rdf:type owl:Class ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "Archetype"@en ;
    rdfs:comment "A universal, primordial pattern or character prototype residing in the collective human imagination. Within the ontology, the class serves as the ultimate analytical anchor that bridges the historical world with the symbolic world, linking a source-bound Interpretation of a Creature directly to its deeper allegorical, spiritual, or psychological meaning."@en .

:NarrativeFunction rdf:type owl:Class ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "Narrative Function"@en ;
    rdfs:comment "A symbolic or thematic role that a creature fulfills within a specific Source, independent of its biological traits. Narrative functions capture the cultural and literary work that a beast performs in a given tradition — e.g. acting as a guardian or an emblem of divine power. Where :Archetype captures the universal psychological pattern, NarrativeFunction captures the contextual, source-specific role that pattern takes within a narrative or iconographic programme."@en . 

# DURAND SCHEME
:DurandImaginary rdf:type skos:ConceptScheme ;
    dcterms:title "Durand's structures of the Imaginary"@en ;
    skos:hasTopConcept :Regime , :ImaginaryStructure ;
    rdfs:isDefinedBy :SymbolicModule ;
    prov:wasDerivedFrom "Durand, G. (1972). Le Strutture Antropologiche dell'Immaginario: introduzione all'archetipologia generale" ;
    rdfs:comment "A conceptual scheme providing a framework for the symbolic and anthropological analysis of creatures within bestiaries. It acts as the theoretical pivot of the Symbolic Module, allowing for the classification of beasts and their attributes based on their relationship with human anxiety regarding time and death. By applying Gilbert Durand's regimes and structures defined in 'Les Structures Anthropologiques de l'Imaginaire', 'beast' can map how physical biological traits - such as wings - serve as archetypal responses to mortality, transforming the creature from a mere biological entity into a profound cultural symbol."@en .

:Regime rdf:type owl:Class ,
                skos:Concept ;
    skos:inScheme :DurandImaginary ;
    skos:topConceptOf :DurandImaginary ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "Regime"@en ;
    skos:prefLabel "Regime"@en ;
    rdfs:comment "The fundamental high-level classification of Durand, organized around sensory-motor dominants (postural, digestive, cyclic). Regimes act as organizational systems of the imagination, condensing multiple symbolic meanings into a coherent structure."@en .

:NocturnalRegime rdf:type owl:Class , 
                        skos:Concept ;
    skos:inScheme :DurandImaginary ;
    skos:broader :Regime ;
    rdfs:isDefinedBy :SymbolicModule ;
    owl:disjointWith :DiurnalRegime ;
    rdfs:label "Nocturnal Regime"@en ;
    skos:prefLabel "Nocturnal Regime"@en ;
    rdfs:comment "The Nocturnal Regime represents an attitude of reconciliation in front of the fleeting nature of time, incorporating symbols of transformation and cyclicality. The symbols belonging to the nocturnal regime exorcise fear by transforming images into reassuring figures. Unlike the diurnal regime, the antidote to the passing of time is not sought on a superhuman or transcendent level, but rather in reassuring intimacy or in the rhytmic constants that govern natural phenomena. The nocturnal regime is divided into synthetic structures and mystical structures."@en .

:DiurnalRegime rdf:type owl:Class ,
                        skos:Concept ;
    skos:inScheme :DurandImaginary ;
    skos:broader :Regime ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "Diurnal Regime"@en ;
    skos:prefLabel "Diurnal Regime"@en ;
    rdfs:comment "The Diurnal Regime is characterized by the battle against death and time. It is governed by antithesis, encompassing axiomatic images that give rise to two polarized facets: a background of darkness against which the victorious splendor of light is contrasted, and antithetical reconquest of negative values. It embodies the sharp logic of the sword and heroic battles against the passage of time. This regime is built upon schizomorphic structures, defined by separation, fall, antithesis, and scission. It is a multifaceted regime that includes theriomorphic, nyctomorphic, catamorphic, ascensional, spectacular, and diaretic symbols. Together, these symbols express both the profound anxiety in front of time and death and the heroic drive to transcend or overcome these forces."@en .

:ImaginaryStructure rdf:type owl:Class ,
                            skos:Concept ;
    skos:inScheme :DurandImaginary ;
    skos:topConceptOf :DurandImaginary ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "Imaginary Structure"@en ;
    skos:prefLabel "Imaginary Structure"@en ;
    rdfs:comment "The structural framework of the imaginary as defined by Gilbert Durand in 'Les Structures Anthropologiques de l'Imaginaire', acting as the mediating layer between biological reflexes and symbolic expression. It represents the archetypal logic that organizes a creature's physical and behavioral attributes into a coherent symbolic system. It provides the protocol through which raw sensory data - such as a beast's fangs, its flight, or its habitat - is transformed into a structured symbolic response (Schizomorphic, Mystical, or Synthetic) to the existential anxiety of time and death."@en .

:SchizomorphicStructure rdf:type owl:Class, skos:Concept ;
    rdfs:subClassOf :ImaginaryStructure ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :isGovernedBy ;
          owl:someValuesFrom :DiurnalRegime ] ;
    skos:inScheme :DurandImaginary ;
    skos:broader :ImaginaryStructure ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "Schizomorphic Structure (or Heroic)"@en ;
    skos:prefLabel "Schizomorphic Structure (or Heroic)"@en ;
    rdfs:comment "The Schizomorphic Structure represents the mode of the imaginary governed by the Diurnal Regime. It functions through the principles of antithesis and verticality as a defensive response to the anxiety of time. It operates via 'diaresis' – the act of cutting, dividing, and establishing absolute distinctions to maintain the separation between light and dark, height and depth. This structure organizes symbols into two polarized groups: the 'symbols of the antithesis' (teriomorphic, nyctomorphic, and catamorphic), which represent the terror of the abyss and devouring time; and the 'symbols of transcendence' (ascensional, spectacular, and diaretic), which provide the tools for the heroic reconquest through verticality, solar vision, and the purifying sword."@en .

:SyntheticStructure rdf:type owl:Class, skos:Concept;
    rdfs:subClassOf :ImaginaryStructure ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :isGovernedBy ;
          owl:someValuesFrom :NocturnalRegime ] ;
    skos:inScheme :DurandImaginary ;
    skos:broader :ImaginaryStructure ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "Synthetic Structure (or Dramatic)"@en ;
    skos:prefLabel "Synthetic Structure"@en ;
    skos:altLabel "Dramatic"@en ;
    rdfs:comment "Synthetic structure operates by bringing contradictions into dialogue and includes cyclical symbols. It treats time as a series of phases, where night is a necessary prelude to dawn and death is a prelude to rebirth. It transforms the fall into a slow, controlled descent, allowing for the acceptance of change and progress through the succession of opposites."@en .

:MysticalStructure rdf:type owl:Class, skos:Concept ;
    rdfs:subClassOf :ImaginaryStructure ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :isGovernedBy ;
          owl:someValuesFrom :NocturnalRegime ] ;
    skos:inScheme :DurandImaginary ;
    skos:broader :ImaginaryStructure ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "Mystical Structure (or Antiphrastic)"@en ;
    skos:prefLabel "Mystical Structure"@en ;
    skos:altLabel "Antiphrastic"@en ;
    rdfs:comment "Mystical structures include symbols of intimacy and calm, the search for light within darkness. The principles underlying mystical structures are analogy and similarity. Instead of battling against time, one enters into union with it. The mind takes images of terror and rewrites them positively, transforming them into refuge and protected space. Within this logic, opposites can coexist. In mystical structures one finds doubling and adherence rather than antithesis. It functions through inversion, doubling, and adherence, turning the devouring mouth of the diurnal regime into a protective container."@en .

:ImaginarySymbol rdf:type owl:Class, skos:Concept ;
    skos:inScheme :DurandImaginary ;
    skos:broader :ImaginaryStructure ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "Imaginary Symbol"@en ;
    skos:prefLabel "Imaginary Symbol"@en ;
    rdfs:comment "The shared OWL class and intermediate SKOS concept grouping all specific symbolic categories recognised by Gilbert Durand within his structures of the imaginary. As an owl:Class it provides the common type for all symbol individuals (TeriomorphicSymbol, AscensionalSymbol, CyclicalSymbol, etc.), allowing properties such as :belongsTo to range over them uniformly. As a skos:Concept it sits between :ImaginaryStructure and the specific symbol individuals in the DurandImaginary thesaurus, making the three-level hierarchy (ImaginaryStructure → ImaginarySymbol → specific symbol) navigable via skos:broader."@en .

# ===== OBJECT PROPERTIES ================
:symbolizes rdf:type owl:ObjectProperty ;
    rdfs:domain [ rdf:type owl:Class ; 
                  owl:unionOf (:Creature :AnatomicalPart :Ability :Interpretation) ] ;
    rdfs:range [ rdf:type owl:Class ; 
                  owl:unionOf (:Archetype :NarrativeFunction :ImaginarySymbol :ImaginaryStructure) ] ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "symbolizes"@en ;
    rdfs:comment "The primary semantic bridge connecting the biological domain to the symbolic domain. It asserts that a specific physical attribute (AnatomicalPart), a behavior (Ability), a Creature or its Interpretation serves as a vehicle for a broader conceptual meaning (Archetype, Structure, etc.)."@en .

:embodiesArchetype rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :symbolizes ;
    rdfs:domain [rdf:type owl:Class ;
                owl:unionOf (:Interpretation :Ability :AnatomicalPart :Creature) ] ;
    rdfs:range :Archetype ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "embodies archetype"@en ;
    rdfs:comment "Links a source-specific Interpretation to the universal psychological pattern or primordial image that the creature instantiates. Where :hasNarrativeFunction captures what role the creature plays in a given text, :embodiesArchetype asserts what deep collective structure it expresses across all its manifestations — e.g. the Dragon as the Archetype of Chaos, the Phoenix as the Archetype of Renewal, the Unicorn as the Archetype of Purity."@en .

:hasNarrativeFunction rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :symbolizes ;
    rdfs:domain [rdf:type owl:Class ;
                owl:unionOf (:Interpretation :Ability :AnatomicalPart :Creature) ] ;
    rdfs:range :NarrativeFunction ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "has narrative function"@en ;
    rdfs:comment "Links a source-specific Interpretation to the symbolic or thematic role that the creature fulfills within that Source. Unlike :embodiesArchetype — which asserts a universal psychological identity — :hasNarrativeFunction captures the contextual, plot-level, or iconographic function the beast performs in a particular text or artwork: guardian, omen, divine messenger, embodiment of sin, etc. The same creature may carry different narrative functions across different Interpretations."@en .

# DURAND SCHEME
:belongsToImaginaryStructure rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :symbolizes ;
    rdfs:domain [ rdf:type owl:Class ;
                owl:unionOf (:Creature :AnatomicalPart :Ability :Interpretation) ] ;
    rdfs:range :ImaginaryStructure ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "belongs to imaginary structure"@en ;
    rdfs:comment "Specifically links a creature, an ability, a part or an interpretation to Durand's structures of the imaginary."@en .

:embodiesImaginarySymbol rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :symbolizes;
    rdfs:domain [ rdf:type owl:Class ;
                owl:unionOf (:Creature :AnatomicalPart :Ability :Interpretation ) ] ;
    rdfs:range :ImaginarySymbol ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "embodies imaginary symbol"@en ;
    rdfs:comment "Specifically links a creature, an ability, a part or an interpretation to Durand's symbols of the imaginary."@en .

:belongsTo rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :symbolizes ;
    rdfs:domain :ImaginarySymbol ;
    rdfs:range :ImaginaryStructure ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "belongs to"@en ;
    rdfs:comment "Specifically links an Imaginary Symbol to the broader Imaginary Structure."@en .

:isGovernedBy rdf:type owl:ObjectProperty ;
    owl:propertyChainAxiom (skos:broader :isGovernedBy) ;
    rdfs:domain [ rdf:type owl:Class ;
                owl:unionOf (:ImaginaryStructure :ImaginarySymbol :Creature :AnatomicalPart :Ability :Interpretation) ] ;
    rdfs:range :Regime ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "is governed by"@en ;
    rdfs:comment "Links one of Durand's Imaginary Structures to its overarching Regime (Diurnal or Nocturnal)."@en .

:hasDivergence rdf:type owl:DatatypeProperty ;
    rdfs:domain :Interpretation ;
    rdfs:range [ rdf:type owl:Class ;
                owl:unionOf (:AnatomicalPart :Ability :Habitat :Diet ) ] ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "has divergence"@en ;
    rdfs:comment "The parent property for all divergence assertions linking a source-specific Interpretation to the biological feature — either an AnatomicalPart or an Ability — that differs from the creature's canonical description in that Source. Subproperties :additionalAbility, :removedAbility, :additionalPart, and :removedPart specialise the nature of the divergence. This structure allows the ontology to answer questions such as 'which interpretations add wings to a normally wingless creature' or 'which sources suppress a creature's canonical venom ability'."@en .

:additionalAbility rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasDivergence ;
    rdfs:domain :Interpretation ;
    rdfs:range :Ability ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "additional ability"@en ;
    rdfs:comment "Links a source-specific Interpretation to an Ability that the creature possesses in that Source but which is absent from or not part of its standard biological description (Creature). Records additions to the creature's standard behavioural repertoire introduced by a specific author, artist, or tradition — e.g. a serpent that in one source is additionally credited with the power of hypnosis."@en .

:removedAbility rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasDivergence ;
    rdfs:domain :Interpretation ;
    rdfs:range :Ability ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "removed ability"@en ;
    rdfs:comment "Links a source-specific Interpretation to an Ability that the creature typically possesses but which is deliberately absent in that particular Source. Documents reductive divergences from the standard behavioural description — e.g. a dragon that in a given medieval text lacks the ability to fly, inverting the conventional image."@en .

:additionalPart rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasDivergence ;
    rdfs:domain :Interpretation ;
    rdfs:range :AnatomicalPart ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "additional part"@en ;
    rdfs:comment "Links a source-specific Interpretation to an AnatomicalPart that the creature possesses in that Source but which is not part of its canonical morphology. Records additive anatomical divergences introduced by a specific tradition — e.g. a lion that in one illumination is given wings absent from the standard description, shifting it toward a composite or hybrid morphology."@en .

:removedPart rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasDivergence ;
    rdfs:domain :Interpretation ;
    rdfs:range :AnatomicalPart ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "removed part"@en ;
    rdfs:comment "Links a source-specific Interpretation to an AnatomicalPart  that the Creature canonically possesses but which is deliberately absent or suppressed in that particular Source. Documents reductive anatomical divergences — e.g. a griffin depicted without its eagle wings in a specific manuscript tradition, fundamentally altering its composite identity."@en .

:alternativeHabitat rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasDivergence ;
    rdfs:domain :Interpretation ;
    rdfs:range :Habitat ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "alternative habitat"@en ;
    rdfs:comment "Records a habitat attributed to a creature in a specific interpretation that departs from its canonical habitat, documenting how a particular source or tradition relocates the creature. It captures source-specific habitat divergence at the level of the individual interpretation."@en .

:alternativeDiet rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :hasDivergence ;
    rdfs:domain :Interpretation ;
    rdfs:range :Diet ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "alternative diet"@en ;
    rdfs:comment "Records a diet attributed to a creature in a specific interpretation that departs from its canonical diet, documenting how a particular source or tradition reimagines what the creature consumes. It captures source-specific dietary divergence at the level of the individual interpretation."@en .

:relatedTo rdf:type owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain [ rdf:type owl:Class ;
                owl:unionOf (:NarrativeFunction :Archetype) ] ;
    rdfs:range [ rdf:type owl:Class ;
                owl:unionOf (:NarrativeFunction :Archetype) ] ;
    rdfs:isDefinedBy :SymbolicModule ;
    rdfs:label "related to"@en ;
    rdfs:comment "A symmetric associative property linking two NarrativeFunction or Archetype individuals that share thematic, structural, or symbolic overlap without one being a specialisation of the other. For example, the function of Guardian and the function of Threshold-Keeper are related but distinct; the Archetype of the Devourer and the Archetype of the Transformer share symbolic territory without subsumption. This property enables lateral navigation across the symbolic vocabulary of the ontology."@en .

# ===== INDIVIDUALS - Controlled Vocabulary ================
:ProvenanceModule rdf:type owl:NamedIndividual , :Module ;
    rdfs:label "Provenance Module (the Anchor)"@en ;
    rdfs:comment "The Provenance Module documents the historical and textual footprint of every creature in the ontology. It distinguishes between the universal, abstract concept of a beast (Creature) and its source-specific manifestations (Interpretation), allowing the ontology to track how a single entity is described, depicted, or reinterpreted across different authors, periods, and media — from medieval manuscripts to contemporary film. It anchors each Interpretation to the primary Source in which it appears and classifies Sources by their genre and intertextual relationships through :cites and :wasInfluencedBy."@en .

:BiologicalModule rdf:type owl:NamedIndividual , :Module ;
    rdfs:label "Biological Module"@en ;
    rdfs:comment "The Biological Module catalogs the physical and behavioural traits of creatures — whether real or imaginary — as described in Bestiaries and other Sources. It distinguishes real animals from imaginary beings, and further classifies the latter into composite and hybrid creatures whose anatomy is derived from two or more biological sources. For real animals it documents deformities and monstrous irregularities through a structured vocabulary of anatomical anomaly: absence of a canonical part, duplication, and modification. For imaginary beings it records the anatomical parts they possess and the real animals, plants, or inanimate elements from which those parts are derived. Across all creatures the module captures habitats — distinguishing real geographic environments from mythological or imaginary spaces — diets, and abilities. This layer serves as the primary morphological record that the Symbolic Module then interprets as archetypal and cultural meaning."@en .

:SymbolicModule rdf:type owl:NamedIndividual , :Module ;
    rdfs:label "Symbolic Module"@en ;
    rdfs:comment "The Symbolic Module represents the analytical and interpretive layer of the ontology, where art history, literary theory, depth psychology, and anthropology converge. It provides two interlocking frameworks for the symbolic analysis of creatures and their source-specific Interpretations. First, the DurandImaginary scheme applies Gilbert Durand's anthropological structures of the imaginary to classify creatures according to the Regime (Diurnal or Nocturnal) and structural logic (Schizomorphic, Mystical, or Synthetic) that governs their symbolic imagery. Second, the archetype and narrative function layer — through :Archetype, :NarrativeFunction, :embodiesArchetype, and :hasNarrativeFunction — distinguishes between the universal psychological pattern a creature instantiates across all its manifestations and the specific contextual role it performs within a given Source. The module also captures symbolic divergences at the level of Interpretation: the properties :additionalPart, :removedPart, :additionalAbility, :removedAbility, :alternativeDiet and :alternativeHabitat document how a specific author or tradition departs from the canonical image of a creature, and what symbolic meaning those departures carry."@en .

:Omnivorous rdf:type owl:NamedIndividual,
                    :Diet ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Omnivorous"@en ;
    rdfs:comment "A diet consisting of both animal and plant matter."@en .

:Herbivorous rdf:type owl:NamedIndividual,
                    :Diet ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Herbivorous"@en ;
    rdfs:comment "A diet consisting primarily of plant matter."@en .

:Carnivorous rdf:type owl:NamedIndividual,
                    :Diet ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Carnivorous"@en ;
    rdfs:comment "A diet consisting primarily of animal meat."@en .

:Scavenger rdf:type owl:NamedIndividual,
                    :Diet ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Scavenger"@en ;
    rdfs:comment "Creatures that eat dead organic matter."@en .

:Hematophagous rdf:type owl:NamedIndividual,
                    :Diet ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Hematophagous"@en ;
    rdfs:comment "Blood-drinkers."@en .

:Lithophagous rdf:type owl:NamedIndividual,
                    :Diet ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Lithophagous"@en ;
    rdfs:comment "Stone-eaters."@en .

:Elemental rdf:type owl:NamedIndividual,
                    :Diet ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Elemental"@en ;
    rdfs:comment "Creatures that eat things like fire, air, or even human souls."@en .

:Terrestrial rdf:type owl:NamedIndividual,
                    :RealWorldPlace ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Terrestrial"@en ;
    rdfs:comment "A physical habitat primarily located on solid ground or within the earth."@en .

:Aerial rdf:type owl:NamedIndividual,
                    :RealWorldPlace ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Aerial"@en ;
    rdfs:comment "A physical habitat located in the sky, clouds, or upper atmosphere."@en .

:Aquatic rdf:type owl:NamedIndividual,
                    :RealWorldPlace ;
    rdfs:isDefinedBy :BiologicalModule ;
    rdfs:label "Aquatic"@en ;
    rdfs:comment "A physical habitat located in or around bodies of water, such as oceans, rivers, or lakes."@en .

:ScientificTaxonomy rdf:type owl:NamedIndividual, :BestiaryType ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Scientific Taxonomy"@en ;
    rdfs:comment "A genre focused on the scientific categorization and biological documentation of animals (e.g. Aldrovandi and Paré)."@en .

:LiteraryMetafiction rdf:type owl:NamedIndividual, :BestiaryType ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Literary Metafiction"@en ;
    rdfs:comment "A post-modern or highly stylized genre where the bestiary is used as a narrative or literary device (e.g. Borges)."@en .

:MoralAllegory rdf:type owl:NamedIndividual, :BestiaryType ;
    rdfs:isDefinedBy :ProvenanceModule ;
    rdfs:label "Moral Allegory"@en ;
    rdfs:comment "The traditional medieval genre where creatures are described primarily for Christian theological or moral lessons."@en .

# DURAND INDIVIDUALS
:TeriomorphicSymbol rdf:type owl:NamedIndividual, :ImaginarySymbol, skos:Concept ;
    rdfs:isDefinedBy :SymbolicModule ;
    skos:inScheme :DurandImaginary ;
    skos:broader :SchizomorphicStructure ;
    :belongsTo :SchizomorphicStructure ;
    rdfs:label "Teriomorphic Symbol"@en ;
    skos:prefLabel "Teriomorphic Symbol"@en ;
    rdfs:comment "Teriomorphic symbol represents the terrifying aspect of animals, embodying biting, devouring, and feral chaos. As 'enemy symbol' of anxiety and darkness, it is linked to the restlessness caused by rapid, undisciplined movement. It captures the chaos of fleeing from 'devouring time' and the archetype of the predatory jaws ready to strike."@en .

:NyctomorphicSymbol rdf:type owl:NamedIndividual, :ImaginarySymbol, skos:Concept ;
    rdfs:isDefinedBy :SymbolicModule ;
    skos:inScheme :DurandImaginary ;
    skos:broader :SchizomorphicStructure ;
    :belongsTo :SchizomorphicStructure ;
    rdfs:label "Nyctomorphic Symbol"@en ;
    skos:prefLabel "Nyctomorphic Symbol"@en ;
    rdfs:comment "Nyctomorphic symbol encapsulates the temporal symbolism of darkness, blindness, and shadows. Linked to the voracity of the night, it often incorporates the element of water - viewed here not as a source of life, but as an elusive, dark surface that doubles the abyss and reflects the formless terror of the unknown."@en .

:CatamorphicSymbol rdf:type owl:NamedIndividual, :ImaginarySymbol, skos:Concept ;
    rdfs:isDefinedBy :SymbolicModule ;
    skos:inScheme :DurandImaginary ;
    skos:broader :SchizomorphicStructure ;
    :belongsTo :SchizomorphicStructure ;
    rdfs:label "Catamorphic Symbol"@en ;
    skos:prefLabel "Catamorphic Symbol"@en ;
    rdfs:comment "Catamorphic symbol embodies falling, gravity, and the physical degradation of flesh. These dynamic images of transience represent the dazzling acceleration of time during a downward plunge. Catamorphic symbol captures the existential anxiety of the fall, where movement signifies the inescapable and rapid passage of time toward death."@en .

:AscensionalSymbol rdf:type owl:NamedIndividual, :ImaginarySymbol, skos:Concept ;
    rdfs:isDefinedBy :SymbolicModule ;
    skos:inScheme :DurandImaginary ;
    skos:broader :SchizomorphicStructure ;
    :belongsTo :SchizomorphicStructure ;
    rdfs:label "Ascensional Symbol"@en ;
    skos:prefLabel "Ascensional Symbol"@en ;
    rdfs:comment "Ascensional symbol embodies heroic symbols of elevation, verticality, and transcendence. It represents the upward movement to escape the degradation of time and the symbolic refusal of death. In this structure, height is synonymous with the pure and the divine; the wing is the ascensional instrument that contradicts gravity. These symbols manifest a quest to regain lost power through movement toward metaphysical spaces (e.g., mountains), dazzling imagery (arrows, wings), and virile archetypes of celestial royalty and the warrior."@en .

:SpectacularSymbol rdf:type owl:NamedIndividual, :ImaginarySymbol, skos:Concept ;
    rdfs:isDefinedBy :SymbolicModule ;
    skos:inScheme :DurandImaginary ;
    skos:broader :SchizomorphicStructure ;
    :belongsTo :SchizomorphicStructure ;
    rdfs:label "Spectacular Symbol"@en ;
    skos:prefLabel "Spectacular Symbol"@en ;
    rdfs:comment "Spectacular symbol relates to intense light, vision, and the heroic gaze. Standing in direct opposition to darkness, it emphasizes the triumph of clarity and the 'solar power' that makes the world intelligible and thus controllable. Sight is the supreme sense of the hero, as clear vision allows for the differentiation of things and the definition of clear boundaries. In this context, light functions as a sword, cutting through obscurity to define reality."@en .

:DiareticSymbol rdf:type owl:NamedIndividual, :ImaginarySymbol, skos:Concept ;
    rdfs:isDefinedBy :SymbolicModule ;
    skos:inScheme :DurandImaginary ;
    skos:broader :SchizomorphicStructure ;
    :belongsTo :SchizomorphicStructure ;
    rdfs:label "Diaretic Symbol"@en ;
    skos:prefLabel "Diaretic Symbol"@en ;
    rdfs:comment "Diaretic symbol embodies figures of cutting, weapons, and purification, derived from the Greek term 'diairesis' (division). They represent the human need for analysis, categorization, and absolute separation to overcome natural chaos. The hero's weapon is a dual symbol of power and purity; by cutting through confusion and separating the real from the imaginary, or good from evil, the hero gains mastery over the world. In this structure, the act of separation is the primary source of intellectual and spiritual power."@en .

:CyclicalSymbol rdf:type owl:NamedIndividual, :ImaginarySymbol,  skos:Concept ;
    rdfs:isDefinedBy :SymbolicModule ;
    skos:inScheme :DurandImaginary ;
    skos:broader :SyntheticStructure ;
    :belongsTo :SyntheticStructure ;
    rdfs:label "Cyclical Symbol"@en ;
    skos:prefLabel "Cyclical Symbol"@en ;
    rdfs:comment "Cyclical symbol represents the archetype of the Eternal Return and time as a series of phases. Using the moon as a primary model - being the first to die and the first to be reborn - these symbols suggest that time is a series of phases where opposites (life/death, light/dark) coexist. This 'lunar optimism' does not negate death but reintegrates it as an essential stage of an incessant, evolving movement where every sunset is a prelude to a new dawn. The repetition of opposites is also linked to evolution: it is not merely a continuous repetition of the same events. Things that change may also evolve or move forward; they may progress."@en .

:InversionSymbol rdf:type owl:NamedIndividual, :ImaginarySymbol,  skos:Concept ;
    rdfs:isDefinedBy :SymbolicModule ;
    skos:inScheme :DurandImaginary ;
    skos:broader :MysticalStructure ;
    :belongsTo :MysticalStructure ;
    rdfs:label "Inversion Symbol"@en ;
    skos:prefLabel "Inversion Symbol"@en ;
    rdfs:comment "Inversion symbol exorcises the fear of time by turning negative images into positive ones. Through an involutive process, the devouring mouth of the Diurnal Regime is transmuted into a protective nest. Instead of a heroic battle against darkness, there is a mystical union with it. This defensive mechanism employs doubling and reassuring symbols of intimacy to transform a dangerous fall into a controlled descent into the secrets of becoming."@en .

:IntimacySymbol rdf:type owl:NamedIndividual , :ImaginarySymbol, skos:Concept ;
    rdfs:isDefinedBy :SymbolicModule ;
    skos:inScheme :DurandImaginary ;
    skos:broader :MysticalStructure ;
    :belongsTo :MysticalStructure ;
    rdfs:label "Intimacy Symbol"@en ;
    skos:prefLabel "Intimacy Symbol"@en ;
    rdfs:comment "Intimacy symbol represents the center, the home, and the magical cradle. This symbol reduces the vast, terrifying world into a controllable, safe microcosm - such as a shell, a tomb seen as a place of rest, or a secret dwelling. It marks an inversion toward interiority and the soul, where the essence of the creature is protected within a restful and familiar space. It embodies the transition from the fear of being 'swallowed' to the comfort of being 'contained'."@en .

# ===== GENERAL AXIOMS ================
[] rdf:type owl:AllDisjointClasses ;
    owl:members (:LiteraryWork :VisualArtwork :CinematicWork) .

[] rdf:type owl:AllDisjointClasses ;
    owl:members (:Source :Creature :Interpretation) .

[] rdf:type owl:AllDisjointClasses ;
    owl:members (:RealAnimal :Plant :InanimateElement) .


[] rdf:type owl:AllDisjointClasses ;
   owl:members ( :SchizomorphicStructure :SyntheticStructure :MysticalStructure ) .

[] rdf:type owl:AllDifferent ;
    owl:distinctMembers (
        :ScientificTaxonomy
        :LiteraryMetafiction
        :MoralAllegory
    ) .

[] rdf:type owl:AllDifferent ;
    owl:distinctMembers (
        :Omnivorous
        :Carnivorous
        :Herbivorous
        :Scavenger
        :Hematophagous
        :Lithophagous
        :Elemental
    ) .