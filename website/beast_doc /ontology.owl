    <owl:AnnotationProperty rdf:about="https://schema.org/codeRepository"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/spar/cito/cites -->


    <owl:ObjectProperty rdf:about="http://purl.org/spar/cito/cites"/>
    


    <!-- http://www.w3.org/ns/prov#wasInfluencedBy -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasInfluencedBy"/>
    


    <!-- https://w3id.org/beast/ontology#additionalAbility -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#additionalAbility">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#hasDivergence"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Interpretation"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Ability"/>
        <rdfs:comment xml:lang="en">Links a source-specific Interpretation to an Ability that the creature possesses in that Source but which is absent from or not part of its standard biological description (Creature). Records additions to the creature&apos;s standard behavioural repertoire introduced by a specific author, artist, or tradition — e.g. a serpent that in one source is additionally credited with the power of hypnosis.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">additional ability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#additionalPart -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#additionalPart">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#hasDivergence"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Interpretation"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#AnatomicalPart"/>
        <rdfs:comment xml:lang="en">Links a source-specific Interpretation to an AnatomicalPart that the creature possesses in that Source but which is not part of its canonical morphology. Records additive anatomical divergences introduced by a specific tradition — e.g. a lion that in one illumination is given wings absent from the standard description, shifting it toward a composite or hybrid morphology.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">additional part</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#alternativeDiet -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#alternativeDiet">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#hasDivergence"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Interpretation"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Diet"/>
        <rdfs:comment xml:lang="en">Records a diet attributed to a creature in a specific interpretation that departs from its canonical diet, documenting how a particular source or tradition reimagines what the creature consumes. It captures source-specific dietary divergence at the level of the individual interpretation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">alternative diet</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#alternativeHabitat -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#alternativeHabitat">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#hasDivergence"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Interpretation"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Habitat"/>
        <rdfs:comment xml:lang="en">Records a habitat attributed to a creature in a specific interpretation that departs from its canonical habitat, documenting how a particular source or tradition relocates the creature. It captures source-specific habitat divergence at the level of the individual interpretation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">alternative habitat</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#appearsIn -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#appearsIn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Interpretation"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Source"/>
        <rdfs:comment xml:lang="en">Links an Interpretation to the specific Source where it is mentioned.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">appears in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#belongsTo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#belongsTo">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#symbolizes"/>
        <owl:inverseOf rdf:resource="https://w3id.org/beast/ontology#hasImaginarySymbol"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#ImaginarySymbol"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#ImaginaryStructure"/>
        <rdfs:comment xml:lang="en">Specifically links an Imaginary Symbol to the broader Imaginary Structure.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">belongs to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#belongsToImaginaryStructure -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#belongsToImaginaryStructure">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#symbolizes"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Ability"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#AnatomicalPart"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Creature"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Interpretation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#ImaginaryStructure"/>
        <rdfs:comment xml:lang="en">Specifically links a creature, an ability, a part or an interpretation to Durand&apos;s structures of the imaginary.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">belongs to imaginary structure</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#cites -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#cites">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/spar/cito/cites"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Source"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Source"/>
        <rdfs:comment xml:lang="en">Indicates an explicit intertextual relationship where one primary Source directly mentions, quotes, copies, or references an earlier primary Source.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">cites</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#containsInterpretation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#containsInterpretation">
        <owl:inverseOf rdf:resource="https://w3id.org/beast/ontology#appearsIn"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Source"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Interpretation"/>
        <rdfs:comment xml:lang="en">Links a Source to the interpretations of creatures that appear within it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">contains interpretation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#dietCategory -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#dietCategory">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Diet"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Diet"/>
        <rdfs:comment xml:lang="en">Assigns a specific diet to its broader dietary class, grouping particular diets under a general category (such as Carnivorous). It provides the higher-level classification through which fine-grained diets are organised.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">diet category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#embodiesArchetype -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#embodiesArchetype">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#symbolizes"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Ability"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#AnatomicalPart"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Creature"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Interpretation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Archetype"/>
        <rdfs:comment xml:lang="en">Links a source-specific Interpretation to the universal psychological pattern or primordial image that the creature instantiates. Where :hasNarrativeFunction captures what role the creature plays in a given text, :embodiesArchetype asserts what deep collective structure it expresses across all its manifestations — e.g. the Dragon as the Archetype of Chaos, the Phoenix as the Archetype of Renewal, the Unicorn as the Archetype of Purity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">embodies archetype</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#embodiesImaginarySymbol -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#embodiesImaginarySymbol">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#symbolizes"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Ability"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#AnatomicalPart"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Creature"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Interpretation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#ImaginarySymbol"/>
        <rdfs:comment xml:lang="en">Specifically links a creature, an ability, a part or an interpretation to Durand&apos;s symbols of the imaginary.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">embodies imaginary symbol</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#extractedFrom -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#extractedFrom">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Citation"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Source"/>
        <rdfs:comment xml:lang="en">Links a Citation to the Source from which its passage was drawn. Where :hasTextualReference connects an Interpretation to a Citation, :extractedFrom connects that Citation upward to the Source document — completing the three-level provenance chain: Interpretation → Citation → Source. This property allows the ontology to answer questions such as &apos;which Sources contain direct textual evidence for this creature&apos; by traversing the chain rather than asserting a direct link between Interpretation and Source.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">extracted from</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#governs -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#governs">
        <owl:inverseOf rdf:resource="https://w3id.org/beast/ontology#isGovernedBy"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Regime"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Ability"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#AnatomicalPart"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Creature"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#ImaginaryStructure"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#ImaginarySymbol"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Interpretation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Inverse of :isGovernedBy. Links a Regime to the structures, symbols, creatures, parts, abilities, or interpretations it governs.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">governs</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#habitatCategory -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#habitatCategory">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Habitat"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Habitat"/>
        <rdfs:comment xml:lang="en">Assigns a specific habitat to its broader environmental class, grouping particular places under a general category (such as Aquatic). It provides the higher-level classification through which individual habitats are organised.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">habitat category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasAbility -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasAbility">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Creature"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Ability"/>
        <rdfs:comment xml:lang="en">Links a creature to a specific behavior or physical action it is known for.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">has ability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasAbsenceOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasAbsenceOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#hasAnomaly"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#RealAnimal"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#AnatomicalPart"/>
        <rdfs:comment xml:lang="en">Indicates that a real animal, in a given Source or Interpretation, is missing an anatomical part that would normally be expected for its species. Records cases where the absence itself constitutes the anomaly — e.g. a serpent without a tongue, a bird without wings, or a humanoid creature lacking a face. Subproperty of :hasAnomaly.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">has absence of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasAnomaly -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasAnomaly">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#RealAnimal"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#AnatomicalPart"/>
        <rdfs:comment xml:lang="en">Links a RealAnimal to an AnatomicalPart that exhibits a monstrous or pathological irregularity in a specific Source. For cases where the nature of the anomaly itself needs to be documented (e.g. whether it is a duplication, absence, or modification), use the subproperties :hasDuplicationOf, :hasAbsenceOf, and :hasModificationOf.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">has anomaly</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasBestiaryType -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasBestiaryType">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Bestiary"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#BestiaryType"/>
        <rdfs:comment xml:lang="en">Defines the primary intent or literary genre of the bestiary</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">has genre</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasBodyOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasBodyOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#hasPartDerivedFrom"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#ImaginaryBeing"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#InanimateElement"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Plant"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#RealAnimal"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Specifies the main torso or body structure of a creature. May be asserted directly for creatures with a single undivided body source, or indirectly through its subproperties hasUpperBodyOf and hasLowerBodyOf for creatures whose body is split into distinct segments.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">has body of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasDiet -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasDiet">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Creature"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Diet"/>
        <rdfs:comment xml:lang="en">Specifies the feeding classification (e.g. carnivorous) of the creature.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">has diet</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasDivergence -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasDivergence">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Interpretation"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Ability"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#AnatomicalPart"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Diet"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Habitat"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasDuplicationOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasDuplicationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#hasAnomaly"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#RealAnimal"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#AnatomicalPart"/>
        <rdfs:comment xml:lang="en">Indicates that a real animal, in a given Source or Interpretation, possesses a duplicated or multiplied instance of an anatomical part — e.g. a two-headed calf, a creature with six limbs, or an animal with a forked tail where one is canonical. Subproperty of :hasAnomaly.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">has duplication of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasEtymology -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasEtymology">
        <owl:inverseOf rdf:resource="https://w3id.org/beast/ontology#isEtymologyOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Creature"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Etymology"/>
        <rdfs:comment xml:lang="en">Links a Creature directly to the documented history of its name&apos;s linguistic origin.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">has etymology</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasGenesis -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasGenesis">
        <owl:inverseOf rdf:resource="https://w3id.org/beast/ontology#isGenesisOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Interpretation"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Genesis"/>
        <rdfs:comment xml:lang="en">Links a source-specific Interpretation to the account of the creature&apos;s origin or birth as told in that Source.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">has genesis</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasHabitat -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasHabitat">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Creature"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Habitat"/>
        <rdfs:comment xml:lang="en">Connects a creature to the environment it natively inhabits.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">has habitat</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasHeadOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasHeadOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#hasPartDerivedFrom"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#ImaginaryBeing"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#InanimateElement"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Plant"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#RealAnimal"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Specifies the head structure of a creature.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">has head of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasImaginarySymbol -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasImaginarySymbol">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#ImaginaryStructure"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#ImaginarySymbol"/>
        <rdfs:comment xml:lang="en">Inverse of :belongsTo. Links an Imaginary Structure to the imaginary symbols that belong to it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">has imaginary symbol</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasInterpretation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasInterpretation">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Creature"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Interpretation"/>
        <rdfs:comment xml:lang="en">Links a universal creature concept to its specific occurrences in a Source.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">has interpretation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasLowerBodyOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasLowerBodyOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#hasPartDerivedFrom"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#ImaginaryBeing"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#InanimateElement"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Plant"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#RealAnimal"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Specifies the lower body, hindquarters, or posterior segment of a creature characterized by a segmented body structure.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">has lower body of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasModificationOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasModificationOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#hasAnomaly"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#RealAnimal"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#AnatomicalPart"/>
        <rdfs:comment xml:lang="en">Indicates that a real animal, in a given Source or Interpretation, exhibits an anatomical part in an altered or aberrant form — neither simply absent nor duplicated, but substantially changed in shape, size, material, or function. Examples include reversed feet, crystalline horns, or scales in place of fur. Subproperty of :hasAnomaly.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">has modification of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasNarrativeFunction -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasNarrativeFunction">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#symbolizes"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Ability"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#AnatomicalPart"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Creature"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Interpretation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#NarrativeFunction"/>
        <rdfs:comment xml:lang="en">Links a source-specific Interpretation to the symbolic or thematic role that the creature fulfills within that Source. Unlike :embodiesArchetype — which asserts a universal psychological identity — :hasNarrativeFunction captures the contextual, plot-level, or iconographic function the beast performs in a particular text or artwork: guardian, omen, divine messenger, embodiment of sin, etc. The same creature may carry different narrative functions across different Interpretations.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">has narrative function</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasOriginContext -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasOriginContext">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Creature"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#ImaginaryPlace"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Source"/>
        <rdfs:comment xml:lang="en">Links a creature or an imaginary place to their earliest known or most culturally foundational source, whether a specific written text or a broader mythological tradition. This property acknowledges that for many creatures a single primary source cannot always be identified.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">has origin context</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasPart -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasPart">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Creature"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#AnatomicalPart"/>
        <rdfs:comment xml:lang="en">Links an ImaginaryBeing to a specific AnatomicalPart that constitutes its body, without asserting the biological origin of that part. Where :hasPartDerivedFrom links a CompositeCreature to the real animal or material from which a part originates, :hasPart simply records which anatomical components are present — useful for imaginary beings whose parts have no clear real-world derivation or whose source is not documented in the available sources.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">has part</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasPartDerivedFrom -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasPartDerivedFrom">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#ImaginaryBeing"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#InanimateElement"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Plant"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#RealAnimal"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Indicates that a composite creature possesses anatomical or morphological features derived from a specific real animal, a plant or an inanimate element.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">has part derived from</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasTailOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasTailOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#hasPartDerivedFrom"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#ImaginaryBeing"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#InanimateElement"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Plant"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#RealAnimal"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Specifies the tail structure of a creature.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">has tail of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasTextualReference -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasTextualReference">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Interpretation"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Citation"/>
        <rdfs:comment xml:lang="en">Links a source-specific Interpretation to a Citation node that captures the precise textual or visual evidence on which that interpretation rests. Where :appearsIn links an Interpretation directly to a Source at the document level, :hasTextualReference provides the finer-grained link to the exact passage and location within that Source.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">has textual reference</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#hasUpperBodyOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#hasUpperBodyOf">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#hasPartDerivedFrom"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#ImaginaryBeing"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#InanimateElement"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Plant"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#RealAnimal"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Specifies the upper body, torso, or anterior segment of a creature characterized by a segmented body structure.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">has upper body of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#involvesParent -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#involvesParent">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Genesis"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Creature"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#MythologicalFigure"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a Genesis account to a Creature or MythologicalFigure identified as a parent or progenitor within that account.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">involves parent</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#isEtymologyOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#isEtymologyOf">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Etymology"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Creature"/>
        <rdfs:comment xml:lang="en">Links an etymological origin back to the modern or targeted term it resulted in.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">is etymology of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#isGenesisOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#isGenesisOf">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Genesis"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Interpretation"/>
        <rdfs:comment xml:lang="en">Links a Genesis account back to the Interpretation it describes the origin of.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">is genesis of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#isGovernedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#isGovernedBy">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Ability"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#AnatomicalPart"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Creature"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#ImaginaryStructure"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#ImaginarySymbol"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Interpretation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Regime"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/beast/ontology#belongsTo"/>
            <rdf:Description rdf:about="https://w3id.org/beast/ontology#isGovernedBy"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/beast/ontology#belongsToImaginaryStructure"/>
            <rdf:Description rdf:about="https://w3id.org/beast/ontology#isGovernedBy"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/beast/ontology#embodiesImaginarySymbol"/>
            <rdf:Description rdf:about="https://w3id.org/beast/ontology#isGovernedBy"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">Links one of Durand&apos;s Imaginary Structures to its overarching Regime (Diurnal or Nocturnal).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">is governed by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#isOfSpecies -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#isOfSpecies">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#RealAnimal"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#RealAnimal"/>
        <rdfs:comment xml:lang="en">Links a real animal individual to the base biological species it belongs to, used particularly for creatures that exhibit anomalies or deformities but remain fundamentally members of a recognizable species.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">is of species</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#isTextualReferenceOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#isTextualReferenceOf">
        <owl:inverseOf rdf:resource="https://w3id.org/beast/ontology#hasTextualReference"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Citation"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Interpretation"/>
        <rdfs:comment xml:lang="en">The inverse of :hasTextualReference. Links a Citation back to the Interpretation it documents, allowing navigation from a specific passage in a Source to the interpretive claim it supports. This inverse direction is useful for querying which interpretations are grounded in a particular passage — for example, retrieving all creature readings that depend on a single chapter of a bestiary.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#ofCreature -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#ofCreature">
        <owl:inverseOf rdf:resource="https://w3id.org/beast/ontology#hasInterpretation"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Interpretation"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Creature"/>
        <rdfs:comment xml:lang="en">The property linking an interpretation with a creature.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">of creature</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#relatedTo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#relatedTo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Archetype"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#NarrativeFunction"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Archetype"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#NarrativeFunction"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">A symmetric associative property linking two NarrativeFunction or Archetype individuals that share thematic, structural, or symbolic overlap without one being a specialisation of the other. For example, the function of Guardian and the function of Threshold-Keeper are related but distinct; the Archetype of the Devourer and the Archetype of the Transformer share symbolic territory without subsumption. This property enables lateral navigation across the symbolic vocabulary of the ontology.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">related to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#removedAbility -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#removedAbility">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#hasDivergence"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Interpretation"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Ability"/>
        <rdfs:comment xml:lang="en">Links a source-specific Interpretation to an Ability that the creature typically possesses but which is deliberately absent in that particular Source. Documents reductive divergences from the standard behavioural description — e.g. a dragon that in a given medieval text lacks the ability to fly, inverting the conventional image.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">removed ability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#removedPart -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#removedPart">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/beast/ontology#hasDivergence"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Interpretation"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#AnatomicalPart"/>
        <rdfs:comment xml:lang="en">Links a source-specific Interpretation to an AnatomicalPart  that the Creature canonically possesses but which is deliberately absent or suppressed in that particular Source. Documents reductive anatomical divergences — e.g. a griffin depicted without its eagle wings in a specific manuscript tradition, fundamentally altering its composite identity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">removed part</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#symbolizes -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#symbolizes">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Ability"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#AnatomicalPart"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Creature"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Interpretation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Archetype"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#ImaginaryStructure"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#ImaginarySymbol"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#NarrativeFunction"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">The primary semantic bridge connecting the biological domain to the symbolic domain. It asserts that a specific physical attribute (AnatomicalPart), a behavior (Ability), a Creature or its Interpretation serves as a vehicle for a broader conceptual meaning (Archetype, Structure, etc.).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">symbolizes</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/beast/ontology#wasInfluencedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/beast/ontology#wasInfluencedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#wasInfluencedBy"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Source"/>
        <rdfs:range rdf:resource="https://w3id.org/beast/ontology#Source"/>
        <rdfs:comment xml:lang="en">Indicates that a Source drew thematic, stylistic, or conceptual inspiration from an earlier work, even without a direct citation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">was influenced by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/spar/fabio/hasSequenceIdentifier -->


    <owl:DatatypeProperty rdf:about="http://purl.org/spar/fabio/hasSequenceIdentifier"/>
    


    <!-- https://w3id.org/beast/ontology#hasAlternativeName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/beast/ontology#hasAlternativeName">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Creature"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">An alternative proper name or alias by which a creature is known across different sources or traditions, distinct from its canonical label and source-specific terminology.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">has alternative name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/beast/ontology#hasDistinctiveTrait -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/beast/ontology#hasDistinctiveTrait">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Creature"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Interpretation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">Records a short, characterizing description of the most defining features of a creature. It captures a headline characterization rather than the structured anatomical, dietary, or symbolic data modelled elsewhere.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">has distinctive trait</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/beast/ontology#hasDivergence -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/beast/ontology#hasDivergence"/>
    


    <!-- https://w3id.org/beast/ontology#hasGenesisDescription -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/beast/ontology#hasGenesisDescription">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Genesis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">A free-text narrative summary of a creature&apos;s origin as told in a specific Interpretation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">has genesis description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/beast/ontology#hasMeaning -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/beast/ontology#hasMeaning">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Archetype"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Etymology"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Interpretation"/>
                    <rdf:Description rdf:about="https://w3id.org/beast/ontology#NarrativeFunction"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">The literal string translation or definition of a term, concept, or archetypal figure.</rdfs:comment>
        <rdfs:label xml:lang="en">has meaning</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/beast/ontology#hasPassageText -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/beast/ontology#hasPassageText">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Citation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">The transcribed text of the passage extracted from a Source in which a creature is described, named, or depicted. Stored as a plain literal, this property preserves the exact wording of the primary source evidence that grounds a given Interpretation, enabling philological comparison across different textual witnesses of the same creature.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">has passage text</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/beast/ontology#hasPersonalName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/beast/ontology#hasPersonalName">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Interpretation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">Records the proper name given to a creature in a specific interpretation, distinguishing a named individual from the generic species to which it belongs. It applies at the level of the interpretation, since a personal name is typically conferred by a particular source rather than shared across all manifestations of the creature.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">has personal name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/beast/ontology#hasRootTerm -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/beast/ontology#hasRootTerm">
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Etymology"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">The literal string representation of the original word.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">has root term</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/beast/ontology#hasSequenceIdentifier -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/beast/ontology#hasSequenceIdentifier">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/spar/fabio/hasSequenceIdentifier"/>
        <rdfs:domain rdf:resource="https://w3id.org/beast/ontology#Citation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">The specific locator identifying the position of a Citation within its Source — such as a page number, folio reference, chapter, canto, stanza, or verse. Declared as a subproperty of fabio:hasSequenceIdentifier, aligning the ontology with the FRBR-aligned bibliographic vocabulary. This property allows precise scholarly referencing and enables the comparison of how different editions or translations of the same work locate their creature passages differently.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">has sequence identifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#ConceptScheme -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    


    <!-- https://schema.org/CreativeWork -->


    <owl:Class rdf:about="https://schema.org/CreativeWork"/>
    


    <!-- https://w3id.org/beast/ontology#Ability -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#Ability">
        <rdfs:comment xml:lang="en">A specific behavior, movement, or activity performed by a creature.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Ability</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#AnatomicalPart -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#AnatomicalPart">
        <rdfs:comment xml:lang="en">An anatomical component of a creature&apos;s body, such as a head, limb or tail.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Anatomical part</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#Archetype -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#Archetype">
        <rdfs:comment xml:lang="en">A universal, primordial pattern or character prototype residing in the collective human imagination. Within the ontology, the class serves as the ultimate analytical anchor that bridges the historical world with the symbolic world, linking a source-bound Interpretation of a Creature directly to its deeper allegorical, spiritual, or psychological meaning.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Archetype</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#Bestiary -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#Bestiary">
        <rdfs:subClassOf rdf:resource="https://w3id.org/beast/ontology#Source"/>
        <rdfs:comment xml:lang="en">A specific type of compendium cataloging various animals and imaginary creatures.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">Bestiary</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#BestiaryType -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#BestiaryType">
        <rdfs:comment xml:lang="en">The thematic or functional classification of a bestiary.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">Bestiary Type</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#CinematicWork -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#CinematicWork">
        <rdfs:subClassOf rdf:resource="https://w3id.org/beast/ontology#Source"/>
        <rdfs:comment xml:lang="en">A cinematographic work serving as a modern source for creature depictions.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">CinematicWork</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#Citation -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#Citation">
        <rdfs:comment xml:lang="en">A structured reference to a specific passage within a Source that documents a creature&apos;s appearance in a particular Interpretation, capturing both the precise textual location and the quoted or paraphrased content.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">Citation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#CompositeCreature -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#CompositeCreature">
        <rdfs:subClassOf rdf:resource="https://w3id.org/beast/ontology#ImaginaryBeing"/>
        <rdfs:comment xml:lang="en">A creature composed of disparate parts, whether those parts are from different animals or distinct materials.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Composite creature</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#Creature -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#Creature">
        <rdfs:comment xml:lang="en">Any living entity, whether based in biological reality or imagination, described within a Source. It serves as the central node tying together all historical, biological and symbolic variations.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">Creature</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#Diet -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#Diet">
        <rdfs:comment xml:lang="en">The standard food consumption habits of a creature.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Diet</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#DiurnalRegime -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#DiurnalRegime">
        <rdfs:subClassOf rdf:resource="https://w3id.org/beast/ontology#Regime"/>
        <owl:disjointWith rdf:resource="https://w3id.org/beast/ontology#NocturnalRegime"/>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#Etymology -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#Etymology">
        <rdfs:comment xml:lang="en">The documented linguistic origin of the name used to identify a Creature, capturing its root term, source language, and original meaning.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">Etymology</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#Genesis -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#Genesis">
        <rdfs:comment xml:lang="en">A source-specific account of a creature&apos;s origin or birth, capturing the parent(s) or progenitor(s) involved, and/or a circumstantial or causal explanation. Because genealogical and origin narratives frequently vary or conflict across sources, Genesis is modelled at the level of Interpretation rather than Creature, allowing multiple, potentially divergent, origin accounts to coexist for the same universal creature concept without asserting a single canonical explanation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">Genesis</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#GeographicPlace -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#GeographicPlace">
        <rdfs:subClassOf rdf:resource="https://w3id.org/beast/ontology#RealWorldPlace"/>
        <rdfs:comment xml:lang="en">A specific, real-world named location (e.g. a country, region, or city) that serves as a creature&apos;s habitat or place of origin, as distinct from a general ecological biome type.</rdfs:comment>
        <rdfs:label xml:lang="en">Geographic place</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#Habitat -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#Habitat">
        <rdfs:comment xml:lang="en">The natural or mythological environment in which a creature lives or is commonly found.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Habitat</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#HybridCreature -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#HybridCreature">
        <rdfs:subClassOf rdf:resource="https://w3id.org/beast/ontology#CompositeCreature"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/beast/ontology#hasPartDerivedFrom"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/beast/ontology#RealAnimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A specific type of imaginary being composed of anatomical parts from two or more distinct real animals.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Hybrid creature</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#ImaginaryBeing -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#ImaginaryBeing">
        <rdfs:subClassOf rdf:resource="https://w3id.org/beast/ontology#Creature"/>
        <owl:disjointWith rdf:resource="https://w3id.org/beast/ontology#RealAnimal"/>
        <rdfs:comment xml:lang="en">A creature that does not exist in the natural world, originating from folklore, myth, or literary invention.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Imaginary being</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#ImaginaryPlace -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#ImaginaryPlace">
        <rdfs:subClassOf rdf:resource="https://w3id.org/beast/ontology#Habitat"/>
        <owl:disjointWith rdf:resource="https://w3id.org/beast/ontology#RealWorldPlace"/>
        <rdfs:comment xml:lang="en">A conceptual, magical, or purely literary space (e.g. the Garden of Eden or Hades). As noted by Borges, these spaces follow the laws of imagination rather than biology.</rdfs:comment>
        <rdfs:label xml:lang="en">Imaginary place</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#ImaginaryStructure -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#ImaginaryStructure"/>
    


    <!-- https://w3id.org/beast/ontology#ImaginarySymbol -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#ImaginarySymbol"/>
    


    <!-- https://w3id.org/beast/ontology#InanimateElement -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#InanimateElement">
        <rdfs:comment xml:lang="en">Non-living matter or material (e.g. stone and metal) that forms part of a creature&apos;s physical anatomy.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Inanimate element</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#Interpretation -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#Interpretation">
        <rdfs:comment xml:lang="en">A specific conceptualization, reading, or artistic depiction of a creature as conceived by a particular creator within a specific Source. It distinguishes the universal concept of a Creature from its specific variations, allowing researchers to document how a single beast&apos;s anatomy, behavior, or allegorical meaning mutates when handled by different authors, artists, or historical periods.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">Interpretation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#LiteraryWork -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#LiteraryWork">
        <rdfs:subClassOf rdf:resource="https://w3id.org/beast/ontology#Source"/>
        <rdfs:comment xml:lang="en">A written source text, such as a poem or novel, in which a creature is described, cited, or appears.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">Literary work</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#Module -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#Module">
        <rdfs:comment xml:lang="en">Top level class for organizing the ontology architecture into three distinct layers (Provenance, Biological, Symbolic).</rdfs:comment>
        <rdfs:label xml:lang="en">Module</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#MysticalStructure -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#MysticalStructure">
        <rdfs:subClassOf rdf:resource="https://w3id.org/beast/ontology#ImaginaryStructure"/>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#MythologicalFigure -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#MythologicalFigure">
        <rdfs:comment xml:lang="en">A deity, hero, personified force, or other agent from myth or tradition.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">Mythological Figure</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#NarrativeFunction -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#NarrativeFunction">
        <rdfs:comment xml:lang="en">A symbolic or thematic role that a creature fulfills within a specific Source, independent of its biological traits. Narrative functions capture the cultural and literary work that a beast performs in a given tradition — e.g. acting as a guardian or an emblem of divine power. Where :Archetype captures the universal psychological pattern, NarrativeFunction captures the contextual, source-specific role that pattern takes within a narrative or iconographic programme.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Narrative Function</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#NocturnalRegime -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#NocturnalRegime">
        <rdfs:subClassOf rdf:resource="https://w3id.org/beast/ontology#Regime"/>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#Plant -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#Plant">
        <rdfs:comment xml:lang="en">A living organism belonging to the botanical kingdom, often serving as a biological component in composite creatures (e.g. roots or branches).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Plant</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#RealAnimal -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#RealAnimal">
        <rdfs:subClassOf rdf:resource="https://w3id.org/beast/ontology#Creature"/>
        <rdfs:comment xml:lang="en">A scientifically recognized biological animal that exists or existed in the natural world.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Real animal</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#RealWorldPlace -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#RealWorldPlace">
        <rdfs:subClassOf rdf:resource="https://w3id.org/beast/ontology#Habitat"/>
        <rdfs:comment xml:lang="en">A geographic or ecological habitat that exists in the physical world. Class influenced by J. L. Borges&apos; distinction between biological reality and the imaginary spaces.</rdfs:comment>
        <rdfs:label xml:lang="en">Real-world place</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#Regime -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#Regime"/>
    


    <!-- https://w3id.org/beast/ontology#SchizomorphicStructure -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#SchizomorphicStructure">
        <rdfs:subClassOf rdf:resource="https://w3id.org/beast/ontology#ImaginaryStructure"/>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#Source -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#Source">
        <rdfs:subClassOf rdf:resource="https://schema.org/CreativeWork"/>
        <rdfs:comment xml:lang="en">A primary text, manuscript, or artifact where a creature is described or depicted.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">Source</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#SyntheticStructure -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#SyntheticStructure">
        <rdfs:subClassOf rdf:resource="https://w3id.org/beast/ontology#ImaginaryStructure"/>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#Tradition -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#Tradition">
        <rdfs:subClassOf rdf:resource="https://w3id.org/beast/ontology#Source"/>
        <rdfs:comment xml:lang="en">A cultural, mythological, or folkloric tradition functioning as the origin context for a creature, predating or existing independently of any identifiable written source.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">Tradition</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/beast/ontology#VisualArtwork -->


    <owl:Class rdf:about="https://w3id.org/beast/ontology#VisualArtwork">
        <rdfs:subClassOf rdf:resource="https://w3id.org/beast/ontology#Source"/>
        <rdfs:comment xml:lang="en">A visual representation, such as an illumination, painting, or sculpture, depicting a creature.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">Visual artwork</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/beast/ontology#Aerial -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#Aerial">
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#RealWorldPlace"/>
        <rdfs:comment xml:lang="en">A physical habitat located in the sky, clouds, or upper atmosphere.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Aerial</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#Aquatic -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#Aquatic">
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#RealWorldPlace"/>
        <rdfs:comment xml:lang="en">A physical habitat located in or around bodies of water, such as oceans, rivers, or lakes.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Aquatic</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#AscensionalSymbol -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#AscensionalSymbol">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#ImaginarySymbol"/>
        <belongsTo rdf:resource="https://w3id.org/beast/ontology#SchizomorphicStructure"/>
        <rdfs:comment xml:lang="en">Ascensional symbol embodies heroic symbols of elevation, verticality, and transcendence. It represents the upward movement to escape the degradation of time and the symbolic refusal of death. In this structure, height is synonymous with the pure and the divine; the wing is the ascensional instrument that contradicts gravity. These symbols manifest a quest to regain lost power through movement toward metaphysical spaces (e.g., mountains), dazzling imagery (arrows, wings), and virile archetypes of celestial royalty and the warrior.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Ascensional Symbol</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/beast/ontology#SchizomorphicStructure"/>
        <skos:inScheme rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
        <skos:prefLabel xml:lang="en">Ascensional Symbol</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#BiologicalModule -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#BiologicalModule">
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#Module"/>
        <rdfs:comment xml:lang="en">The Biological Module catalogs the physical and behavioural traits of creatures — whether real or imaginary — as described in Bestiaries and other Sources. It distinguishes real animals from imaginary beings, and further classifies the latter into composite and hybrid creatures whose anatomy is derived from two or more biological sources. For real animals it documents deformities and monstrous irregularities through a structured vocabulary of anatomical anomaly: absence of a canonical part, duplication, and modification. For imaginary beings it records the anatomical parts they possess and the real animals, plants, or inanimate elements from which those parts are derived. Across all creatures the module captures habitats — distinguishing real geographic environments from mythological or imaginary spaces — diets, and abilities. This layer serves as the primary morphological record that the Symbolic Module then interprets as archetypal and cultural meaning.</rdfs:comment>
        <rdfs:label xml:lang="en">Biological Module</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#Carnivorous -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#Carnivorous">
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#Diet"/>
        <rdfs:comment xml:lang="en">A diet consisting primarily of animal meat.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Carnivorous</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#CatamorphicSymbol -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#CatamorphicSymbol">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#ImaginarySymbol"/>
        <belongsTo rdf:resource="https://w3id.org/beast/ontology#SchizomorphicStructure"/>
        <rdfs:comment xml:lang="en">Catamorphic symbol embodies falling, gravity, and the physical degradation of flesh. These dynamic images of transience represent the dazzling acceleration of time during a downward plunge. Catamorphic symbol captures the existential anxiety of the fall, where movement signifies the inescapable and rapid passage of time toward death.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Catamorphic Symbol</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/beast/ontology#SchizomorphicStructure"/>
        <skos:inScheme rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
        <skos:prefLabel xml:lang="en">Catamorphic Symbol</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#CyclicalSymbol -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#CyclicalSymbol">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#ImaginarySymbol"/>
        <belongsTo rdf:resource="https://w3id.org/beast/ontology#SyntheticStructure"/>
        <rdfs:comment xml:lang="en">Cyclical symbol represents the archetype of the Eternal Return and time as a series of phases. Using the moon as a primary model - being the first to die and the first to be reborn - these symbols suggest that time is a series of phases where opposites (life/death, light/dark) coexist. This &apos;lunar optimism&apos; does not negate death but reintegrates it as an essential stage of an incessant, evolving movement where every sunset is a prelude to a new dawn. The repetition of opposites is also linked to evolution: it is not merely a continuous repetition of the same events. Things that change may also evolve or move forward; they may progress.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Cyclical Symbol</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/beast/ontology#SyntheticStructure"/>
        <skos:inScheme rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
        <skos:prefLabel xml:lang="en">Cyclical Symbol</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#DiareticSymbol -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#DiareticSymbol">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#ImaginarySymbol"/>
        <belongsTo rdf:resource="https://w3id.org/beast/ontology#SchizomorphicStructure"/>
        <rdfs:comment xml:lang="en">Diaretic symbol embodies figures of cutting, weapons, and purification, derived from the Greek term &apos;diairesis&apos; (division). They represent the human need for analysis, categorization, and absolute separation to overcome natural chaos. The hero&apos;s weapon is a dual symbol of power and purity; by cutting through confusion and separating the real from the imaginary, or good from evil, the hero gains mastery over the world. In this structure, the act of separation is the primary source of intellectual and spiritual power.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Diaretic Symbol</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/beast/ontology#SchizomorphicStructure"/>
        <skos:inScheme rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
        <skos:prefLabel xml:lang="en">Diaretic Symbol</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#DiurnalRegime -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#DiurnalRegime">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#DurandImaginary -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#DurandImaginary">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <terms:title xml:lang="en">Durand&apos;s structures of the Imaginary</terms:title>
        <rdfs:comment xml:lang="en">A conceptual scheme providing a framework for the symbolic and anthropological analysis of creatures within bestiaries. It acts as the theoretical pivot of the Symbolic Module, allowing for the classification of beasts and their attributes based on their relationship with human anxiety regarding time and death. By applying Gilbert Durand&apos;s regimes and structures defined in &apos;Les Structures Anthropologiques de l&apos;Imaginaire&apos;, &apos;beast&apos; can map how physical biological traits - such as wings - serve as archetypal responses to mortality, transforming the creature from a mere biological entity into a profound cultural symbol.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <skos:hasTopConcept rdf:resource="https://w3id.org/beast/ontology#ImaginaryStructure"/>
        <skos:hasTopConcept rdf:resource="https://w3id.org/beast/ontology#Regime"/>
        <prov:wasDerivedFrom>Durand, G. (1972). Le Strutture Antropologiche dell&apos;Immaginario: introduzione all&apos;archetipologia generale</prov:wasDerivedFrom>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#Elemental -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#Elemental">
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#Diet"/>
        <rdfs:comment xml:lang="en">Creatures that eat things like fire, air, or even human souls.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Elemental</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#Hematophagous -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#Hematophagous">
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#Diet"/>
        <rdfs:comment xml:lang="en">Blood-drinkers.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Hematophagous</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#Herbivorous -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#Herbivorous">
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#Diet"/>
        <rdfs:comment xml:lang="en">A diet consisting primarily of plant matter.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Herbivorous</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#ImaginaryStructure -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#ImaginaryStructure">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#ImaginarySymbol -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#ImaginarySymbol">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#IntimacySymbol -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#IntimacySymbol">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#ImaginarySymbol"/>
        <belongsTo rdf:resource="https://w3id.org/beast/ontology#MysticalStructure"/>
        <rdfs:comment xml:lang="en">Intimacy symbol represents the center, the home, and the magical cradle. This symbol reduces the vast, terrifying world into a controllable, safe microcosm - such as a shell, a tomb seen as a place of rest, or a secret dwelling. It marks an inversion toward interiority and the soul, where the essence of the creature is protected within a restful and familiar space. It embodies the transition from the fear of being &apos;swallowed&apos; to the comfort of being &apos;contained&apos;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Intimacy Symbol</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/beast/ontology#MysticalStructure"/>
        <skos:inScheme rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
        <skos:prefLabel xml:lang="en">Intimacy Symbol</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#InversionSymbol -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#InversionSymbol">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#ImaginarySymbol"/>
        <belongsTo rdf:resource="https://w3id.org/beast/ontology#MysticalStructure"/>
        <rdfs:comment xml:lang="en">Inversion symbol exorcises the fear of time by turning negative images into positive ones. Through an involutive process, the devouring mouth of the Diurnal Regime is transmuted into a protective nest. Instead of a heroic battle against darkness, there is a mystical union with it. This defensive mechanism employs doubling and reassuring symbols of intimacy to transform a dangerous fall into a controlled descent into the secrets of becoming.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Inversion Symbol</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/beast/ontology#MysticalStructure"/>
        <skos:inScheme rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
        <skos:prefLabel xml:lang="en">Inversion Symbol</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#LiteraryMetafiction -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#LiteraryMetafiction">
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#BestiaryType"/>
        <rdfs:comment xml:lang="en">A post-modern or highly stylized genre where the bestiary is used as a narrative or literary device (e.g. Borges).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">Literary Metafiction</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#Lithophagous -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#Lithophagous">
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#Diet"/>
        <rdfs:comment xml:lang="en">Stone-eaters.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Lithophagous</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#MoralAllegory -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#MoralAllegory">
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#BestiaryType"/>
        <rdfs:comment xml:lang="en">The traditional medieval genre where creatures are described primarily for Christian theological or moral lessons.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">Moral Allegory</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#MysticalStructure -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#MysticalStructure">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <isGovernedBy rdf:resource="https://w3id.org/beast/ontology#NocturnalRegime"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#NocturnalRegime -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#NocturnalRegime">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#NyctomorphicSymbol -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#NyctomorphicSymbol">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#ImaginarySymbol"/>
        <belongsTo rdf:resource="https://w3id.org/beast/ontology#SchizomorphicStructure"/>
        <rdfs:comment xml:lang="en">Nyctomorphic symbol encapsulates the temporal symbolism of darkness, blindness, and shadows. Linked to the voracity of the night, it often incorporates the element of water - viewed here not as a source of life, but as an elusive, dark surface that doubles the abyss and reflects the formless terror of the unknown.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Nyctomorphic Symbol</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/beast/ontology#SchizomorphicStructure"/>
        <skos:inScheme rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
        <skos:prefLabel xml:lang="en">Nyctomorphic Symbol</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#Omnivorous -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#Omnivorous">
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#Diet"/>
        <rdfs:comment xml:lang="en">A diet consisting of both animal and plant matter.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Omnivorous</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#ProvenanceModule -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#ProvenanceModule">
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#Module"/>
        <rdfs:comment xml:lang="en">The Provenance Module documents the historical and textual footprint of every creature in the ontology. It distinguishes between the universal, abstract concept of a beast (Creature) and its source-specific manifestations (Interpretation), allowing the ontology to track how a single entity is described, depicted, or reinterpreted across different authors, periods, and media — from medieval manuscripts to contemporary film. It anchors each Interpretation to the primary Source in which it appears and classifies Sources by their genre and intertextual relationships through :cites and :wasInfluencedBy.</rdfs:comment>
        <rdfs:label xml:lang="en">Provenance Module (the Anchor)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#Regime -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#Regime">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#Scavenger -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#Scavenger">
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#Diet"/>
        <rdfs:comment xml:lang="en">Creatures that eat dead organic matter.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Scavenger</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#SchizomorphicStructure -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#SchizomorphicStructure">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <isGovernedBy rdf:resource="https://w3id.org/beast/ontology#DiurnalRegime"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#ScientificTaxonomy -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#ScientificTaxonomy">
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#BestiaryType"/>
        <rdfs:comment xml:lang="en">A genre focused on the scientific categorization and biological documentation of animals (e.g. Aldrovandi and Paré).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#ProvenanceModule"/>
        <rdfs:label xml:lang="en">Scientific Taxonomy</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#SpectacularSymbol -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#SpectacularSymbol">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#ImaginarySymbol"/>
        <belongsTo rdf:resource="https://w3id.org/beast/ontology#SchizomorphicStructure"/>
        <rdfs:comment xml:lang="en">Spectacular symbol relates to intense light, vision, and the heroic gaze. Standing in direct opposition to darkness, it emphasizes the triumph of clarity and the &apos;solar power&apos; that makes the world intelligible and thus controllable. Sight is the supreme sense of the hero, as clear vision allows for the differentiation of things and the definition of clear boundaries. In this context, light functions as a sword, cutting through obscurity to define reality.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Spectacular Symbol</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/beast/ontology#SchizomorphicStructure"/>
        <skos:inScheme rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
        <skos:prefLabel xml:lang="en">Spectacular Symbol</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#SymbolicModule -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#SymbolicModule">
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#Module"/>
        <rdfs:comment xml:lang="en">The Symbolic Module represents the analytical and interpretive layer of the ontology, where art history, literary theory, depth psychology, and anthropology converge. It provides two interlocking frameworks for the symbolic analysis of creatures and their source-specific Interpretations. First, the DurandImaginary scheme applies Gilbert Durand&apos;s anthropological structures of the imaginary to classify creatures according to the Regime (Diurnal or Nocturnal) and structural logic (Schizomorphic, Mystical, or Synthetic) that governs their symbolic imagery. Second, the archetype and narrative function layer — through :Archetype, :NarrativeFunction, :embodiesArchetype, and :hasNarrativeFunction — distinguishes between the universal psychological pattern a creature instantiates across all its manifestations and the specific contextual role it performs within a given Source. The module also captures symbolic divergences at the level of Interpretation: the properties :additionalPart, :removedPart, :additionalAbility, :removedAbility, :alternativeDiet and :alternativeHabitat document how a specific author or tradition departs from the canonical image of a creature, and what symbolic meaning those departures carry.</rdfs:comment>
        <rdfs:label xml:lang="en">Symbolic Module</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#SyntheticStructure -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#SyntheticStructure">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <isGovernedBy rdf:resource="https://w3id.org/beast/ontology#NocturnalRegime"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#TeriomorphicSymbol -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#TeriomorphicSymbol">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#ImaginarySymbol"/>
        <belongsTo rdf:resource="https://w3id.org/beast/ontology#SchizomorphicStructure"/>
        <rdfs:comment xml:lang="en">Teriomorphic symbol represents the terrifying aspect of animals, embodying biting, devouring, and feral chaos. As &apos;enemy symbol&apos; of anxiety and darkness, it is linked to the restlessness caused by rapid, undisciplined movement. It captures the chaos of fleeing from &apos;devouring time&apos; and the archetype of the predatory jaws ready to strike.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Teriomorphic Symbol</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/beast/ontology#SchizomorphicStructure"/>
        <skos:inScheme rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
        <skos:prefLabel xml:lang="en">Teriomorphic Symbol</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/beast/ontology#Terrestrial -->


    <owl:NamedIndividual rdf:about="https://w3id.org/beast/ontology#Terrestrial">
        <rdf:type rdf:resource="https://w3id.org/beast/ontology#RealWorldPlace"/>
        <rdfs:comment xml:lang="en">A physical habitat primarily located on solid ground or within the earth.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#BiologicalModule"/>
        <rdfs:label xml:lang="en">Terrestrial</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotations
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <rdf:Description rdf:about="https://w3id.org/beast/ontology#DiurnalRegime">
        <rdfs:comment xml:lang="en">The Diurnal Regime is characterized by the battle against death and time. It is governed by antithesis, encompassing axiomatic images that give rise to two polarized facets: a background of darkness against which the victorious splendor of light is contrasted, and antithetical reconquest of negative values. It embodies the sharp logic of the sword and heroic battles against the passage of time. This regime is built upon schizomorphic structures, defined by separation, fall, antithesis, and scission. It is a multifaceted regime that includes theriomorphic, nyctomorphic, catamorphic, ascensional, spectacular, and diaretic symbols. Together, these symbols express both the profound anxiety in front of time and death and the heroic drive to transcend or overcome these forces.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Diurnal Regime</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/beast/ontology#Regime"/>
        <skos:inScheme rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
        <skos:prefLabel xml:lang="en">Diurnal Regime</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/beast/ontology#ImaginaryStructure">
        <rdfs:comment xml:lang="en">The structural framework of the imaginary as defined by Gilbert Durand in &apos;Les Structures Anthropologiques de l&apos;Imaginaire&apos;, acting as the mediating layer between biological reflexes and symbolic expression. It represents the archetypal logic that organizes a creature&apos;s physical and behavioral attributes into a coherent symbolic system. It provides the protocol through which raw sensory data - such as a beast&apos;s fangs, its flight, or its habitat - is transformed into a structured symbolic response (Schizomorphic, Mystical, or Synthetic) to the existential anxiety of time and death.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Imaginary Structure</rdfs:label>
        <skos:inScheme rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
        <skos:prefLabel xml:lang="en">Imaginary Structure</skos:prefLabel>
        <skos:topConceptOf rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/beast/ontology#ImaginarySymbol">
        <rdfs:comment xml:lang="en">The shared OWL class and intermediate SKOS concept grouping all specific symbolic categories recognised by Gilbert Durand within his structures of the imaginary. As an owl:Class it provides the common type for all symbol individuals (TeriomorphicSymbol, AscensionalSymbol, CyclicalSymbol, etc.), allowing properties such as :belongsTo to range over them uniformly. As a skos:Concept it sits between :ImaginaryStructure and the specific symbol individuals in the DurandImaginary thesaurus, making the three-level hierarchy (ImaginaryStructure → ImaginarySymbol → specific symbol) navigable via skos:broader.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Imaginary Symbol</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/beast/ontology#ImaginaryStructure"/>
        <skos:inScheme rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
        <skos:prefLabel xml:lang="en">Imaginary Symbol</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/beast/ontology#MysticalStructure">
        <rdfs:comment xml:lang="en">Mystical structures include symbols of intimacy and calm, the search for light within darkness. The principles underlying mystical structures are analogy and similarity. Instead of battling against time, one enters into union with it. The mind takes images of terror and rewrites them positively, transforming them into refuge and protected space. Within this logic, opposites can coexist. In mystical structures one finds doubling and adherence rather than antithesis. It functions through inversion, doubling, and adherence, turning the devouring mouth of the diurnal regime into a protective container.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Mystical Structure (or Antiphrastic)</rdfs:label>
        <skos:altLabel xml:lang="en">Antiphrastic</skos:altLabel>
        <skos:broader rdf:resource="https://w3id.org/beast/ontology#ImaginaryStructure"/>
        <skos:inScheme rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
        <skos:prefLabel xml:lang="en">Mystical Structure</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/beast/ontology#NocturnalRegime">
        <rdfs:comment xml:lang="en">The Nocturnal Regime represents an attitude of reconciliation in front of the fleeting nature of time, incorporating symbols of transformation and cyclicality. The symbols belonging to the nocturnal regime exorcise fear by transforming images into reassuring figures. Unlike the diurnal regime, the antidote to the passing of time is not sought on a superhuman or transcendent level, but rather in reassuring intimacy or in the rhytmic constants that govern natural phenomena. The nocturnal regime is divided into synthetic structures and mystical structures.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Nocturnal Regime</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/beast/ontology#Regime"/>
        <skos:inScheme rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
        <skos:prefLabel xml:lang="en">Nocturnal Regime</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/beast/ontology#Regime">
        <rdfs:comment xml:lang="en">The fundamental high-level classification of Durand, organized around sensory-motor dominants (postural, digestive, cyclic). Regimes act as organizational systems of the imagination, condensing multiple symbolic meanings into a coherent structure.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Regime</rdfs:label>
        <skos:inScheme rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
        <skos:prefLabel xml:lang="en">Regime</skos:prefLabel>
        <skos:topConceptOf rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/beast/ontology#SchizomorphicStructure">
        <rdfs:comment xml:lang="en">The Schizomorphic Structure represents the mode of the imaginary governed by the Diurnal Regime. It functions through the principles of antithesis and verticality as a defensive response to the anxiety of time. It operates via &apos;diaresis&apos; – the act of cutting, dividing, and establishing absolute distinctions to maintain the separation between light and dark, height and depth. This structure organizes symbols into two polarized groups: the &apos;symbols of the antithesis&apos; (teriomorphic, nyctomorphic, and catamorphic), which represent the terror of the abyss and devouring time; and the &apos;symbols of transcendence&apos; (ascensional, spectacular, and diaretic), which provide the tools for the heroic reconquest through verticality, solar vision, and the purifying sword.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Schizomorphic Structure (or Heroic)</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/beast/ontology#ImaginaryStructure"/>
        <skos:inScheme rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
        <skos:prefLabel xml:lang="en">Schizomorphic Structure (or Heroic)</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/beast/ontology#SyntheticStructure">
        <rdfs:comment xml:lang="en">Synthetic structure operates by bringing contradictions into dialogue and includes cyclical symbols. It treats time as a series of phases, where night is a necessary prelude to dawn and death is a prelude to rebirth. It transforms the fall into a slow, controlled descent, allowing for the acceptance of change and progress through the succession of opposites.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">Synthetic Structure (or Dramatic)</rdfs:label>
        <skos:altLabel xml:lang="en">Dramatic</skos:altLabel>
        <skos:broader rdf:resource="https://w3id.org/beast/ontology#ImaginaryStructure"/>
        <skos:inScheme rdf:resource="https://w3id.org/beast/ontology#DurandImaginary"/>
        <skos:prefLabel xml:lang="en">Synthetic Structure</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://w3id.org/beast/ontology#hasDivergence">
        <rdfs:comment xml:lang="en">The parent property for all divergence assertions linking a source-specific Interpretation to the biological feature — either an AnatomicalPart or an Ability — that differs from the creature&apos;s canonical description in that Source. Subproperties :additionalAbility, :removedAbility, :additionalPart, and :removedPart specialise the nature of the divergence. This structure allows the ontology to answer questions such as &apos;which interpretations add wings to a normally wingless creature&apos; or &apos;which sources suppress a creature&apos;s canonical venom ability&apos;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/beast/ontology#SymbolicModule"/>
        <rdfs:label xml:lang="en">has divergence</rdfs:label>
    </rdf:Description>
    


