    {
      "@id": "beastiary:ability_sing",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SyntheticStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:CyclicalSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "Song as harmonious, rhythmic utterance expresses the cyclical register of patterned, reassuring repetition."
        },
        {
          "@language": "en",
          "@value": "The ability to produce melodious vocalizations, often with enchanting or symbolic effects on listeners."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Singing"
      }
    },
    {
