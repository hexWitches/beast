    {
      "@id": "beastiary:citation_plinio_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_naturalis_historia"
      },
      "beast:hasPassageText": {
        "@language": "la",
        "@value": "Prima che delle piramidi, bisogna parlare della Sfinge, monumento che meriterebbe addirittura una trattazione più ampia. Ma su di essa c'è silenzio: gli abitanti la considerano una divinità. Ritengono che vi sia sepolto il re Harmais e vogliono credere che sembri costruita con materiale portato colà. È invece scolpita nella pietra viva, ed il volto rosso del mostro è oggetto di culto; la circonferenza di esso all'altezza della fornte raggiunge i 102 piedi; la lunghezza dell'intera statua è di 143 piedi e l'altezza del ventre fino al vertice dell'aspide che sta sul capo è 61 piedi e mezzo."
      },
      "beast:hasSequenceIdentifier": [
        "Book 36",
        "Paragraph 17"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_sphinx_plinio"
      }
    },
