    {
      "@id": "beastiary:citation_aldrovandi_11",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_monstrorum_historia_aldrovandi"
      },
      "beast:hasPassageText": "Nell'opera di Ambroise Paré è riportata l'effigie di una fanciulla a due teste, la quale era molto bella e ben formata in tutte le membra, ma aveva due teste, entrambe le quali avevano la medesima necessità di bere, mangiare, dormire e parlare. Questo mostro elemosinava di che vivere andando di porta in porta, tuttavia fu infine allontanato dalla Baviera su ordine dei governanti, poiché temevano che le donne incinte, vedendo frequentemente il mostro, trasmettessero quella stessa deformità ai propri figli.",
      "beast:hasSequenceIdentifier": "Capitolo 5: Anomalie delle singole parti del corpo",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_anomaly_aldrovandi_3"
      }
    },
