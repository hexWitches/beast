    {
      "@id": "beastiary:etymology_horse",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word derives from the Proto-Germanic 'harss-', of unknown origin. By some, connected to Proto-Indo-European root 'kers-' to run, source of Latin currere, to run."
      },
      "beast:hasRootTerm": {
        "@language": "gem",
        "@value": "Harss"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_horse"
      }
    },
    {
      "@id": "beastiary:function_apotropaic",
      "@type": "beast:NarrativeFunction",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The creature, or its image, serves to ward off evil and protect against harm."
      }
    },
    {
      "@id": "beastiary:etymology_scorpion",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word \"'scorpion' originates from the Latin term 'scorpionem', which is derived from the Greek word 'skorpios'. This Greek term is related to the Proto-Indo-European root 'sker-', meaning to cut or to shear."
      },
      "beast:hasRootTerm": {
        "@language": "la",
        "@value": "Scorpionem"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_scorpion"
      }
    },
    {
      "@id": "beastiary:genesis_giant_teogonia",
      "@type": "beast:Genesis",
      "beast:hasGenesisDescription": {
        "@language": "en",
        "@value": "Sprang from Gaia (Earth) after she was fertilised by the blood of Uranus's castration."
      },
      "beast:involvesParent": [
        {
          "@id": "beastiary:myth_gaia"
        },
        {
          "@id": "beastiary:myth_uranus"
        }
      ],
      "beast:isGenesisOf": {
        "@id": "beastiary:int_giant_teogonia"
      }
    },
    {
      "@id": "beastiary:int_snake_dante",
      "@type": "beast:Interpretation",
      "beast:alternativeHabitat": {
        "@id": "beast:habitat_hell"
      },
      "beast:appearsIn": {
        "@id": "beastiary:source_dante_inferno"
      },
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:TeriomorphicSymbol"
      },
      "beast:hasNarrativeFunction": {
        "@id": "beastiary:function_punisher"
      },
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_dante_inferno_5"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_snake"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Dante's serpents bite, poison, and devour the thieves, instruments of an animal terror that dissolves human identity; the biting, venomous reptile is the teriomorphic beast par excellence."
      }
    },
    {
      "@id": "beastiary:archetype_resilience",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The figure of endurance that withstands and recovers from oppression or adversity."
      },
      "beast:relatedTo": {
        "@id": "beastiary:archetype_defiance"
      }
    },
    {
      "@id": "beastiary:creature_centaur",
      "@type": [
        "beast:Creature",
        "beast:HybridCreature"
      ],
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:TeriomorphicSymbol"
      },
      "beast:hasAbility": [
        {
          "@id": "beastiary:ability_archery"
        },
        {
          "@id": "beastiary:ability_wine_drinking"
        }
      ],
      "beast:hasAlternativeName": [
        "Hippocentaurus",
        "Sagitarius"
      ],
      "beast:hasDiet": {
        "@id": "beast:Omnivorous"
      },
      "beast:hasEtymology": {
        "@id": "beastiary:etymology_centaur"
      },
      "beast:hasHabitat": [
        {
          "@id": "beastiary:habitat_forests"
        },
        {
          "@id": "beastiary:habitat_mountains"
        }
      ],
      "beast:hasHeadOf": {
        "@id": "beastiary:creature_human"
      },
      "beast:hasLowerBodyOf": {
        "@id": "beastiary:creature_horse"
      },
      "beast:hasOriginContext": {
        "@id": "beastiary:source_greek_mythology"
      },
      "beast:hasTailOf": {
        "@id": "beastiary:creature_horse"
      },
      "beast:hasUpperBodyOf": {
        "@id": "beastiary:creature_human"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Across most sources the centaur's horse-lower-body dominates its symbolism: uncontrolled instinct, drunken violence, and predatory appetite erupting through the fragile veneer of human reason, placing the creature within the teriomorphic register of feral chaos, even where individual figures like Chiron invert this dominant."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Centaur"
      }
    },
    {
      "@id": "beastiary:citation_rochester_1",
