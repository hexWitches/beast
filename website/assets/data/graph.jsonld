    {
      "@id": "beastiary:citation_dante_inferno_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_dante_inferno"
      },
      "beast:hasPassageText": {
        "@language": "it",
        "@value": "Così per li gran savi si confessa / che la fenice more e poi rinasce, / quando al cinquecentesimo anno appressa; / erba né biado in sua vita non pasce, / ma sol d’incenso lagrime e d’amomo, / e nardo e mirra son l’ultime fasce."
      },
      "beast:hasSequenceIdentifier": [
        "XXIV",
        "vv. 106-111"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_phoenix_dante"
      }
    },
