      },
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_dante_inferno_5"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_snake"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Dante's serpents bite, poison, and devour the thieves, instruments of an animal terror that dissolves human identity; the biting, venomous reptile is the teriomorphic beast par excellence."
      }
    },
    {
      "@id": "beastiary:citation_rowling_4",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_fantastic_beasts"
      },
      "beast:hasPassageText": {
        "@language": "en",
        "@value": "The Egyptian sphinx has a human head on a lion’s body. For over a thousand years it has been used by witches and wizards to guard valuables and secret hideaways. Highly intelligent, the sphinx delights in puzzles and riddles. It is usually dangerous only when what it is guarding is threatened."
      },
      "beast:hasSequenceIdentifier": "Chapter: Ministry of Magic Classifications",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_sphinx_rowling_fantastic"
      }
    },
    {
      "@id": "beastiary:person_ariosto",
