        },
        {
          "@id": "beastiary:archetype_shameful_offspring"
        }
      ],
      "beast:hasDistinctiveTrait": [
        "The chimera is produced through human transmutation",
        "a forbidden alchemical act. The product is a new",
        "combined creature which inherits features and attributes from both of its original base organisms."
      ],
      "beast:hasNarrativeFunction": {
        "@id": "beastiary:function_guardian"
      },
