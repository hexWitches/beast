      }
    },
    {
      "@id": "beastiary:citation_ovid_met_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_ovidius_metamorphoses"
      },
      "beast:hasPassageText": {
        "@language": "la",
        "@value": "“L’essere che era il disonore della stirpe era già divenuto adulto e il turpe / adulterio della madre diveniva evidente a causa della singolarità del mostro biforme"
      },
      "beast:hasSequenceIdentifier": [
        "VIII",
        "vv. 155-156"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_minotaur_ovidius"
      }
    },
    {
      "@id": "beastiary:archetype_love",
