    },
    {
      "@id": "beastiary:etymology_onocentaur",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "From Ancient Greek onokentauros (ὀνοκένταυρος), a compound of onos ('donkey') and kentauros ('centaur'), literally meaning 'donkey-centaur'. The term appears in the Septuagint as a translation of Hebrew im (איִם), a term for a desert creature of uncertain identity, and later in Physiologus where it acquired allegorical Christian meaning representing hypocrisy and the divided self."
      },
      "beast:hasRootTerm": {
        "@language": "grc",
        "@value": "Onokentauros"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_onocentaur"
      }
    },
    {
      "@id": "beastiary:etymology_amelic",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The term amelic comes from the Greek prefix a- (without) and mélos (limb), combined with the suffix -ic."
      },
      "beast:hasRootTerm": {
        "@language": "grc",
        "@value": "a + mélos"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_amelic"
      }
    },
