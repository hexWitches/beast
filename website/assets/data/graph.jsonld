      },
      "beast:hasAbility": {
        "@id": "beastiary:ability_strenght"
      },
      "beast:hasBodyOf": {
        "@id": "beastiary:creature_human"
      },
      "beast:hasDiet": {
        "@id": "beast:Omnivorous"
      },
      "beast:hasEtymology": {
        "@id": "beastiary:etymology_giant"
      },
      "beast:hasHabitat": {
        "@id": "beastiary:habitat_terrestrial"
      },
      "beast:hasOriginContext": {
        "@id": "beastiary:GreekMythology"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Giants, in different interpretation, are symbols of the primordial chaos that needs to be reordered in order to bring balance to the universe. They stick to the nyctomorphic symbolism by representing the dark times of humanity. While in Attack on Titan this caos manifest as a terrifying voracitiy, where giands devour human bodies, in classical interpretation and art it is represented by the trauma of the fall and cosmic cataclysm."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Giant"
      }
    },
    {
      "@id": "beastiary:source_teogonia",
      "@type": "beast:LiteraryWork",
      "dcterms:language": "grc",
      "dcterms:title": "Toeogonia",
      "schema:creator": {
        "@id": "beastiary:person_esiodo"
