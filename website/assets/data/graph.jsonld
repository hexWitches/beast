      }
    },
    {
      "@id": "beastiary:ability_blindness",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:NyctomorphicSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "The condition of impaired or absent sight, whether innate, induced, or afflicting the creature; the inability to see, sometimes overcome by remedies or compensated by other senses."
        },
        {
          "@language": "en",
          "@value": "The loss of vision, blindness, and the physical mutilation of the eyes are terrifying nyctomorphic symbols, representing the ultimate triumph of the void."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Blindness"
      }
    },
    {
      "@id": "beastiary:int_minotaur_gospodinov",
      "@type": "beast:Interpretation",
      "beast:appearsIn": {
        "@id": "beastiary:source_gospodinov_fisica_della_malinconia"
      },
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:MysticalStructure"
      },
      "beast:embodiesArchetype": [
        {
          "@id": "beastiary:archetype_abandoned_child"
        },
        {
          "@id": "beastiary:archetype_shameful_offspring"
        }
      ],
      "beast:embodiesImaginarySymbol": [
        {
          "@id": "beast:IntimacySymbol"
        },
        {
          "@id": "beast:InversionSymbol"
        }
      ],
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_gospodinov_1"
      },
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_minotaur"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "\"Gospodinov inverts the teriomorphic monster into a figure of intimacy: the terrifying beast as abandoned child alone and vulnerable at the center of the labyrinth, self sheltering within interiority. The labyrinth functions as an intimacy symbol, the cradle of abandoned childhood memory where time folds back on itself, allowing chilhood and present to coexist."
      }
    },
