      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "Acephalus originates from the Late Latin acephalus. It is rooted in the Ancient Greek aképhalos, which breaks down into the prefix a- (without or not) and kephalē (head)."
