    {
      "@id": "beastiary:ability_deadly_scream",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:NyctomorphicSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "A vocalization so powerful it causes death or severe harm to those who hear it."
        },
        {
          "@language": "en",
          "@value": "The lethal cry is formless sonic terror erupting from the unknown, enacting the nyctomorphic voracity of night that dissolves the listener into the abyss."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Deadly scream"
      }
    },
    {
      "@id": "beastiary:etymology_goat",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word is inherited from Middle English goot, got, gat, from Old English gāt, from Proto-West Germanic 'gait', from Proto-Germanic 'gaits'."
      },
      "beast:hasRootTerm": {
        "@language": "enm",
        "@value": "Gaits"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_goat"
      }
    },
    {
      "@id": "beastiary:creature_phoenix",
      "@type": [
        "beast:Creature",
        "beast:ImaginaryBeing"
      ],
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SyntheticStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:CyclicalSymbol"
      },
      "beast:hasAbility": [
        {
          "@id": "beastiary:ability_immortal"
        },
        {
          "@id": "beastiary:ability_self-renewal"
        }
      ],
      "beast:hasDiet": {
        "@id": "beast:Elemental"
      },
      "beast:hasDistinctiveTrait": "Phoenix is known for being immortal - it regenerates from its own ashes.",
      "beast:hasEtymology": {
        "@id": "beastiary:etymology_phoenix"
      },
      "beast:hasHabitat": [
        {
          "@id": "beastiary:habitat_forests"
        },
        {
          "@id": "beastiary:habitat_terrestrial"
        }
      ],
      "beast:hasOriginContext": {
        "@id": "beastiary:GreekMythology"
      },
      "beast:hasPart": {
        "@id": "beastiary:part_red_and_gold_feathers"
      },
      "beast:hasPartDerivedFrom": {
        "@id": "beastiary:creature_eagle"
      },
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The phoenix is the supreme cyclical symbol: its death-and-rebirth from ashes is the very image of the Eternal Return, where death is reintegrated as a stage of incessant renewal."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Phoenix"
      }
    },
    {
      "@id": "beastiary:ability_poisonous",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:TeriomorphicSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "Aggressive natural weaponry expresses the teriomorphic 'enemy symbol' of feral chaos and the bestial threat of the striking attack."
        },
        {
          "@language": "en",
          "@value": "The creature produces or secretes a toxic substance capable of harming or killing through bite, touch, or breath."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Venomous"
      }
    },
