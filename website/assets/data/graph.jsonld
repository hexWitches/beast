      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The North Pole, is the the northernmost point on Earth, located at the exact intersection of the planet's axis and its surface, known by its very cold temperatures all year round."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
