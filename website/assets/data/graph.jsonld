    {
      "@id": "beastiary:citation_isidore_8",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_etymologies"
      },
      "beast:hasPassageText": "The Onocentaur is so called because it seems to look half like a human, half like an ass. Likewise the Hippocentaur, which is thought to combine the natures of horse and human in itself.",
      "beast:hasSequenceIdentifier": [
        "Book XI",
        "paragraph 3"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_onocentaur_isidore"
      }
    },
