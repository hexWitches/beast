    {
      "@id": "beastiary:etymology_hippogriff",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word derives from the Ancient Greek híppos (horse) and the Italian grifo, which stems from the Late Latin gryphus and the Ancient Greek grýps (γρύψ), meaning griffin."
      },
      "beast:hasRootTerm": [
        {
          "@language": "grc",
          "@value": "Hippos + grifo"
        },
        {
          "@language": "la",
          "@value": "Hippos + grifo"
        }
      ],
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_hippogriff"
      }
    },
