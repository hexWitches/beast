    {
      "@id": "beastiary:citation_rowling_8",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_fantastic_beasts"
      },
      "beast:hasPassageText": "[…] a chicken egg hatched beneath a toad would produce a gigantic serpent possessed of extraordinarily dangerous powers. The Basilisk is a brilliant green serpent that may reach up to fifty feet in length. The male has a scarlet plume upon its head. It has exceptionally venomous fangs but its most dangerous means of attack is the gaze of its large yellow eyes. Anyone looking directly into these will suffer instant death.",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_basilisk_rowling_fantastic"
      }
    },
    {
      "@id": "beastiary:citation_flaubert_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_tentazione_antonio"
      },
      "beast:hasPassageText": "Di fronte, sull’altra sponda del Nilo, ecco apparire la Sfinge. Allunga le zampe, scuote le bende dalla sua fronte, e si accuccia sul ventre. Saltando, volando, sputando fuoco dalle narici [...].",
      "beast:hasSequenceIdentifier": "Chapter 7",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_sphinx_flaubert"
      }
    },
    {
      "@id": "beastiary:person_sturluson",
