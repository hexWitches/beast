      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The Riphean Mountains, a remote and semi-legendary range placed at the far north of the world, beyond the frozen seas; in Ariosto's Orlando Furioso the rare native haunt from which the hippogriff comes."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Riphean Mountains"
      }
    },
