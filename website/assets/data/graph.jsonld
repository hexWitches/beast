    {
      "@id": "beastiary:ability_self_renewal",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SyntheticStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:CyclicalSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "Self-renewal is the cyclical symbol itself: death reintegrated as a necessary phase of an incessant movement in which every ending is the prelude to rebirth."
        },
        {
          "@language": "en",
          "@value": "The capacity to regenerate, rejuvenate, or be reborn, often cyclically."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Self-renewal"
      }
    },
