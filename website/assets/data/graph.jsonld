          "@id": "http://viaf.org/viaf/http://viaf.org/viaf/108159964"
        },
        {
          "@id": "wd:Q859"
        }
      ]
    },
    {
      "@id": "beastiary:citation_omero_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_iliade_omero"
      },
      "beast:hasPassageText": "Era il mostro di origine divina, / leone la testa, il petto capra, e drago / la coda; e dalla bocca orrende vampe / vomitava di foco: e nondimeno, /col favor degli Dei, l'eroe la spense.'",
      "beast:hasSequenceIdentifier": [
        "Book VI",
        "verses 180-184"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_chimera_omero"
      }
    },
    {
      "@id": "beastiary:ability_fire_breathing",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:TeriomorphicSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "Fire-breathing is the consuming, devouring jaw of the beast, fitting the teriomorphic register of feral, annihilating chaos."
        },
        {
          "@language": "en",
          "@value": "The ability to exhale fire or intense heat, capable of burning living beings and objects."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Fire breathing"
      }
    },
    {
      "@id": "beastiary:int_unicorn_isidor",
      "@type": "beast:Interpretation",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:MysticalStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:IntimacySymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Isidore writes that the unicorn is so strong no hunter can catch it, however when the virgin girl approaches, the beast forgets its ferocity, lays its head in her lap, and falls asleep and it can be captured following a intimacy scene."
      }
    },
    {
      "@id": "beastiary:citation_isidore_4",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_etymologies"
      },
      "beast:hasPassageText": "Fish have their name from feeding. Some fish are amphibious, able to swim and to walk on land. Beasts and birds were named first, because they are easily seen; when fish were named, the names were often related to similar land animals, by shape or color or habit. According to David the Psalmist, the sea contains fish without number.",
      "beast:hasSequenceIdentifier": [
        "Book XII",
        "paragraph 6"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_fish_isidore"
      }
    },
    {
      "@id": "beastiary:genesis_pegaso_esiodo",
      "@type": "beast:Genesis",
      "beast:hasGenesisDescription": [
        {
          "@language": "en",
          "@value": "Sprang"
        },
        {
          "@language": "en",
          "@value": "from the neck of Medusa at the moment of her beheading by Perseus."
        },
        {
          "@language": "en",
          "@value": "together with his brother Chrysaor"
        }
      ],
      "beast:involvesParent": {
        "@id": "beastiary:creature_medusa"
      },
      "beast:isGenesisOf": {
        "@id": "beastiary:int_pegaso_esiodo"
      }
    },
