    {
      "@id": "beastiary:etymology_centaur",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "From Ancient Greek kentauros (Κένταυρος), of disputed etymology. The most accepted derivation compounds ken- (possibly related to kentein, 'to prick' or 'to spur') and tauros ('bull'), suggesting 'bull-piercer' or 'bull-slayer', possibly referencing early Thessalian horsemen who hunted bulls. Alternative proposals derive it from a pre-Greek substrate language. First attested in Homer's Iliad and Hesiod's Theogony."
      },
      "beast:hasRootTerm": {
        "@language": "grc",
        "@value": "Kentauros"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_centaur"
      }
    },
    {
      "@id": "beastiary:etymology_satyr",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word derives from the ancient greek sathe (σαθη), which refers to the male member and highlights the tendency of satyrs to always be prone to lust."
      },
      "beast:hasRootTerm": {
        "@language": "grc",
        "@value": "Sátyros"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_satyr"
      }
    },
    {
      "@id": "beastiary:genesis_chimera_fullmetal",
      "@type": "beast:Genesis",
      "beast:hasGenesisDescription": [
        {
          "@language": "en",
          "@value": "Produced through human transmutation"
        },
        {
          "@language": "en",
          "@value": "a forbidden alchemical act combining two base organisms into a new composite creature."
        }
      ],
      "beast:isGenesisOf": {
        "@id": "beastiary:int_chimera_fullmetal_alchemist"
      }
    },
    {
      "@id": "beastiary:etymology_antlion",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "Compound of myrmex (ant) and leon (lion). Derived from a mistranslation of the Hebrew lajisch (lion) in Job 4:11 of the Septuagint, possibly influenced by the classical term myrmex used by Strabo and Aelian for an obscure Arabian lion-like animal."
      },
      "beast:hasRootTerm": {
        "@language": "grc",
        "@value": "Myrmekoleon"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_antlion"
      }
    },
    {
      "@id": "beastiary:etymology_onager",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "From Ancient Greek onagros (ὄναγρος), compound of onos ('donkey') and agrios ('wild'), literally 'wild donkey'. Passed into Latin as onager. The term designated the Asiatic wild ass (Equus hemionus) in ancient natural history, appearing in Aristotle's Historia Animalium and Pliny's Naturalis Historia."
      },
      "beast:hasRootTerm": {
        "@language": "grc",
        "@value": "Onagros"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_onager"
      }
    },
    {
      "@id": "beastiary:int_sphinx_egypt",
      "@type": "beast:Interpretation",
