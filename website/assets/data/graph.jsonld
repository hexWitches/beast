        }
      ],
      "beast:hasAlternativeName": [
        "Basilicock",
        "Sibilus"
      ],
      "beast:hasBodyOf": {
        "@id": "beastiary:creature_snake"
      },
      "beast:hasDiet": {
        "@id": "beast:Carnivorous"
      },
      "beast:hasEtymology": {
        "@id": "beastiary:etymology_basilisk"
      },
      "beast:hasHabitat": {
        "@id": "beastiary:habitat_dry_places"
      },
      "beast:hasHeadOf": {
        "@id": "beastiary:creature_snake"
      },
      "beast:hasOriginContext": {
        "@id": "beastiary:source_greek_natural_history"
      },
      "beast:hasPart": {
        "@id": "beastiary:part_crest"
      },
      "beast:hasTailOf": {
        "@id": "beastiary:creature_snake"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The basilisk embodies both the theriomorphic archetype of predatory animality and the nyctomorphic terror of darkness and corruption. Its serpentine body and lethal gaze represent the ultimate expression of bestial destruction, while its poisonous breath and invisible lethality transform darkness into an active force of death. As an enemy of life, the basilisk materializes the fear of devouring chaos and unseen corruption."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Basilisk"
      }
    },
