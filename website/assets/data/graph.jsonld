    {
      "@id": "beastiary:int_sphinx_rowling_fantastic",
      "@type": "beast:Interpretation",
      "beast:additionalAbility": {
        "@id": "beastiary:ability_posing_riddles"
      },
      "beast:appearsIn": {
        "@id": "beastiary:source_fantastic_beasts"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:diaretic_symbol"
      },
      "beast:hasNarrativeFunction": {
        "@id": "beastiary:function_guardian"
      },
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_rowling_4"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_sphinx"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Rowling's sphinx is a diaretic guardian: it poses the riddle as an act of intellectual division and separation, testing the seeker without the devouring violence of its Theban ancestor."
      }
    },
    {
      "@id": "beastiary:citation_flaubert_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_tentazione_antonio"
      },
      "beast:hasPassageText": {
        "@language": "fr",
        "@value": "Di fronte, sull’altra sponda del Nilo, ecco apparire la Sfinge. Allunga le zampe, scuote le bende dalla sua fronte, e si accuccia sul ventre. Saltando, volando, sputando fuoco dalle narici [...]."
      },
      "beast:hasSequenceIdentifier": "Book 7",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_sphinx_flaubert"
      }
    },
    {
      "@id": "beastiary:citation_rowling_5",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_fantastic_beasts"
      },
      "beast:hasPassageText": {
        "@language": "en",
        "@value": "The Hippogriff is native to Europe, though now found worldwide. It has the head of a giant eagle and the body of a horse. It can be tamed, though this should be attempted only by experts. Eye contact should be maintained when approaching a Hippogriff. Bowing shows good intentions. If the Hippogriff returns the greeting, it is safe to draw closer.\nThe Hippogriff burrows for insects but will also eat birds and small mammals. Breeding Hippogriffs build nests upon the ground into which they will lay a single large and fragile egg, which hatches within twenty-four hours. The fledgling Hippogriff should be ready to fly within a week, though it will be a matter of months before it is able to accompany its parent on longer journeys."
      },
      "beast:hasSequenceIdentifier": "Chapter: Ministry of Magic Classifications",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_hippogriff_rowling_fantastic"
      }
    },
