    {
      "@id": "beastiary:etymology_troll",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "In Old Norse the noun troll (or trǫll) used to mean 'fiend', as in Middle High German, 'demon', 'werewolf'. It also comes from the Old Norse verb 'trylla' which means to enchant, to turn into a troll and the Middle High German verb trüllen, 'to flutter'."
      },
      "beast:hasRootTerm": [
        {
          "@language": "gmh",
          "@value": "Troll"
        },
        {
          "@language": "non",
          "@value": "Troll"
        }
      ],
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_troll"
      }
    },
    {
      "@id": "beastiary:etymology_snake",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word traces back to the Old English snaca, from Proto-Germanic 'snakon' and from Proto-Indo-European root 'sneg-', to crawl, creeping thing. In Modern English, gradually replacing serpent in popular use."
      },
      "beast:hasRootTerm": {
        "@language": "enm",
        "@value": "Snake"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_snake"
      }
    },
