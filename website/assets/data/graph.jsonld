    {
      "@id": "beastiary:etymology_sphinx",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word originates from the Ancient Greek sphínx, which the Greeks likely derived from their own verb sphíngō, meaning to squeeze or to bind tight."
      },
      "beast:hasRootTerm": "Sphínx",
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_sphinx"
      },
      "dcterms:language": "grc"
    },
    {
      "@id": "beastiary:archetype_raw_instinct",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "Represents raw and primal fears like famine, lack of intelligence and the danger of the wilderness, sometimes also misunderstood outcast."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Raw Instinct"
      }
    },
