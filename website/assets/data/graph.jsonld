    {
      "@id": "beastiary:habitat_forests",
      "@type": "beast:RealWorldPlace",
      "beast:habitatCategory": {
        "@id": "beast:habitat_terrestrial"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "A dense woodland environment characterized by thick tree cover, serving as a natural habitat for many creatures."
      },
