    {
      "@id": "beastiary:citation_poem_hermaphroditus",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_poem_hermaphroditus"
      },
      "beast:hasPassageText": {
        "@language": "en",
        "@value": "Where between sleep and life some brief space is, / With love like gold bound round about the head, / Sex to sweet sex with lips and limbs is wed, / Turning the fruitful feud of hers and his / To the waste wedlock of a sterile kiss."
      },
      "beast:hasSequenceIdentifier": "vv. 17-21",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_hermaphrodite_swinburne"
      }
    },
    {
