      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The snake's sloughing of its old skin to regain youth, allegorized as the believer shedding the \"old self\" for new life, embodies the cyclical symbol of renewal where casting off the old is the condition of rebirth."
      }
    },
    {
      "@id": "beastiary:citation_shakespeare_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_phoenix_and_turtle_shakespeare"
      },
      "beast:hasPassageText": {
        "@language": "en",
        "@value": "Here the anthem doth commence: / Love and constancy is dead, / Phoenix and the Turtle fled / In a mutual flame from hence."
