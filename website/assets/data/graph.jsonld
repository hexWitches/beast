      "@id": "beastiary:archetype_shameful_offspring",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "A creature born of transgression and condemned to concealment, embodying the social and moral need to hide the consequences of forbidden desire."
