      "beast:hasPassageText": {
        "@language": "en",
        "@value": "He was chubby and plump, a right jolly old elf, / And I laughed when I saw him, in spite of myself;"
      },
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_elf_moore"
      }
    },
