    {
      "@id": "beastiary:citation_frammenti_esiodo",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_frammenti_esiodo"
      },
      "beast:hasPassageText": {
        "@language": "grc",
        "@value": "Onde le dive montanine Ninfe / Nacquero, il seme degl’inetti a ogn’opra / Satiri imbelli, e degli additti ai giuochi, / Di danze intrecciator divi Cureti."
      },
      "beast:hasSequenceIdentifier": [
        "XLIV",
        "vv. 1-4"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_satyr_esiodo"
      }
    },
