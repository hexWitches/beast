    {
      "@id": "beastiary:citation_poem_hermaphroditus_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_poem_hermaphroditus"
      },
      "beast:hasPassageText": "Where between sleep and life some brief space is, / With love like gold bound round about the head, / Sex to sweet sex with lips and limbs is wed, / Turning the fruitful feud of hers and his / To the waste wedlock of a sterile kiss.",
      "beast:hasSequenceIdentifier": "Verse 17-21",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_hermaphrodite_swinburne"
      }
    },
