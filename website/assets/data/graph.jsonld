    {
      "@id": "beastiary:source_ovidius_metamorphoses",
      "@type": [
        "beast:Citation",
        "beast:LiteraryWork"
      ],
      "beast:extractedFrom": {
        "@id": "beastiary:source_gospodinov_fisica_della_malinconia"
      },
      "beast:hasPassageText": {
        "@language": "bg",
        "@value": "Il trauma non viene dal fatto che sembri una bestia, ma che in qualche modo sia umano. Proprio la sua umanità è sconvolgente. Il suo corpo è quello di un ragazzo, proprio come il mio. La prima peluria dell'adolescenza sulle gambe, i piedi con le dita lunghe, chissà perché mi aspettavo di vedere degli zoccoli."
      },
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_minotaur_gospodinov"
      },
      "dcterms:title": "Metamorphoses",
      "schema:creator": {
        "@id": "beastiary:person_ovid"
      }
    },
    {
      "@id": "beastiary:int_manticore_flaubert",
      "@type": "beast:Interpretation",
      "beast:additionalAbility": [
        {
          "@id": "beastiary:ability_plague_spreading"
        },
        {
          "@id": "beastiary:ability_speech"
        }
      ],
      "beast:appearsIn": {
        "@id": "beastiary:source_tentazione_antonio"
      },
      "beast:embodiesArchetype": {
        "@id": "beastiary:archetype_seduction"
      },
      "beast:embodiesImaginarySymbol": [
        {
          "@id": "beast:catamorphic_symbol"
        },
        {
          "@id": "beast:teriomorphic_symbol"
        }
      ],
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_flaubert_2"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_manticore"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Flaubert preserves the teriomorphic devourer but adds a catamorphic register through its plague-breath and army-consuming death, the degradation and downward dissolution of bodies in the desert."
      }
    },
