    {
      "@id": "beastiary:source_liber_monstrorum",
      "@type": "beast:LiteraryWork",
      "beast:hasBestiaryType": {
        "@id": "beast:MoralAllegory"
      },
      "beast:wasInfluencedBy": {
        "@id": "beastiary:source_odissea_omero"
