      }
    },
    {
      "@id": "beastiary:genesis_anomaly_paré_1",
      "@type": "beast:Genesis",
      "beast:hasGenesisDescription": [
        {
          "@language": "en",
          "@value": "Paré includes the creature among his examples of monsters created by the imagination. According to his description"
