    {
      "@id": "beastiary:creature_medusa",
      "@type": [
        "beast:Creature",
        "beast:HybridCreature"
      ],
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": [
        {
          "@id": "beast:CatamorphicSymbol"
        },
        {
          "@id": "beast:TeriomorphicSymbol"
        }
      ],
      "beast:hasAbility": {
        "@id": "beastiary:ability_petrifying_gaze"
      },
      "beast:hasAlternativeName": "Gorgon",
      "beast:hasBodyOf": {
        "@id": "beastiary:creature_human"
      },
      "beast:hasDistinctiveTrait": [
        "A once-beautiful woman transformed into a monster whose gaze turns the living to stone",
        "her hair replaced by living serpents. It is the only one Gorgon to be mortal."
      ],
      "beast:hasEtymology": {
        "@id": "beastiary:etymology_medusa"
      },
      "beast:hasHabitat": {
        "@id": "beast:Terrestrial"
      },
      "beast:hasHeadOf": {
        "@id": "beastiary:creature_human"
      },
      "beast:hasOriginContext": {
        "@id": "beastiary:source_greek_mythology"
      },
      "beast:hasPart": {
        "@id": "beastiary:part_snake_hair"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Medusa's defining power — turning flesh to stone — is catamorphic, the degradation and downward fixing of living flesh; her serpent-hair adds a teriomorphic register."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Medusa"
      }
    },
