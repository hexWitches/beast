    {
      "@id": "beastiary:citation_cantimpre_4",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_liber_de_natura_rerum"
      },
      "beast:hasPassageText": "The goat is a bearded animal, with long and sharp horns, it grazes in the valley, in the mountains and in the branches of trees, which it can reach with its mouth. It has an abundance of milk, and its milk is the healthiest, but immediately, when it will have curdled, it spoils; for cheese having been made from it (the milk) is nearly useful for nothing. The he-goat of the woodlands is a very perceptive animal, it loves high mountains, it recognizes walking people placed far off, if they be travelers or hunters.",
      "beast:hasSequenceIdentifier": "Chapter 4: Animals (quadrupeds)",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_goat_cantimpre"
      }
    },
