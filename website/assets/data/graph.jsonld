      },
      "beast:hasDistinctiveTrait": "Tinker Bell is described as a very tiny fairy that has the magic dust to make the character fly",
      "beast:hasNarrativeFunction": {
        "@id": "beastiary:function_guide"
      },
      "beast:hasTextualReference": {
