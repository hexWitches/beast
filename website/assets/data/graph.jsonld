      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Satyrs are lead by their primordial instinct. These creatures are brutally violent and they do not possess inhibitory brakes. Satyrs are only concern to dance, drink wine and engage in sexual activities."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
