      }
    },
    {
      "@id": "beastiary:citation_maier_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_atalanta_fugiens"
      },
      "beast:hasPassageText": "The Lion green, white fume, and stinking juice, Are all that to our Process do conduce: Water the mother is of the Elements, And the sole matter of the Sophic Ens. This Lion is the Hermetic Stone and Brass, And the white fume a watery nature has.",
      "beast:hasSequenceIdentifier": "Emblem 37",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_lion_maier"
      }
    },
    {
      "@id": "beastiary:ability_dance",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SyntheticStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:CyclicalSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "Rhythmic movement attributed to the creature, often in mythological or allegorical contexts."
        },
        {
          "@language": "en",
          "@value": "Rhythmic, repetitive movement embodies the cyclical 'rhythmic constants that govern natural phenomena,' the patterned return that reconciles the imagination with passing time."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Dance"
      }
    },
    {
      "@id": "beastiary:etymology_phoenix",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word phoenix traces back to the Ancient Greek word phoinix (φοῖνιξ), which originally referred to a mythological firebird."
      },
      "beast:hasRootTerm": {
        "@language": "grc",
        "@value": "Phoinix"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_phoenix"
      }
    },
    {
      "@id": "beastiary:citation_sturluson_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_prose_edda"
      },
      "beast:hasPassageText": "Trolls call me moon of dwelling-Rungnir, giant's wealth-sucker, storm-sun's bale, seeress's friendly companion, guardian of corpse-fiord, swallower of heaven-wheel; what is a troll other than that?",
      "beast:hasSequenceIdentifier": "Paragraph 53",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_troll_prose_edda"
      }
    },
