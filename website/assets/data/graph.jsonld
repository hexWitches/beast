    {
      "@id": "beastiary:etymology_centaur",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "From Ancient Greek kentauros (Κένταυρος), of disputed etymology. The most accepted derivation compounds ken- (possibly related to kentein, 'to prick' or 'to spur') and tauros ('bull'), suggesting 'bull-piercer' or 'bull-slayer', possibly referencing early Thessalian horsemen who hunted bulls. Alternative proposals derive it from a pre-Greek substrate language. First attested in Homer's Iliad and Hesiod's Theogony."
      },
      "beast:hasRootTerm": {
        "@language": "grc",
        "@value": "Kentauros"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_centaur"
      }
    },
