    {
      "@id": "beastiary:person_isayama",
      "@type": "schema:Person",
      "foaf:familyName": "Isayama",
      "foaf:givenName": "Hajime",
      "schema:birthDate": "1986",
      "schema:nationality": "Japanese",
      "schema:sameAs": [
