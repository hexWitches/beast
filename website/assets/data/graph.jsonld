    {
      "@id": "beastiary:ability_speed",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:TeriomorphicSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "Durand's scheme ties the teriomorphic directly to 'restlessness caused by rapid, undisciplined movement' and 'fleeing from devouring time,' making animal speed a near-definitional fit."
        },
        {
          "@language": "en",
          "@value": "Exceptional swiftness of movement on land, in water, or in the air."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Speed"
      }
    },
