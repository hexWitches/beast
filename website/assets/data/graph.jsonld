    {
      "@id": "beastiary:citation_bierce_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_devil_dictionary"
      },
      "beast:hasPassageText": "An animal (now extinct) which was half horse and half griffin. The griffin was itself a compound creature, half lion and half eagle. The hippogriff was actually, therefore, a one-quarter eagle, which is two dollars and fifty cents in gold. The study of zoology is full of surprises.",
      "beast:hasSequenceIdentifier": "Chapter H",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_hippogriff_bierce"
      }
    },
    {
      "@id": "beastiary:citation_isidore_7",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_etymologies"
      },
      "beast:hasPassageText": "Their appearance gave their name to the Centaurs, that is, a man combined with a horse. Some say that they were horsemen of Thessaly, but because, as they rushed into battle, the horses and men seemed to have one body, they maintained the fiction of the Centaurs.",
      "beast:hasSequenceIdentifier": [
        "Book XI",
        "paragraph 3"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_centaur_isidore"
      }
    },
