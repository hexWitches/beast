    {
      "@id": "beastiary:etymology_human",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word derives from humain, humaigne, 'human', from Old French humain, umain (adj.) 'of or belonging to man' (12c.), from Latin humanus 'of man, human', also 'humane, philanthropic, kind, gentle, polite; learned, refined, civilized.'"
      },
      "beast:hasRootTerm": {
        "@language": "fro",
        "@value": "Humains"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_human"
      }
    },
