      },
      "beast:embodiesArchetype": {
        "@id": "beastiary:archetype_guardian_hell"
      },
      "beast:hasDistinctiveTrait": [
        "Il mostro è descritto con occhi rossi",
        "emette latrati che assordano i dannati e ciò acuisce il loro tormento.",
        "i peli del muso sporchi e neri",
        "il ventre largo e le zampe artigliate"
      ],
      "beast:hasNarrativeFunction": {
        "@id": "beastiary:function_guardian"
      },
