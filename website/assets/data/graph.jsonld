    {
      "@id": "beastiary:part_three_lines_of_teeth",
      "@type": "beast:AnatomicalPart",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:TeriomorphicSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The triple rows of teeth are the paradigmatic teriomorphic image of predatory jaws 'ready to strike,' concentrating the symbol's devouring, feral chaos."
      }
    },
