    {
      "@id": "beastiary:ability_killing_gaze",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:NyctomorphicSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "A lethal power transmitted invisibly through the eyes, without weapon or bite, belongs to the nyctomorphic register: death arrives as formless, unseeable agency, the abyss looking back rather than a jaw striking."
        },
        {
          "@language": "en",
          "@value": "The ability to cause instant death through direct eye contact, distinct from petrification."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Killing gaze"
      }
    },
    {
      "@id": "beastiary:genesis_siren_ovidius",
      "@type": "beast:Genesis",
      "beast:hasGenesisDescription": [
        {
          "@language": "en",
          "@value": "Daughters of the river god Achelous and originally companions of Persephone. They were transformed into part-bird creatures at their own request"
        },
        {
          "@language": "en",
          "@value": "so that they might search the world by both land and sea for the abducted Persephone."
        }
      ],
      "beast:involvesParent": {
        "@id": "beastiary:myth_achelous"
      },
      "beast:isGenesisOf": {
        "@id": "beastiary:int_siren_ovidius"
      }
    },
