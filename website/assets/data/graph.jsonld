      }
    },
    {
      "@id": "beastiary:citation_perrault_fairy",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_cinderella_perrault"
      },
      "beast:hasPassageText": {
        "@language": "fr",
        "@value": "Well, be but a good girl, and I will contrive, that thou shalt go. Run into the garden, and bring me a pumpkin."
      },
      "beast:hasSequenceIdentifier": "Cinderella",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_fairy_perrault"
      }
    },
    {
      "@id": "beastiary:citation_ovid_met_3",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_ovidius_metamorphoses"
      },
      "beast:hasPassageText": {
        "@language": "la",
        "@value": "Forse perché Proserpina coglieva i fiori / primaverili, eravate nel numero delle sue compagne, / dotte Sirene? Dopo che inutilmente l'avete cercata / per tutto il mondo, / avete desiderato, perché il mare sentisse la vostra pena / di potervi fermare sulle onde col remeggio delle ali, /\ne avendo il consenso degli dèi, avete visto / improvvisamente i vostri arti fiorire di penne; / ma perché il vostro canto, nato a blandire le orecchie, /\ne il tesoro della vostra bocca non perdesse l'uso / della lingua, vi restò volto di vergini e voce umana."
      },
      "beast:hasSequenceIdentifier": [
        "V",
        "vv. 560-567"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_siren_ovidius"
      }
    },
    {
      "@id": "beastiary:archetype_prima_materia",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
