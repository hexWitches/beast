        "@value": "https://upload.wikimedia.org/wikipedia/commons/6/68/Tacuinum_Sanitatis_Mandrake_Dog.jpg"
      }
    },
    {
      "@id": "beastiary:int_sphinx_ende",
      "@type": "beast:Interpretation",
      "beast:additionalAbility": [
        {
          "@id": "beastiary:ability_lethal_gaze"
        },
        {
          "@id": "beastiary:ability_posing_riddles"
