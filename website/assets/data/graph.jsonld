    {
      "@id": "beastiary:citation_apollodorus_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_biblioteca"
      },
      "beast:hasPassageText": "But Earth, vexed on account of the Titans, brought forth the giants, whom she had by Sky. These were matchless in the bulk of their bodies and invincible in their might; terrible of aspect did they appear, with long locks drooping from their head and chin, and with the scales of dragons for feet. They were born, as some say, in Phlegrae, but according to others in Pallene. And they darted rocks and burning oaks at the sky.",
      "beast:hasSequenceIdentifier": "Book I",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_giant_apollodorus"
      }
    },
