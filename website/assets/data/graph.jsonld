    {
      "@id": "beastiary:archetype_uncanny",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The unsettling familiarity-in-strangeness that provokes dread."
      },
      "beast:relatedTo": {
