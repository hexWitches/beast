    {
      "@id": "beastiary:citation_paré_4",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_monstres_prodiges"
      },
      "beast:hasPassageText": "Nel 1493 venne concepito e generato un bambino da una donna e da un cane. Le parti sopra l'ombelico erano nella forma e nell'aspetto simili alla madre ed era in tutto e per tutto completo senza che la Natura avesse omesso nulla; dall'ombelico in giù tutte le parti inferiori assomigliavano, nella forma e nell'aspetto, all'animale che era il padre. Questo essere fu inviato al Papa che regnava in quel periodo.",
      "beast:hasSequenceIdentifier": "Capitolo 19: Esempi della commistione e della mescolanza del seme",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_mostro_paré_3"
      }
    },
