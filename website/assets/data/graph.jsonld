    {
      "@id": "beastiary:etymology_chimera",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "From Ancient Greek Khímaira (Χίμαιρα), literally 'she-goat', derived from khímaros (male goat), linked to kheîma (winter), as goats were used to mark the passing of a year. The monster is first attested in Homer's Iliad (VIII century BCE), where it is described as lion in front, serpent behind, and goat in the middle. The name's broader meaning of 'wild impossible fantasy' developed in early modern European languages through Latin Chimaera and Old French Chimere."
      },
      "beast:hasRootTerm": {
        "@language": "grc",
        "@value": "Chimaera"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_chimera"
      }
    },
    {
      "@id": "beastiary:etymology_bull",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "From old Norse 'boli bull', male of the domestic bovine, perhaps also from an old English 'bula', both from Proto-Germanic 'bullon-'. Some sources attribute its etymology to a Germanic verbal stem meaning 'to roar', which survives in some German dialect. The other possibility [Watkins] is that the Germanic word is from Proto-Indo-European root 'bhel-', 'to blow, swell'."
      },
      "beast:hasRootTerm": [
        {
          "@language": "ang",
          "@value": "Bule"
        },
        {
          "@language": "non",
          "@value": "Bule"
        }
      ],
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_bull"
      }
    },
    {
      "@id": "beastiary:int_lion_maier",
      "@type": "beast:Interpretation",
      "beast:appearsIn": {
        "@id": "beastiary:source_atalanta_fugiens"
      },
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:MysticalStructure"
      },
      "beast:embodiesArchetype": [
        {
          "@id": "beastiary:archetype_cosmic"
        },
        {
          "@id": "beastiary:archetype_prima_materia"
        }
      ],
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:InversionSymbol"
      },
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_maier_2"
      },
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_lion"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "In Maier's alchemical emblem the green lion is the prima materia undergoing transmutation, the conversion of base matter into the philosophical Stone; this turning of one nature into another belongs to the inversion symbol of transformation."
      }
    },
    {
      "@id": "beastiary:citation_esiodo_3",
