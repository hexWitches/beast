          "@id": "beast:IntimacySymbol"
        }
      ],
      "beast:hasDistinctiveTrait": [
        "Here the Elves are described as tiny jolly companions with twinkling eyes",
        "a cherry-like nose",
        "rosy cheeks"
      ],
      "beast:hasNarrativeFunction": {
        "@id": "beastiary:function_guide"
      },
      "beast:hasTextualReference": {
