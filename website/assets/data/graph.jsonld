      "@id": "beastiary:archetype_seduction",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "Someone who tries to induce or attract someone to guilt, sin, or to do something that one should not; the danger of untamed mundane passions and the uncontrolled urges of the flesh."
