    {
      "@id": "beastiary:citation_ariosto_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_orlando_furioso"
      },
      "beast:hasPassageText": "Non è finto il destrier, ma naturale, / ch’una giumenta generò d’un grifo: / simile al padre avea la piuma e l’ale, / li piedi anteriori, il capo e il grifo; / in tutte l’altre membra parea quale / era la madre, e chiamasi ippogrifo; / che nei monti Rifei vengon, ma rari, / molto di lá dagli aghiacciati mari.",
      "beast:hasSequenceIdentifier": [
        "Canto IV",
        "paragraph 18"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_hippogriff_ariosto"
      }
    },
    {
      "@id": "beastiary:archetype_natural_marvel",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The wonder of the natural world rationalized as a marvel rather than a monster."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Natural Marvel"
      }
    },
    {
      "@id": "beastiary:person_ovid",
      "@type": "schema:Person",
      "foaf:familyName": "Ovidius",
      "foaf:givenName": "Publius Naso",
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "43 BCE - 17"
      },
      "schema:birthDate": {
        "@type": "http://www.w3.org/2001/XMLSchema#gYear",
        "@value": "-43"
      },
      "schema:deathDate": {
