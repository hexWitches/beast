    {
      "@id": "beastiary:ability_posing_riddles",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:DiareticSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "The intellectual capacity to challenge others through cryptic questions or complex linguistic puzzles; it functions as a test of wisdom or a mechanism for defense, requiring the interlocutor to provide a specific solution to avoid misfortune."
        },
        {
          "@language": "en",
          "@value": "The riddle performs an intellectual diairesis, forcing the separation of truth from falsehood and embodying the diaretic drive toward analysis and absolute distinction."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Posing Riddles"
      }
    },
