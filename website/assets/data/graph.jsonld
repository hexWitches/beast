      },
      "beast:hasDistinctiveTrait": [
        "A classified magical species whose hide",
        "and horn are prized for their magical properties. The species is said to comprise ten distinct breeds",
        "blood",
        "heart",
        "liver",
        "taxonomic manner of a wizarding textbook.",
        "treated in the naturalist"
      ],
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_rowling_6"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_dragon"
      }
    },
