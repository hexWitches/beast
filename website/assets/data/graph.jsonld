        "@id": "beastiary:creature_eagle"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "As a winged, airborne composite, the hippogriff carries the ascensional symbolism of flight and elevation toward metaphysical heights"
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
