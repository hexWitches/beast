    {
      "@id": "beastiary:etymology_lion",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word originated from the latin word \"leo\" which means leopard. The word traces back to the ancient greek \"leon\" which also meant leopard and has evolved over time to describe the lion, animal belonging to the family of felines."
      },
      "beast:hasRootTerm": "Leo",
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_lion"
      },
      "dcterms:language": "grc, la"
    },
    {
      "@id": "beastiary:citation_maier_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_atalanta_fugiens"
      },
      "beast:hasPassageText": {
        "@language": "la",
        "@value": "The Lion green, white fume, and stinking juice, Are all that to our Process do conduce: Water the mother is of the Elements, And the sole matter of the Sophic Ens. This Lion is the Hermetic Stone and Brass, And the white fume a watery nature has."
      },
      "beast:hasSequenceIdentifier": "Emblem 37",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_lion_maier"
      }
    }
  ]
}