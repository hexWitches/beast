    {
      "@id": "beastiary:citation_plinio_3",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_naturalis_historia"
      },
      "beast:hasPassageText": {
        "@language": "la",
        "@value": "The story is that it is as large as an eagle, and has a gleam of gold round its neck and all the rest of it is purple, but the tail blue picked out with rosecoloured feathers and the throat picked out with tufts, and a feathered crest adorning its head."
      },
      "beast:hasSequenceIdentifier": [
        "Book X",
        "paragraph 2"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_phoenix_plinio"
      }
    },
    {
      "@id": "beastiary:citation_barbie_pegasus",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
