    {
      "@id": "beastiary:citation_bierce_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_devil_dictionary"
      },
      "beast:hasPassageText": {
        "@language": "en",
        "@value": "An animal (now extinct) which was half horse and half griffin. The griffin was itself a compound creature, half lion and half eagle. The hippogriff was actually, therefore, a one-quarter eagle, which is two dollars and fifty cents in gold. The study of zoology is full of surprises."
      },
      "beast:hasSequenceIdentifier": "Chapter H",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_hippogriff_bierce"
      }
    },
    {
      "@id": "beastiary:creature_bull",
      "@type": "beast:RealAnimal",
      "beast:hasDiet": {
        "@id": "beast:Herbivorous"
      },
      "beast:hasEtymology": {
