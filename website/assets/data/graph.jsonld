      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_lion"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The Nemean lion is the invulnerable, devouring chaos-beast born of Typhon, the feral monster the hero must overcome; it concentrates the teriomorphic terror of predatory jaws and bestial violence."
      }
    },
    {
      "@id": "beastiary:part_horn",
      "@type": "beast:AnatomicalPart",
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:ascensional_symbol"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
