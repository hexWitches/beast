      }
    },
    {
      "@id": "beastiary:person_rembrandt",
      "@type": "schema:Person",
      "foaf:familyName": "Van Rijn",
      "foaf:givenName": "Rembrandt",
      "schema:birthDate": "1606",
      "schema:deathDate": "1669",
      "schema:nationality": "Dutch",
      "schema:sameAs": [
        {
          "@id": "http://viaf.org/viaf/http://viaf.org/viaf/64013650"
        },
        {
          "@id": "wd:Q5598"
        }
      ]
    },
    {
      "@id": "beastiary:citation_rochester_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_rochester_bestiary"
      },
      "beast:hasPassageText": "The manticore is a beast born in India. It has three rows of teeth that intertwine like the teeth of a comb. It has the face of a human, greyish-blue eyes and a blood-red colour. It has a leonine body, and its tail resembles a scorpion's sting. It has a sharp, hissing voice similar to the sound of flutes and bagpipes. It eagerly longs for human flesh. It is so swift and jumps so high that neither the vastest areas nor the most insuperable obstacles can force it to die.",
      "beast:hasSequenceIdentifier": "Folio 27r",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_manticore_rochester"
      }
    },
    {
      "@id": "beastiary:citation_maier_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_atalanta_fugiens"
      },
      "beast:hasPassageText": "The Lion green, white fume, and stinking juice, Are all that to our Process do conduce: Water the mother is of the Elements, And the sole matter of the Sophic Ens. This Lion is the Hermetic Stone and Brass, And the white fume a watery nature has.",
      "beast:hasSequenceIdentifier": "Emblem 37",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_lion_maier"
      }
    },
    {
      "@id": "beastiary:source_fantastic_beasts",
      "@type": "beast:LiteraryWork",
      "dcterms:language": "en",
      "dcterms:title": "Fantastic Beasts and Where to Find Them",
      "schema:creator": {
        "@id": "beastiary:person_rowling"
      },
      "schema:dateCreated": {
        "@type": "http://www.w3.org/2001/XMLSchema#gYear",
        "@value": "2001"
      }
    },
    {
      "@id": "beastiary:int_elf_sturluson_1",
      "@type": "beast:Interpretation",
      "beast:additionalPart": {
        "@id": "beastiary:part_dark_elves"
      },
      "beast:appearsIn": {
        "@id": "beastiary:source_prose_edda"
      },
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesArchetype": {
        "@id": "beastiary:archetype_semi_divine"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:SpectacularSymbol"
      },
      "beast:hasNarrativeFunction": {
        "@id": "beastiary:function_sacred_symbol"
      },
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_sturluson_2"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_elf"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "In Sturluson the division of elves, the light-elves are ultimate spectacular symbols of solar clarity, floating high up in the branches of the world tree. In Tolkien they do not decay or wrinkle with time. They escape the 'gravitational pull' of human mortality."
      }
    },
