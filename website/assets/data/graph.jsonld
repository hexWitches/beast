      "@id": "beastiary:citation_dante_inferno_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_dante_inferno"
      },
      "beast:hasPassageText": {
        "@language": "it",
        "@value": "e ’n su la punta de la rotta lacca / l’infamia di Creti era distesa / che fu concetta ne la falsa vacca; / e quando vide noi, sé stesso morse, / sì come quei cui l’ira dentro fiacca."
      },
