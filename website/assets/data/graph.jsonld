    {
      "@id": "beastiary:citation_machiavelli_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_mandragola"
      },
      "beast:hasPassageText": {
        "@language": "it",
        "@value": "Voi avete ad intender questo, che non è cosa più certa ad ingravidare una donna che dargli bere una pozione fatta di mandragola. Questa è una cosa esperimentata da me dua paia di volte, e trovata sempre vera; e, se non era questo, la reina di Francia sarebbe sterile, ed infinite altre principesse di quello stato."
      },
      "beast:hasSequenceIdentifier": [
        "Act II",
        "Scene 6"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_mandrake_machiavelli"
      }
    },
    {
      "@id": "beastiary:source_medusa_caravaggio",
