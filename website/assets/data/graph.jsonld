    {
      "@id": "beastiary:citation_cantimpre_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_liber_de_natura_rerum"
      },
      "beast:hasPassageText": "The pegasus, as Pliny says, is a large and fearsome animal in Ethiopia. It has the body of a horse, wings like an eagle, but much larger, the head is equipped with horns and it is truly monstrous, such that almost all /  They devour many foods, they are moved by restlessness, they are unsafe for animals, and the most unsafe for humankind.",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_pegaso_cantimpre"
      }
    },
    {
      "@id": "beastiary:etymology_eagle",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "\"The word comes from the Old French egle, from Old Provençal aigla, from Latin aquila. It refers to a very large diurnal raptorial bird\"."
      },
      "beast:hasRootTerm": {
        "@language": "la",
        "@value": "Aquila"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_eagle"
      }
    },
