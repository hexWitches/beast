    {
      "@id": "beastiary:citation_virgil_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_aeneid"
      },
      "beast:hasPassageText": "Giunti che furo, il gran Cerbero udiro / Abbaiar con tre gole, e ’l buio regno / Intonar tutto; indi in un antro immenso / Sel vider pria giacer disteso avanti, / Poi sorger, digrignar, rabido farsi, / Con tre colli arruffarsi, e mille serpi / Squassarsi intorno.",
      "beast:hasSequenceIdentifier": [
        "Book 6",
        "verses 612-618"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_cerberus_virgil"
      }
    },
    {
      "@id": "beastiary:person_g_martin",
      "@type": "schema:Person",
      "foaf:familyName": "Martin",
      "foaf:givenName": "George R. R.",
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "1984 – present"
      },
      "schema:birthDate": {
