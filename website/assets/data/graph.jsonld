    {
      "@id": "beastiary:citation_aldrovandi_9",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_monstrorum_historia_aldrovandi"
      },
      "beast:hasPassageText": "Not long after, a six-legged female cat was born, colored partly white and partly dark gray; four feet supported the cat's hindquarters and only two the front. We provide the likeness of this monstrous cat, together with \"cat-joy\" - that is, bugloss.\"",
      "beast:hasSequenceIdentifier": "Capitolo 5: Anomalie delle singole parti del corpo",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_mostro_aldrovandi_5"
      }
    },
    {
      "@id": "beastiary:int_elf_moore",
      "@type": "beast:Interpretation",
      "beast:alternativeHabitat": {
        "@id": "beastiary:habitat_north_pole"
      },
      "beast:appearsIn": {
