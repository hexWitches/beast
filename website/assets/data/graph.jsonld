      }
    },
    {
      "@id": "beastiary:ability_petrifying_gaze",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:CatamorphicSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "The ability to turn living beings to stone through direct eye contact."
        },
        {
          "@language": "en",
          "@value": "Turning living flesh to stone is the catamorphic degradation of flesh: the body fixed, fallen, and hardened out of life."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Petrifying gaze"
      }
    },
    {
      "@id": "beastiary:int_centaur_ovid",
      "@type": "beast:Interpretation",
      "beast:appearsIn": {
        "@id": "beastiary:source_ovidius_metamorphoses"
      },
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesArchetype": [
        {
          "@id": "beastiary:archetype_predatory_lust"
        },
        {
          "@id": "beastiary:archetype_raw_instinct"
        },
        {
          "@id": "beastiary:archetype_violence"
        }
      ],
      "beast:embodiesImaginarySymbol": [
        {
          "@id": "beast:CatamorphicSymbol"
        },
        {
          "@id": "beast:TeriomorphicSymbol"
        }
      ],
      "beast:hasNarrativeFunction": {
        "@id": "beastiary:function_instigator"
      },
      "beast:hasPersonalName": "Eurytus",
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_ovid_met_12"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_centaur"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "\"Eurytus and the centaurs in Ovid embody teriomorphic chaos as the instigators of the Centauromachia: the bestial appetite triggered by wine erupts into collective violence. The general fall from human rationality into bestial behavior represents also catamorphic descent, the degradation of the hybrid form downward into pure animal impulse."
      }
    },
