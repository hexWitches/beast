        }
      ]
    },
    {
      "@id": "beastiary:int_lion_aberdeen",
      "@type": "beast:Interpretation",
      "beast:appearsIn": {
        "@id": "beastiary:source_aberdeen_bestiary"
      },
      "beast:embodiesArchetype": {
        "@id": "beastiary:archetype_divine_power"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:cyclical_symbol"
      },
      "beast:hasNarrativeFunction": {
        "@id": "beastiary:function_exemplum"
      },
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_aberdeen_2"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_lion"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "In the bestiary the lion's cubs are born dead and revived on the third day by their father's breath, a figure of Christ's resurrection; this death-and-rebirth aligns the interpretation with the cyclical symbol of death reintegrated as a prelude to renewal."
      }
    },
    {
      "@id": "beastiary:source_etymologies",
      "@type": "beast:LiteraryWork",
      "dcterms:title": {
        "@language": "la",
        "@value": "Etymologiae"
      },
      "schema:creator": {
        "@id": "beastiary:person_idsidor"
      },
      "schema:dateCreated": {
        "@type": "http://www.w3.org/2001/XMLSchema#gYear",
        "@value": "625"
      }
    },
    {
      "@id": "beastiary:citation_dante_inferno_4",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_dante_inferno"
      },
      "beast:hasPassageText": {
        "@language": "it",
        "@value": "Temp’era dal principio del mattino, / e ’l sol montava ’n sù con quelle stelle / ch’eran con lui quando l’amor divino / mosse di prima quelle cose belle; / sì ch’a bene sperar m’era cagione /di quella fiera a la gaetta pelle / l’ora del tempo e la dolce stagione; / ma non sì che paura non mi desse / la vista che m’apparve d’un leone. / Questi parea che contra me venisse / con la test’alta e con rabbiosa fame, / sì che parea che l’aere ne tremesse."
      },
      "beast:hasSequenceIdentifier": [
        "Canto I",
        "vv. 37-48"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_lion_dante"
      }
    },
    {
      "@id": "beastiary:citation_peter_pan_tinkerbell",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_peter_pan"
      },
      "beast:hasPassageText": {
        "@language": "en",
        "@value": "“Tink was not all bad: or, rather, she was all bad just now, sometimes she was all good. Fairies have to be one thing or the other, because being so small they unfortunately have room for one feeling only at a time."
      },
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_fairy_disney"
      }
    },
