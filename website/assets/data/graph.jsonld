      },
      "beast:hasPersonalName": "Ariel",
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_siren"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "In the movie 'The Little SIren' the authors reverse the brutality of the original Anderson's tale, rewriting the images of terror into a positive happy ending. Through this euphemization of danger, the main character's voicr is not mutilated but safely kept in a shell. This inversion allows her to reach her dream of becoming a human and marrying the prince she fell in love with."
      }
    },
    {
      "@id": "beastiary:habitat_edge_of_world",
