      },
      "beast:removedPart": {
        "@id": "beastiary:part_masculinity"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Hermaphrodite is describe as a young man deprived from his masculinity becuase of his union with the nymph Salmace, who was desperately in love with him. This union happens inside a water source which traps him into a body with feminine characteristic, causing the loss of his masculine traits, adhering to the nyctomorphic symbolism of the mutilation."
      }
    },
    {
      "@id": "beastiary:citation_rowling_9",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_fantastic_beasts"
      },
      "beast:hasPassageText": "The centaur has a human head, torso and arms joined to a horse’s body which may be any of several colours. Being intellinge and capable of speech, it should not strictly speaking be termed a beast […]. The centaur is forest-dwelling. […] They live in herds ranging in size from ten to fifty members. They are reputed to be well-versed in magical healing, divination, archery and astronomy.'",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_centaur_rowling_fantastic"
      }
    },
    {
      "@id": "beastiary:etymology_snake",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word traces back to the Old English snaca, from Proto-Germanic 'snakon' and from Proto-Indo-European root 'sneg-', to crawl, creeping thing. In Modern English, gradually replacing serpent in popular use."
      },
      "beast:hasRootTerm": {
        "@language": "enm",
        "@value": "Snake"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_snake"
      }
    },
