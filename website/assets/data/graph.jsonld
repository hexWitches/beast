      "dcterms:language": "grc, la"
    },
    {
      "@id": "beastiary:citation_cantimpre_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_liber_de_natura_rerum"
      },
      "beast:hasPassageText": {
        "@language": "la",
        "@value": "The pegasus, as Pliny says, is a large and fearsome animal in Ethiopia. It has the body of a horse, wings like an eagle, but much larger, the head is equipped with horns and it is truly monstrous, such that almost all /  They devour many foods, they are moved by restlessness, they are unsafe for animals, and the most unsafe for humankind."
      },
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_pegaso_cantimpre"
      }
    },
