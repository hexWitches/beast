      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Fantastica is the limitless realm of imagination in 'The Neverending Story', ruled by the Childlike Empress, home to all imagined creatures, and sustained by human dreams - threatened by the Nothing when people cease to believe."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Fantastica"
      }
    },
