      "beast:extractedFrom": {
        "@id": "beastiary:source_teogonia"
      },
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_pegaso_esiodo"
      }
    },
    {
      "@id": "beastiary:genesis_hermaphrodite_ovidius",
      "@type": "beast:Genesis",
      "beast:hasGenesisDescription": [
        {
          "@language": "en",
          "@value": "Child of Hermes and Aphrodite"
        },
        {
          "@language": "en",
          "@value": "originally a male youth of great beauty. Fused into a single dual-sexed body with the nymph Salmacis after she embraced him in her pool and prayed never to be parted from him."
        }
      ],
      "beast:involvesParent": [
        {
          "@id": "beastiary:myth_aphrodite"
        },
        {
          "@id": "beastiary:myth_hermes"
        }
