    {
      "@id": "beastiary:archetype_divine_power",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The manifestation of godhead and sacred might, the power proper to a deity."
      },
      "beast:relatedTo": [
        {
          "@id": "beastiary:archetype_cosmic"
        },
        {
          "@id": "beastiary:archetype_semi_divine"
        }
