      }
    },
    {
      "@id": "beastiary:ability_petrifying_gaze",
      "@type": "beast:Ability",
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:catamorphic_symbol"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Turning living flesh to stone is the catamorphic degradation of flesh: the body fixed, fallen, and hardened out of life."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Petrifying gaze"
      }
    },
    {
      "@id": "beastiary:citation_rowling_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_harry_potter_book_4"
      },
      "beast:hasPassageText": {
        "@language": "en",
        "@value": "It was a sphinx. It had the body of an over-large lion: great clawed paws and a long yellowish tail ending in a brown tuft. Its head, however, was that of a woman. She turned her long, almond-shaped eyes upon Harry as he approached. He raised his wand, hesitating. She was not crouching as if to spring, but pacing from side to side of the path, blocking his progress. Then she spoke, in a deep, hoarse voice."
      },
      "beast:hasSequenceIdentifier": "Chapter 31",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_sphinx_rowling_harry"
      }
    },
