    {
      "@id": "beastiary:ability_courage",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:AscensionalSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "A behavioral disposition toward fearlessness and boldness in the face of danger, often attributed symbolically rather than as a physical trait."
        },
        {
          "@language": "en",
          "@value": "Courage belongs to the ascensional register of virile, heroic archetypes (the warrior, celestial royalty); it is the upward, transcendent virtue that confronts and rises above fear and the threat of time."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Courage"
      }
    },
    {
      "@id": "beastiary:citation_aldrovandi_4",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_monstrorum_historia_aldrovandi"
      },
      "beast:hasPassageText": "[...] ella portava infatti al proprio seguito una fanciulla di otto anni coperta di peli. [...] Il viso della fanciulla, come anche la fronte, era coperto di peli, a parte il naso e il contorno delle labbra. I peli della fronte erano più lunghi e ispidi rispetto a quelli che coprivano le guance, che erano più morbidi al tatto; il resto del corpo, e soprattutto il dorso, era coperto di peli ispidi, e brulicava di peli biondi fino al principio dei lombi. Mentre le altre parti erano intatte, la gola, il petto, le mani, e le braccia erano stati rasati e somigliavano alla pelle degli uccelli che non hanno ancora messo le piume.\"",
      "beast:hasSequenceIdentifier": "Capitolo 2: Diversità nella specie umana",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_anomaly_aldrovandi_1"
      }
    },
