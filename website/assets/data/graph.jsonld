    {
      "@id": "beastiary:citation_beowulf_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_beowulf"
      },
      "beast:hasPassageText": {
        "@language": "ang",
        "@value": "Then the ancient dusk-scather / The fire-dragon. Found the great treasure standing all open, / He who flaming and fiery flies to the barrows, /Naked war-dragon, nightly escapeth / Encompassed with fire ; men under heaven / Widely beheld him. 'Tis said that he looks for / The hoard in the earth, where old he is guarding / The heathenish treasure ; he'll be nowise the better."
      },
      "beast:hasSequenceIdentifier": "Chapter XXXIII",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_dragon_beowulf"
      }
    },
