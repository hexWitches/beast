    {
      "@id": "beastiary:citation_isidore_6",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_etymologies"
      },
      "beast:hasPassageText": "Basilisk (basiliscus) is a Greek word, translated into Latin as “little king” (regulus), because it is the king of the snakes, so that they flee when they see it because it kills them with its odor – it also kills a human if it looks at one. [...] It is half a foot in length, and marked with white spots.",
      "beast:hasSequenceIdentifier": [
        "Book XII",
        "paragraph 4"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_basilisk_isidore"
      }
    },
    {
      "@id": "beastiary:ability_courage",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:AscensionalSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "A behavioral disposition toward fearlessness and boldness in the face of danger, often attributed symbolically rather than as a physical trait."
        },
        {
          "@language": "en",
          "@value": "Courage belongs to the ascensional register of virile, heroic archetypes (the warrior, celestial royalty); it is the upward, transcendent virtue that confronts and rises above fear and the threat of time."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Courage"
      }
    },
    {
      "@id": "beastiary:archetype_rebirth",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "Death reintegrated as a prelude to renewal; the cycle of dying and returning to new life."
      },
      "beast:relatedTo": {
        "@id": "beastiary:archetype_metamorphosis"
      }
    },
