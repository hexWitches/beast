    {
      "@id": "beastiary:ability_fly",
      "@type": "beast:Ability",
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:ascensional_symbol"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Flight enacts the same ascensional drive as the wing: an upward movement toward the pure, the divine, and the metaphysical heights, expressing the symbolic refusal of death through elevation"
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Fly"
      }
    },
    {
      "@id": "beastiary:citation_aberdeen_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_aberdeen_bestiary"
      },
      "beast:hasPassageText": {
        "@language": "la",
        "@value": "The phoenix is a bird of Arabia, so called either because its colouring is Phoenician purple, or because there is only one of its kind in the whole world. It lives for upwards of five hundred years, and when it observes that it has grown old, it erects a funeral pyre for itself from small branches of aromatic plants, and having turned to face the rays of the sun, beating its wings, it deliberately fans the flames for itself and is consumed in the fire. But on the ninth day after that, the bird rises from its own ashes."
      },
      "beast:hasSequenceIdentifier": "Folio 55r",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_phoenix_aberdeen"
      }
    },
