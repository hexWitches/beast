    {
      "@id": "beastiary:etymology_bull",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "From old Norse 'boli bull', male of the domestic bovine, perhaps also from an old English 'bula', both from Proto-Germanic 'bullon-'. Some sources attribute its etymology to a Germanic verbal stem meaning 'to roar', which survives in some German dialect. The other possibility [Watkins] is that the Germanic word is from Proto-Indo-European root 'bhel-', 'to blow, swell'."
      },
      "beast:hasRootTerm": [
        {
          "@language": "ang",
          "@value": "Bule"
        },
        {
          "@language": "non",
          "@value": "Bule"
        }
      ],
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_bull"
      }
    },
    {
      "@id": "beastiary:person_adamson",
      "@type": "schema:Person",
      "foaf:familyName": "Adamson",
      "foaf:givenName": "Andrew",
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "1966 – present"
      },
      "schema:birthDate": {
        "@type": "http://www.w3.org/2001/XMLSchema#gYear",
        "@value": "1966"
      },
      "schema:nationality": "New Zealander",
      "schema:sameAs": [
        {
          "@id": "http://viaf.org/viaf/http://viaf.org/viaf/23252298"
        },
        {
          "@id": "wd:Q432845"
        }
      ]
    },
    {
      "@id": "beastiary:citation_aldrovandi_6",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_monstrorum_historia_aldrovandi"
      },
      "beast:hasPassageText": "Per rafforzare ancor di più la tesi di coloro che pongono più mostri in acqua che sulla terra, aggiungiamo l'immagine di un mostro marino, riportato dal Paré, con testa, criniera e petto di cavallo il resto del corpo di pesce. Il Gessner riferisce che questa creatura, presa nell'oceano, fu portata a Roma e mostrata al sommo pontefice. Sia perciò resa giustizia a coloro che, negli antichi racconti, parlarono con grande libertà di cavalli marini, dipingendoli con forme in parte equine [...]. Al riguardo, molti hanno affermato che fu l'ambizione dei Romani a dare spunto alla figura di questo cavallo: dal momento che essi dimostrarono a tutti la loro preminenza sulla terra e sul mare, pensarono di dipingere uniti insieme due animali, uno per ciascun elemento, cioè il cavallo e il delfino. In seguito molti, sbalorditi da tale figura, e convinti che un simile mostro esistesse sotto forma di un'unica creatura, lo chiamarono cavallo marino. Ma, dato che l'immagine qui proposta trova un certo riscontro nella realtà, non dobbiamo più farci prendere dallo stupore.",
      "beast:hasSequenceIdentifier": "Capitolo 3: Il mostro in generale",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_mostro_aldrovandi_2"
      }
    },
    {
      "@id": "beastiary:archetype_hypocrisy",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The figure whose outward appearance or speech professes virtue while concealing or enacting baseness and vice, embodying the moral duplicity of one who says truth but does villainy."
      },
      "beast:relatedTo": {
        "@id": "beastiary:archetype_divided_self"
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Hypocrisy"
      }
    },
