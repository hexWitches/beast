      }
    },
    {
      "@id": "beastiary:citation_paré_5",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_monstres_prodiges"
      },
      "beast:hasPassageText": "Nell'anno in corso 1577 nacque, nel villaggio chiamato Blandy, a una lega e mezzo da Melun, un agnello con tre teste in una; quella di mezzo era più grossa delle altre e quando una di queste teste belava, le altre facevano la stessa cosa. Maestro Jean Bellanger, un chirurgo abitante della città di Melun, afferma d'averlo visto e di averne fatto ritrarre l'aspetto; il ritratto fu messo all'asta e fu venduto qui a Parigi col privilegio assieme a quelli di altri due mostri: uno di due figlie gemelle e un altro con la faccia di rana raffigurato in un'immagine precedente.",
      "beast:hasSequenceIdentifier": "Capitolo 19: Esempi della commistione e della mescolanza del seme",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_anomaly_paré_2"
      }
    },
    {
      "@id": "beastiary:int_ogre_shrek",
      "@type": "beast:Interpretation",
      "beast:additionalPart": {
        "@id": "beastiary:part_green_skin"
      },
      "beast:alternativeHabitat": {
        "@id": "beastiary:habitat_duloc_swamp"
      },
      "beast:appearsIn": {
        "@id": "beastiary:source_shrek"
      },
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:MysticalStructure"
      },
      "beast:embodiesArchetype": {
        "@id": "beastiary:archetype_anti_fairy_tale"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:InversionSymbol"
      },
      "beast:hasNarrativeFunction": {
        "@id": "beastiary:function_exemplum"
      },
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_shrek_1"
      },
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_ogre"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Shrek is the example of inversion symbols whre the monstrous ogre is actually the protector of peace, while the noble prince (Farquaad) is a insecure tyrant."
      }
    },
    {
      "@id": "beastiary:citation_paré_6",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_monstres_prodiges"
      },
      "beast:hasPassageText": "Gesner menziona questo mostro marino, di cui aveva ottenuto il ritratto da un pittore che lo aveva visto nel suo ambiente naturale in Antwerp: aveva una testa molto selvaggia con due corna, le orecchie lunghe e il resto del corpo da pesce, con l'eccezione delle braccia che erano quasi normali. Fu catturato nel mare Illirico quando si gettò sulla spiaggia nel tentativo di prendere un piccolo bambino che era lì vicino; inseguito da alcuni marinai che l'avevano visto, fu ferito a colpi di sassi e poco dopo venne sulla banchina a morire.",
      "beast:hasSequenceIdentifier": "Capitolo 34: Ora parliamo di mostri marini",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_mostro_paré_4"
      }
    },
