      "@id": "beastiary:etymology_basilisk",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "Diminutive of basileus (king), literally little king. Named for the crown-like crest on its head resembling a diadem, reflecting its status as king of serpents."
