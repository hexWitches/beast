      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Dante's serpents bite, poison, and devour the thieves, instruments of an animal terror that dissolves human identity; the biting, venomous reptile is the teriomorphic beast par excellence."
      }
    },
    {
      "@id": "beastiary:citation_ibsen_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_peer_gynt"
      },
      "beast:hasPassageText": "The Old Man: What difference is there 'twixt trolls and men? / Peer: No difference at all, as it seems to me. / Big trolls would roast you and small trolls would claw you; - / With us it were likewise, if only they dared.",
      "beast:hasSequenceIdentifier": "Act II",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_troll_ibsen"
      }
    },
