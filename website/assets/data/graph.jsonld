    {
      "@id": "beastiary:citation_tolkien_3",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_lotr"
      },
      "beast:hasPassageText": {
        "@language": "en",
        "@value": "The doom of the Elves is to be immortal, to love the beauty of the world, to bring it to full flower with their gifts of delicacy and perfection, to last while it lasts, never leaving it even when slain."
      },
      "beast:hasSequenceIdentifier": "Libro 1",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_elf_tolkien"
      }
    },
