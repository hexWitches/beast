    {
      "@id": "beastiary:ability_fly",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:AscensionalSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "Flight enacts the same ascensional drive as the wing: an upward movement toward the pure, the divine, and the metaphysical heights, expressing the symbolic refusal of death through elevation"
        },
        {
          "@language": "en",
          "@value": "The capacity to move through the air using wings or other supernatural means."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Flight"
      }
    },
    {
      "@id": "beastiary:citation_dante_inferno_5",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_dante_inferno"
      },
      "beast:hasPassageText": "Come 'l ramarro sotto la gran fersa / dei dì canicular, cangiando sepe, / folgore par se la via attraversa, / sì pareva, venendo verso l’epe / de li altri due, un serpentello acceso, / livido e nero come gran di pepe; / e quella parte onde prima è preso / nostro alimento, a l’un di lor trafisse; / poi cadde giuso innanzi lui disteso. / Lo trafitto ’l mirò, ma nulla disse; / anzi, co’ piè fermati, sbadigliava / pur come sonno o febbre l’assalisse. / Elli ’l serpente e quei lui riguardava; / l’un per la piaga e l’altro per la bocca / fummavan forte, e ’l fummo si scontrava.",
      "beast:hasSequenceIdentifier": [
        "Canto XXV",
        "verses 79-93"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_snake_dante"
      }
    },
    {
