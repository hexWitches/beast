        },
        {
          "@id": "wd:Q102323"
        }
      ]
    },
    {
      "@id": "beastiary:ability_extinct",
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The condition of having died out entirely, with no living members of the kind remaining; the creature is known only through past attestation rather than present existence."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Extinct"
      }
    },
    {
      "@id": "beastiary:citation_isidore_3",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_etymologies"
      },
      "beast:hasPassageText": "Indeed, many creatures naturally undergo mutation and, when they decay, are transformed into different species – for instance... scorpions from crabs. Thus Ovid: If you take its curved arms from a crab on the shore a scorpion will emerge and threaten with its hooked tail. Scorpions are land vermin; they are counted more appropriately among the vermin than among the snakes. The scorpion is an animal armed with a sting, and was named from this in Greek, because it stings with its tail and infuses venom through the bow-shaped wound. It is characteristic of the scorpion that it does not attack the palm of the hand. If ten crabs are tied with basil, all of the scorpions in that area will gather together.",
      "beast:hasSequenceIdentifier": [
        "Book XI",
        "paragraph 4"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_scorpion_isidore"
      }
    },
    {
      "@id": "beastiary:etymology_horse",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word derives from the Proto-Germanic 'harss-', of unknown origin. By some, connected to Proto-Indo-European root 'kers-' to run, source of Latin currere, to run."
      },
      "beast:hasRootTerm": {
        "@language": "gem",
        "@value": "Harss"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_horse"
      }
    },
    {
      "@id": "beastiary:function_transformation",
      "@type": "beast:NarrativeFunction",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The creature embodies or undergoes metamorphosis, the change of form that is itself the narrative event."
      }
    },
    {
      "@id": "beastiary:citation_cantimpre_3",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_liber_de_natura_rerum"
      },
      "beast:hasPassageText": "The bull is an animal robust in strength, and among all social animals tame enough to surpass those who oppose the rest with rapacity. Several together fight most bitterly, but when alone, it easily succumbs to cowardice. When they are taken, they have their tongues stuck out, they do nothing with their teeth, but only with their horns: for there is no terror in their teeth. When they graze on the grass, they do not injure the roots, but only take what is visible on the surface. Bulls are gentler, and are made suitable for all work, and especially for the hills, if they are kept from lust by being castrated. And the older they are, the more tender their flesh, if they have been fattened.",
      "beast:hasSequenceIdentifier": "Chapter 4: Animals (quadrupeds)",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_bull_cantimpre"
      }
    },
