      }
    },
    {
      "@id": "beastiary:etymology_dragon",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word dragon entered the English language in the early 13th century from Old French 'dragon', which, in turn, comes from Latin 'draco', meaning 'huge serpent', from Ancient Greek: δράκων, drákōn, 'serpent'. The Greek and Latin term referred to any great serpent, not necessarily mythological."
      },
      "beast:hasRootTerm": {
        "@language": "grc",
        "@value": "Drákōn"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_dragon"
      }
    },
    {
      "@id": "beastiary:citation_aldrovandi_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_monstrorum_historia_aldrovandi"
      },
      "beast:hasPassageText": "At the end of this category, we place those distinguished by being composed of both sexes, which includes Androgynes, or Hermaphrodites.",
      "beast:hasSequenceIdentifier": "Page 39",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_hermaphrodite_aldrovandi"
      }
    },
