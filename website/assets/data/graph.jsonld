    {
      "@id": "beastiary:citation_sturluson_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_prose_edda"
      },
      "beast:hasPassageText": {
        "@language": "is",
        "@value": "There is one place that is called Álfheimr. There live the folk called Light-Elves, but the Dark-Elves live down in the ground, and they are unlike them in appearance, and even more unlike them in nature. Light-Elves are fairer than the sun to look at, but Dark-Elves are blacker than pitch."
      },
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_elf_sturluson"
      }
    },
