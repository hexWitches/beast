      }
    },
    {
      "@id": "beastiary:citation_paré_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_monstres_prodiges"
      },
      "beast:hasPassageText": "Una prova ulteriore: al tempo in cui papa Giulio II causò tante calamità in Italia, quando cioè mosse guerra a Luigi XII (1512) - guerra nel corso della quale presso Ravenna fu combattuta una cruenta battaglia - ebbene, poco tempo dopo nacque nella medesima città un essere mostruoso con un corno in testa, due ali e con un unico piede simile a quello di un uccello da preda, con un occhio che si apriva in corrispondenza dell'articolazione del ginocchio, e inoltre era partecipe sia della natura maschile che di quella femminile [...].",
      "beast:hasSequenceIdentifier": "Capitolo 3: Esempi dell'ira di Dio",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_mostro_paré_1"
      }
    },
    {
      "@id": "beastiary:source_canterbury_tales",
