      "dcterms:title": "Liber monstrorum de diversis generibus",
      "schema:creator": {
        "@id": "beastiary:Unknown"
      },
      "schema:temporalCoverage": "VIII century"
    },
    {
      "@id": "beastiary:citation_beowulf_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_beowulf"
      },
      "beast:hasPassageText": "Then the ancient dusk-scather / The fire-dragon. Found the great treasure standing all open, / He who flaming and fiery flies to the barrows, / Naked war-dragon, nightly escapeth / Encompassed with fire ; men under heaven / Widely beheld him. 'Tis said that he looks for / The hoard in the earth, where old he is guarding / The heathenish treasure ; he'll be nowise the better.",
      "beast:hasSequenceIdentifier": "Chapter XXXIII",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_dragon_beowulf"
      }
    },
    {
      "@id": "beastiary:citation_ctesias_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_indika"
      },
      "beast:hasPassageText": "There are in India certain wild asses which are as large as horses, and larger. Their bodies are white, their heads dark red, and their eyes dark blue. They have a horn on the forehead which is about a foot and a half in length. The dust filed from this horn is administered in a potion as a protection against deadly drugs.",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_unicorn_ctesias"
      }
    },
    {
      "@id": "beastiary:int_siren_omero",
      "@type": "beast:Interpretation",
      "beast:additionalAbility": {
        "@id": "beastiary:ability_fly"
      },
      "beast:additionalPart": [
