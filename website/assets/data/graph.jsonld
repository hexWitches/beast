    {
      "@id": "beastiary:etymology_giant",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word Giant comes from the ancient greek Gígas (γίγας) which was used to describe divine and savages human beings."
      },
      "beast:hasRootTerm": "Gígas",
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_giant"
      },
      "dcterms:language": "grc"
    },
    {
      "@id": "beastiary:etymology_dragon",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word dragon entered the English language in the early 13th century from Old French dragon, which, in turn, comes from Latin draco, meaning \"huge serpent\", from Ancient Greek: δράκων, drákōn, \"serpent\". The Greek and Latin term referred to any great serpent, not necessarily mythological."
      },
      "beast:hasRootTerm": "Drákōn",
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_dragon"
      },
      "dcterms:language": "grc"
    },
    {
      "@id": "beastiary:ability_fire_breathing",
      "@type": "beast:Ability",
      "beast:embodiesImaginarySymbol": {
