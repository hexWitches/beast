        "@id": "beastiary:citation_plinio_5"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_manticore"
      }
    },
    {
      "@id": "beastiary:archetype_victim",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The wronged or suffering figure, harmed and made vulnerable by others."
      },
