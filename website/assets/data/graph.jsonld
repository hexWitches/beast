      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Chamber of Secrets"
      }
    },
    {
      "@id": "beastiary:function_obstacle",
      "@type": "beast:NarrativeFunction",
      "beast:hasMeaning": {
