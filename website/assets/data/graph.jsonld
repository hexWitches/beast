      }
    },
    {
      "@id": "beastiary:etymology_cow",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word derives from the Proto-Indo-European root 'gwou-', which indicates the female of a bovine animal."
      },
      "beast:hasRootTerm": {
        "@language": "ine",
        "@value": "Gwou"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_cow"
      }
    },
    {
      "@id": "beastiary:citation_sturluson_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_prose_edda"
      },
      "beast:hasPassageText": "There is one place that is called Álfheimr. There live the folk called Light-Elves, but the Dark-Elves live down in the ground, and they are unlike them in appearance, and even more unlike them in nature. Light-Elves are fairer than the sun to look at, but Dark-Elves are blacker than pitch.",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_elf_sturluson"
      }
    },
    {
      "@id": "beastiary:int_siren_andersen",
      "@type": "beast:Interpretation",
      "beast:appearsIn": {
        "@id": "beastiary:source_andersen"
      },
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesArchetype": {
        "@id": "beastiary:archetype_innocence"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:AscensionalSymbol"
      },
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_andersen_1"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_siren"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The siren in Anderson's tale desires to become a human being to be able to live after death throughout her immortal spirit, which ascends to heaven."
      }
    },
    {
      "@id": "beastiary:int_minotaur_gospodinov",
      "@type": "beast:Interpretation",
      "beast:appearsIn": {
        "@id": "beastiary:source_gospodinov_fisica_della_malinconia"
      },
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:MysticalStructure"
      },
      "beast:embodiesArchetype": [
        {
          "@id": "beastiary:archetype_abandoned_child"
        },
        {
          "@id": "beastiary:archetype_shameful_offspring"
        }
      ],
      "beast:embodiesImaginarySymbol": [
        {
          "@id": "beast:IntimacySymbol"
        },
        {
          "@id": "beast:InversionSymbol"
        }
      ],
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_gospodinov_1"
      },
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_minotaur"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "\"Gospodinov inverts the teriomorphic monster into a figure of intimacy: the terrifying beast as abandoned child alone and vulnerable at the center of the labyrinth, self sheltering within interiority. The labyrinth functions as an intimacy symbol, the cradle of abandoned childhood memory where time folds back on itself, allowing chilhood and present to coexist."
      }
    },
    {
