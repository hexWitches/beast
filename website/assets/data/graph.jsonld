    },
    {
      "@id": "beastiary:citation_pharsalia_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_pharsalia"
      },
      "beast:hasPassageText": "Quel suol però sí sterile, e que' campi / Di niun bene fecondi, un tosco atroce / Concepiscono in lor dalle corrotte Gocciole di Medusa [...] Ivi dispiega [...] e'l Basilisco horrendo / (Che Sibili tramanda, onde rimane / Ogni serpe atterrito, e pria che sparga / Il veleno, dà morte) il serpentino / Volgo da sé rimove, e in vuote arene / Solo il regno ritien.",
      "beast:hasSequenceIdentifier": "Book IX",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_basilisk_lucano"
      }
    },
    {
      "@id": "beastiary:citation_dante_inferno_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_dante_inferno"
      },
      "beast:hasPassageText": "Così per li gran savi si confessa / che la fenice more e poi rinasce, / quando al cinquecentesimo anno appressa; / erba né biado in sua vita non pasce, / ma sol d’incenso lagrime e d’amomo, / e nardo e mirra son l’ultime fasce.",
      "beast:hasSequenceIdentifier": [
        "Canto XXIV",
        "verses 106-111"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_phoenix_dante"
      }
    },
    {
      "@id": "beastiary:citation_perrault_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_cinderella_perrault"
      },
      "beast:hasPassageText": "Well, be but a good girl, and I will contrive, that thou shalt go. Run into the garden, and bring me a pumpkin.",
      "beast:hasSequenceIdentifier": [
        "Cinderella",
        "Tale VI"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_fairy_perrault"
      }
    },
