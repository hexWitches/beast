    {
      "@id": "beastiary:citation_rowling_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_harry_potter_book_3"
      },
      "beast:hasPassageText": "Trotting toward them were a dozen of the most bizarre creatures Harry had ever seen. They had the bodies, hind legs, and tails of horses, but the front legs, wings, and heads of what seemed to be giant eagles, with cruel, steel-colored beaks and large, brilliantly, orange eyes. The talons on their front legs were half a foot long and deadly looking. Each of the beasts had a thick leather collar around its neck, which was attached to a long chain, and the ends of all of these were held in the vast hands of Hagrid, who came jogging into the paddock behind the creatures.",
      "beast:hasSequenceIdentifier": "Chapter 6",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_hippogriff_rowling_harry"
      }
    },
    {
      "@id": "beastiary:person_plinio",
