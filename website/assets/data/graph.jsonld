    {
      "@id": "beastiary:creature_eagle",
      "@type": [
        "beast:Creature",
        "beast:RealAnimal"
      ],
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:AscensionalSymbol"
      },
      "beast:hasAbility": {
        "@id": "beastiary:ability_fly"
      },
      "beast:hasDiet": {
        "@id": "beast:Carnivorous"
      },
      "beast:hasEtymology": {
        "@id": "beastiary:etymology_eagle"
      },
      "beast:hasHabitat": {
        "@id": "beastiary:habitat_aerial"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The eagle is consistently ascensional across all its interpretations: soaring toward the sun, the heights, and the divine, it embodies verticality and the heroic escape from earthly gravity in Dante's justice, Ovid's rapture to Olympus, and the bestiary's renewal-flight."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Eagle"
      }
    },
    {
      "@id": "beastiary:diet_man_eater",
