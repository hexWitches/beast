    {
      "@id": "beastiary:source_liber_monstrorum",
      "@type": "beast:LiteraryWork",
      "beast:containsInterpretation": {
        "@id": "beastiary:int_siren_anonymous"
      },
      "beast:hasBestiaryType": {
        "@id": "beast:MoralAllegory"
      },
      "beast:wasInfluencedBy": {
        "@id": "beastiary:source_odissea_omero"
      },
      "dcterms:created": {
        "@type": "http://www.w3.org/2001/XMLSchema#gYear",
        "@value": "701/800"
      },
      "dcterms:language": "la",
      "dcterms:title": "Liber monstrorum de diversis generibus",
      "http://www.w3.org/2000/01/rdf-schema#comment": "8th century"
    },
    {
      "@id": "beastiary:citation_plinio_7",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_naturalis_historia"
      },
      "beast:hasPassageText": "Land scorpions also like spiders produce grubs resembling eggs and die in the same way as spiders; they are a horrible plague, poisonous like snakes, except that they inflict a worse torture by dispatching the victim with a lingering death lasting three days, their wound being always fatal to girls and almost absolutely so to women, but to men only in the morning, when they are coming out of their holes, before they emit their yet unsated poison by some accidental stroke. Their tail is always engaged in striking and does not stop practicing at any moment, lest it should ever miss an opportunity it strikes both a sideways stroke and one with the tail bent up.",
      "beast:hasSequenceIdentifier": [
        "Book XI",
        "paragraph 30"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_scorpion_plinio"
      }
    },
    {
      "@id": "beastiary:source_mandragola",
      "@type": "beast:LiteraryWork",
      "beast:containsInterpretation": {
        "@id": "beastiary:int_mandrake_machiavelli"
      },
      "dcterms:created": {
        "@type": "http://www.w3.org/2001/XMLSchema#gYear",
        "@value": "1512/1520"
      },
      "dcterms:language": "it",
      "dcterms:title": "Mandragola",
      "http://www.w3.org/2000/01/rdf-schema#comment": "1512 – 1520",
      "schema:creator": {
        "@id": "beastiary:person_machiavelli"
      }
    },
    {
      "@id": "beastiary:ability_killing_gaze",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:NyctomorphicSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "A lethal power transmitted invisibly through the eyes, without weapon or bite, belongs to the nyctomorphic register: death arrives as formless, unseeable agency, the abyss looking back rather than a jaw striking."
        },
        {
          "@language": "en",
          "@value": "The ability to cause instant death through direct eye contact, distinct from petrification."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Killing gaze"
      }
    },
    {
      "@id": "beastiary:citation_dante_paradiso_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_dante_paradiso"
      },
      "beast:hasPassageText": "Parea dinanzi a me con l’ali aperte / la bella image che nel dolce frui / liete facevan l’anime conserte; / parea ciascuna rubinetto in cui / raggio di sole ardesse sì acceso, / che ne’ miei occhi rifrangesse lui. / E quel che mi convien ritrar testeso, / non portò voce mai, né scrisse incostro, / né fu per fantasia già mai compreso; / ch’io vidi e anche udi’ parlar lo rostro, / e sonar ne la voce e «io» e «mio», / quand’ era nel concetto e ’noi’ e ’nostro’.",
      "beast:hasSequenceIdentifier": [
        "Canto XIX",
        "verses 1-12"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_eagle_dante"
      }
    },
    {
      "@id": "beastiary:etymology_sphinx",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "\"The word originates from the Ancient Greek sphínx, which the Greeks likely derived from their own verb sphíngō, meaning to squeeze or to bind tight\"."
      },
      "beast:hasRootTerm": {
        "@language": "grc",
        "@value": "Sphínx"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_sphinx"
      }
    },
