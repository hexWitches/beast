        "@language": "en",
        "@value": "Magical powers"
      }
    },
    {
      "@id": "beastiary:genesis_centaur_ovid",
      "@type": "beast:Genesis",
      "beast:hasGenesisDescription": [
        {
          "@language": "en",
          "@value": "Descended from the union of Ixion with Nephele"
