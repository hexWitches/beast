    {
      "@id": "beastiary:ability_speed",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:TeriomorphicSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "Durand's scheme ties the teriomorphic directly to 'restlessness caused by rapid, undisciplined movement' and 'fleeing from devouring time,' making animal speed a near-definitional fit."
        },
        {
          "@language": "en",
          "@value": "Exceptional swiftness of movement on land, in water, or in the air."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Speed"
      }
    },
    {
      "@id": "beastiary:habitat_lonely_mountain",
      "@type": "beast:ImaginaryPlace",
      "beast:hasOriginContext": {
        "@id": "beastiary:source_the_hobbit"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The solitary mountain of Erebor in Tolkien's legendarium, whose excavated halls house the dwarves' kingdom and, after its seizure, the dragon Smaug and his hoard."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Lonely Mountain (Erebor)"
      }
    },
    {
      "@id": "beastiary:citation_apollodorus_5",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_biblioteca"
      },
      "beast:hasPassageText": "Come dodicesima fatica gli fu imposto di portare via Cerbero dall'Ade. Cerbero aveva tre teste di cane, una coda di drago e lungo la schiena gli spuntavano teste di serpente di ogni tipo.",
      "beast:hasSequenceIdentifier": [
        "\"Book II",
        "chapter 5\""
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_cerberus_apollodorus"
      }
    },
    {
      "@id": "beastiary:int_elf_tolkien",
      "@type": "beast:Interpretation",
