    {
      "@id": "beastiary:etymology_manticore",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The English-language term manticore comes via Latin mantichorās, from Ancient Greek μαρτιχόρας (martikhórās). This in turn is a transliteration of an Old Persian compound word consisting of martīya 'man' and xuar- stem, 'to eat', i.e., man-eater."
      },
      "beast:hasRootTerm": "Martikhórās",
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_manticore"
      },
      "dcterms:language": "grc"
    },
    {
      "@id": "beastiary:etymology_fish",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word comes from Proto-Germanic *fiskaz which indicates a vertebrate which has grills and fins adapting it for living in the water."
      },
      "beast:hasRootTerm": "Fish",
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_fish"
      },
      "dcterms:language": "gem"
    },
    {
      "@id": "beastiary:citation_plinio_5",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_naturalis_historia"
      },
      "beast:hasPassageText": {
        "@language": "la",
        "@value": "C'è in Etiopia un animale chiamato manticora, il quale ha tre ordini di denti connessi come quelli d'un pettine, faccia e orecchie d'uomo, occhi azzurri, corpo cremisi di leone, e coda terminante in aculeo come di scorpione. Corre con somma rapidità ed è amantissimo della carne umana; la sua voce è come un concerto di flauto e tromba."
      },
      "beast:hasSequenceIdentifier": [
        "Book VIII",
        "paragraph 30"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_manticore_plinio"
      }
    },
