    {
      "@id": "beastiary:ability_courage",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:AscensionalSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "A behavioral disposition toward fearlessness and boldness in the face of danger, often attributed symbolically rather than as a physical trait."
        },
        {
          "@language": "en",
          "@value": "Courage belongs to the ascensional register of virile, heroic archetypes (the warrior, celestial royalty); it is the upward, transcendent virtue that confronts and rises above fear and the threat of time."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Courage"
      }
    },
    {
      "@id": "beastiary:creature_phoenix",
      "@type": [
        "beast:Creature",
        "beast:ImaginaryBeing"
      ],
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SyntheticStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:CyclicalSymbol"
      },
      "beast:hasAbility": [
        {
          "@id": "beastiary:ability_immortal"
        },
        {
          "@id": "beastiary:ability_self-renewal"
        }
      ],
      "beast:hasDiet": {
        "@id": "beast:Elemental"
      },
      "beast:hasDistinctiveTrait": "Phoenix is known for being immortal - it regenerates from its own ashes or from the father's body depending on the source.",
      "beast:hasEtymology": {
        "@id": "beastiary:etymology_phoenix"
      },
      "beast:hasHabitat": [
        {
          "@id": "beastiary:habitat_forests"
        },
        {
          "@id": "beastiary:habitat_terrestrial"
        }
      ],
      "beast:hasOriginContext": {
        "@id": "beastiary:source_greek_mythology"
      },
      "beast:hasPart": {
        "@id": "beastiary:part_red_and_gold_feathers"
      },
      "beast:hasPartDerivedFrom": {
        "@id": "beastiary:creature_eagle"
      },
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The phoenix is the supreme cyclical symbol: its death-and-rebirth from ashes is the very image of the Eternal Return, where death is reintegrated as a stage of incessant renewal."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Phoenix"
      }
    },
    {
      "@id": "beastiary:function_transformation",
      "@type": "beast:NarrativeFunction",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The creature embodies or undergoes metamorphosis, the change of form that is itself the narrative event."
      }
    },
    {
      "@id": "beastiary:citation_ovid_met_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_ovidius_metamorphoses"
      },
      "beast:isTextualReferenceOf": {
