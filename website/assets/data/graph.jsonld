      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The bull embodies the teriomorphic terror of untamed animality. The image of the “roaring bull” evokes deep-rooted human anxiety, alarm and the instinct to flee from violent, animated forces of nature."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Bull"
      }
    },
    {
      "@id": "beastiary:myth_uranus",
      "@type": "beast:MythologicalFigure",
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Uranus"
      }
    },
    {
      "@id": "beastiary:archetype_predatory_lust",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The embodiment of destructive male desire and moral bestiality, representing the abuse of power driven by animal instinct over rational and ethical constraint."
      },
      "beast:relatedTo": {
        "@id": "beastiary:archetype_violence"
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Predatory Lust"
      }
    },
    {
      "@id": "beastiary:creature_phoenix",
      "@type": [
        "beast:Creature",
        "beast:ImaginaryBeing"
      ],
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SyntheticStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:CyclicalSymbol"
      },
      "beast:hasAbility": [
        {
          "@id": "beastiary:ability_immortal"
        },
        {
          "@id": "beastiary:ability_self-renewal"
        }
      ],
      "beast:hasDiet": {
        "@id": "beast:Elemental"
      },
      "beast:hasDistinctiveTrait": "Phoenix is known for being immortal - it regenerates from its own ashes or from the father's body depending on the source.",
      "beast:hasEtymology": {
        "@id": "beastiary:etymology_phoenix"
      },
      "beast:hasHabitat": {
        "@id": "beastiary:habitat_forests"
      },
      "beast:hasOriginContext": {
        "@id": "beastiary:source_greek_mythology"
      },
      "beast:hasPart": {
        "@id": "beastiary:part_red_and_gold_feathers"
      },
      "beast:hasPartDerivedFrom": {
        "@id": "beastiary:creature_eagle"
      },
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The phoenix is the supreme cyclical symbol: its death-and-rebirth from ashes is the very image of the Eternal Return, where death is reintegrated as a stage of incessant renewal."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Phoenix"
      }
    },
