        "@language": "en",
        "@value": "The far western limit of the cosmos in Hesiod's Theogony, beyond glorious Ocean toward Night and near the Hesperides, where the Gorgons dwell at the boundary of the known world."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Edge of the World"
      }
    },
    {
      "@id": "beastiary:int_elf_moore",
      "@type": "beast:Interpretation",
