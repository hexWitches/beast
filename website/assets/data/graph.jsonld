        "@id": "beast:SpectacularSymbol"
      },
      "beast:hasNarrativeFunction": [
        {
          "@id": "beastiary:function_guide"
        },
        {
          "@id": "beastiary:function_protector"
        }
      ],
      "beast:hasPersonalName": "Firenze",
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_rowling_10"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_centaur"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Firenze and his kind read the future in the stars, positioning the centaur as a creature of celestial vision and solar clarity; their role as guides and protectors of the Forbidden Forest is grounded in this spectacular, sky-watching wisdom rather than in bestial appetite."
      }
    },
