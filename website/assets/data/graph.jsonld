        "@id": "beastiary:source_aberdeen_bestiary"
      },
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SyntheticStructure"
      },
      "beast:embodiesArchetype": {
        "@id": "beastiary:archetype_rebirth"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:CyclicalSymbol"
      },
      "beast:hasNarrativeFunction": {
        "@id": "beastiary:function_exemplum"
      },
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_aberdeen_4"
      },
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_snake"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The snake's sloughing of its old skin to regain youth, allegorized as the believer shedding the 'old self' for new life, embodies the cyclical symbol of renewal where casting off the old is the condition of rebirth."
      }
    },
    {
      "@id": "beastiary:archetype_predatory_lust",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The embodiment of destructive male desire and moral bestiality, representing the abuse of power driven by animal instinct over rational and ethical constraint."
      },
      "beast:relatedTo": {
        "@id": "beastiary:archetype_violence"
      }
    },
    {
      "@id": "beastiary:part_horn",
      "@type": "beast:AnatomicalPart",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:AscensionalSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The horn rises vertically toward the heavens, aligning with ascensional verticality and the purifying, transcendent power traditionally attached to it."
      }
    },
    {
      "@id": "beastiary:int_snake_ovid",
      "@type": "beast:Interpretation",
      "beast:appearsIn": {
        "@id": "beastiary:source_ovidius_metamorphoses"
      },
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:MysticalStructure"
      },
      "beast:embodiesArchetype": {
        "@id": "beastiary:archetype_metamorphosis"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:InversionSymbol"
      },
      "beast:hasNarrativeFunction": {
        "@id": "beastiary:function_transformation"
      },
      "beast:hasPersonalName": "Cadmus and Harmonia",
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_ovid_met_9"
      },
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_snake"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Cadmus and Harmonia are transformed into serpents, a metamorphosis that converts human into animal while memory and love survive; this doubling and conversion of form is the inversion symbol."
      }
    },
