    {
      "@id": "beastiary:citation_rowling_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_harry_potter_book_3"
      },
      "beast:hasPassageText": {
        "@language": "en",
        "@value": "Trotting toward them were a dozen of the most bizarre creatures Harry had ever seen. They had the bodies, hind legs, and tails of horses, but the front legs, wings, and heads of what seemed to be giant eagles, with cruel, steel-colored beaks and large, brilliantly, orange eyes. The talons on their front legs were half a foot long and deadly looking. Each of the beasts had a thick leather collar around its neck, which was attached to a long chain, and the ends of all of these were held in the vast hands of Hagrid, who came jogging into the paddock behind the creatures."
      },
      "beast:hasSequenceIdentifier": "Chapter",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_hippogriff_rowling_harry"
      }
    },
    {
      "@id": "beastiary:citation_ibsen",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_peer_gynt"
      },
      "beast:hasPassageText": {
        "@language": "da",
        "@value": "The Old Man: What difference is there 'twixt trolls and men?\nPeer: No difference at all, as it seems to me.\nBig trolls would roast you and small trolls would claw you;—\nWith us it were likewise, if only they dared."
      },
      "beast:hasSequenceIdentifier": "Act II",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_troll_ibsen"
      }
    },
    {
      "@id": "beastiary:int_snake_ovid",
      "@type": "beast:Interpretation",
      "beast:appearsIn": {
        "@id": "beastiary:source_ovidius_metamorphoses"
      },
      "beast:embodiesArchetype": {
        "@id": "beastiary:archetype_metamorphosis"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:inversion_symbol"
      },
      "beast:hasNarrativeFunction": {
        "@id": "beastiary:function_transformation"
      },
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_ovid_met_9"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_snake"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Cadmus and Harmonia are transformed into serpents, a metamorphosis that converts human into animal while memory and love survive; this doubling and conversion of form is the inversion symbol."
      }
    },
    {
      "@id": "beastiary:citation_ovid_met_5",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_ovidius_metamorphoses"
      },
      "beast:hasPassageText": {
        "@language": "la",
        "@value": "Now the entwined bodies of the two were joined together, and one form covered both. Just as when someone grafts a twig into the bark, they see both grow joined together, and develop as one, so when they were mated together in a close embrace, they were not two, but a two-fold form, so that they could not be called male or female, and seemed neither or either."
      },
      "beast:hasSequenceIdentifier": [
        "IV",
        "vv. 373-379"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_hermaphrodite_ovidius"
      }
    },
