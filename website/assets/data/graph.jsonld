    {
      "@id": "beastiary:citation_claudio_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_claudio_phoenix"
      },
      "beast:hasPassageText": {
        "@language": "la",
        "@value": "A mysterious fire flashes from its eye, and a flaming aureole enriches its head. Its crest shines with the sun's own light and shatters the darkness with its calm brilliance. Its legs are of Tyrian purple; swifter than those of the Zephyrs are its wings of flower-like blue dappled with rich gold."
      },
      "beast:hasSequenceIdentifier": [
        "Book II",
        "vv. 17–22"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_phoenix_claudio"
      }
    },
