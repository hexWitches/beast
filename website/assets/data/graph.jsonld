    {
      "@id": "beastiary:ability_self_destructive",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:CatamorphicSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "A creature undone by its own internally contradictory nature enacts the catamorphic fall turned inward: degradation and death as the direct consequence of the body's own impossible composition."
        },
        {
          "@language": "en",
          "@value": "The creature is driven to destroy itself due to its internally contradictory nature, whether physiological, psychological, or ontological."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Self-destruction"
      }
    },
