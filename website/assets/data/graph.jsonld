    {
      "@id": "beastiary:citation_rowling_4",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_fantastic_beasts"
      },
      "beast:hasPassageText": "The Egyptian sphinx has a human head on a lion’s body. For over a thousand years it has been used by witches and wizards to guard valuables and secret hideaways. Highly intelligent, the sphinx delights in puzzles and riddles. It is usually dangerous only when what it is guarding is threatened.",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_sphinx_rowling_fantastic"
      }
    },
    {
      "@id": "beastiary:habitat_fantastica",
      "@type": "beast:ImaginaryPlace",
      "beast:hasOriginContext": {
        "@id": "beastiary:source_unendliche_geschichte"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Fantastica is the limitless realm of imagination in 'The Neverending Story', ruled by the Childlike Empress, home to all imagined creatures, and sustained by human dreams - threatened by the Nothing when people cease to believe."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Fantastica"
      }
    },
