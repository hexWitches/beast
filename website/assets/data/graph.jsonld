    {
      "@id": "beastiary:citation_moore_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_st_Nicholas"
      },
      "beast:hasPassageText": "He was chubby and plump, a right jolly old elf, / And I laughed when I saw him, in spite of myself;",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_elf_moore"
      }
    },
    {
      "@id": "beastiary:citation_thaon_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_thaon_bestiary"
      },
      "beast:hasPassageText": "[...] the onocentaur, which has the shape of a man down to the waist, and behind has the make of an ass, by great reason; Ονος, in Greek, is the name given to an ass; thus they call it; hear what signifies a beast of such a quality. Man, when he says truth, is rightly named man, and ass, signifies, when he does villany'",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_onocentaur_thaon"
      }
    },
