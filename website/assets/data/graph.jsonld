      },
      "dcterms:language": "ang"
    },
    {
      "@id": "beastiary:citation_sturluson_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_prose_edda"
      },
      "beast:hasPassageText": {
        "@language": "non",
        "@value": "Trolls call me moon of dwelling-Rungnir, giant's wealth-sucker, storm-sun's bale, seeress's friendly companion, guardian of corpse-fiord, swallower of heaven-wheel; what is a troll other than that?"
      },
      "beast:hasSequenceIdentifier": "Paragraph 53",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_troll_prose_edda"
      }
    },
    {
      "@id": "beastiary:function_weapon",
      "@type": "beast:NarrativeFunction",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The creature is deployed as an instrument of war or destruction, a tool of power wielded against others."
      },
      "beast:relatedTo": {
        "@id": "beastiary:function_agent"
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Weapon"
      }
    },
    {
      "@id": "beastiary:etymology_scorpion",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word \"scorpion\" originates from the Latin term \"scorpionem,\" which is derived from the Greek word \"skorpios.\" This Greek term is related to the Proto-Indo-European root \"sker-\", meaning \"to cut\" or \"to shear."
      },
      "beast:hasRootTerm": "Scorpionem",
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_scorpion"
      },
      "dcterms:language": "la"
    },
    {
      "@id": "beastiary:person__øvredal",
      "@type": "schema:Person",
      "foaf:familyName": "Øvredal",
      "foaf:givenName": "André",
      "schema:birthDate": "1973",
      "schema:nationality": "Norwegian",
      "schema:sameAs": [
        {
          "@id": "http://viaf.org/viaf/288292099"
        },
        {
          "@id": "wd:Q2848912"
        }
      ]
    },
    {
      "@id": "beastiary:citation_maier_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_atalanta_fugiens"
      },
      "beast:hasPassageText": {
        "@language": "la",
        "@value": "For Sphinx is a certain kind of monster most obscure to the Thebans, propounding riddles, nor only to them, but as before to the Egyptians, so after all others to those that aspire to art, and watches in the Philosophers books as before the gates of Thebes; if any man can pass by the monster, he suffers no evil by him, but he that through presumption of mind or wit endeavors to resolve his riddles, and cannot perform, acquires his own destruction, that is, grief to the heart, and damage to his affairs by error in this work."
      },
      "beast:hasSequenceIdentifier": "Emblem 39",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_sphinx_maier"
      }
    },
    {
      "@id": "beastiary:citation_bible_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_bible"
      },
      "beast:hasPassageText": {
        "@language": "hbo",
        "@value": "In quel tempo c'erano sulla terra i giganti, e ci furono anche in seguito, quando i figli di Dio si unirono alle figlie degli uomini, ed ebbero da loro dei figli. Questi sono gli uomini potenti che, fin dai tempi antichi, sono stati famosi."
      },
      "beast:hasSequenceIdentifier": "Genesi 6:4",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_giant_bible"
      }
    },
    {
      "@id": "beastiary:int_medusa_esiodo",
      "@type": "beast:Interpretation",
      "beast:appearsIn": {
        "@id": "beastiary:source_teogonia"
      },
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_esiodo_2"
      },
      "beast:ofCreature": {
