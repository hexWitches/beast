    {
      "@id": "beastiary:source_destruction_doré",
      "@type": "beast:VisualArtwork",
      "dcterms:title": "The Destruction of Leviathan",
      "schema:creator": {
        "@id": "beastiary:person_doré"
      },
      "schema:dateCreated": {
        "@type": "http://www.w3.org/2001/XMLSchema#gYear",
