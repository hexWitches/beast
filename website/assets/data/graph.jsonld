    {
      "@id": "beastiary:citation_shakespeare_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_romeo_and_juliet"
      },
      "beast:hasPassageText": {
        "@language": "en",
        "@value": "Alack, alack, is it not like that I, / So early waking, what with loathsome smells, / And shrieks like mandrakes torn out of the earth, / That living mortals, hearing them, run mad –"
      },
      "beast:hasSequenceIdentifier": [
        "Act IV",
        "Scene 3"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_mandrake_shakespeare"
