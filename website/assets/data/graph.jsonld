    {
      "@id": "beastiary:citation_dante_inferno_6",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_dante_inferno"
      },
      "beast:hasPassageText": "Poi mi tentò, e disse: «Quelli è Nesso, / che morì per la bella Deianira / e fé di sé la vendetta elli stesso.'",
