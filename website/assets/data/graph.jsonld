        "@id": "beastiary:function_antagonist"
      },
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_ovid_met_10"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_snake"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The serpent of Mars is a giant, fire-eyed, venom-swollen guardian with triple rows of teeth that devours Cadmus's men; it is a pure teriomorphic chaos-monster."
      }
    },
    {
      "@id": "beastiary:int_mandrake_machiavelli",
      "@type": "beast:Interpretation",
      "beast:additionalAbility": {
        "@id": "beastiary:ability_fertility"
      },
      "beast:appearsIn": {
