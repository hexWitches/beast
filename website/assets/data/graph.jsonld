    {
      "@id": "beastiary:etymology_polycephalus",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "Polycephaly is the condition of having more than one head. The term is derived from the Greek stems poly (Greek: πολύ) meaning 'many' and kephalē (Greek: κεφαλή) meaning 'head'."
      },
      "beast:hasRootTerm": {
        "@language": "grc",
        "@value": "poly + kephalē"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_polycephalus_sheep"
      }
    },
    {
      "@id": "beastiary:creature_minotaur",
      "@type": [
        "beast:Creature",
        "beast:HybridCreature"
      ],
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": [
        {
          "@id": "beast:CatamorphicSymbol"
        },
        {
          "@id": "beast:TeriomorphicSymbol"
        }
      ],
      "beast:hasAbility": {
        "@id": "beastiary:ability_strength"
      },
      "beast:hasAlternativeName": "Asterion",
      "beast:hasBodyOf": {
        "@id": "beastiary:creature_human"
      },
      "beast:hasDiet": {
        "@id": "beastiary:diet_man_eater"
      },
      "beast:hasEtymology": {
        "@id": "beastiary:etymology_minotaur"
      },
      "beast:hasHabitat": {
        "@id": "beastiary:habitat_labyrinth"
      },
      "beast:hasHeadOf": {
        "@id": "beastiary:creature_bull"
      },
      "beast:hasOriginContext": {
        "@id": "beastiary:source_greek_mythology"
      },
      "beast:hasTailOf": {
        "@id": "beastiary:creature_bull"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The Minotaur is fundamentally a teriomorphic symbol: its bull head embodies violent force, instinct, and uncontrolled movement, while its consumption of Athenian youths exemplifies the schema of the devouring jaws. The Minotaur carries also a catamorphic dimension through its inhabiting of the labyrinth, an enclosed descending structure symbolizing the fall into darkness, confusion and the unconscious."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Minotaur"
      }
    },
