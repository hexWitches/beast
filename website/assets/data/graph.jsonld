    {
      "@id": "beastiary:citation_isidore_5",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_etymologies"
      },
      "beast:hasPassageText": "The ant-lion is so called either because it is equally lion and ant, or because it is the lion of ants. It is a small animal that is hostile to ants; it hides in the sand and kills other ants that are carrying grain. In this way it is like a lion to ants though it is like an ant to other animals.",
      "beast:hasSequenceIdentifier": [
        "Book XII",
        "paragraph 3"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_antlion_isidore"
      }
    },
    {
      "@id": "beastiary:int_manticore_rochester",
      "@type": "beast:Interpretation",
      "beast:additionalAbility": [
        {
          "@id": "beastiary:ability_speed"
        },
