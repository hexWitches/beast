    },
    {
      "@id": "beastiary:citation_rowling_10",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_harry_potter_book_1"
      },
      "beast:hasPassageText": "A centaur was standing over him, not Ronan or Bane; this one looked younger; he had white-blond hair and a palomino body. [...] The centaur didn’t answer. He had astonishingly blue eyes, like pale sapphires. He looked carefully at Harry, his eyes lingering on the scar which stood out, livid, on Harry’s forehead. ‘You are the Potter boy,’ he said. ‘You had better get back to Hagrid. The Forest is not safe at this time – especially for you. Can you ride? It will be quicker this way.'",
      "beast:hasSequenceIdentifier": "Chapter 15",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_centaur_rowling_harry"
      }
    },
    {
      "@id": "beastiary:genesis_medusa_esiodo",
      "@type": "beast:Genesis",
      "beast:hasGenesisDescription": [
        {
          "@language": "en",
          "@value": "Daughter of the ancient sea deities Phorcys and Ceto"
        },
        {
          "@language": "en",
          "@value": "one of the three Gorgon sisters."
        }
      ],
      "beast:involvesParent": [
        {
          "@id": "beastiary:myth_ceto"
        },
        {
          "@id": "beastiary:myth_phorcys"
        }
      ],
      "beast:isGenesisOf": {
        "@id": "beastiary:int_medusa_esiodo"
      }
    },
    {
      "@id": "beastiary:citation_paré_8",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_monstres_prodiges"
      },
      "beast:hasPassageText": "Il primo novembre 1562 nacqua a Villefranche de Beyan in Guascogna questo mostro senza testa. L'immagine frontale e dorsale qui riprodotta mi è stata fornita dal Signor Hautin, medico reggente nella Facoltà di Medicina di Parigi, che mi ha assicurato di averlo visto.",
      "beast:hasSequenceIdentifier": "Capitolo 8: Esempi di carenza di seme",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_anomaly_paré_3"
      }
    },
