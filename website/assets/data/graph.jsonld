      "beast:embodiesArchetype": {
        "@id": "beastiary:archetype_fertility"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:IntimacySymbol"
      },
      "beast:hasDistinctiveTrait": [
        "The mandrake appears not as a creature but purely as a botanical ingredient",
        "used to prepare a fertility potion."
      ],
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_machiavelli_1"
      },
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_mandrake"
      },
      "beast:removedAbility": {
        "@id": "beastiary:deadly_scream"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "In Machiavelli's comedy the mandrake is reduced to a fertility potion, its generative power aligning with the intimacy symbol's nurturing, protective interior and the promise of the cradle."
      }
    },
