        "@id": "beastiary:source_greek_mythology"
      },
      "beast:hasTailOf": {
        "@id": "beastiary:creature_bull"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "The Minotaur is fundamentally a teriomorphic symbol: its bull head embodies violent force, instinct, and uncontrolled movement, while its consumption of Athenian youths exemplifies the schema of the devouring jaws. The Minotaur carries also a catamorphic dimension through its inhabiting of the labyrinth, an enclosed descending structure symbolizing the fall into darkness, confusion and the unconscious."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Minotaur"
      }
    },
    {
      "@id": "beastiary:int_centaur_rowling_harry",
      "@type": "beast:Interpretation",
      "beast:appearsIn": {
        "@id": "beastiary:source_harry_potter_book_1"
