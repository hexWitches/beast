    {
      "@id": "beastiary:etymology_elf",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The Germanic word presumably originally meant 'white one', perhaps as a euphemism."
      },
      "beast:hasRootTerm": "ælf",
