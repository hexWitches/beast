      }
    },
    {
      "@id": "beastiary:citation_aberdeen_4",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_aberdeen_bestiary"
      },
      "beast:hasPassageText": {
        "@language": "la",
        "@value": "The monoceros is a monster the body of a horse, the feet of an elephant and a tail very like that of a deer. A magnificent, marvellous horn projects from the middle of its forehead, four feet in length, so sharp that whatever it strikes is easily pierced with the blow. No living monoceros has ever come into man's hands, and while it can be killed, it cannot be captured"
      },
      "beast:hasSequenceIdentifier": "Folio 15r",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_unicorn_aberdeen"
      }
    },
    {
