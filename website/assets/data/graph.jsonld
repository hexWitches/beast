    {
      "@id": "beastiary:citation_plinio_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_naturalis_historia"
      },
      "beast:hasPassageText": {
        "@language": "la",
        "@value": "Among the mountainous districts of the eastern parts of India, in what is called the country of the Catharcludi, we find the Satyr, an animal of extraordinary swiftness. These go sometimes on four feet, and sometimes walk erect; they have also the features of a human being. On account of their swiftness, these creatures are never to be caught, except when they are either aged or sickly."
      },
      "beast:hasSequenceIdentifier": [
        "Liber VII",
        "paragraph 24"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_satyr_pliny"
      }
    },
    {
      "@id": "beastiary:source_tacuinum_sanitatis",
      "@type": "beast:VisualArtwork",
