      },
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesArchetype": {
        "@id": "beastiary:archetype_seduction"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:NyctomorphicSymbol"
      },
      "beast:hasTextualReference": {
        "@id": "beastiary:citation_omero_1"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_siren"
      },
      "beast:removedPart": {
        "@id": "beastiary:part_fish_tail"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Sirens are scary creatures that live in the ocean depths. They are described as temptresses that seduce sailors with their sweet voice. Sirens are often associated to death demons whose seduction leads to death"
      }
    },
    {
      "@id": "beastiary:ability_strenght",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:AscensionalSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Heroic, virile strenght belongs to the ascensional repertoire of warrior and royal archetypes, it indicates the power to overcome the forces of time."
      }
    },
    {
      "@id": "beastiary:citation_machiavelli_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_mandragola"
      },
      "beast:hasPassageText": "Voi avete ad intender questo, che non è cosa più certa ad ingravidare una donna che dargli bere una pozione fatta di mandragola. Questa è una cosa esperimentata da me dua paia di volte, e trovata sempre vera; e, se non era questo, la reina di Francia sarebbe sterile, ed infinite altre principesse di quello stato.",
      "beast:hasSequenceIdentifier": [
        "Act II",
        "scene 6"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_mandrake_machiavelli"
      }
    },
    {
      "@id": "beastiary:etymology_siren",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "Siren derives from the ancient greek Seirēn, which indicated female mythological creatures endowed with enchanting and often dangerous powers for sailors."
      },
      "beast:hasRootTerm": {
        "@language": "grc",
        "@value": "Seirḗn"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_siren"
      }
    },
    {
      "@id": "beastiary:ability_dance",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SyntheticStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:CyclicalSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "Rhythmic movement attributed to the creature, often in mythological or allegorical contexts."
        },
        {
          "@language": "en",
          "@value": "Rhythmic, repetitive movement embodies the cyclical 'rhythmic constants that govern natural phenomena,' the patterned return that reconciles the imagination with passing time."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Dance"
      }
    },
