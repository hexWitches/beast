      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Trolls live in hollow parts of the earth and dark caves. They are strictly connected with darkness, especially because if caught in the sun these creatures turn to stone."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Troll"
      }
    },
