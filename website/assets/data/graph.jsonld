    {
      "@id": "beastiary:ability_hypnotic_gaze",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:NyctomorphicSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "The capacity to exert control over the will, perceptions, or motor functions of another through direct visual contact; it induces a state of trance, paralysis, or psychological subjugation that renders the subject vulnerable to the creature's intent."
        },
        {
          "@language": "en",
          "@value": "The entrancing gaze draws its victim down into shadow, sleep, and loss of self, enacting the nyctomorphic engulfment by darkness."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Hypnotic_gaze"
      }
    },
