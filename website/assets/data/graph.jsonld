    {
      "@id": "beastiary:citation_nietzsche_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_nietzsche_ndt"
      },
      "beast:hasPassageText": "Così nasce quindi la figura fantastica e tanto ripugnante del satiro sapiente ed entusiasta che, nello stesso tempo, in contrapposto al dio, è «il tonto uomo»: immagine della natura e dei suoi più forti istinti, vero simbolo di lei e, insieme, annunziatore della sua scienza ed arte; musico, poeta, danzatore tutto in uno, e contemplatore di spiriti.",
      "beast:hasSequenceIdentifier": "Chapter 8",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_satyr_nietzsche"
      }
    },
    {
      "@id": "beastiary:diet_elephant_blood",
      "beast:dietCategory": {
        "@id": "beast:Carnivorous"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "A specialized carnivorous diet of elephant blood, sought by the dragon of Pliny's tradition to cool its own heat; the creature lies in wait to drain the elephant."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Elephant blood"
      }
    },
    {
