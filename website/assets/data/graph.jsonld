    {
      "@id": "beastiary:source_dante_paradiso",
      "@type": "beast:LiteraryWork",
      "beast:wasInfluencedBy": {
        "@id": "beastiary:source_ovidius_metamorphoses"
      },
      "dcterms:title": {
