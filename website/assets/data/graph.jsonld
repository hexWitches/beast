      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Sirens are scary creatures that live in the ocean depths. They are described as temptresses that seduce sailors with their sweet voice. Sirens are often associated to death demons whose seduction leads to death"
      }
    },
    {
      "@id": "beastiary:int_snake_ovid_2",
      "@type": "beast:Interpretation",
