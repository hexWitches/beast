    {
      "@id": "beastiary:citation_nietzsche_ndt",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_nietzsche_ndt"
      },
      "beast:hasPassageText": {
        "@language": "de",
        "@value": "Così nasce quindi la figura fantastica e tanto ripugnante del satiro sapiente ed entusiasta che, nello stesso tempo, in contrapposto al dio, è «il tonto uomo»: immagine della natura e dei suoi più forti istinti, vero simbolo di lei e, insieme, annunziatore della sua scienza ed arte; musico, poeta, danzatore tutto in uno, e contemplatore di spiriti."
      },
      "beast:hasSequenceIdentifier": "Chapter VIII",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_satyr_nietzsche"
      }
    },
    {
      "@id": "beastiary:ability_poisonous",
      "@type": "beast:Ability",
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:teriomorphic_symbol"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Aggressive natural weaponry expresses the teriomorphic \"enemy symbol\" of feral chaos and the bestial threat of the striking attack."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Poisonous"
      }
    },
