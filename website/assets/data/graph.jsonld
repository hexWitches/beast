    {
      "@id": "beastiary:citation_ctesias_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_indika"
      },
      "beast:hasPassageText": "There are in India certain wild asses which are as large as horses, and larger. Their bodies are white, their heads dark red, and their eyes dark blue. They have a horn on the forehead which is about a foot and a half in length. The dust filed from this horn is administered in a potion as a protection against deadly drugs.",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_unicorn_ctesias"
      }
    },
    {
      "@id": "beastiary:ability_blindness",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:SchizomorphicStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:NyctomorphicSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "The condition of impaired or absent sight, whether innate, induced, or afflicting the creature; the inability to see, sometimes overcome by remedies or compensated by other senses."
        },
        {
          "@language": "en",
          "@value": "The loss of vision, blindness, and the physical mutilation of the eyes are terrifying nyctomorphic symbols, representing the ultimate triumph of the void."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Blindness"
      }
    },
    {
      "@id": "beastiary:ability_healing_tears",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:MysticalStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:IntimacySymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "Healing turns wound into refuge and harm into shelter, aligning the intimacy symbol's movement from the fear of being swallowed to the comfort of being contained."
        },
        {
          "@language": "en",
          "@value": "The unique medicinal property attributed to the secretions or lacrimal fluids of a creature, possessing the power to mend wounds, cure afflictions, or restore vitality to those they touch, often highlighting the creature's paradoxical nature as a source of both danger and salvation."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Healing tears"
      }
    },
    {
      "@id": "beastiary:archetype_belief",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The embodiment of belief without belief, her magic fades, that things exist only so long as we believe in them."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Belief"
      }
    },
    {
      "@id": "beastiary:citation_shakespeare_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_romeo_and_juliet"
      },
      "beast:hasPassageText": "Alack, alack, is it not like that I, / So early waking, what with loathsome smells, / And shrieks like mandrakes torn out of the earth, / That living mortals, hearing them, run mad –",
      "beast:hasSequenceIdentifier": [
        "Act IV",
        "scene 3"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_mandrake_shakespeare"
      }
    },
