    {
      "@id": "beastiary:etymology_centaur",
      "@type": "beast:Etymology"
    },
    {
      "@id": "beastiary:citation_ovid_met_6",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_ovidius_metamorphoses"
      },
      "beast:hasPassageText": "Unico a riseminarsi e rigenerarsi da sé è un uccello che gli Assiri chiamano 'fenice'. Non di chicchi di grano né di erbe vive la fenice, ma di lacrime d'incenso e di succo d'amomo, e quando ha compiuto cinque secoli di vita, se ne va in cima a una tremula palma e con gli artigli e col suo becco incontaminato si costruisce un nido tra il fogliame. Appena ha steso sul fondo uno strato di cassia e di spighe di nardo delicato, di cannella sminuzzata e di mirra bionda, vi si adagia sopra e chiude la sua esistenza in mezzo ai profumi. Allora, si dice, dal corpo paterno rinasce una piccola fenice, la quale dovrà vivere altrettanti anni.",
      "beast:hasSequenceIdentifier": [
        "Book XV",
        "verses 392-402"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_phoenix_ovidius"
      }
    },
    {
      "@id": "beastiary:citation_bible_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_bible"
      },
      "beast:hasPassageText": "In quel tempo c'erano sulla terra i giganti, e ci furono anche in seguito, quando i figli di Dio si unirono alle figlie degli uomini, ed ebbero da loro dei figli. Questi sono gli uomini potenti che, fin dai tempi antichi, sono stati famosi.",
      "beast:hasSequenceIdentifier": [
        "Genesi 6:4",
        "verse 4"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_giant_bible"
      }
    },
    {
      "@id": "beastiary:person_gospodinov",
