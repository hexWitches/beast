    {
      "@id": "beastiary:etymology_manticore",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "\"The English-language term manticore comes via Latin mantichorās, from Ancient Greek μαρτιχόρας (martikhórās). This in turn is a transliteration of an Old Persian compound word consisting of martīya 'man' and xuar- stem, 'to eat', i.e., man-eater."
      },
      "beast:hasRootTerm": {
        "@language": "grc",
        "@value": "Martikhórās"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_manticore"
      }
    },
