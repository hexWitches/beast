    {
      "@id": "beastiary:citation_chaucer_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_canterbury_tales"
      },
      "beast:hasPassageText": "All was this land fulfild of fayerye. The elf-queene, with hir joly compaignye, Daunced ful ofte in many a grene mede.",
      "beast:hasSequenceIdentifier": "Tale: The Wife of Bath's Tale",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_fairy_chaucer"
      }
    },
    {
      "@id": "beastiary:citation_anonymous",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_liber_monstrorum"
      },
      "beast:hasPassageText": "Le Sirene sono fanciulle marine che seducono i marinai con la bellezza del corpo e la dolcezza del canto. Dalla testa fino all’ombelico hanno aspetto di vergine, del tutto simili a creature umane. Hanno però code squamose di pesce, che nascondono sempre sott’acqua.",
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_siren_anonymous"
      }
    },
