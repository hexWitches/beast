    {
      "@id": "beastiary:citation_aldrovandi_2",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_monstrorum_historia_aldrovandi"
      },
      "beast:hasPassageText": {
        "@language": "la",
        "@value": "At the end of this category, we place those distinguished by being composed of both sexes, which includes Androgynes, or Hermaphrodites."
      },
      "beast:hasSequenceIdentifier": "Page 39",
      "beast:isTextualReferenceOf": {
