      },
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_pegasus"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Pegasus represents the ascensional symbol since it is an explosion of solar light out of primordial darkness (medusa head), it rejects the heavy, muddy earth, soaring straight to Mount Olympus."
      }
    },
    {
      "@id": "beastiary:etymology_manticore",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "\"The English-language term manticore comes via Latin mantichorās, from Ancient Greek μαρτιχόρας (martikhórās). This in turn is a transliteration of an Old Persian compound word consisting of martīya 'man' and xuar- stem, 'to eat', i.e., man-eater."
      },
      "beast:hasRootTerm": {
        "@language": "grc",
        "@value": "Martikhórās"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_manticore"
      }
    },
