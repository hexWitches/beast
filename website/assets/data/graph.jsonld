    {
      "@id": "beastiary:citation_isidore_6",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_etymologies"
      },
      "beast:hasPassageText": "Basilisk (basiliscus) is a Greek word, translated into Latin as “little king” (regulus), because it is the king of the snakes, so that they flee when they see it because it kills them with its odor – it also kills a human if it looks at one. [...] It is half a foot in length, and marked with white spots.",
      "beast:hasSequenceIdentifier": [
        "Book XII",
        "paragraph 4"
      ],
      "beast:isTextualReferenceOf": {
        "@id": "beastiary:int_basilisk_isidore"
      }
    },
