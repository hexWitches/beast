    {
      "@id": "beastiary:ability_shapeshifting",
      "@type": "beast:Ability",
      "beast:belongsToImaginaryStructure": {
        "@id": "beast:MysticalStructure"
      },
      "beast:embodiesImaginarySymbol": {
        "@id": "beast:InversionSymbol"
      },
      "beast:isGovernedBy": {
        "@id": "beast:NocturnalRegime"
      },
      "http://www.w3.org/2000/01/rdf-schema#comment": [
        {
          "@language": "en",
          "@value": "Shapeshifting enacts the inversive logic of transformation and doubling, by which a single being turns into its other."
        },
        {
          "@language": "en",
          "@value": "he inherent biological or magical fluidity allowing a creature to alter its physical appearance, form, or species identity, effectively blurring the lines of its original manifestation to deceive, escape, or adapt to different environments."
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Shape shifting"
      }
    },
