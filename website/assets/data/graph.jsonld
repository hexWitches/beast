    {
      "@id": "beastiary:archetype_emasculation",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "Privation of the vital force, sovereignty, or active identity. It represents the transition from a place of autonomy and force to a state of submission, fragmentation, or sterile softness."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Emasculation"
      }
    },
    {
      "@id": "beastiary:archetype_metamorphosis",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The principle of transformation and change of form as such."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Metamorphosis"
      }
    },
    {
      "@id": "beastiary:archetype_divine_punishment",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "Retribution inflicted by the gods for transgression, the sacred sanction against hubris."
      },
      "http://www.w3.org/2000/01/rdf-schema#label": {
        "@language": "en",
        "@value": "Divine Punishment"
      }
    },
    {
      "@id": "beastiary:citation_aldrovandi_1",
      "@type": "beast:Citation",
      "beast:extractedFrom": {
        "@id": "beastiary:source_monstrorum_historia_aldrovandi"
      },
      "beast:hasPassageText": {
        "@language": "la",
        "@value": "Satyrs, Tritons, Nymphs, Nereids, and Sirens are also deservedly placed by many in the category of wild men."
