    {
      "@id": "beastiary:etymology_hermaphrodite",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The word that refers to a character belonging to greek mythology, the child of Ermes (Ἑρμῆς) and Aphrodite (Aphrodítē). Represented in greek mythology as a female figure with male genitals, they are historically used to describe androgynous and effeminacy."
      },
      "beast:hasRootTerm": {
        "@language": "grc",
        "@value": "Hermaphroditos"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_hermaphrodite"
      }
    },
    {
      "@id": "beastiary:habitat_riphean_mountains",
