    {
      "@id": "beastiary:archetype_divided_self",
      "@type": "beast:Archetype",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "A figure torn between animal impulse and human consciousness, embodying the internal conflict between instinct and reason."
