        }
      ],
      "beast:hasPersonalName": "The Chimera",
      "beast:isGovernedBy": {
        "@id": "beast:DiurnalRegime"
      },
      "beast:ofCreature": {
        "@id": "beastiary:creature_chimera"
      },
      "beast:removedAbility": {
        "@id": "beastiary:ability_fire_breathing"
      },
      "beast:removedPart": [
        {
          "@id": "beastiary:part_goat_lower_body"
        },
        {
          "@id": "beastiary:part_lion_head"
        },
        {
          "@id": "beastiary:part_lion_upper_body"
        },
        {
          "@id": "beastiary:part_snake_tail"
        }
      ],
      "http://www.w3.org/2000/01/rdf-schema#comment": {
        "@language": "en",
        "@value": "Moreau's Chimera converts the threatening hybrid into an object of desire: winged and human above, bestial below, she fuses the ascensional pull of flight with a nyctomorphic undertow of obscurity and seduction, where fire and fang no longer signal attack but the dark, submerged allure of the abyss itself."
      }
    },
    {
      "@id": "beastiary:archetype_abandoned_child",
