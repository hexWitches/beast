        "@value": "Pegasus represents the ascensional symbol since it is an explosion of solar light out of primordial darkness (medusa head), it rejects the heavy, muddy earth, soaring straight to Mount Olympus."
      }
    },
    {
      "@id": "beastiary:etymology_medusa",
      "@type": "beast:Etymology",
      "beast:hasMeaning": {
        "@language": "en",
        "@value": "The name comes from the Ancient Greek verb medein (μήδω), meaning 'to rule over' or 'to protect'. As a proper noun, it translates literally to 'guardian' or 'protector'."
      },
      "beast:hasRootTerm": {
        "@language": "grc",
        "@value": "Medein"
      },
      "beast:isEtymologyOf": {
        "@id": "beastiary:creature_medusa"
      }
    },
