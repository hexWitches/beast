    beast:hasPart beastiary:part_crest ;
    beast:hasTailOf beastiary:creature_snake ;
    beast:isGovernedBy beast:DiurnalRegime .

beastiary:creature_centaur a beast:Creature,
        beast:HybridCreature ;
    rdfs:label "Centaur"@en ;
    rdfs:comment "Across most sources the centaur's horse-lower-body dominates its symbolism: uncontrolled instinct, drunken violence, and predatory appetite erupting through the fragile veneer of human reason, placing the creature within the teriomorphic register of feral chaos, even where individual figures like Chiron invert this dominant."@en ;
    beast:belongsToImaginaryStructure beast:SchizomorphicStructure ;
    beast:embodiesImaginarySymbol beast:TeriomorphicSymbol ;
    beast:hasAbility beastiary:ability_archery,
        beastiary:ability_wine_drinking ;
    beast:hasAlternativeName "Hippocentaurus, Sagitarius"^^xsd:string ;
    beast:hasDiet beast:Omnivorous ;
    beast:hasEtymology beastiary:etymology_centaur ;
    beast:hasHabitat beastiary:habitat_forests,
        beastiary:habitat_mountains ;
    beast:hasHeadOf beastiary:creature_human ;
