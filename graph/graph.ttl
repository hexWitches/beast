        beast:HybridCreature ;
    rdfs:label "Cerberus"@en ;
    rdfs:comment "Cerberus embodies the teriomorphic symbol of devouring jaws and feral chaos, guarding the threshold of the underworld against the passage of the living and the escape of the dead."@en ;
