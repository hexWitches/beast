@prefix beast: <https://w3id.org/beast/ontology#> .
@prefix beastiary: <https://w3id.org/beast/graph/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix wd: <http://www.wikidata.org/entity/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@prefix vann: <http://purl.org/vocab/vann/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix void: <http://rdfs.org/ns/void#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

beastiary: rdf:type owl:Ontology,
                void:Dataset ;
    dcterms:conformsTo <https://w3id.org/beast/ontology> ;
    dcterms:created "2026-05-01"^^xsd:date ;
    dcterms:creator "Maria Juliana Gamboa Nivia",
        "Miriana Pinto",
        "Sara Roggiani",
        "Alice Spadavecchia" ;
    dcterms:description "A dataset describing creatures, their interpretations and biological composition, the sources in which the creatures are depicted. The BEASTiary knowledge graph is aligned with the BEAST ontology."@en ;
    owl:imports <https://w3id.org/beast/ontology> ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:publisher <https://github.com/hexWitches> ;
    dcterms:title "The BEAST Graph"@en ;
    vann:preferredNamespacePrefix "beastiary" ;
    void:dataDump <https://w3id.org/beast/graph/graph.ttl> ;
    void:vocabulary <https://w3id.org/beast/ontology> .

beastiary:genesis_anomaly_paré_1 a beast:Genesis ;
    beast:hasGenesisDescription "Paré includes the creature among his examples of monsters created by the imagination. According to his description, the hairy girl was born because her mother looked for too long at a painting."@en ;
    beast:isGenesisOf beastiary:int_anomaly_paré_1 .

beastiary:genesis_anomaly_paré_3 a beast:Genesis ;
    beast:hasGenesisDescription "Paré includes the creature among his examples of monsters created by the absence of seed."@en ;
    beast:isGenesisOf beastiary:int_anomaly_paré_3 .

beastiary:genesis_anomaly_paré_4 a beast:Genesis ;
    beast:hasGenesisDescription "Paré includes the creature among his examples of monsters createy by an excessive quantity of seed."@en ;
    beast:isGenesisOf beastiary:int_anomaly_paré_4 .

beastiary:genesis_basilisk_lucano a beast:Genesis ;
    beast:hasGenesisDescription "Sprung from the blood of Medusa's severed head as Perseus carried it in flight over Libya; one among the many venomous serpents born from those drops."@en ;
    beast:involvesParent beastiary:creature_medusa ;
    beast:isGenesisOf beastiary:int_basilisk_lucano .

beastiary:genesis_basilisk_theophilus a beast:Genesis ;
    beast:hasGenesisDescription "Hatched from a yolkless egg laid by an old cock, incubated by a toad in place of the natural mother."@en ;
    beast:isGenesisOf beastiary:int_basilisk_theophilus .

beastiary:genesis_centaur_ovid a beast:Genesis ;
    beast:hasGenesisDescription "Descended from the union of Ixion with Nephele, a cloud shaped by Zeus in the likeness of Hera to deceive Ixion."@en ;
    beast:involvesParent beastiary:myth_ixion,
        beastiary:myth_nephele ;
    beast:isGenesisOf beastiary:int_centaur_ovid .

beastiary:genesis_cerberus_esiodo a beast:Genesis ;
    beast:hasGenesisDescription "Offspring of Echidna and Typhon, one of the monstrous brood born to the two primordial serpent-giants."@en ;
    beast:involvesParent beastiary:myth_echidna,
        beastiary:myth_typhon ;
    beast:isGenesisOf beastiary:int_cerberus_esiodo .

beastiary:genesis_chimera_esiodo a beast:Genesis ;
    beast:hasGenesisDescription "Offspring of Echidna and Typhon, one of the monstrous brood born to the two primordial serpent-giants."@en ;
    beast:involvesParent beastiary:myth_echidna,
        beastiary:myth_typhon ;
    beast:isGenesisOf beastiary:int_chimera_esiodo .

beastiary:genesis_chimera_fullmetal a beast:Genesis ;
    beast:hasGenesisDescription "Produced through human transmutation, a forbidden alchemical act combining two base organisms into a new composite creature."@en ;
    beast:isGenesisOf beastiary:int_chimera_fullmetal_alchemist .

beastiary:genesis_giant_teogonia a beast:Genesis ;
    beast:hasGenesisDescription "Sprang from Gaia (Earth) after she was fertilised by the blood of Uranus's castration."@en ;
    beast:involvesParent beastiary:myth_gaia,
        beastiary:myth_uranus ;
    beast:isGenesisOf beastiary:int_giant_teogonia .

beastiary:genesis_hermaphrodite_ovidius a beast:Genesis ;
    beast:hasGenesisDescription "Child of Hermes and Aphrodite, originally a male youth of great beauty. Fused into a single dual-sexed body with the nymph Salmacis after she embraced him in her pool and prayed never to be parted from him."@en ;
    beast:involvesParent beastiary:myth_aphrodite,
        beastiary:myth_hermes ;
    beast:isGenesisOf beastiary:int_hermaphrodite_ovidius .

beastiary:genesis_medusa_esiodo a beast:Genesis ;
    beast:hasGenesisDescription "Daughter of the ancient sea deities Phorcys and Ceto, one of the three Gorgon sisters."@en ;
    beast:involvesParent beastiary:myth_ceto,
        beastiary:myth_phorcys ;
    beast:isGenesisOf beastiary:int_medusa_esiodo .

beastiary:genesis_medusa_ovid a beast:Genesis ;
    beast:hasGenesisDescription "Originally a beautiful mortal maiden, transformed into a monstrous Gorgon as punishment by Athena after being violated by Poseidon within Athena's temple."@en ;
    beast:isGenesisOf beastiary:int_medusa_ovid .

beastiary:genesis_minotaur_ovidius a beast:Genesis ;
    beast:hasGenesisDescription "Born of Queen Pasiphae's union with the Cretan Bull, an offspring bearing the head of a bull upon a man's body."@en ;
    beast:involvesParent beastiary:creature_bull,
        beastiary:myth_pasiphae ;
    beast:isGenesisOf beastiary:int_minotaur_ovidius .

beastiary:genesis_mostro_paré_1 a beast:Genesis ;
    beast:hasGenesisDescription "Paré includes the creature among his examples of monsters created by God's rage. He recounts the story of Pope Julius II, arguing that the Pope provoked divine anger by waging war against Louis XII."@en ;
    beast:isGenesisOf beastiary:int_mostro_paré_1 .

beastiary:genesis_mostro_paré_3 a beast:Genesis ;
    beast:hasGenesisDescription "Paré includes the creature among his examples of monsters created by 'commistion des semences', the mixing of seed. This creatures is generated by a human and a dog."@en ;
    beast:isGenesisOf beastiary:int_mostro_paré_3 .

beastiary:genesis_pegaso_esiodo a beast:Genesis ;
    beast:hasGenesisDescription "Sprang, together with his brother Chrysaor, from the neck of Medusa at the moment of her beheading by Perseus."@en ;
    beast:involvesParent beastiary:creature_medusa ;
    beast:isGenesisOf beastiary:int_pegaso_esiodo .

beastiary:genesis_phoenix_claudio a beast:Genesis ;
    beast:hasGenesisDescription "The Phoenix is not born of parents but self-immolates upon a pyre of aromatic wood at the end of its life cycle to be reborn from its own ashes."@en ;
    beast:involvesParent beastiary:creature_phoenix ;
    beast:isGenesisOf beastiary:int_phoenix_claudio .

beastiary:genesis_siren_ovidius a beast:Genesis ;
    beast:hasGenesisDescription "Daughters of the river god Achelous and originally companions of Persephone. They were transformed into part-bird creatures at their own request, so that they might search the world by both land and sea for the abducted Persephone."@en ;
    beast:involvesParent beastiary:myth_achelous ;
    beast:isGenesisOf beastiary:int_siren_ovidius .

beastiary:genesis_sphinx_apollodoro a beast:Genesis ;
    beast:hasGenesisDescription "Daughter of Echidna and Typhon, sent to Thebes as an instrument of divine punishment."@en ;
    beast:involvesParent beastiary:myth_echidna,
        beastiary:myth_typhon ;
    beast:isGenesisOf beastiary:int_sphinx_apollodoro .

beastiary:habitat_lonely_mountain a beast:ImaginaryPlace ;
    rdfs:label "Lonely Mountain (Erebor)"@en ;
    rdfs:comment "The solitary mountain of Erebor in Tolkien's legendarium, whose excavated halls house the dwarves' kingdom and, after its seizure, the dragon Smaug and his hoard."@en ;
    beast:hasOriginContext beastiary:source_the_hobbit .

beastiary:int_unicorn_isidor a beast:Interpretation ;
    rdfs:comment "Isidore writes that the unicorn is so strong no hunter can catch it, however when the virgin girl approaches, the beast forgets its ferocity, lays its head in her lap, and falls asleep and it can be captured following a intimacy scene."@en ;
    beast:belongsToImaginaryStructure beast:MysticalStructure ;
    beast:embodiesImaginarySymbol beast:IntimacySymbol ;
    beast:isGovernedBy beast:NocturnalRegime .

beastiary:myth_poseidon a beast:MythologicalFigure ;
    rdfs:label "Poseidon"@en .

beastiary:person_brueghel_jeune a schema:Person ;
    rdfs:comment "1564 – 1638"@en ;
    foaf:familyName "Brueghel"^^xsd:string ;
    foaf:givenName "Pieter"^^xsd:string ;
    schema:birthDate "1564"^^xsd:gYear ;
    schema:deathDate "1638"^^xsd:gYear ;
    schema:nationality "Dutch"^^xsd:string ;
    schema:sameAs <http://viaf.org/viaf/http://viaf.org/viaf/106974142>,
        wd:Q255828 .

beastiary:person_isayama a schema:Person ;
    rdfs:comment "1986 – present"@en ;
    foaf:familyName "Isayama"^^xsd:string ;
    foaf:givenName "Hajime"^^xsd:string ;
    schema:birthDate "1986"^^xsd:gYear ;
    schema:nationality "Japanese"^^xsd:string ;
    schema:sameAs <http://viaf.org/viaf/http://viaf.org/viaf/171550535>,
        wd:Q3782468 .

beastiary:ability_agility rdfs:label "Agility"@en ;
    rdfs:comment "The physical capacity for swift, nimble, and graceful movement, allowing the creature to easily evade threats, navigate hazardous terrain, or strike with exceptional speed."@en .

beastiary:ability_archery rdfs:label "Archery"@en ;
    rdfs:comment "Exceptional skill with a bow and arrow."@en .

beastiary:ability_blindness a beast:Ability ;
    rdfs:label "Blindness"@en ;
    rdfs:comment "The condition of impaired or absent sight, whether innate, induced, or afflicting the creature; the inability to see, sometimes overcome by remedies or compensated by other senses."@en,
        "The loss of vision, blindness, and the physical mutilation of the eyes are terrifying nyctomorphic symbols, representing the ultimate triumph of the void."@en ;
    beast:belongsToImaginaryStructure beast:SchizomorphicStructure ;
    beast:embodiesImaginarySymbol beast:NyctomorphicSymbol ;
    beast:isGovernedBy beast:DiurnalRegime .

beastiary:ability_compassion rdfs:label "Compassion"@en ;
    rdfs:comment "The capacity for mercy and restraint toward the vulnerable; the creature spares those it has overcome, releases captives, and refrains from harming the weak."@en .

beastiary:ability_courage a beast:Ability ;
    rdfs:label "Courage"@en ;
    rdfs:comment "A behavioral disposition toward fearlessness and boldness in the face of danger, often attributed symbolically rather than as a physical trait."@en,
        "Courage belongs to the ascensional register of virile, heroic archetypes (the warrior, celestial royalty); it is the upward, transcendent virtue that confronts and rises above fear and the threat of time."@en ;
    beast:belongsToImaginaryStructure beast:SchizomorphicStructure ;
    beast:embodiesImaginarySymbol beast:AscensionalSymbol ;
    beast:isGovernedBy beast:DiurnalRegime .

beastiary:ability_dance a beast:Ability ;
    rdfs:label "Dance"@en ;
    rdfs:comment "Rhythmic movement attributed to the creature, often in mythological or allegorical contexts."@en,
        "Rhythmic, repetitive movement embodies the cyclical 'rhythmic constants that govern natural phenomena,' the patterned return that reconciles the imagination with passing time."@en ;
    beast:belongsToImaginaryStructure beast:SyntheticStructure ;
    beast:embodiesImaginarySymbol beast:CyclicalSymbol ;
    beast:isGovernedBy beast:NocturnalRegime .

beastiary:ability_fertility rdfs:label "Fertility"@en ;
    rdfs:comment "The biological or symbolic power to generate abundant life, ensure reproductive success, or bring vitality and growth to the surrounding environment, often associated with natural or divine blessings."@en .

beastiary:ability_fight_elephant rdfs:label "Fight Elephant"@en .

beastiary:ability_healing_tears a beast:Ability ;
    rdfs:label "Healing tears"@en ;
    rdfs:comment "Healing turns wound into refuge and harm into shelter, aligning the intimacy symbol's movement from the fear of being swallowed to the comfort of being contained."@en,
        "The unique medicinal property attributed to the secretions or lacrimal fluids of a creature, possessing the power to mend wounds, cure afflictions, or restore vitality to those they touch, often highlighting the creature's paradoxical nature as a source of both danger and salvation."@en ;
    beast:belongsToImaginaryStructure beast:MysticalStructure ;
    beast:embodiesImaginarySymbol beast:IntimacySymbol ;
    beast:isGovernedBy beast:NocturnalRegime .

beastiary:ability_hypnotic_gaze a beast:Ability ;
    rdfs:label "Hypnotic gaze"@en ;
    rdfs:comment "The capacity to exert control over the will, perceptions, or motor functions of another through direct visual contact; it induces a state of trance, paralysis, or psychological subjugation that renders the subject vulnerable to the creature's intent."@en,
        "The entrancing gaze draws its victim down into shadow, sleep, and loss of self, enacting the nyctomorphic engulfment by darkness."@en ;
    beast:belongsToImaginaryStructure beast:SchizomorphicStructure ;
    beast:embodiesImaginarySymbol beast:NyctomorphicSymbol ;
    beast:isGovernedBy beast:DiurnalRegime .

beastiary:ability_intellect rdfs:label "Intellect"@en ;
    rdfs:comment "The advanced cognitive capacity for abstract reasoning, problem-solving, strategic planning, or the acquisition of deep knowledge."@en .

beastiary:ability_lethal_breath rdfs:label "Lethal breath"@en ;
    rdfs:comment "Exhalation capable of killing living beings, scorching vegetation, and breaking stones."@en .

beastiary:ability_lethal_hiss rdfs:label "Lethal hiss"@en ;
    rdfs:comment "A hissing sound capable of causing death or severe harm."@en .

beastiary:ability_lethal_odor rdfs:label "Lethal odor"@en ;
    rdfs:comment "A smell so toxic it kills serpents and other creatures in proximity."@en .

beastiary:ability_magic rdfs:label "Magic"@en ;
    rdfs:comment "The inherent power to manipulate reality, cast enchantments, or manifest supernatural phenomena through occult or supernatural means, transcending ordinary physical laws."@en .

beastiary:ability_magical_song rdfs:label "Magical song"@en ;
    rdfs:comment "The capacity to produce vocal melodies or auditory frequencies embedded with supernatural influence, capable of enchanting minds, manipulating emotions, or altering the physical environment of those who hear it."@en .

beastiary:ability_manipulation rdfs:label "Manipulation"@en ;
    rdfs:comment "The deceptive or tactical capacity to influence, control, or exploit the behaviors, minds, or situations of others, often reflecting symbolic associations with cunning, betrayal, or malice."@en .

beastiary:ability_plague_spreading rdfs:label "Plague Spreading"@en ;
    rdfs:comment "The hazardous capacity or biological disposition to generate, harbor, and transmit deadly pestilence or infectious diseases, acting as an agent of widespread physical decay or divine judgment."@en .

beastiary:ability_play_foot_castanet rdfs:label "Play foot castanet"@en ;
    rdfs:comment "A highly specific behavioral or anatomical skill where the creature produces rhythmic, clicking sounds using its feet or hooves, typically utilized for communication, distraction, or ritualistic displays."@en .

beastiary:ability_play_the_flute rdfs:label "Play the flute"@en ;
    rdfs:comment "The ability to play a musical instrument, attributed symbolically or as a marker of the creature's connection to music and nature."@en .

beastiary:ability_purify_water rdfs:label "Water purification"@en ;
    rdfs:comment "The ability to cleanse or sanctify bodies of water through presence or touch."@en .

beastiary:ability_regenerate_lost_limbs rdfs:label "Regenerate lost limbs"@en ;
    rdfs:comment "The exceptional biological capacity to organically regrow, mend, or completely replace severed body parts or heavily damaged tissue, rendering the creature remarkably resilient against permanent physical trauma."@en .

beastiary:ability_resolution rdfs:label "Resolution"@en ;
    rdfs:comment "Firmness of will and steadfast determination; the creature's resolute, unyielding disposition, located by the bestiaries in the head as the seat of its resolve."@en .

beastiary:ability_self_destructive a beast:Ability ;
    rdfs:label "Self-destruction"@en ;
    rdfs:comment "A creature undone by its own internally contradictory nature enacts the catamorphic fall turned inward: degradation and death as the direct consequence of the body's own impossible composition."@en,
        "The creature is driven to destroy itself due to its internally contradictory nature, whether physiological, psychological, or ontological."@en ;
    beast:belongsToImaginaryStructure beast:SchizomorphicStructure ;
    beast:embodiesImaginarySymbol beast:CatamorphicSymbol ;
    beast:isGovernedBy beast:DiurnalRegime .

beastiary:ability_self_renewal a beast:Ability ;
    rdfs:label "Self-renewal"@en ;
    rdfs:comment "Self-renewal is the cyclical symbol itself: death reintegrated as a necessary phase of an incessant movement in which every ending is the prelude to rebirth."@en,
        "The capacity to regenerate, rejuvenate, or be reborn, often cyclically."@en ;
    beast:belongsToImaginaryStructure beast:SyntheticStructure ;
    beast:embodiesImaginarySymbol beast:CyclicalSymbol ;
    beast:isGovernedBy beast:NocturnalRegime .

beastiary:ability_shapeshifting a beast:Ability ;
    rdfs:label "Shape shifting"@en ;
    rdfs:comment "Shapeshifting enacts the inversive logic of transformation and doubling, by which a single being turns into its other."@en,
        "he inherent biological or magical fluidity allowing a creature to alter its physical appearance, form, or species identity, effectively blurring the lines of its original manifestation to deceive, escape, or adapt to different environments."@en ;
    beast:belongsToImaginaryStructure beast:MysticalStructure ;
    beast:embodiesImaginarySymbol beast:InversionSymbol ;
    beast:isGovernedBy beast:NocturnalRegime .

beastiary:ability_skin_shedding a beast:Ability ;
    rdfs:label "Skin Shedding"@en ;
    rdfs:comment "Periodically shedding skin symbolizes cyclical regeneration, renewal through repetition, and the eternal return, transforming apparent decay into the promise of rebirth."@en,
        "The periodic sloughing of the outer skin to renew the body, by which the creature casts off its old self and regains its youth, as the snake squeezes through a narrow crack to shed its skin."@en ;
    beast:belongsToImaginaryStructure beast:SyntheticStructure ;
    beast:embodiesImaginarySymbol beast:CyclicalSymbol ;
    beast:isGovernedBy beast:NocturnalRegime .

beastiary:ability_soporific rdfs:label "Soporific"@en ;
    rdfs:comment "The specialized power or chemical/auditory trait to induce deep, unnatural sleep or profound lethargy in other beings, leaving them incapacitated and vulnerable to the creature's intent."@en .

beastiary:ability_speak_black_speech rdfs:label "Speak Black Speech"@en ;
    rdfs:comment "The capacity to speak the dark tongue of evil or infernal beings; articulate speech in a malign or forbidden language."@en .

beastiary:ability_sunlight_petrification rdfs:label "Sunlight Petrification"@en ;
    rdfs:comment "The power, or vulnerability, by which exposure to sunlight turns a creature to stone; petrifaction induced by daylight."@en .

beastiary:ability_swim rdfs:label "Swimming"@en ;
    rdfs:comment "The ability to move efficiently through water."@en .

beastiary:ability_swim_in_air rdfs:label "Swim in the air"@en ;
    rdfs:comment "The capacity to move through the air as though swimming through water, flying in constant, fluid motion without the aid of wings."@en .

beastiary:ability_untameable rdfs:label "Untameable"@en ;
    rdfs:comment "The absolute behavioral resistance to subjugation, domestication, or human control; it reflects an unyielding nature and an innate commitment to wild autonomy that defies all efforts of mastery."@en .

beastiary:ability_venomous rdfs:label "Venomous"@en ;
    rdfs:comment "The biological trait of producing and delivering toxic secretions through bites, stings, or skin contact, capable of inflicting severe illness, paralysis, or agonizing death upon adversaries."@en .

beastiary:ability_weather_control rdfs:label "Weather Control"@en ;
    rdfs:comment "The majestic supernatural capacity to summon, alter, or pacify atmospheric conditions, allowing the creature to command storms, winds, rain, or lightning to shape its immediate environment."@en .

beastiary:ability_wine_drinking rdfs:label "Wine Drinking"@en ;
    rdfs:comment "An exceptional or culturally distinctive relationship with wine consumption, often associated with loss of rational control, festivity, or ritual behavior."@en .

beastiary:archetype_androgynous a beast:Archetype ;
    rdfs:label "Androgynous"@en ;
    beast:hasMeaning "The androgynous is a symbol of unity and completeness, representing the integration and armonization of the polarities of the human being."@en .

beastiary:archetype_anti_fairy_tale a beast:Archetype ;
    rdfs:label "Anti-Fairy Tale"@en ;
    beast:hasMeaning "Here the character subverts the traditional figure of the evil and goes over a personal and interior journey where it becomes the story hero."@en .

beastiary:archetype_belief a beast:Archetype ;
    rdfs:label "Belief"@en ;
    beast:hasMeaning "The embodiment of belief without belief, her magic fades, that things exist only so long as we believe in them."@en .

beastiary:archetype_christmas_elf a beast:Archetype ;
    rdfs:label "Christmas Elf"@en ;
    beast:hasMeaning "Lives with Santa Claus at the North Pole and acts as his helper. Christmas elves are usually depicted as green- or red-clad, with large, pointy ears and wearing pointy hats."@en .

beastiary:archetype_constancy a beast:Archetype ;
    rdfs:label "Constancy"@en ;
    beast:hasMeaning "Steadfast faithfulness and devotion, unwavering even unto death."@en .

beastiary:archetype_darkness a beast:Archetype ;
    rdfs:label "Darkness"@en ;
    beast:hasMeaning "They are often linked to shadows, darkness, and the chthonic aspects of the world, such as death, magic, and the hidden forces of nature."@en .

beastiary:archetype_exotic_marvel a beast:Archetype ;
    rdfs:label "Exotic Marvel"@en ;
    beast:hasMeaning "Represents the classic archetype of geographic alterità, other countries seen as spaces full of weird creatures to document and organize."@en .

beastiary:archetype_fertility a beast:Archetype ;
    rdfs:label "Fertility"@en ;
    beast:hasMeaning "The generative principle of abundance, reproduction, and the renewal of life."@en .

beastiary:archetype_godmother a beast:Archetype ;
    rdfs:label "Godmother"@en ;
    beast:hasMeaning "The benevolent supernatural protector who guides and aids the protagonist."@en .

beastiary:archetype_guardian_threshold a beast:Archetype ;
    rdfs:label "Guardian of the Threshold"@en ;
    beast:hasMeaning "A powerful figure stationed at the boundary between worlds or states of being, controlling access to forbidden or sacred spaces."@en ;
    beast:relatedTo beastiary:archetype_guardian_hell .

beastiary:archetype_hypocrisy a beast:Archetype ;
    rdfs:label "Hypocrisy"@en ;
    beast:hasMeaning "The figure whose outward appearance or speech professes virtue while concealing or enacting baseness and vice, embodying the moral duplicity of one who says truth but does villainy."@en ;
    beast:relatedTo beastiary:archetype_divided_self .

beastiary:archetype_justice a beast:Archetype ;
    rdfs:label "Justice"@en ;
    beast:hasMeaning "The principle of right order and equitable judgment."@en .

beastiary:archetype_love a beast:Archetype ;
    rdfs:label "Love"@en ;
    beast:hasMeaning "The embodiment of devoted, transcendent love."@en .

beastiary:archetype_mourner a beast:Archetype ;
    rdfs:label "Mourner"@en ;
    beast:hasMeaning "The figure defined by grief and lament for a loss."@en .

beastiary:archetype_natural_marvel a beast:Archetype ;
    rdfs:label "Natural Marvel"@en ;
    beast:hasMeaning "The wonder of the natural world rationalized as a marvel rather than a monster."@en .

beastiary:archetype_parasite a beast:Archetype ;
    rdfs:label "Parasite"@en ;
    beast:hasMeaning "An organism whose life depends on the exploitation of another being, causing damage to it."@en .

beastiary:archetype_poetic_inspiration a beast:Archetype ;
    rdfs:label "Poetic Inspiration"@en ;
    beast:hasMeaning "Represents the poetic inspiration that the muses give to have the spontaneous artistic and intellectual brilliance."@en .

beastiary:archetype_power a beast:Archetype ;
    rdfs:label "Power"@en ;
    beast:hasMeaning "Worldly sovereignty and dynastic might, the power of rule and dominion."@en .

beastiary:archetype_pride a beast:Archetype ;
    rdfs:label "Pride"@en ;
    beast:hasMeaning "Overweening self-exaltation, the vice of superbia. archetype_prima_materia The alchemical first matter, the base substance of transformation."@en .

beastiary:archetype_prima_materia a beast:Archetype ;
    rdfs:label "Prima Materia"@en ;
    beast:hasMeaning "The role of shielding and safeguarding from harm."@en ;
    beast:relatedTo beastiary:archetype_cosmic .

beastiary:archetype_protection a beast:Archetype ;
    rdfs:label "Protection"@en ;
    beast:hasMeaning "The role of shielding and safeguarding from harm."@en .

beastiary:archetype_resilience a beast:Archetype ;
    rdfs:label "Resilience"@en ;
    beast:hasMeaning "The figure of endurance that withstands and recovers from oppression or adversity."@en ;
    beast:relatedTo beastiary:archetype_defiance .

beastiary:archetype_scientific_transgression a beast:Archetype ;
    rdfs:label "Scientific Transgression"@en ;
    beast:hasMeaning "The creature born of forbidden knowledge and technical hubris, produced by the violation of natural boundaries through human artifice rather than divine or monstrous agency."@en ;
    beast:relatedTo beastiary:archetype_shameful_offspring .

beastiary:archetype_spirit a beast:Archetype ;
    rdfs:label "Spirit"@en ;
    beast:hasMeaning "The numinous animating presence, a being of pure spirit or nature."@en .

beastiary:archetype_uncanny a beast:Archetype ;
    rdfs:label "Uncanny"@en ;
    beast:hasMeaning "The unsettling familiarity-in-strangeness that provokes dread."@en ;
    beast:relatedTo beastiary:archetype_sublime .

beastiary:archetype_vice a beast:Archetype ;
    rdfs:label "Vice"@en ;
    beast:hasMeaning "The embodiment of a moral failing or sinful disposition - a creature that personifies a specific human vice such as pride, lust, or wrath, serving as an allegorical warning against that failing."@en .

beastiary:citation_aberdeen_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_aberdeen_bestiary ;
    beast:hasPassageText "The phoenix is a bird of Arabia, so called either because its colouring is Phoenician purple, or because there is only one of its kind in the whole world. It lives for upwards of five hundred years, and when it observes that it has grown old, it erects a funeral pyre for itself from small branches of aromatic plants, and having turned to face the rays of the sun, beating its wings, it deliberately fans the flames for itself and is consumed in the fire. But on the ninth day after that, the bird rises from its own ashes."^^xsd:string ;
    beast:hasSequenceIdentifier "Folio 55r"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_phoenix_aberdeen .

beastiary:citation_aberdeen_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_aberdeen_bestiary ;
    beast:hasPassageText "There are said to be three kinds. Of these, the ones which are short in stature, with curly manes, are peaceable; the tall ones, with straight hair, are fierce. Their brow and tail show their mettle; their courage is in their breast, their resolution in their head. They fear the rumbling sound of wheels, but are even more frightened by fire. The lion takes pride in the strength of its nature; it does not know how to join in the ferocity of other kinds of wild beasts, but like a king disdains the company of large numbers. Those who study nature say that the lion has three main characteristics. The first is that it loves to roam amid mountain peaks. If it happens that the lion is pursued by hunters, it picks up their scent and obliterates the traces behind it with its tail. [...] The second characteristic of the lion is that when it sleeps, it seems to have its eyes open. [...] The third characteristic of the lion is that when a lioness gives birth to her cubs, she produces them dead and watches over them for three days, until their father comes on the third day and breathes into their faces and restores them to life. [...] Where men are concerned, it is the nature of lions not to grow angry unless they are harmed. An example which thoughtful men should heed; for men grow angry even when they have not been harmed, and they oppress the innocent, although Christian law bids them set even the guilty free. The compassion of lions is apparent from endless examples. They spare those whom they have brought down. They allow captives whom they encounter to return home. They vent their rage on men rather than women. They do not kill children except in time of great hunger. Equally, lions refrain from over-feeding. First, because they drink and feed on alternate days; and often, if their food remains undigested, they postpone the next feed. Then, because they feel uncomfortable when they have devoured more meat than they should, they insert their paws in their mouth and pull the food out, of their own accord. And when they have to take flight, they do exactly the same thing if they are full. Missing teeth show that a lion is old. Lions mate face to face; and not only lions, but lynxes, and camels, and elephants, and rhinoceroses, and tigers."^^xsd:string ;
    beast:hasSequenceIdentifier "Folio 7v-8r"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_lion_aberdeen .

beastiary:citation_aberdeen_3 a beast:Citation ;
    beast:extractedFrom beastiary:source_aberdeen_bestiary ;
    beast:hasPassageText "The eagle is so called because of the sharpness of its eyes, for it is said to be of such keen vision that it glides above the sea on unmoving wings, out of human sight, yet from such a height sees small fish swimmming below and, swooping down like a missile thrown from a siege engine, it seizes its prey on the wing and carries it to land. When the eagle grows old, however, its wings grow heavy, and its eyes grow dim. Then it seeks out a spring and, turning away from it, flies up into the atmosphere of the sun; there it sets its wings alight and, likewise, burns off the dimness in its eyes in the sun's rays. Descending at length, it immerses itself in the spring three times; immediately it is restored to the full strength of its wings, the former brightness of its eyes."^^xsd:string ;
    beast:hasSequenceIdentifier "Folio 61r"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_eagle_aberdeen .

beastiary:citation_aberdeen_4 a beast:Citation ;
    beast:extractedFrom beastiary:source_aberdeen_bestiary ;
    beast:hasPassageText "The snake has three characteristics. The first of these is that when it grows old, its eyes grow dim; if it wants to regain its youth, it fasts for many days until its skin grows loose; then it seeks out a narrow crack in a rock, enters it, and scrapes through, sloughing off its old skin. [...] The snake's second characteristic is this: when it comes to a river to drink water, it does not bring its venom with it, but discharges it into a pit. [...] All snakes suffer from poor sight; they can rarely see what is in front of them. This is not without reason, since their eyes are not at the front but in the temples of the head, so that they hear better than they see. No creature moves its tongue as swiftly as the snake, to such an extent that it seems to have a triple tongue, when in fact there is only one. The bodies of snakes are moist, so that wherever they go, they mark their path with moisture. The tracks of snakes are such that, since they seem to lack feet, they crawl using their flanks and the pressure of their scales, which are laid out in the same pattern from the throat to the lowest part of the belly. For they support themselves on their scales as if on claws, and on their flanks as if on legs. As a result, if a snake is struck on any part of the body, from the belly to the head, it is disabled and cannot get away quickly, because where the blow falls, it dislocates the spine, through which the foot-like movement of the flanks and the motion of the body are activated. Snakes are said to live for a long time, to such an extent that it also claimed that when they shed their old skins, they shed their old age and regain their youth. The snake's skin is called exuvie, because they shed it, exuere, when they grow old."^^xsd:string ;
    beast:hasSequenceIdentifier "Folio 71r-72r"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_snake_aberdeen .

beastiary:citation_aberdeen_5 a beast:Citation ;
    beast:extractedFrom beastiary:source_aberdeen_bestiary ;
    beast:hasPassageText "The monoceros is a monster the body of a horse, the feet of an elephant and a tail very like that of a deer. A magnificent, marvellous horn projects from the middle of its forehead, four feet in length, so sharp that whatever it strikes is easily pierced with the blow. No living monoceros has ever come into man's hands, and while it can be killed, it cannot be captured."^^xsd:string ;
    beast:hasSequenceIdentifier "Folio 15r"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_unicorn_aberdeen .

beastiary:citation_aldrovandi_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstrorum_historia_aldrovandi ;
    beast:hasPassageText "Satyrs, Tritons, Nymphs, Nereids, and Sirens are also deservedly placed by many in the category of wild men."^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 2: Diversità nella specie umana"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_satyr_aldrovandi .

beastiary:citation_aldrovandi_10 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstrorum_historia_aldrovandi ;
    beast:hasPassageText "Ora, qualcuno sosterrà che il motivo per cui talvolta, da genitori normali, nasce un bambino mutilo è che, nell'utero, il feto perde quella parte del corpo a causa di qualche malattia. Ma ciò non è condivisibile, dal momento che la testa è la parte principale, e se essa viene compromessa o perduta, il feto perisce nell'utero. Né bisogna ricorrere, per spiegare la generazione di un simile mostro, alla suggestione, poiché la forza della suggestione, per quanto intensa, non può eliminare una porzione della materia esistente nell'u-tero. Per questo motivo si dovrà concludere che, per qualche ragione, la materia destinata alla formazione della testa può venire dispersa e deviata verso il petto. E poiché la materia seminale conserva sempre la facoltà di generare quella determinata parte, cui in origine era destinata, ecco che i lineamenti del volto possono apparire sul petto."^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 5: Anomalie delle singole parti del corpo"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_anomaly_aldrovandi_2 .

beastiary:citation_aldrovandi_11 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstrorum_historia_aldrovandi ;
    beast:hasPassageText "Nell'opera di Ambroise Paré è riportata l'effigie di una fanciulla a due teste, la quale era molto bella e ben formata in tutte le membra, ma aveva due teste, entrambe le quali avevano la medesima necessità di bere, mangiare, dormire e parlare. Questo mostro elemosinava di che vivere andando di porta in porta, tuttavia fu infine allontanato dalla Baviera su ordine dei governanti, poiché temevano che le donne incinte, vedendo frequentemente il mostro, trasmettessero quella stessa deformità ai propri figli."^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 5: Anomalie delle singole parti del corpo"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_anomaly_aldrovandi_3 .

beastiary:citation_aldrovandi_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstrorum_historia_aldrovandi ;
    beast:hasPassageText "At the end of this category, we place those distinguished by being composed of both sexes, which includes Androgynes, or Hermaphrodites."^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 2: Diversità nella specie umana"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_hermaphrodite_aldrovandi .

beastiary:citation_aldrovandi_3 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstrorum_historia_aldrovandi ;
    beast:hasPassageText "Furthermore, there is a certain plant among the Greeks called andreikelos, which is similar to a man – the name being formed by syncope and the change of a smooth breathing to a rough one. This plant seems to correspond with the Mandrake, which reflects the basic outlines of the human figure in its root; this is why Columella called the Mandrake 'half-human,' writing: 'Though the mandrake, sown with frantic grass, produces flowers of the half-human, and the mournful Hemlock.' This same plant was called anthropomorphos by Pythagoras, as it reflects the form of a man. We might also pass over other plants representing the human figure, such as certain species of Satyrium orchids, one of which has a flower that beautifully mimics the human shape; for this reason, it is known to the Greeks as anthropozoos, as if the plant bears the image of a living human in its bloom."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_mandrake_aldrovandi .

beastiary:citation_aldrovandi_4 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstrorum_historia_aldrovandi ;
    beast:hasPassageText "[...] ella portava infatti al proprio seguito una fanciulla di otto anni coperta di peli. [...] Il viso della fanciulla, come anche la fronte, era coperto di peli, a parte il naso e il contorno delle labbra. I peli della fronte erano più lunghi e ispidi rispetto a quelli che coprivano le guance, che erano più morbidi al tatto; il resto del corpo, e soprattutto il dorso, era coperto di peli ispidi, e brulicava di peli biondi fino al principio dei lombi. Mentre le altre parti erano intatte, la gola, il petto, le mani, e le braccia erano stati rasati e somigliavano alla pelle degli uccelli che non hanno ancora messo le piume.\""^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 2: Diversità nella specie umana"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_anomaly_aldrovandi_1 .

beastiary:citation_aldrovandi_5 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstrorum_historia_aldrovandi ;
    beast:hasPassageText "Inoltre, se spaziamo nel vasto campo del tempo passato, troveremo mostri ancor più orrendi. Infatti nell'anno del Signore 1512 nacque a Ravenna un mostro che aveva un corno sulla testa, ed era dotato di entrambi i sessi; le altre parti erano umane, come si può vedere nella relativa figura. E questo mostro venne alla luce al tempo in cui il pontefice Giulio II aizzò l'Italia intera e gran parte della cristianità contro il re di Francia Luigi XII: perciò in seguito, la domenica di Pasqua, a Ravenna infuriò una tremenda battaglia. Ma altri, dall'aspetto di questo mostro, trassero il vaticinio che in quell'epoca non sarebbero mancati gli svariati e deleteri vizi degli uomini: associarono infatti il corno del mostro alla superbia, le ali alla frivolezza e incostanza dello spirito, la mancanza di braccia alla mancanza di opere giuste, la zampa di uccello rapace alla rapina, all'usura e all'avarizia, il ginocchio munito di occhio alla propensione degli uominbi verso le sole cose mondane, e la compresenza di entrambi i sessi a ogni specie di oscena lussuria."^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 3: Il mostro in generale"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_mostro_aldrovandi_1 .

beastiary:citation_aldrovandi_6 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstrorum_historia_aldrovandi ;
    beast:hasPassageText "Per rafforzare ancor di più la tesi di coloro che pongono più mostri in acqua che sulla terra, aggiungiamo l'immagine di un mostro marino, riportato dal Paré, con testa, criniera e petto di cavallo il resto del corpo di pesce. Il Gessner riferisce che questa creatura, presa nell'oceano, fu portata a Roma e mostrata al sommo pontefice. Sia perciò resa giustizia a coloro che, negli antichi racconti, parlarono con grande libertà di cavalli marini, dipingendoli con forme in parte equine [...]. Al riguardo, molti hanno affermato che fu l'ambizione dei Romani a dare spunto alla figura di questo cavallo: dal momento che essi dimostrarono a tutti la loro preminenza sulla terra e sul mare, pensarono di dipingere uniti insieme due animali, uno per ciascun elemento, cioè il cavallo e il delfino. In seguito molti, sbalorditi da tale figura, e convinti che un simile mostro esistesse sotto forma di un'unica creatura, lo chiamarono cavallo marino. Ma, dato che l'immagine qui proposta trova un certo riscontro nella realtà, non dobbiamo più farci prendere dallo stupore."^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 3: Il mostro in generale"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_mostro_aldrovandi_2 .

beastiary:citation_aldrovandi_7 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstrorum_historia_aldrovandi ;
    beast:hasPassageText "Quali siano i nomi, la natura, il comportamento e l'alimentazione di questo animale, è stato ampiamente discusso nello studio sui quadrupedi digitati. Rimane solo da aggiungere quanto dice in proposito il Paré, e da proporre un'immagine da poter osservare, che non era ancora disponibile al tempo del precedente volume. Ebbene, il Paré afferma che questo animale viene chiamato haut, ha le dimensioni di un cercopiteco, ma la testa e il volto somigliano a quelli di un bambino. Quando viene catturato si lamenta e tira fuori dal petto profondi sospiri, come un uomo ansioso e sofferente. Le sue zampe sono munite di tre artigli; scala gli alberi e trascorre lassù più tempo che a terra. Cammina così lentamente che, nell'atto di allungare le zampe, tocca quasi il suolo con il ventre. In quindici giorni non copre la distanza di un tiro di pietra; una volta che è salito su un albero, vi trascorre due giorni, e non accelera i movimenti neanche quando è minacciato o in pericolo."^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 3: il mostro in generale"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_mostro_aldrovandi_3 .

beastiary:citation_aldrovandi_8 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstrorum_historia_aldrovandi ;
    beast:hasPassageText "Possiamo avvalorare ancora la tesi in discorso aggiungendo l'immagine di un mostro acquatico più repellente, ricordato dal Gessner, il quale attribuisce questo ritratto da lui ricevuto a un disegnatore che lo aveva visto dal vivo ad Anversa. La testa del mostro aveva un aspetto selvaggio, munita com'era di due corna e di orecchie assai sporgenti. Le braccia invece non erano dissimili da quelle umane; il resto del corpo somigliava a quello di un pesce. Fu catturato nel mare della regione illirica, quando era emerso dall'acqua per rapire un bambino che si trovava sulla spiaggia. Alcuni pescatori, assistendo alla scena, colpirono il mostro con pietre; esso tentò di fuggire, ma essendo ferito a morte spirò poco dopo riverso sulla spiaggia, dalla quale aveva cercato di allontanarsi. Nell'immagine vengono quindi offerti all'osservazione i tratti di tale mostro."^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 3: il mostro in generale"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_mostro_aldrovandi_4 .

beastiary:citation_aldrovandi_9 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstrorum_historia_aldrovandi ;
    beast:hasPassageText "Not long after, a six-legged female cat was born, colored partly white and partly dark gray; four feet supported the cat's hindquarters and only two the front. We provide the likeness of this monstrous cat, together with \"cat-joy\" - that is, bugloss.\""^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 5: Anomalie delle singole parti del corpo"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_mostro_aldrovandi_5 .

beastiary:citation_andersen_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_andersen ;
    beast:hasPassageText "They were six beautiful children; but the youngest was the prettiest of them all; her skin was as clear and delicate as a rose-leaf, and her eyes as blue as the deepest sea; but, like all the others, she had no feet, and her body ended in a fish's tail.'"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_siren_andersen .

beastiary:citation_anonymous a beast:Citation ;
    beast:extractedFrom beastiary:source_liber_monstrorum ;
    beast:hasPassageText "Le Sirene sono fanciulle marine che seducono i marinai con la bellezza del corpo e la dolcezza del canto. Dalla testa fino all’ombelico hanno aspetto di vergine, del tutto simili a creature umane. Hanno però code squamose di pesce, che nascondono sempre sott’acqua."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_siren_anonymous .

beastiary:citation_apollodorus_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_mito_edipo ;
    beast:hasPassageText "Era infatti inviò la Sfinge, che era (nata) dalla madre Echidna e dal padre Tifone, ed aveva volto di donna, ma petto e parte inferiore del corpo e coda di leone e ali di uccello. Ed avendo appreso un indovinello dalle Muse stava seduta sul monte Ficio e lo proponeva ai Tebani. E l'indovinello era: cos'è che, (pur) avendo una sola voce, diventa quadrupede e bipede e tripede? Ed essendoci per i Tebani un oracolo (secondo cui) allora si sarebbero liberati della Sfinge, quando avessero risolto l'indovinello, radunandosi molte volte insieme cercavano che cosa fosse ciò che veniva detto, ma poiché non trovavano, afferrando uno lo divorava. Ed essendo morti molti, e alla fine Emone, il figlio di Creonte, Creonte promette con un bando di dare sia il regno sia la moglie di Laio a colui che avesse risolto l'indovinello."^^xsd:string ;
    beast:hasSequenceIdentifier "Section 3, lines 52-54"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_sphinx_apollodoro .

beastiary:citation_apollodorus_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_biblioteca ;
    beast:hasPassageText "But Earth, vexed on account of the Titans, brought forth the giants, whom she had by Sky. These were matchless in the bulk of their bodies and invincible in their might; terrible of aspect did they appear, with long locks drooping from their head and chin, and with the scales of dragons for feet. They were born, as some say, in Phlegrae, but according to others in Pallene. And they darted rocks and burning oaks at the sky."^^xsd:string ;
    beast:hasSequenceIdentifier "Book I"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_giant_apollodorus .

beastiary:citation_apollodorus_3 a beast:Citation ;
    beast:extractedFrom beastiary:source_biblioteca ;
    beast:hasPassageText "Ed ottenuto da Mercurio una falce d’adamante, volò all’ Oceano, ove vide le Gorgoni dormienti. Una d’esse avea nome Steno, Euriala la seconda, la terza Medusa; e questa sola dicesi che fosse mortale. Era essa quella, la cui testa Perseo era stato mandato a prendere. Le teste delle Gorgoni erano tutte piene di squamose serpi attorcigliate; ed aveano in bocca denti grandi quanto quelli de’ cinghiali: poi di bronzo erano le loro mani, ed aveano ali d’oro colle quali volavano: di più chiunque esse guardassero, lo trasmutavano in sasso. Assalitele Perseo così immerse com'erano nel sonno, direttone il braccio suo da Minerva, e tenendo gli occhi fissi nello scudo di bronzo per cui vedea l'immagine della Gorgona, tagliò la testa a Medusa: il che fatto, Pegaso, cavallo alato, balzò fuori all’istante, e nel tempo stesso Criasore padre di Gerione, di cui per opera di Nettuno essa era gravida."^^xsd:string ;
    beast:hasSequenceIdentifier "Book II, capo IV"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_medusa_apollodoro .

beastiary:citation_apollodorus_4 a beast:Citation ;
    beast:extractedFrom beastiary:source_biblioteca ;
    beast:hasPassageText "Come primo compito gli fu imposto di riportare la pelle del Leone Nemeo, una belva invulnerabile, nata da Tifone. E dunque Eracle partì per affrontare il leone e giunse a Cleone, dove fu ospitato da un bracciante, Molorco. Questi stava per offrire in quel giorno una vittima in sacrificio, ma Eracle gli disse di aspettare trenta giorni: se fosse tornato sano e salvo dalla caccia, avrebbe sacrificato a Zeus Salvatore, e se invece fosse morto, Molorco avrebbe dovuto offrire il sacrificio a Eracle stesso, come eroe. Arrivato a Nemea, Eracle seguì le tracce del leone e cominciò a colpirlo con le sue frecce; ma capì subito che era invulnerabile: così si mise in spalla la clava, e gli andò dietro. Il leone si rifugiò in una grotta con due ingressi: Eracle ne chiuse uno ed entrò dall'altro, si avvicinò alla bestia, la prese al collo e la immobilizzò, e le strinse la gola fino a che morì soffocata - poi si mise il leone in spalla e tornò a Cleone. Qui incontrò Molorco che ormai, essendo l'ultimo giorno, stava per compiere il sacrificio in onore di Eracle morto: così, insieme a lui, sacrificò invece a Zeus Salvatore, e poi portò il leone a Micene. Euristeo, atterrito dalla forza dell'eroe, gli vietò per il futuro l'ingresso in città: i risultati delle sue imprese avrebbero dovuto essere esposti davanti alle porte."^^xsd:string ;
    beast:hasSequenceIdentifier "Book II, chapter 5"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_lion_apollodorus .

beastiary:citation_apollodorus_5 a beast:Citation ;
    beast:extractedFrom beastiary:source_biblioteca ;
    beast:hasPassageText "Come dodicesima fatica gli fu imposto di portare via Cerbero dall'Ade. Cerbero aveva tre teste di cane, una coda di drago e lungo la schiena gli spuntavano teste di serpente di ogni tipo."^^xsd:string ;
    beast:hasSequenceIdentifier "\"Book II, chapter 5\""^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_cerberus_apollodorus .

beastiary:citation_ariosto_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_orlando_furioso ;
    beast:hasPassageText "Non è finto il destrier, ma naturale, / ch’una giumenta generò d’un grifo: / simile al padre avea la piuma e l’ale, / li piedi anteriori, il capo e il grifo; / in tutte l’altre membra parea quale / era la madre, e chiamasi ippogrifo; / che nei monti Rifei vengon, ma rari, / molto di lá dagli aghiacciati mari."^^xsd:string ;
    beast:hasSequenceIdentifier "Canto IV, paragraph 18"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_hippogriff_ariosto .

beastiary:citation_ariosto_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_orlando_furioso ;
    beast:hasPassageText "L’Orco da noi s’aspetta, ad ogni suono di sentirlo parci, ch’affamato ritorni a divorarci."^^xsd:string ;
    beast:hasSequenceIdentifier "Canto XVII, paragraph 38"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_ogre_ariosto .

beastiary:citation_barbie_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_barbie ;
    beast:hasPassageText "A measure of courage is not based on what you look like on the outside, but what you are willing to fight for."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_pegaso_barbie .

beastiary:citation_beowulf_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_beowulf ;
    beast:hasPassageText "Then the ancient dusk-scather / The fire-dragon. Found the great treasure standing all open, / He who flaming and fiery flies to the barrows, / Naked war-dragon, nightly escapeth / Encompassed with fire ; men under heaven / Widely beheld him. 'Tis said that he looks for / The hoard in the earth, where old he is guarding / The heathenish treasure ; he'll be nowise the better."^^xsd:string ;
    beast:hasSequenceIdentifier "Chapter XXXIII"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_dragon_beowulf .

beastiary:citation_bible_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_bible ;
    beast:hasPassageText "In quel tempo c'erano sulla terra i giganti, e ci furono anche in seguito, quando i figli di Dio si unirono alle figlie degli uomini, ed ebbero da loro dei figli. Questi sono gli uomini potenti che, fin dai tempi antichi, sono stati famosi."^^xsd:string ;
    beast:hasSequenceIdentifier "Genesi 6:4, verse 4"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_giant_bible .

beastiary:citation_bierce_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_devil_dictionary ;
    beast:hasPassageText "An animal (now extinct) which was half horse and half griffin. The griffin was itself a compound creature, half lion and half eagle. The hippogriff was actually, therefore, a one-quarter eagle, which is two dollars and fifty cents in gold. The study of zoology is full of surprises."^^xsd:string ;
    beast:hasSequenceIdentifier "Chapter H"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_hippogriff_bierce .

beastiary:citation_book_of_invation_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_book_of_invations ;
    beast:hasPassageText "Under obscurity,  a people without a covenant of religion; whelps of the wood that has not withered."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_fairy_celtic .

beastiary:citation_cantimpre_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_liber_de_natura_rerum ;
    beast:hasPassageText "The unicorn is indeed a small animal, as Isidore says, according to the strength of the body. He also has short legs for his size. Its horn is very sharp, so that it cannot be captured by force by any hunter./A virgin girl is taken to the forest and left alone. When the unicorn arrives, putting aside all its ferocity, it respects the chastity of the virgin's body and places its head in the girl's bosom."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_unicorn_cantimpre .

beastiary:citation_cantimpre_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_liber_de_natura_rerum ;
    beast:hasPassageText "The pegasus, as Pliny says, is a large and fearsome animal in Ethiopia. It has the body of a horse, wings like an eagle, but much larger, the head is equipped with horns and it is truly monstrous, such that almost all /  They devour many foods, they are moved by restlessness, they are unsafe for animals, and the most unsafe for humankind."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_pegaso_cantimpre .

beastiary:citation_cantimpre_3 a beast:Citation ;
    beast:extractedFrom beastiary:source_liber_de_natura_rerum ;
    beast:hasPassageText "The bull is an animal robust in strength, and among all social animals tame enough to surpass those who oppose the rest with rapacity. Several together fight most bitterly, but when alone, it easily succumbs to cowardice. When they are taken, they have their tongues stuck out, they do nothing with their teeth, but only with their horns: for there is no terror in their teeth. When they graze on the grass, they do not injure the roots, but only take what is visible on the surface. Bulls are gentler, and are made suitable for all work, and especially for the hills, if they are kept from lust by being castrated. And the older they are, the more tender their flesh, if they have been fattened."^^xsd:string ;
    beast:hasSequenceIdentifier "Chapter 4: Animals (quadrupeds)"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_bull_cantimpre .

beastiary:citation_cantimpre_4 a beast:Citation ;
    beast:extractedFrom beastiary:source_liber_de_natura_rerum ;
    beast:hasPassageText "The goat is a bearded animal, with long and sharp horns, it grazes in the valley, in the mountains and in the branches of trees, which it can reach with its mouth. It has an abundance of milk, and its milk is the healthiest, but immediately, when it will have curdled, it spoils; for cheese having been made from it (the milk) is nearly useful for nothing. The he-goat of the woodlands is a very perceptive animal, it loves high mountains, it recognizes walking people placed far off, if they be travelers or hunters."^^xsd:string ;
    beast:hasSequenceIdentifier "Chapter 4: Animals (quadrupeds)"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_goat_cantimpre .

beastiary:citation_cantimpre_5 a beast:Citation ;
    beast:extractedFrom beastiary:source_liber_de_natura_rerum ;
    beast:hasPassageText "A scorpion is a serpent, which is said to have a charming and virgin-like face. But it certainly has a poisonous sting in its knotted tail, with which it stings and infects any that approach it. But it strikes once with a slanted blow and once with a bent tail; and it never ceases to look for opportunities to strike. Those infected with its poison die a protracted death over three days. It is said that some have two stings, and that the males are very savage to each other. But the males are distinguished by their thinness and length. Apollodorus clearly says that there are some that can fly. The people of Psilli, by regurgitating poisons from the limbs of men, filled Italy with foreign evils. Hence they tried to bring these also into Italy, but they could not live in the country. They are, however, sometimes seen in Italy, but most of them are harmless. For a man who has been stung by a scorpion, the remedy is thought to be the drinking of the ashes of them in wine. [...] The scorpion is the only insect that has a tail, and arms, and a spike in the tail. Scorpions lay eggs in spring and likewise in autumn. The scorpion, as Aristotle says, has two stings. The scorpion lives in the earth."^^xsd:string ;
    beast:hasSequenceIdentifier "Chapter 8: Serpents"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_scorpion_cantimpre .

beastiary:citation_chaucer_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_canterbury_tales ;
    beast:hasPassageText "All was this land fulfild of fayerye. The elf-queene, with hir joly compaignye, Daunced ful ofte in many a grene mede."^^xsd:string ;
    beast:hasSequenceIdentifier "Tale: The Wife of Bath's Tale"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_fairy_chaucer .

beastiary:citation_chretien_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_percival ;
    beast:hasPassageText "To all the realms of Logres, which was formerly land of ogres, and destroy them with that lance."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_ogre_chretien .

beastiary:citation_claudio_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_claudio_phoenix ;
    beast:hasPassageText "A mysterious fire flashes from its eye, and a flaming aureole enriches its head. Its crest shines with the sun's own light and shatters the darkness with its calm brilliance. Its legs are of Tyrian purple; swifter than those of the Zephyrs are its wings of flower-like blue dappled with rich gold."^^xsd:string ;
    beast:hasSequenceIdentifier "Book II, verses 17–22"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_phoenix_claudio .

beastiary:citation_ctesias_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_indika ;
    beast:hasPassageText "There are in India certain wild asses which are as large as horses, and larger. Their bodies are white, their heads dark red, and their eyes dark blue. They have a horn on the forehead which is about a foot and a half in length. The dust filed from this horn is administered in a potion as a protection against deadly drugs."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_unicorn_ctesias .

beastiary:citation_dante_inferno_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_dante_inferno ;
    beast:hasPassageText "e ’n su la punta de la rotta lacca / l’infamia di Creti era distesa / che fu concetta ne la falsa vacca; / e quando vide noi, sé stesso morse, / sì come quei cui l’ira dentro fiacca."^^xsd:string ;
    beast:hasSequenceIdentifier "Canto XII, verses 11-14"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_minotaur_dante .

beastiary:citation_dante_inferno_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_dante_inferno ;
    beast:hasPassageText "Così per li gran savi si confessa / che la fenice more e poi rinasce, / quando al cinquecentesimo anno appressa; / erba né biado in sua vita non pasce, / ma sol d’incenso lagrime e d’amomo, / e nardo e mirra son l’ultime fasce."^^xsd:string ;
    beast:hasSequenceIdentifier "Canto XXIV, verses 106-111"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_phoenix_dante .

beastiary:citation_dante_inferno_3 a beast:Citation ;
    beast:extractedFrom beastiary:source_dante_inferno ;
    beast:hasPassageText "Vegna Medusa: sì ’l farem di smalto', / dicevan tutte riguardando in giuso; / 'mal non vengiammo in Tesëo l’assalto'. / 'Volgiti ’n dietro e tien lo viso chiuso; / ché se ’l Gorgón si mostra e tu ’l vedessi, / nulla sarebbe di tornar mai suso'."^^xsd:string ;
    beast:hasSequenceIdentifier "Canto IX, verses 52-57"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_medusa_dante .

beastiary:citation_dante_inferno_4 a beast:Citation ;
    beast:extractedFrom beastiary:source_dante_inferno ;
    beast:hasPassageText "Temp’era dal principio del mattino, / e ’l sol montava ’n su con quelle stelle / ch’eran con lui quando l’amor divino / mosse di prima quelle cose belle; / sì ch’a bene sperar m’era cagione / di quella fiera a la gaetta pelle / l’ora del tempo e la dolce stagione; / ma non sì che paura non mi desse / la vista che m’apparve d’un leone. / Questi parea che contra me venisse / con la test’alta e con rabbiosa fame, / sì che parea che l’aere ne tremesse."^^xsd:string ;
    beast:hasSequenceIdentifier "Canto I, verses 37-48"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_lion_dante .

beastiary:citation_dante_inferno_5 a beast:Citation ;
    beast:extractedFrom beastiary:source_dante_inferno ;
    beast:hasPassageText "Come 'l ramarro sotto la gran fersa / dei dì canicular, cangiando sepe, / folgore par se la via attraversa, / sì pareva, venendo verso l’epe / de li altri due, un serpentello acceso, / livido e nero come gran di pepe; / e quella parte onde prima è preso / nostro alimento, a l’un di lor trafisse; / poi cadde giuso innanzi lui disteso. / Lo trafitto ’l mirò, ma nulla disse; / anzi, co’ piè fermati, sbadigliava / pur come sonno o febbre l’assalisse. / Elli ’l serpente e quei lui riguardava; / l’un per la piaga e l’altro per la bocca / fummavan forte, e ’l fummo si scontrava."^^xsd:string ;
    beast:hasSequenceIdentifier "Canto XXV, verses 79-93"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_snake_dante .

beastiary:citation_dante_inferno_6 a beast:Citation ;
    beast:extractedFrom beastiary:source_dante_inferno ;
    beast:hasPassageText "Poi mi tentò, e disse: «Quelli è Nesso, / che morì per la bella Deianira / e fé di sé la vendetta elli stesso.'"^^xsd:string ;
    beast:hasSequenceIdentifier "Canto XII, verses 67-69"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_centaur_dante2 .

beastiary:citation_dante_inferno_7 a beast:Citation ;
    beast:extractedFrom beastiary:source_dante_inferno ;
    beast:hasPassageText "E quel di mezzo, ch’al petto si mira, / è il gran Chirón, il qual nodrì Achille'"^^xsd:string ;
    beast:hasSequenceIdentifier "Canto XII, verses 70-71"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_centaur_dante .

beastiary:citation_dante_inferno_8 a beast:Citation ;
    beast:extractedFrom beastiary:source_dante_inferno ;
    beast:hasPassageText "Cerbero, fiera crudele e diversa, / con tre gole caninamente latra / sovra la gente che quivi è sommersa. / Li occhi ha vermigli, la barba unta e atra, / e ’l ventre largo, e unghiate le mani; / graffia li spirti, ed iscoia ed isquatra."^^xsd:string ;
    beast:hasSequenceIdentifier "Canto VI, verses 13-18"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_cerberus_dante .

beastiary:citation_dante_paradiso_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_dante_paradiso ;
    beast:hasPassageText "Parea dinanzi a me con l’ali aperte / la bella image che nel dolce frui / liete facevan l’anime conserte; / parea ciascuna rubinetto in cui / raggio di sole ardesse sì acceso, / che ne’ miei occhi rifrangesse lui. / E quel che mi convien ritrar testeso, / non portò voce mai, né scrisse incostro, / né fu per fantasia già mai compreso; / ch’io vidi e anche udi’ parlar lo rostro, / e sonar ne la voce e «io» e «mio», / quand’ era nel concetto e ’noi’ e ’nostro’."^^xsd:string ;
    beast:hasSequenceIdentifier "Canto XIX, verses 1-12"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_eagle_dante .

beastiary:citation_ende_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_unendliche_geschichte ;
    beast:hasPassageText "And beside this pillar, as Atreyu now saw, an enormous sphinx was sitting motionless in the moonlight. The forepaws, on which she was propped, were those of a lion, the hindquarters were those of a bull; on her back she bore the wings of an eagle, and her face was that of a human woman - in form at any rate, for the expression was far from human. I was hard to tell whether this face was smiling or whether it expressed deep grief or utter indifference. After looking at it for some time, Atreyu seemed to see abysmal wickedness and cruelty, but a moment later he had to correct his impression, for he found only unruffled calm. [...] Then the right-hand pillar came into Atreyu's view. And there, in the same posture, sat a second sphinx. The enormous body shimmered like liquid silver in the moonlight. She seemed to be staring fixedly at the first, just as the first was gazing fixedly at her."^^xsd:string ;
    beast:hasSequenceIdentifier "Chapter 6"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_sphinx_ende .

beastiary:citation_ende_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_unendliche_geschichte ;
    beast:hasPassageText "Luckdragons are among the strangest animals in Fantastica. They bear no resemblance to ordinary dragons, which look like loathsome snakes and live in deep caves, diffusing a noxious stench and guarding some real or imaginary treasure. [...] Luckdragons are creatures of air, warmth, and pure joy. Despite their great size, they are as light as a summer cloud, and consequently need no wings for flying. They swim in the air of heaven as fish swim in water. Seen from the earth, they look like slow lightning flashes. The most amazing thing about them is their song. Their voice sounds like the golden note of a large bell, and when they speak softly the bell seems to be ringing in the distance. Anyone who has heard this sound will remember it as long as he lives and tell his grandchildren about it. But the luckdragon Atreyu saw could hardly have been in a mood for singing. His long, graceful body with its pearly, pink-and-white scales hung tangled and twisted in the great spider web. His bristling fangs, his thick, luxuriant mane, and the fringes on his tail and limbs were all caught in the sticky ropes. He could hardly move. The eyeballs in his lionlike head glistened ruby-red. The splendid beast bled from many wounds, for there was something else, something very big, that descended like a dark cloud on the dragon's white body. It rose and fell, rose and fell, all the while changing its shape. Sometimes it resembled a gigantic long-legged spider with many fiery eyes and a fat body encased in shaggy black hair; then it became a great hand with long claws that tried to crush the luckdragon, and in the next moment it changed to a giant scorpion, piercing its unfortunate victim with its venomous sting."^^xsd:string ;
    beast:hasSequenceIdentifier "Chapter 4"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_dragon_ende .

beastiary:citation_erodoto_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_erodoto_histories ;
    beast:hasPassageText "There is also another sacred bird called the phoenix which I did not myself see except in painting, for in truth he comes to them very rarely, at intervals, as the people of Heliopolis say, of five hundred years; and these say that he comes regularly when his father dies; and if he be like the painting, he is of this size and nature, that is to say, some of his feathers are of gold colour and others red, and in outline and size he is as nearly as possible like an eagle. This bird they say (but I cannot believe the story) contrives as follows: - setting forth from Arabia he conveys his father, they say, to the temple of the Sun (Helios) plastered up in myrrh, and buries him in the temple of the Sun; and he conveys him thus: - he forms first an egg of myrrh as large as he is able to carry, and then he makes trial of carrying it, and when he has made trial sufficiently, then he hollows out the egg and places his father within it and plasters over with other myrrh that part of the egg where he hollowed it out to put his father in, and when his father is laid in it, it proves (they say) to be of the same weight as it was; and after he has plastered it up, he conveys the whole to Egypt to the temple of the Sun. Thus they say that this bird does."^^xsd:string ;
    beast:hasSequenceIdentifier "Book II, paragraph 73"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_phoenix_erodoto .

beastiary:citation_esiodo_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_teogonia ;
    beast:hasPassageText "[...] for all the bloody drops that gushed forth Earth received, and as the seasons moved round she bare the strong Erinyes and the great Giants with gleaming armour, holding long spears in their hands and the Nymphs whom they call Meliae all over the boundless earth."^^xsd:string ;
    beast:hasSequenceIdentifier "Lines 179-181"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_giant_teogonia .

beastiary:citation_esiodo_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_teogonia ;
    beast:hasPassageText "A Forci Ceto generò le Graie dalle belle guance, / canute dalla nascita, che chiamano Graie / gli dèi immortali e gli uomini che camminano sulla terra, / Penfredo dal bel peplo e Enio dal peplo di croco, / e le Gorgoni, che abitano al di là dell'illustre Oceano, / al limite verso la Notte, dove sono le Esperidi dalla voce sonora, / Stenno e Euriale e Medusa che soffrì sciagure: / questa era mortale, mentre immortali e eternamente giovani / le altre due; ma accanto a lei sola giacque l'Azzurrochiomato / sul tenero prato e tra i fiori di primavera. / E quando Perseo le tagliò la testa, / saltarono fuori il grande Crisaore e il cavallo Pegaso."^^xsd:string ;
    beast:hasSequenceIdentifier "Lines 270-281"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_medusa_esiodo .

beastiary:citation_esiodo_3 a beast:Citation ;
    beast:extractedFrom beastiary:source_teogonia ;
    beast:hasPassageText "And when Perseus cut off her head, there sprang forth great Chrysaor and the horse Pegasus who is so called because he was born near the springs of Ocean."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_pegaso_esiodo .

beastiary:citation_esiodo_4 a beast:Citation ;
    beast:extractedFrom beastiary:source_frammenti_esiodo ;
    beast:hasPassageText "Onde le dive montanine Ninfe / Nacquero, il seme degl’inetti a ogn’opra / Satiri imbelli, e degli additti ai giuochi, / Di danze intrecciator divi Cureti."^^xsd:string ;
    beast:hasSequenceIdentifier "fr. XLIV, verses 1-4"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_satyr_esiodo .

beastiary:citation_esiodo_5 a beast:Citation ;
    beast:extractedFrom beastiary:source_teogonia ;
    beast:hasPassageText "Essa partorì Chimera spirante un fuoco irresistibile, / tremenda e grande e veloce e forte, / che aveva tre teste: una di leone dagli occhi fieri, / un'altra di capra, un'altra ancora di serpente, di forte drago, / [davanti leone, dietro serpente, in mezzo capra, / spirante impeto terribile di fuoco ardente]. / La uccisero Pegaso e il valoroso Bellerofonte.'"^^xsd:string ;
    beast:hasSequenceIdentifier "Lines 319-325"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_chimera_esiodo .

beastiary:citation_esiodo_6 a beast:Citation ;
    beast:extractedFrom beastiary:source_teogonia ;
    beast:hasPassageText "poi per secondo partoriva l'imbattibile, indicibile, / Cerbero feroce, di Ade il cane dalla voce di bronzo, / con cinquanta teste, spietato e violento"^^xsd:string ;
    beast:hasSequenceIdentifier "\"Lines 310-12\""^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_cerberus_esiodo .

beastiary:citation_flaubert_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_flaubert_tentation ;
    beast:hasPassageText "Di fronte, sull’altra sponda del Nilo, ecco apparire la Sfinge. Allunga le zampe, scuote le bende dalla sua fronte, e si accuccia sul ventre. Saltando, volando, sputando fuoco dalle narici [...]."^^xsd:string ;
    beast:hasSequenceIdentifier "Chapter 7"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_sphinx_flaubert .

beastiary:citation_flaubert_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_flaubert_tentation ;
    beast:hasPassageText "La manticora (gigantesco leone rosso, dal volto umano, con tre filari di denti): / - I marezzi del mio pelame scarlatto si confondono col riverbero delle grandi sabbie. Soffio dalle narici lo spavento delle solitudini. Sputo la peste. Mangio gli eserciti, quando s'avventurano nel deserto. / - Ho le unghie ritorte a succhiello, i denti tagliati a sega; e la mia coda roteante è irta di dardi che lancio a destra, a sinistra, in avanti, in dietro. Guarda! Guarda! / (La manticora lancia le spine della coda, che s'irradiano come frecce in tutte le direzioni. Gocce di sangue piovono schioccando sul fogliame)."^^xsd:string ;
    beast:hasSequenceIdentifier "Chapter 7"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_manticore_flaubert .

beastiary:citation_flaubert_3 a beast:Citation ;
    beast:extractedFrom beastiary:source_flaubert_tentation ;
    beast:hasPassageText "Lion in its foreparts, ant in its hindparts, with the organs of its sex the wrong way."^^xsd:string ;
    beast:hasSequenceIdentifier "Chapter 7"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_antlion_flaubert .

beastiary:citation_gospodinov_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_gospodinov_fisica_della_malinconia ;
    beast:hasPassageText "Il trauma non viene dal fatto che sembri una bestia, ma che in qualche modo sia umano. Proprio la sua umanità è sconvolgente. Il suo corpo è quello di un ragazzo, proprio come il mio. La prima peluria dell'adolescenza sulle gambe, i piedi con le dita lunghe, chissà perché mi aspettavo di vedere degli zoccoli."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_minotaur_gospodinov .

beastiary:citation_ibsen_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_peer_gynt ;
    beast:hasPassageText "The Old Man: What difference is there 'twixt trolls and men? / Peer: No difference at all, as it seems to me. / Big trolls would roast you and small trolls would claw you; - / With us it were likewise, if only they dared."^^xsd:string ;
    beast:hasSequenceIdentifier "Act II"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_troll_ibsen .

beastiary:citation_isidore_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_etymologies ;
    beast:hasPassageText "The unicorn [unicornus], because it has a single four-foot horn in the middle of its forehead, so sharp and strong that it tosses in the air or impales whatever it attacks."^^xsd:string ;
    beast:hasSequenceIdentifier "Book 12"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_unicorn_isidore .

beastiary:citation_isidore_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_etymologies ;
    beast:hasPassageText "The kid is so called from eating, for the young ones are very juicy and pleasing in flavor. Whence also eat and foodstuffs are named. Some people have said he-goats and she-goats are named from their cropping of bushes, others because they ‘hold to uneven places’. Some say it derives from the creaking of their legs, whence also they are often called crepae. They dwell in the high mountains, and even from a great distance they can still see anyone who is approaching."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_goat_isidore .

beastiary:citation_isidore_3 a beast:Citation ;
    beast:extractedFrom beastiary:source_etymologies ;
    beast:hasPassageText "Indeed, many creatures naturally undergo mutation and, when they decay, are transformed into different species – for instance... scorpions from crabs. Thus Ovid: If you take its curved arms from a crab on the shore a scorpion will emerge and threaten with its hooked tail. Scorpions are land vermin; they are counted more appropriately among the vermin than among the snakes. The scorpion is an animal armed with a sting, and was named from this in Greek, because it stings with its tail and infuses venom through the bow-shaped wound. It is characteristic of the scorpion that it does not attack the palm of the hand. If ten crabs are tied with basil, all of the scorpions in that area will gather together."^^xsd:string ;
    beast:hasSequenceIdentifier "Book XI, paragraph 4"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_scorpion_isidore .

beastiary:citation_isidore_4 a beast:Citation ;
    beast:extractedFrom beastiary:source_etymologies ;
    beast:hasPassageText "Fish have their name from feeding. Some fish are amphibious, able to swim and to walk on land. Beasts and birds were named first, because they are easily seen; when fish were named, the names were often related to similar land animals, by shape or color or habit. According to David the Psalmist, the sea contains fish without number."^^xsd:string ;
    beast:hasSequenceIdentifier "Book XII, paragraph 6"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_fish_isidore .

beastiary:citation_isidore_5 a beast:Citation ;
    beast:extractedFrom beastiary:source_etymologies ;
    beast:hasPassageText "The ant-lion is so called either because it is equally lion and ant, or because it is the lion of ants. It is a small animal that is hostile to ants; it hides in the sand and kills other ants that are carrying grain. In this way it is like a lion to ants though it is like an ant to other animals."^^xsd:string ;
    beast:hasSequenceIdentifier "Book XII, paragraph 3"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_antlion_isidore .

beastiary:citation_isidore_6 a beast:Citation ;
    beast:extractedFrom beastiary:source_etymologies ;
    beast:hasPassageText "Basilisk (basiliscus) is a Greek word, translated into Latin as “little king” (regulus), because it is the king of the snakes, so that they flee when they see it because it kills them with its odor – it also kills a human if it looks at one. [...] It is half a foot in length, and marked with white spots."^^xsd:string ;
    beast:hasSequenceIdentifier "Book XII, paragraph 4"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_basilisk_isidore .

beastiary:citation_isidore_7 a beast:Citation ;
    beast:extractedFrom beastiary:source_etymologies ;
    beast:hasPassageText "Their appearance gave their name to the Centaurs, that is, a man combined with a horse. Some say that they were horsemen of Thessaly, but because, as they rushed into battle, the horses and men seemed to have one body, they maintained the fiction of the Centaurs."^^xsd:string ;
    beast:hasSequenceIdentifier "Book XI, paragraph 3"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_centaur_isidore .

beastiary:citation_isidore_8 a beast:Citation ;
    beast:extractedFrom beastiary:source_etymologies ;
    beast:hasPassageText "The Onocentaur is so called because it seems to look half like a human, half like an ass. Likewise the Hippocentaur, which is thought to combine the natures of horse and human in itself."^^xsd:string ;
    beast:hasSequenceIdentifier "Book XI, paragraph 3"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_onocentaur_isidore .

beastiary:citation_job_4_11 a beast:Citation ;
    beast:extractedFrom beastiary:source_septuagint ;
    beast:hasPassageText "The lion perishes for lack of prey."^^xsd:string ;
    beast:hasSequenceIdentifier "Job 4:11"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_antlion_septuagint .

beastiary:citation_lattanzio_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_ave_phoenice ;
    beast:hasPassageText "In this grove, in these woods, dwells the peerless bird, the Phoenix, peerless, since she lives renewed by her own death. An acolyte worthy of record, she yields obedience and homage to Phoebus: such the duty that parent Nature assigned to her for observance. Soon as saffron Aurora reddens at her rising, soon as she routs the stars with rosy light, thrice and again that bird plunges her body into the kindly waves, thrice and again sips water from the living flood. Soaring she settles on the topmost height of a lofty tree which alone commands the whole of the grove, and, turning towards the fresh rising of Phoebus at his birth, awaits the emergence of his radiant beam. [...] She it is also who marks off the swift hours by day and night in sounds which may not be described, priestess of the grove and aweinspiring ministrant of the woods, the only confidant of thy mysteries, Phoebus. When she has already fulfilled a thousand years of life and long lapse of time has made it burdensome to her, she flees from her sweet and wonted nest in the grove, so that in the closing span she may restore her bygone existence, and when in passion for re-birth she has left her sacred haunts, then she seeks this world where Death holds sovereignty. Despite her length of years she directs her swift flight into Syria, to which she herself of old gave the name of Phoenice, and seeks through desert wilds the care-free groves, here where the sequestered woodland lurks among the glades. Then she chooses a palm-tree towering with airy crest which bears its Greek name Phoenix from the bird: against it no hurtful living creature could steal forth, or slippery serpent, or any bird of prey. [...] Meanwhile her body, by birthgiving death destroyed, is aglow, the very heat producing flame and catching fire from the ethereal light afar : it blazes and when burned dissolves into ashes. These ashes she welds together, as if they were concentrated by moisture in a mass, possessing in the result what takes the place of seed. Therefrom, 'tis said, rises a living creature first of all without limbs, but this worm is said to have a milky colour: when suddenly at the appointed hour it has grown enormously, gathering into what looks like a rounded egg, from it she is remoulded in such shape as she had before, bursting her shell and springing to life a Phoenix; 'tis even so that larvae in the country fastened by their threads to stones are wont to change into a butterfly."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_phoenix_lattanzio .

beastiary:citation_machiavelli_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_mandragola ;
    beast:hasPassageText "Voi avete ad intender questo, che non è cosa più certa ad ingravidare una donna che dargli bere una pozione fatta di mandragola. Questa è una cosa esperimentata da me dua paia di volte, e trovata sempre vera; e, se non era questo, la reina di Francia sarebbe sterile, ed infinite altre principesse di quello stato."^^xsd:string ;
    beast:hasSequenceIdentifier "Act II, scene 6"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_mandrake_machiavelli .

beastiary:citation_maier_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_atalanta_fugiens ;
    beast:hasPassageText "For Sphinx is a certain kind of monster most obscure to the Thebans, propounding riddles, nor only to them, but as before to the Egyptians, so after all others to those that aspire to art, and watches in the Philosophers books as before the gates of Thebes; if any man can pass by the monster, he suffers no evil by him, but he that through presumption of mind or wit endeavors to resolve his riddles, and cannot perform, acquires his own destruction, that is, grief to the heart, and damage to his affairs by error in this work."^^xsd:string ;
    beast:hasSequenceIdentifier "Emblem 39"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_sphinx_maier .

beastiary:citation_maier_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_atalanta_fugiens ;
    beast:hasPassageText "The Lion green, white fume, and stinking juice, Are all that to our Process do conduce: Water the mother is of the Elements, And the sole matter of the Sophic Ens. This Lion is the Hermetic Stone and Brass, And the white fume a watery nature has."^^xsd:string ;
    beast:hasSequenceIdentifier "Emblem 37"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_lion_maier .

beastiary:citation_martin_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_got_2 ;
    beast:hasPassageText "Their span was three times their length, each wing a delicate fan of translucent skin, gorgeously colored, stretched taut between long thin bones. When you looked hard, you could see that most of their body was neck, tail, and wing. Such little things, she thought as she fed them by hand, or rather, tried to feed them, for the dragons would not eat. They would hiss and spit at each bloody morsel of horsemeat, steam rising from their nostrils, yet they would not take the food . . . until Dany recalled something Viserys had told her when they were children."^^xsd:string ;
    beast:hasSequenceIdentifier "Chapter 12"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_dragon_martin .

beastiary:citation_moore_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_st_Nicholas ;
    beast:hasPassageText "He was chubby and plump, a right jolly old elf, / And I laughed when I saw him, in spite of myself;"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_elf_moore .

beastiary:citation_nietzsche_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_nietzsche_ndt ;
    beast:hasPassageText "Così nasce quindi la figura fantastica e tanto ripugnante del satiro sapiente ed entusiasta che, nello stesso tempo, in contrapposto al dio, è «il tonto uomo»: immagine della natura e dei suoi più forti istinti, vero simbolo di lei e, insieme, annunziatore della sua scienza ed arte; musico, poeta, danzatore tutto in uno, e contemplatore di spiriti."^^xsd:string ;
    beast:hasSequenceIdentifier "Chapter 8"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_satyr_nietzsche .

beastiary:citation_norske_folkeeventyr_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_norske_folkeeventyr ;
    beast:hasPassageText "On the way up was a bridge over a burn they had to cross; and under the bridge lived a great ugly Troll, with eyes as big as saucers, and a nose as long as a poker."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_troll_norske_folkeeventyr .

beastiary:citation_omero_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_odissea_omero ;
    beast:hasPassageText "Alle Sirene presso tu giungere devi anzitutto, / che tutti quanti gli uomini incantan che giungono ad esse. / Chi s’avvicina a loro, mal cauto, ed ascolta la voce / delle Sirene, quello non mai la sua sposa ed i figli / piú lo vedranno tornare, diletto mai piú non ne avranno; / ma le Sirene, incanto gli fan con le limpide voci, / sedute sopra un prato. D’intorno c’è d’ossa un gran mucchio, / d’uomini putrescenti, di scheletri e pelli aggrinzite."^^xsd:string ;
    beast:hasSequenceIdentifier "Book XII, verses 39-46"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_siren_omero .

beastiary:citation_omero_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_iliade_omero ;
    beast:hasPassageText "Era il mostro di origine divina, / leone la testa, il petto capra, e drago / la coda; e dalla bocca orrende vampe / vomitava di foco: e nondimeno, /col favor degli Dei, l'eroe la spense.'"^^xsd:string ;
    beast:hasSequenceIdentifier "Book VI, verses 180-184"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_chimera_omero .

beastiary:citation_ovid_met_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_ovidius_metamorphoses ;
    beast:hasPassageText "L’essere che era il disonore della stirpe era già divenuto adulto e il turpe / adulterio della madre diveniva evidente a causa della singolarità del mostro biforme"^^xsd:string ;
    beast:hasSequenceIdentifier "Book VIII, verses 155-156"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_minotaur_ovidius .

beastiary:citation_ovid_met_11 a beast:Citation ;
    beast:extractedFrom beastiary:source_ovidius_metamorphoses ;
    beast:hasPassageText "Così dice. E già i buoi scacciati dal monte si dirigono, come ha ordinato, verso la spiaggia, dove la figlia del grande re è solita giocare col suo seguito di fanciulle di Tiro. Maestà ed amore non vanno molto d'accordo, non possono convivere. Perciò, lasciato lo scettro solenne, il padre e signore degli dèi, colui che ha la destra armata di fulmini a tre punte, che con un cenno fa tremare il mondo, assume l'aspetto di un toro e mescolatosi alle giovenche mugge e gironzola, bello, sul terreno prato. Il colore è proprio quello della neve non calcata dalla pianta di duro piede, non sciolta dall'Austro piovoso. Il collo è rigonfio di muscoli, dalle scapole pende la giogaia. Le corna, è vero, sono piccolette, ma così ben fatte che potresti sostenere che son fabbricate a mano, e sono più diafane di una gemma pura. Niente di minaccioso nella fronte, e lo sguardo non mette paura. Un muso tutto pace."^^xsd:string ;
    beast:hasSequenceIdentifier "Book II, verses 843-568"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_bull_ovid .

beastiary:citation_ovid_met_12 a beast:Citation ;
    beast:extractedFrom beastiary:source_ovidius_metamorphoses ;
    beast:hasPassageText "E infatti tu, èurito, il più feroce di quei feroci Centauri, / già infiammato dal vino, più t'infiammi vedendo la vergine, / e l'ebbrezza aggiunta alla libidine ha il sopravvento. / Rovesciate le tavole, in un attimo il banchetto va in rovina, / e la giovane, afferrata per i capelli, è trascinata via. / èurito rapisce Ippòdame; gli altri ognuno la donna che più / gli piace o quella che può: una scena da città conquistata.."^^xsd:string ;
    beast:hasSequenceIdentifier "Book XII, verses 219-225"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_centaur_ovid .

beastiary:citation_ovid_met_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_ovidius_metamorphoses ;
    beast:hasPassageText "il mostro mezzo uomo e mezzo toro"^^xsd:string ;
    beast:hasSequenceIdentifier "Book VIII, verse 169"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_minotaur_ovidius .

beastiary:citation_ovid_met_3 a beast:Citation ;
    beast:extractedFrom beastiary:source_ovidius_metamorphoses ;
    beast:hasPassageText "Forse perché Proserpina coglieva i fiori / primaverili, eravate nel numero delle sue compagne, / dotte Sirene? Dopo che inutilmente l'avete cercata / per tutto il mondo, / avete desiderato, perché il mare sentisse la vostra pena / di potervi fermare sulle onde col remeggio delle ali, / e avendo il consenso degli dèi, avete visto / improvvisamente i vostri arti fiorire di penne; / ma perché il vostro canto, nato a blandire le orecchie, / e il tesoro della vostra bocca non perdesse l'uso / della lingua, vi restò volto di vergini e voce umana."^^xsd:string ;
    beast:hasSequenceIdentifier "Book V, verses 560-567"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_siren_ovidius .

beastiary:citation_ovid_met_4 a beast:Citation ;
    beast:extractedFrom beastiary:source_ovidius_metamorphoses ;
    beast:hasPassageText "Rendering the heights of heaven no safer than the earth, they say the giants attempted to take the Celestial kingdom, piling mountains up to the distant stars. Then the all-powerful father of the gods hurled his bolt of lightning, fractured Olympus and threw Mount Pelion down from Ossa below. Her sons’ dreadful bodies, buried by that mass, drenched Earth with streams of blood, and they say she warmed it to new life, so that a trace of her children might remain, transforming it into the shape of human beings. But these progeny also despising the gods were savage, violent, and eager for slaughter, so that you might know they were born from blood."^^xsd:string ;
    beast:hasSequenceIdentifier "Book I, verses 151-160"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_giant_ovidius .

beastiary:citation_ovid_met_5 a beast:Citation ;
    beast:extractedFrom beastiary:source_ovidius_metamorphoses ;
    beast:hasPassageText "Now the entwined bodies of the two were joined together, and one form covered both. Just as when someone grafts a twig into the bark, they see both grow joined together, and develop as one, so when they were mated together in a close embrace, they were not two, but a two-fold form, so that they could not be called male or female, and seemed neither or either."^^xsd:string ;
    beast:hasSequenceIdentifier "Book IV, verses 373-379"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_hermaphrodite_ovidius .

beastiary:citation_ovid_met_6 a beast:Citation ;
    beast:extractedFrom beastiary:source_ovidius_metamorphoses ;
    beast:hasPassageText "Unico a riseminarsi e rigenerarsi da sé è un uccello che gli Assiri chiamano 'fenice'. Non di chicchi di grano né di erbe vive la fenice, ma di lacrime d'incenso e di succo d'amomo, e quando ha compiuto cinque secoli di vita, se ne va in cima a una tremula palma e con gli artigli e col suo becco incontaminato si costruisce un nido tra il fogliame. Appena ha steso sul fondo uno strato di cassia e di spighe di nardo delicato, di cannella sminuzzata e di mirra bionda, vi si adagia sopra e chiude la sua esistenza in mezzo ai profumi. Allora, si dice, dal corpo paterno rinasce una piccola fenice, la quale dovrà vivere altrettanti anni."^^xsd:string ;
    beast:hasSequenceIdentifier "Book XV, verses 392-402"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_phoenix_ovidius .

beastiary:citation_ovid_met_7 a beast:Citation ;
    beast:extractedFrom beastiary:source_ovidius_metamorphoses ;
    beast:hasPassageText "Ed ora tu, fortissimo Perseo, / racconta, ti prego, con qual valore e quali stratagemmi / mozzasti quella testa irta di serpenti'. / L'erede di Agenore narra come ai piedi del gelido Atlante / si distenda un luogo protetto da un bastione invalicabile, / e come al suo ingresso abitassero due gemelle, / figlie di Forco, che si dividevano l'uso di un occhio solo; / come lui con destrezza glielo carpì, inserendo la propria mano / mentre se lo scambiavano; come attraverso sentieri sperduti / e impervi, attraverso orridi nell'intrico di foreste, / giunse alla casa di Gòrgone, e qua e là in mezzo ai campi, / nei sentieri gli avvenne di vedere figure di uomini e belve / mutati da esseri vivi in granito per aver visto Medusa. / Ma lui aveva scorto, riflessa nel bronzo dello scudo / che reggeva col braccio sinistro, l'orrenda immagine, / e mentre un sonno pesante gravava sui serpenti e su lei stessa, / le spiccò il capo dal collo: quasi fosse linfa materna / dal sangue nacquero Pegaso, l'alato destriero, e suo fratello. / Ed enumera i veri pericoli corsi nel suo lungo viaggio; / quali mari e quali terre abbia intravisto dall'alto, / quali stelle abbia raggiunto col suo battito d'ali. / Ma prima del previsto s'interrompe. Uno dei presenti interviene / allora chiedendo perché solo Medusa / fra le sorelle avesse serpenti in mezzo ai capelli. / E l'ospite risponde: 'Visto che vuoi sapere cosa che merita / raccontare, eccoti il perché. Di eccezionale bellezza, / Medusa fu desiderata e contesa da molti pretendenti, / e in tutta la sua persona nulla era più splendido dei capelli: / ho conosciuto chi sosteneva d'averla vista. / Si dice che il signore del mare la violasse in un tempio / di Minerva: inorridita la casta figlia di Giove con l'egida / si coprì il volto, ma perché il fatto non restasse impunito / mutò i capelli della Gòrgone in ripugnanti serpenti. / Ancor oggi la dea, per sbigottire e atterrire i nemici, / porta davanti, sul petto, quei rettili che lei stessa ha creato."^^xsd:string ;
    beast:hasSequenceIdentifier "Book IV, verses 769-803"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_medusa_ovid .

beastiary:citation_ovid_met_8 a beast:Citation ;
    beast:extractedFrom beastiary:source_ovidius_metamorphoses ;
    beast:hasPassageText "Ci fu una volta che il re degli dèi s'infiammò d'amore per il frigio Ganimède, ed ebbe l'idea di trasformarsi in una cosa che, una volta tanto, gli parve più bella che essere Giove: un uccello. Ma, fra tutti gli uccelli, non si degnò di trasformarsi che in quello capace di portare i fulmini, le armi sue. Detto fatto: battendo l'aria con false penne, rapì il giovinetto della stirpe di Ilo, che tuttora gli riempie i calici e gli serve il nèttare, con rabbia di Giunone."^^xsd:string ;
    beast:hasSequenceIdentifier "Book X, verses 155-161"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_eagle_ovid .

beastiary:citation_ovid_met_9 a beast:Citation ;
    beast:extractedFrom beastiary:source_ovidius_metamorphoses ;
    beast:hasPassageText "Cadmo figlio di Agenore non sa che la figlia e il nipotino sono diventati divinità marine. Vinto dal dolore, da quella serie di sciagure e dai tanti prodigi che ha visto, il fondatore di Tebe parte dalla sua città, come se la maledizione gravasse sul luogo invece che su di lui. Dopo aver errato a lungo, in fuga con la moglie giunge nella regione degli Illiri. E mentre, oppressi ormai dalle sventure e dagli anni, conversano rievocando gli eventi del casato e rivangano i loro guai, Cadmo osserva: 'Forse era un serpente sacro quello che, al tempo in cui lasciammo Sidone, io trafissi con la lancia, spargendone al suolo, come assurda semente, i denti velenosi. Se è volontà degli dei vendicarlo con ira così spietata, possa io strisciare lungo il ventre come un serpente'. Disse, e come un serpente si distese lungo il ventre, sentendo che sulla pelle indurita gli spuntano squame, che il corpo si fa nero e si chiazza di macchie azzurre. Caduto prono sul petto, le gambe si fondono insieme e a poco a poco si assottigliano in una punta affilata. Non gli restano che le braccia, e le braccia, finché gli restano, tende, con le lacrime che gli scorrono sul viso ancora umano: 'Accòstati, moglie mia,' dice, 'accòstati, moglie mia infelice, e finché qualcosa di me sopravvive, toccami, prendimi la mano, finché è tale, finché il serpente tutto non mi pervade!'. Vorrebbe, sì, dire di più, ma la lingua si scinde a un tratto in due, le parole che ha in animo di dire si spengono e ogni volta che cerca di emettere un lamento, sibila: questa è l'unica voce che natura gli lascia. Colpendosi con le mani il petto ignudo, la moglie grida: 'Cadmo, no, no! spògliati, sventurato, di questa forma mostruosa! Cadmo, che accade? dove sono i piedi? e le spalle, le mani, il tuo colore e, mentre parlo, il viso e ciò che resta? Perché mai, dei del cielo, non mutate anche me in un serpente uguale?'. Così protesta, e lui lambisce il volto della moglie, s'insinua in quel suo seno adorato, come se lo riconoscesse, e avvolgendola in un abbraccio, cerca il collo che gli è familiare. Tutti i presenti, i loro compagni, guardano atterriti; ma lei accarezza il collo viscido di quel serpente crestato e di colpo sono in due a strisciare intrecciando le spire, finché non si nascondono nel folto di un bosco vicino. Ancor oggi non fuggono l'uomo o l'aggrediscono per ferirlo: serpenti innocui, che non possono scordare chi furono un tempo."^^xsd:string ;
    beast:hasSequenceIdentifier "Book IV, verses 563-603"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_snake_ovid .

beastiary:citation_paré_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstres_prodiges ;
    beast:hasPassageText "Una prova ulteriore: al tempo in cui papa Giulio II causò tante calamità in Italia, quando cioè mosse guerra a Luigi XII (1512) - guerra nel corso della quale presso Ravenna fu combattuta una cruenta battaglia - ebbene, poco tempo dopo nacque nella medesima città un essere mostruoso con un corno in testa, due ali e con un unico piede simile a quello di un uccello da preda, con un occhio che si apriva in corrispondenza dell'articolazione del ginocchio, e inoltre era partecipe sia della natura maschile che di quella femminile [...]."^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 3: Esempi dell'ira di Dio"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_mostro_paré_1 .

beastiary:citation_paré_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstres_prodiges ;
    beast:hasPassageText "Damasceno - un autore serio - afferma di aver visto una ragazza pelosa come un orso, uscita dal ventre della madre così deforme e orripilante perché questa al momento di concepirla aveva guardato troppo intensamente l'immagine di un san Giovanni vestito di pelli e pieno di peli che era collocata ai piedi del letto."^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 9: Esempi di mostri craeti dall'immaginazione"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_anomaly_paré_1 .

beastiary:citation_paré_3 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstres_prodiges ;
    beast:hasPassageText "[...] dice che in Africa si trova un animale che i selvaggi chiamano haiit, molto deforme; chi lo vede stenta a credere che esista una bestia tale. Può raggiungere la grandezza di un grosso guenon. La sua pancia pende quasi fino a terra anche quando sta ritto. Il suo viso e la testa sono pressoché uguali a quelli di un bambino. Questo haiit, se viene catturato, getta dei profondi sospiri paragonabili a quelli che un uomo afflitto da un grande ed eccessivo dolore emetterebbe. È di color grigio e ha solo tre artigli per zampa lunghi quattro dita e fatti a forma delle ossa di una carpa; con questi artigli, che sono taglienti tanto quanto - o anche più taglienti - di quelli di un leone o di altre bestie crudeli, egli monta sugli alberi, dove preferisce vivere piuttosto che in terra. La sua coda è lunga solo tre dita. È inoltre strano che nessun uomo abbia mai potuto dire di averlo visto mangiare cosa alcuna, sebbene i selvaggi ne abbiano tenuto a lungo alcuni nelle proprie capanne per vedere se avrebbero mangiato qualcosa; i selvaggi dicevano che vivevano di vento."^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 36: Dei mostri terrestri"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_mostro_paré_2 .

beastiary:citation_paré_4 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstres_prodiges ;
    beast:hasPassageText "Nel 1493 venne concepito e generato un bambino da una donna e da un cane. Le parti sopra l'ombelico erano nella forma e nell'aspetto simili alla madre ed era in tutto e per tutto completo senza che la Natura avesse omesso nulla; dall'ombelico in giù tutte le parti inferiori assomigliavano, nella forma e nell'aspetto, all'animale che era il padre. Questo essere fu inviato al Papa che regnava in quel periodo."^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 19: Esempi della commistione e della mescolanza del seme"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_mostro_paré_3 .

beastiary:citation_paré_5 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstres_prodiges ;
    beast:hasPassageText "Nell'anno in corso 1577 nacque, nel villaggio chiamato Blandy, a una lega e mezzo da Melun, un agnello con tre teste in una; quella di mezzo era più grossa delle altre e quando una di queste teste belava, le altre facevano la stessa cosa. Maestro Jean Bellanger, un chirurgo abitante della città di Melun, afferma d'averlo visto e di averne fatto ritrarre l'aspetto; il ritratto fu messo all'asta e fu venduto qui a Parigi col privilegio assieme a quelli di altri due mostri: uno di due figlie gemelle e un altro con la faccia di rana raffigurato in un'immagine precedente."^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 19: Esempi della commistione e della mescolanza del seme"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_anomaly_paré_2 .

beastiary:citation_paré_6 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstres_prodiges ;
    beast:hasPassageText "Gesner menziona questo mostro marino, di cui aveva ottenuto il ritratto da un pittore che lo aveva visto nel suo ambiente naturale in Antwerp: aveva una testa molto selvaggia con due corna, le orecchie lunghe e il resto del corpo da pesce, con l'eccezione delle braccia che erano quasi normali. Fu catturato nel mare Illirico quando si gettò sulla spiaggia nel tentativo di prendere un piccolo bambino che era lì vicino; inseguito da alcuni marinai che l'avevano visto, fu ferito a colpi di sassi e poco dopo venne sulla banchina a morire."^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 34: Ora parliamo di mostri marini"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_mostro_paré_4 .

beastiary:citation_paré_7 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstres_prodiges ;
    beast:hasPassageText "Questo mostro marino, con la testa, la criniera e il davanti equino fu visto nel mare Oceano; il suo ritratto fu portato a Roma al papa allora regnante."^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 34: Ora parliamo di mostri marini"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_mostro_paré_5 .

beastiary:citation_paré_8 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstres_prodiges ;
    beast:hasPassageText "Il primo novembre 1562 nacqua a Villefranche de Beyan in Guascogna questo mostro senza testa. L'immagine frontale e dorsale qui riprodotta mi è stata fornita dal Signor Hautin, medico reggente nella Facoltà di Medicina di Parigi, che mi ha assicurato di averlo visto."^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 8: Esempi di carenza di seme"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_anomaly_paré_3 .

beastiary:citation_paré_9 a beast:Citation ;
    beast:extractedFrom beastiary:source_monstres_prodiges ;
    beast:hasPassageText "A proposito della genesi dei mostri, Ippocrate afferma che una eccessiva quantità di materia può generare un numero eccessivo di nati, oppure un infante mostruoso con parti superflue e inutili, tipo due teste, quattro braccia, quattro gambe, sei dita nelle mani o nei piedi, eccetera. [...] Sarà opportuno ricordare a questo punto che a proposito di questa donna-mostro Licostene aggiunge una notizia strabiliante: raddoppiandone la testa, la natura non aveva tralasciato nulla, tant'è che le due teste, egli dice, avevano lo stesso desiderio di bere, di mangiare, e di dormire e uguali erano il loro modo di parlare e il loro modo di sentire. Questa ragazza andava a chiedere l'elemosina di casa in casa e la gente le offriva volentieri qualcosa per l'eccezionalità del fenomeno, così straordinario e nuovo. Ciononostante, trascorso un po' di tempo, ella fu bandita dal ducato di Baviera perché si era diffusa la voce che la sua presenza poteva deformare il frutto delle donne gravide, in quanto l'aspetto di questa creatura così mostruosa poteva imprimere e fissare la propria forma nella loro immaginativa."^^xsd:string ;
    beast:hasSequenceIdentifier "Capitolo 4: Esempi di eccesso di seme"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_anomaly_paré_4 .

beastiary:citation_perrault_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_cinderella_perrault ;
    beast:hasPassageText "Well, be but a good girl, and I will contrive, that thou shalt go. Run into the garden, and bring me a pumpkin."^^xsd:string ;
    beast:hasSequenceIdentifier "Tale VI, Cinderella"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_fairy_perrault .

beastiary:citation_peter_pan_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_peter_pan ;
    beast:hasPassageText "Tink was not all bad: or, rather, she was all bad just now, sometimes she was all good. Fairies have to be one thing or the other, because being so small they unfortunately have room for one feeling only at a time."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_fairy_disney .

beastiary:citation_pharsalia_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_pharsalia ;
    beast:hasPassageText "Quel suol però sí sterile, e que' campi / Di niun bene fecondi, un tosco atroce / Concepiscono in lor dalle corrotte Gocciole di Medusa [...] Ivi dispiega [...] e'l Basilisco horrendo / (Che Sibili tramanda, onde rimane / Ogni serpe atterrito, e pria che sparga / Il veleno, dà morte) il serpentino / Volgo da sé rimove, e in vuote arene / Solo il regno ritien."^^xsd:string ;
    beast:hasSequenceIdentifier "Book IX"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_basilisk_lucano .

beastiary:citation_physiologus_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_physiologus ;
    beast:hasPassageText "It had the face (or fore-part) of a lion and the hinder parts of an ant. Its father eats flesh, but its mother grains. If they engender the ant-lion, they engender a thing of two natures, such that it cannot eat flesh because of the nature of its mother, nor grains because of the nature of its father. It perishes, therefore, because it has no nutriment."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_antlion_physiologus .

beastiary:citation_plato_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_symposium ;
    beast:hasPassageText "The sexes were not two as they are now, but originally three in number; there was man, woman, and the union of the two, having a name corresponding to this double nature, which had once a real existence, but is now lost, and the word 'Androgynous' is only preserved as a term of reproach. In the second place, the primeval man was round, his back and sides forming a circle; and he had four hands and four feet, one head with two faces, looking opposite ways, set on a round neck and precisely alike; also four ears, two privy members, and the remainder to correspond. He could walk upright as men now do, backwards or forwards as he pleased, and he could also roll over and over at a great pace, turning on his four hands and four feet, eight in all, like tumblers going over and over with their legs in the air; this was when he wanted to run fast. Now the sexes were three, and such as I have described them; because the sun, moon, and earth are three; and the man was originally the child of the sun, the woman of the earth, and the man-woman of the moon, which is made up of sun and earth, and they were all round and moved round and round like their parents."^^xsd:string ;
    beast:hasSequenceIdentifier "189d"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_hermaphrodite_plato .

beastiary:citation_plinio_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_naturalis_historia ;
    beast:hasPassageText "Prima che delle piramidi, bisogna parlare della Sfinge, monumento che meriterebbe addirittura una trattazione più ampia. Ma su di essa c'è silenzio: gli abitanti la considerano una divinità. Ritengono che vi sia sepolto il re Harmais e vogliono credere che sembri costruita con materiale portato colà. È invece scolpita nella pietra viva, ed il volto rosso del mostro è oggetto di culto; la circonferenza di esso all'altezza della fornte raggiunge i 102 piedi; la lunghezza dell'intera statua è di 143 piedi e l'altezza del ventre fino al vertice dell'aspide che sta sul capo è 61 piedi e mezzo."^^xsd:string ;
    beast:hasSequenceIdentifier "Book XXXVI, paragraph 17"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_sphinx_plinio .

beastiary:citation_plinio_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_naturalis_historia ;
    beast:hasPassageText "Among the mountainous districts of the eastern parts of India, in what is called the country of the Catharcludi, we find the Satyr, an animal of extraordinary swiftness. These go sometimes on four feet, and sometimes walk erect; they have also the features of a human being. On account of their swiftness, these creatures are never to be caught, except when they are either aged or sickly."^^xsd:string ;
    beast:hasSequenceIdentifier "Book VII, paragraph 24"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_satyr_pliny .

beastiary:citation_plinio_3 a beast:Citation ;
    beast:extractedFrom beastiary:source_naturalis_historia ;
    beast:hasPassageText "The story is that it is as large as an eagle, and has a gleam of gold round its neck and all the rest of it is purple, but the tail blue picked out with rosecoloured feathers and the throat picked out with tufts, and a feathered crest adorning its head."^^xsd:string ;
    beast:hasSequenceIdentifier "Book X, paragraph 2"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_phoenix_plinio .

beastiary:citation_plinio_4 a beast:Citation ;
    beast:extractedFrom beastiary:source_naturalis_historia ;
    beast:hasPassageText "In Africa nascono elefanti al di là dei deserti delle Sirti ed in Mauritania, ed anche nei territori degli Etiopi e dei Trogloditi, come si è già detto; ma l'India produce gli esemplari più grandi, ed enormi draghi-serpenti che combattono con essi in perpetua discordia, di tali dimensioni anche questi che facilmente riescono ad avvolgere un elefante nelle loro spire e a stringerlo nella stretta del loro nodo. Questo combattimento provoca la morte di entrambi i contendenti, perché l'elefante sconfitto, cadendo, col suo peso schiaccia il drago-serpente che lo tiene avvinto."^^xsd:string ;
    beast:hasSequenceIdentifier "Book VIII, paragraph 11"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_dragon_plinio .

beastiary:citation_plinio_5 a beast:Citation ;
    beast:extractedFrom beastiary:source_naturalis_historia ;
    beast:hasPassageText "C'è in Etiopia un animale chiamato manticora, il quale ha tre ordini di denti connessi come quelli d'un pettine, faccia e orecchie d'uomo, occhi azzurri, corpo cremisi di leone, e coda terminante in aculeo come di scorpione. Corre con somma rapidità ed è amantissimo della carne umana; la sua voce è come un concerto di flauto e tromba."^^xsd:string ;
    beast:hasSequenceIdentifier "Book VIII, paragraph 30"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_manticore_plinio .

beastiary:citation_plinio_6 a beast:Citation ;
    beast:extractedFrom beastiary:source_naturalis_historia ;
    beast:hasPassageText "Goats use ivy and a diet consisting mostly of crabs thrown up from the sea [to cure themselves of sickness]. Mucianus has described a case of this animal's cleverness seen by himself - two goats coming in opposite directions met on a very narrow bridge, and as the narrow space did not permit them to turn round and the length did not allow of backing blindly on the scanty passageway with a rushing torrent flowing threateningly below, one of them lay down and so the other one passed over, treading on top of it... according to Archelaus they breathe through the ears, not the nostrils, and are never free from fever: this is perhaps the reason why they are more high-spirited than sheep and hotter in coupling. It is said that goats can see by night as well as they can in the daytime, and that consequently a diet of goat's liver restores sight to persons suffering from what is called night-blindness.They say that she-goats in the pastures when the sun is setting do not look at one another but He down with their backs to each other, though at other times of the day they lie facing each other and take notice of one another. Their bite kills a tree; they make an olive tree barren even by licking it, and for this reason they are not offered in sacrifice to Minerva. Herds of goats also have their special reputation for cheese, in the case of fresh cheese especially when smoke increases its flavor, as with the supremely desirable cheese made in the city itself; for the cheese of the Gallic goats always has a strong medicinal taste. The horn or hair of she-goats, when burnt, is said to keep serpents away, and the ash from the horn, whether taken in drink or applied, to be efficacious for their bites; as are also draughts of their milk with taminian grapes, or of their urine with squill vinegar; so too an application of goat cheese with marjoram, or of goat suet with wax. Thousands of remedies besides from the goat are given in prescriptions, as will be pointed out; this is surprising to me, because it is said never to be free from fever.."^^xsd:string ;
    beast:hasSequenceIdentifier "Book VIII, paragraph 41"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_goat_plinio .

beastiary:citation_plinio_7 a beast:Citation ;
    beast:extractedFrom beastiary:source_naturalis_historia ;
    beast:hasPassageText "Land scorpions also like spiders produce grubs resembling eggs and die in the same way as spiders; they are a horrible plague, poisonous like snakes, except that they inflict a worse torture by dispatching the victim with a lingering death lasting three days, their wound being always fatal to girls and almost absolutely so to women, but to men only in the morning, when they are coming out of their holes, before they emit their yet unsated poison by some accidental stroke. Their tail is always engaged in striking and does not stop practicing at any moment, lest it should ever miss an opportunity it strikes both a sideways stroke and one with the tail bent up."^^xsd:string ;
    beast:hasSequenceIdentifier "Book XI, paragraph 30"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_scorpion_plinio .

beastiary:citation_plinio_8 a beast:Citation ;
    beast:extractedFrom beastiary:source_naturalis_historia ;
    beast:hasPassageText "The basilisk serpent also has the same power. It is a native of the province of Cyrenaica, not more than 12 inches long, and adorned with a bright white marking on the head like a sort of diadem. It routs all snakes with its hiss, and does not move its body forward in manifold coils like the other snakes but advancing with its middle raised high. It kills bushes not only by its touch but also by its breath, scorches up grass and bursts rocks. Its effect on other animals is disastrous."^^xsd:string ;
    beast:hasSequenceIdentifier "Book VIII, paragraph 33"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_basilisk_plinio .

beastiary:citation_poem_hermaphroditus a beast:Citation ;
    beast:extractedFrom beastiary:source_poem_hermaphroditus ;
    beast:hasPassageText "Where between sleep and life some brief space is, / With love like gold bound round about the head, / Sex to sweet sex with lips and limbs is wed, / Turning the fruitful feud of hers and his / To the waste wedlock of a sterile kiss."^^xsd:string ;
    beast:hasSequenceIdentifier "Verse 17-21"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_hermaphrodite_swinburne .

beastiary:citation_rochester_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_rochester_bestiary ;
    beast:hasPassageText "The manticore is a beast born in India. It has three rows of teeth that intertwine like the teeth of a comb. It has the face of a human, greyish-blue eyes and a blood-red colour. It has a leonine body, and its tail resembles a scorpion's sting. It has a sharp, hissing voice similar to the sound of flutes and bagpipes. It eagerly longs for human flesh. It is so swift and jumps so high that neither the vastest areas nor the most insuperable obstacles can force it to die."^^xsd:string ;
    beast:hasSequenceIdentifier "Folio 27r"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_manticore_rochester .

beastiary:citation_rowling_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_harry_potter_book_4 ;
    beast:hasPassageText "It was a sphinx. It had the body of an over-large lion: great clawed paws and a long yellowish tail ending in a brown tuft. Its head, however, was that of a woman. She turned her long, almond-shaped eyes upon Harry as he approached. He raised his wand, hesitating. She was not crouching as if to spring, but pacing from side to side of the path, blocking his progress. Then she spoke, in a deep, hoarse voice."^^xsd:string ;
    beast:hasSequenceIdentifier "Chapter 31"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_sphinx_rowling_harry .

beastiary:citation_rowling_10 a beast:Citation ;
    beast:extractedFrom beastiary:source_harry_potter_book_1 ;
    beast:hasPassageText "A centaur was standing over him, not Ronan or Bane; this one looked younger; he had white-blond hair and a palomino body. [...] The centaur didn’t answer. He had astonishingly blue eyes, like pale sapphires. He looked carefully at Harry, his eyes lingering on the scar which stood out, livid, on Harry’s forehead. ‘You are the Potter boy,’ he said. ‘You had better get back to Hagrid. The Forest is not safe at this time – especially for you. Can you ride? It will be quicker this way.'"^^xsd:string ;
    beast:hasSequenceIdentifier "Chapter 15"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_centaur_rowling_harry .

beastiary:citation_rowling_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_harry_potter_book_3 ;
    beast:hasPassageText "Trotting toward them were a dozen of the most bizarre creatures Harry had ever seen. They had the bodies, hind legs, and tails of horses, but the front legs, wings, and heads of what seemed to be giant eagles, with cruel, steel-colored beaks and large, brilliantly, orange eyes. The talons on their front legs were half a foot long and deadly looking. Each of the beasts had a thick leather collar around its neck, which was attached to a long chain, and the ends of all of these were held in the vast hands of Hagrid, who came jogging into the paddock behind the creatures."^^xsd:string ;
    beast:hasSequenceIdentifier "Chapter 6"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_hippogriff_rowling_harry .

beastiary:citation_rowling_3 a beast:Citation ;
    beast:extractedFrom beastiary:source_fantastic_beasts ;
    beast:hasPassageText "The phoenix is a magnificent, swan-sized, scarlet bird with a long golden tail, beak, and talons. It nests on mountain peaks and is found in Egypt, India, and China. The phoenix lives to an immense age as it can regenerate, bursting into flames when its body begins to fail and rising again from the ashes as a chick. The phoenix is a gentle creature that has never been known to kill and eats only herbs. Like the Diricaw, it can disappear and reappear at will. Phoenix song is magical; it is reputed to increase the courage of the pure of heart and to strike fear into the hearts of the impure. Phoenix tears have powerful healing properties."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_phoenix_rowling .

beastiary:citation_rowling_4 a beast:Citation ;
    beast:extractedFrom beastiary:source_fantastic_beasts ;
    beast:hasPassageText "The Egyptian sphinx has a human head on a lion’s body. For over a thousand years it has been used by witches and wizards to guard valuables and secret hideaways. Highly intelligent, the sphinx delights in puzzles and riddles. It is usually dangerous only when what it is guarding is threatened."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_sphinx_rowling_fantastic .

beastiary:citation_rowling_5 a beast:Citation ;
    beast:extractedFrom beastiary:source_fantastic_beasts ;
    beast:hasPassageText "The Hippogriff is native to Europe, though now found worldwide. It has the head of a giant eagle and the body of a horse. It can be tamed, though this should be attempted only by experts. Eye contact should be maintained when approaching a Hippogriff. Bowing shows good intentions. If the Hippogriff returns the greeting, it is safe to draw closer. The Hippogriff burrows for insects but will also eat birds and small mammals. Breeding Hippogriffs build nests upon the ground into which they will lay a single large and fragile egg, which hatches within twenty-four hours. The fledgling Hippogriff should be ready to fly within a week, though it will be a matter of months before it is able to accompany its parent on longer journeys."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_hippogriff_rowling_fantastic .

beastiary:citation_rowling_6 a beast:Citation ;
    beast:extractedFrom beastiary:source_fantastic_beasts ;
    beast:hasPassageText "Probably the most famous of all magical beasts, dragons are among the most difficult to hide. The female is generally larger and more aggressive than the male, though neither should be approached by any but highly skilled and trained wizards. Dragon hide, blood, heart, liver, and horn all have highly magical properties, but dragon eggs are defined as Class A Non-Tradeable Goods. There are ten breeds of dragon, though these have been known to interbreed on occasion, producing rare hybrids."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_dragon_rowling_fantastic .

beastiary:citation_rowling_7 a beast:Citation ;
    beast:extractedFrom beastiary:source_harry_potter_book_4 ;
    beast:hasPassageText "Four fully grown, enormous, vicious-looking dragons were rearing onto their hind legs inside an enclosure fenced with thick planks of wood, roaring and snorting - torrents of fire were shooting into the dark sky from their open, fanged mouths, fifty feet above the ground on their outstretched necks. There was a silvery-blue one with long, pointed horns, snapping and snarling at the wizards on the ground; a smooth-scaled green one, which was writhing and stamping with all its might; a red one with an odd fringe of fine gold spikes around its face, which was shooting mushroom-shaped fire clouds into the air; and a gigantic black one, more lizardhike than the others, which was nearest to them."^^xsd:string ;
    beast:hasSequenceIdentifier "Chapter 19"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_dragon_rowling_harry .

beastiary:citation_rowling_8 a beast:Citation ;
    beast:extractedFrom beastiary:source_fantastic_beasts ;
    beast:hasPassageText "[…] a chicken egg hatched beneath a toad would produce a gigantic serpent possessed of extraordinarily dangerous powers. The Basilisk is a brilliant green serpent that may reach up to fifty feet in length. The male has a scarlet plume upon its head. It has exceptionally venomous fangs but its most dangerous means of attack is the gaze of its large yellow eyes. Anyone looking directly into these will suffer instant death."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_basilisk_rowling_fantastic .

beastiary:citation_shakespeare_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_phoenix_and_turtle_shakespeare ;
    beast:hasPassageText "Here the anthem doth commence: / Love and constancy is dead, / Phoenix and the Turtle fled / In a mutual flame from hence."^^xsd:string ;
    beast:hasSequenceIdentifier "Verse 21-24"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_phoenix_shakespeare .

beastiary:citation_shakespeare_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_romeo_and_juliet ;
    beast:hasPassageText "Alack, alack, is it not like that I, / So early waking, what with loathsome smells, / And shrieks like mandrakes torn out of the earth, / That living mortals, hearing them, run mad –"^^xsd:string ;
    beast:hasSequenceIdentifier "Act IV, scene 3"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_mandrake_shakespeare .

beastiary:citation_shelley_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_on_the_medusa ;
    beast:hasPassageText "I. / It lieth, gazing on the midnight sky, / Upon the cloudy mountain-peak supine; / Below, far lands are seen tremblingly; / Its horror and its beauty are divine. / Upon its lips and eyelids seems to lie / Loveliness like a shadow, from which shine, / Fiery and lurid, struggling underneath, / The agonies of anguish and of death. / II. / Yet it is less the horror than the grace / Which turns the gazer's spirit into stone, / Whereon the lineaments of that dead face / Are graven, till the characters be grown / Into itself, and thought no more can trace; / 'Tis the melodious hue of beauty thrown / Athwart the darkness and the glare of pain, / Which humanize and harmonize the strain. / III. / And from its head as from one body grow, / As grass out of a watery rock, / Hairs which are vipers, and they curl and flow / And their long tangles in each other lock, / And with unending involutions show / Their mailed radiance, as it were to mock / The torture and the death within, and saw / The solid air with many a ragged jaw. / IV. / And, from a stone beside, a poisonous eft / Peeps idly into those Gorgonian eyes; / Whilst in the air a ghastly bat, bereft / Of sense, has flitted with a mad surprise / Out of the cave this hideous light had cleft, / And he comes hastening like a moth that hies / After a taper; and the midnight sky / Flares, a light more dread than obscurity. / V. / 'Tis the tempestuous loveliness of terror; / For from the serpents gleams a brazen glare / Kindled by that inextricable error, / Which makes a thrilling vapour of the air / Become a and ever-shifting mirror / Of all the beauty and the terror there-- / A woman's countenance, with serpent-locks, / Gazing in death on Heaven from those wet rocks."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_medusa_shelley .

beastiary:citation_shrek_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_shrek ;
    beast:hasPassageText "It's the world that seems to have a problem with me. People take one look at me and go, 'Ah! Help! Run! Big, stupid, ugly ogre!' They judge me before they even know me."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_ogre_shrek .

beastiary:citation_sturluson_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_prose_edda ;
    beast:hasPassageText "Trolls call me moon of dwelling-Rungnir, giant's wealth-sucker, storm-sun's bale, seeress's friendly companion, guardian of corpse-fiord, swallower of heaven-wheel; what is a troll other than that?"^^xsd:string ;
    beast:hasSequenceIdentifier "Paragraph 53"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_troll_prose_edda .

beastiary:citation_tasso_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_mondo_creato ;
    beast:hasPassageText "Tra queste piante, e 'n quella selva alberga / Appresso 'l fonte l'unica Fenice, / Che della morte sua rinasce e vive: / Augello eguale alle celesti forme, / che vivace le stelle adegua, e 'l tempo / Consuma, e vince con rifatte membra. / E come sia del Sol gradita ancella, / Ha questo da natura officio, e dono, / Che quand'in cielo ad apparir comincia / Sparsa di rose la novella Aurora, / E dal ciel caccia le minute stelle; / Ella tre volte e quattro in mezzo all'acque / Sommerge 'l corpo, e pur tre volte e quattro / Liba quel dolce umor del vivo gorgo. / Poscia a volo s'innalza, e siede in cima / Dell'arbore frondosa, e quinci intorno / La selva tutta signoreggia e mira : [...] / Ma poi, forniti cento e cento lustri, / Nella vetusta età più grave e tarda, / Ella, che già passare a volo i nembi / Poteva, e le sonore, alte procelle, /  Per rinnovar la stanca vita, e 'l tempo / Chiuso, e ristretto pur da spazi angusti, / Fugge del bosco usato il dolce albergo. /  E di rinascer vaga, i lochi sacri / Addietro lascia, e vola al nostro mondo, / Ov'ha suo regni l'importuna morte. / E già drizza invecchiata 'l lento volo / In quella di Soría famosa parte, / A cui died'ella di Fenice 'l nome. / E di selve deserte ivi ricerca / Per non calcate vie secreta stanza, / E si ricovra nell'oscuro bosco. / Ed allor coglie dell'aereo giogo / Forte palma sublime, a cui pur anco / Comparti di Fenice 'I caro nome, / Cui romper non potria co' feri denti / Serpe squammosa, o pure augel rapace, / Od altra ingiuríosa orrida belva. / E chiusi allor nelle spelonche i venti / Taccion fra' cavernosi orridi chiostri, / Per non turbar co' lor torbidi spirti / Del bell'aer purpureo 'l dolce aspetto. / Nè condensato turbo i vani campi / Del ciel ricopre, ed al felice Augello / Toglie la vista de soavi raggi. / Quinci 'l nido si fa: sia nido, o tomba / Quello, in cui pere, accio rinasca, e viva L'Augel, che di se stesso è padre e figlio, / E se medesmo egli produce e cria. [...] / Sparge poi colla bocca i dolci succhi / Intorno, e sovra alle sue proprie membra. / Ivi l' esequie sue si fa morendo: / E debol già con lusinghieri accenti / Saluta 'l Sole, anzi l'adora, e placa : / E mesce umil preghiera all' umil canto, / Chiedendo i cari incendj, onde risorga / Col nuovo acquisto di perpetua forza. / Fra'vari odori poi l'alma spirante / Raccomanda al sepolcro; e nou paventa / L'ardita fede di si caro pegno. / Parte di vital morte 'l corpo estinto / S'accende, e l'ardor suo fiamme produce, / E del lume lontan concepe 'I foco, / Ond' egli ferve oltra misura, e flagra, / Lieto del suo morir, perchè veloce / Al rinascer di nuovo egli s' affretta. / Splende quasi di stelle ardenti 'l rogo, / E consuma l già lasso e pigro veglio. / La Luna'l corso suo raffrena e tarda, E par che tema in quel mirabil parto / Natura faticosa, e stanca madre, / Che non si perda l'immortale Augello; / Ma di gemina vita in mezz'al foco /  Posto in dubbio confin distingue e parte. / Nelle ceneri aduste alfin converso, / Le sue ceneri accolte egli raduna / In massa condensate, e quasi in vece / È l'occulta virtù d'interno seme. / E quinci prima l'animal ci nasce, / E 'n forma d'ovo si raccoglie 'n giro, / Poi si riforma nel primier sembiante: / E dalle nuove sue squarciate spoglie /Alfin germoglia l'immortal Fenice."^^xsd:string ;
    beast:hasSequenceIdentifier "Giornata V"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_phoenix_tasso .

beastiary:citation_thaon_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_thaon_bestiary ;
    beast:hasPassageText "[...] the onocentaur, which has the shape of a man down to the waist, and behind has the make of an ass, by great reason; Ονος, in Greek, is the name given to an ass; thus they call it; hear what signifies a beast of such a quality. Man, when he says truth, is rightly named man, and ass, signifies, when he does villany'"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_onocentaur_thaon .

beastiary:citation_theophilus_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_schedula_theophilus ;
    beast:hasPassageText "the heathen, who are said to be skilled in this art, produce basilisks for themselves in this way. They have a structure under the ground [...] In this they place two old fowls, twelve or fifteen years old, and they give them plenty to eat. When they have become plump, with the heat of their fatness they copulate and lay eggs. When these have been laid, the fowls are taken away and toads are introduced to sit on the eggs, and bread is given them for food. When the eggs are hatched, male chicks emerge like hens' chicks. After seven days they grow the tails of serpents."^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_basilisk_theophilus .

beastiary:citation_tolkien_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_the_hobbit ;
    beast:hasPassageText "There he lay, a vast red-golden dragon, fast asleep; thrumming came from his jaws and nostrils, and wisps of smoke, but his fires were low in slumber. Beneath him, under all his limbs and his huge coiled tail, and about him on all sides stretching away across the unseen floors, lay countless piles of precious things, gold wrought and unwrought, gems and jewels, and silver red-stained in the ruddy light. Smaug lay, with wings folded like an immeasurable bat, turned partly on one side, so that the hobbit could see his underparts and his long pale belly crusted with gems and fragments of gold from his long lying on his costly bed. Behind him where the walls were nearest could dimly be seen coats of mail, helms and axes, swords and spears hanging; and there in rows stood great jars and vessels filled with a wealth that could not be guessed."^^xsd:string ;
    beast:hasSequenceIdentifier "Chapter 12"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_dragon_tolkien .

beastiary:citation_tolkien_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_lotr ;
    beast:hasPassageText "Trolls they were, but filled with the evil will of their master: a fell race, strong, agile, fierce and cunning, but harder than stone. Unlike the older race of the Twilight they could endure the Sun, so long as the will of Sauron held sway over them. They spoke little, and the only tongue that they knew was the Black Speech of Barad-dûr."^^xsd:string ;
    beast:hasSequenceIdentifier "Appendix F"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_troll_tolkien .

beastiary:citation_tolkien_3 a beast:Citation ;
    beast:extractedFrom beastiary:source_lotr ;
    beast:hasPassageText "The doom of the Elves is to be immortal, to love the beauty of the world, to bring it to full flower with their gifts of delicacy and perfection, to last while it lasts, never leaving it even when slain."^^xsd:string ;
    beast:hasSequenceIdentifier "Book 1"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_elf_tolkien .

beastiary:citation_topsell_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_history_of_four_footed_beasts ;
    beast:hasPassageText "This beast or rather Monster is bred among the Indians, having a treble row of teeth beneath and above, whose greatness, roughness, and feet are like a Lyon, his face and ears like unto a mans, his eyes gray, and colour red, his tail like the tail of a Scorpion, of the earth, armed with a sting, casting forth sharp pointed quils; his voyce like the voyce of a small Trumpet or Pipe, being in course as swift as a Hart; his wildeness such as can never be tamed, and his appetite is especially to the flesh of man. His body like the body of a Lyon, being very apt both to leap and to run,  so as no distance or space doth hinder him [...]."^^xsd:string ;
    beast:hasSequenceIdentifier "Volume 1, chapter: Of the Mantichora"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_manticore_topsell .

beastiary:citation_virgil_1 a beast:Citation ;
    beast:extractedFrom beastiary:source_aeneid ;
    beast:hasPassageText "Giunti che furo, il gran Cerbero udiro / Abbaiar con tre gole, e ’l buio regno / Intonar tutto; indi in un antro immenso / Sel vider pria giacer disteso avanti, / Poi sorger, digrignar, rabido farsi, / Con tre colli arruffarsi, e mille serpi / Squassarsi intorno."^^xsd:string ;
    beast:hasSequenceIdentifier "Book 6, verses 612-618"^^xsd:string ;
    beast:isTextualReferenceOf beastiary:int_cerberus_virgil .

beastiary:creature_bear a beast:RealAnimal ;
    rdfs:label "Bear"@en ;
    beast:hasDiet beast:Carnivorous ;
    beast:hasHabitat beastiary:habitat_forests .

beastiary:creature_bird a beast:RealAnimal ;
    rdfs:label "Bird"@en ;
    beast:hasDiet beast:Herbivorous ;
    beast:hasHabitat beast:Terrestrial .

beastiary:creature_cat a beast:RealAnimal ;
    rdfs:label "Cat"@en ;
    beast:hasDiet beast:Carnivorous ;
    beast:hasHabitat beast:Terrestrial .

beastiary:creature_human_dog a beast:HybridCreature ;
    rdfs:label "Half human, half dog"@en ;
    beast:hasHeadOf beastiary:creature_human ;
    beast:hasLowerBodyOf beastiary:creature_dog ;
    beast:hasOriginContext beastiary:source_monstres_prodiges ;
    beast:hasTailOf beastiary:creature_dog ;
    beast:hasUpperBodyOf beastiary:creature_human .

beastiary:diet_autotrophic rdfs:label "Autotrophic"@en ;
    rdfs:comment "Self-nourishing through sunlight and nutrients drawn from the soil rather than by consuming other organisms; the mode proper to plant-creatures such as the mandrake."@en .

beastiary:diet_crabs_eater rdfs:label "Crabs eater"@en ;
    rdfs:comment "A diet consisting of crabs and similar shellfish; the creature feeds on crustaceans."@en .

beastiary:diet_elephant_blood rdfs:label "Elephant blood"@en ;
    rdfs:comment "A specialized carnivorous diet of elephant blood, sought by the dragon of Pliny's tradition to cool its own heat; the creature lies in wait to drain the elephant."@en ;
    beast:dietCategory beast:Carnivorous .

beastiary:diet_wind rdfs:label "Wind"@en ;
    rdfs:comment "A creature sustaining itself entirely by consuming air or wind, rather than solid food or water."@en ;
    beast:dietCategory beast:Elemental .

beastiary:etymology_acephalus a beast:Etymology ;
    beast:hasMeaning "Acephalus originates from the Late Latin acephalus. It is rooted in the Ancient Greek aképhalos, which breaks down into the prefix a- (without or not) and kephalē (head)."@en ;
    beast:hasRootTerm "aképhalos"@grc ;
    beast:isEtymologyOf beastiary:creature_acephalus .

beastiary:etymology_ant a beast:Etymology ;
    beast:hasMeaning "From Ancient Greek myrmex (μύρμηξ), meaning 'ant'. The term passed into Latin as formica, though the Greek myrmex was retained in learned and naturalistic contexts."@en ;
    beast:hasRootTerm "Myrmex"@grc ;
    beast:isEtymologyOf beastiary:creature_ant .

beastiary:etymology_antlion a beast:Etymology ;
    beast:hasMeaning "Compound of myrmex (ant) and leon (lion). Derived from a mistranslation of the Hebrew lajisch (lion) in Job 4:11 of the Septuagint, possibly influenced by the classical term myrmex used by Strabo and Aelian for an obscure Arabian lion-like animal."@en ;
    beast:hasRootTerm "Myrmekoleon"@grc ;
    beast:isEtymologyOf beastiary:creature_antlion .

beastiary:etymology_basilisk a beast:Etymology ;
    beast:hasMeaning "Diminutive of basileus (king), literally little king. Named for the crown-like crest on its head resembling a diadem, reflecting its status as king of serpents."@en ;
    beast:hasRootTerm "Basilískos"@grc ;
    beast:isEtymologyOf beastiary:creature_basilisk .

beastiary:etymology_bull a beast:Etymology ;
    beast:hasMeaning "From old Norse 'boli bull', male of the domestic bovine, perhaps also from an old English 'bula', both from Proto-Germanic 'bullon-'. Some sources attribute its etymology to a Germanic verbal stem meaning 'to roar', which survives in some German dialect. The other possibility [Watkins] is that the Germanic word is from Proto-Indo-European root 'bhel-', 'to blow, swell'."@en ;
    beast:hasRootTerm "Bule"@ang,
        "Bule"@non ;
    beast:isEtymologyOf beastiary:creature_bull .

beastiary:etymology_centaur a beast:Etymology ;
    beast:hasMeaning "From Ancient Greek kentauros (Κένταυρος), of disputed etymology. The most accepted derivation compounds ken- (possibly related to kentein, 'to prick' or 'to spur') and tauros ('bull'), suggesting 'bull-piercer' or 'bull-slayer', possibly referencing early Thessalian horsemen who hunted bulls. Alternative proposals derive it from a pre-Greek substrate language. First attested in Homer's Iliad and Hesiod's Theogony."@en ;
    beast:hasRootTerm "Kentauros"@grc ;
    beast:isEtymologyOf beastiary:creature_centaur .

beastiary:etymology_cerberus a beast:Etymology ;
    beast:hasMeaning "The etymology of Cerberus (the Latinized form of the Greek Kerberos) is ultimately unknown."@en ;
    beast:hasRootTerm "Kerberos"@grc ;
    beast:isEtymologyOf beastiary:creature_cerberus .

beastiary:etymology_chimera a beast:Etymology ;
    beast:hasMeaning "From Ancient Greek Khímaira (Χίμαιρα), literally 'she-goat', derived from khímaros (male goat), linked to kheîma (winter), as goats were used to mark the passing of a year. The monster is first attested in Homer's Iliad (VIII century BCE), where it is described as lion in front, serpent behind, and goat in the middle. The name's broader meaning of 'wild impossible fantasy' developed in early modern European languages through Latin Chimaera and Old French Chimere."@en ;
    beast:hasRootTerm "Chimaera"@grc ;
    beast:isEtymologyOf beastiary:creature_chimera .

beastiary:etymology_cow a beast:Etymology ;
    beast:hasMeaning "The word derives from the Proto-Indo-European root 'gwou-', which indicates the female of a bovine animal."@en ;
    beast:hasRootTerm "Gwou"@ine ;
    beast:isEtymologyOf beastiary:creature_cow .

beastiary:etymology_dragon a beast:Etymology ;
    beast:hasMeaning "The word dragon entered the English language in the early 13th century from Old French 'dragon', which, in turn, comes from Latin 'draco', meaning 'huge serpent', from Ancient Greek: δράκων, drákōn, 'serpent'. The Greek and Latin term referred to any great serpent, not necessarily mythological."@en ;
    beast:hasRootTerm "Drákōn"@grc ;
    beast:isEtymologyOf beastiary:creature_dragon .

beastiary:etymology_eagle a beast:Etymology ;
    beast:hasMeaning "\"The word comes from the Old French egle, from Old Provençal aigla, from Latin aquila. It refers to a very large diurnal raptorial bird\"."@en ;
    beast:hasRootTerm "Aquila"@la ;
    beast:isEtymologyOf beastiary:creature_eagle .

beastiary:etymology_elf a beast:Etymology ;
    beast:hasMeaning "The Germanic word presumably originally meant 'white one', perhaps as a euphemism."@en ;
    beast:hasRootTerm "ælf"@ang ;
    beast:isEtymologyOf beastiary:creature_elf .

beastiary:etymology_fairy a beast:Etymology ;
    beast:hasMeaning "The Fates were the three mythological goddesses who spun, measured, and cut the thread of human life."@en ;
    beast:hasRootTerm "Fatum"@la ;
    beast:isEtymologyOf beastiary:creature_fairy .

beastiary:etymology_fish a beast:Etymology ;
    beast:hasMeaning "The word comes from Proto-Germanic 'fiskaz' which indicates a vertebrate which has grills and fins adapting it for living in the water."@en ;
    beast:hasRootTerm "Fish"@gem ;
    beast:isEtymologyOf beastiary:creature_fish .

beastiary:etymology_giant a beast:Etymology ;
    beast:hasMeaning "The word Giant comes from the ancient greek Gígas (γίγας) which was used to describe divine and savages human beings."@en ;
    beast:hasRootTerm "Gígas"@grc ;
    beast:isEtymologyOf beastiary:creature_giant .

beastiary:etymology_goat a beast:Etymology ;
    beast:hasMeaning "The word is inherited from Middle English goot, got, gat, from Old English gāt, from Proto-West Germanic 'gait', from Proto-Germanic 'gaits'."@en ;
    beast:hasRootTerm "Gaits"@enm ;
    beast:isEtymologyOf beastiary:creature_goat .

beastiary:etymology_hermaphrodite a beast:Etymology ;
    beast:hasMeaning "The word that refers to a character belonging to greek mythology, the child of Ermes (Ἑρμῆς) and Aphrodite (Aphrodítē). Represented in greek mythology as a female figure with male genitals, they are historically used to describe androgynous and effeminacy."@en ;
    beast:hasRootTerm "Hermaphroditos"@grc ;
    beast:isEtymologyOf beastiary:creature_hermaphrodite .

beastiary:etymology_hippogriff a beast:Etymology ;
    beast:hasMeaning "The word derives from the Ancient Greek híppos (horse) and the Italian grifo, which stems from the Late Latin gryphus and the Ancient Greek grýps (γρύψ), meaning griffin."@en ;
    beast:hasRootTerm "Hippos + grifo"@grc,
        "Hippos + grifo"@la ;
    beast:isEtymologyOf beastiary:creature_hippogriff .

beastiary:etymology_horse a beast:Etymology ;
    beast:hasMeaning "The word derives from the Proto-Germanic 'harss-', of unknown origin. By some, connected to Proto-Indo-European root 'kers-' to run, source of Latin currere, to run."@en ;
    beast:hasRootTerm "Harss"@gem ;
    beast:isEtymologyOf beastiary:creature_horse .

beastiary:etymology_human a beast:Etymology ;
    beast:hasMeaning "The word derives from humain, humaigne, 'human', from Old French humain, umain (adj.) 'of or belonging to man' (12c.), from Latin humanus 'of man, human', also 'humane, philanthropic, kind, gentle, polite; learned, refined, civilized.'"@en ;
    beast:hasRootTerm "Humains"@fro ;
    beast:isEtymologyOf beastiary:creature_human .

beastiary:etymology_lion a beast:Etymology ;
    beast:hasMeaning "The word originated from the latin word 'leo' which means leopard. The word traces back to the ancient greek 'leon' which also meant leopard and has evolved over time to describe the lion, animal belonging to the family of felines."@en ;
    beast:hasRootTerm "Leo"@grc,
        "Leo"@la ;
    beast:isEtymologyOf beastiary:creature_lion .

beastiary:etymology_mandrake a beast:Etymology ;
    beast:hasMeaning "The word mandrake derives from the Ancient Greek mandragόras (μανδραγόρας), which traces back to an ancient, non-Indo-European language."@en ;
    beast:hasRootTerm "Mandragóras"@grc ;
    beast:isEtymologyOf beastiary:creature_mandrake .

beastiary:etymology_manticore a beast:Etymology ;
    beast:hasMeaning "\"The English-language term manticore comes via Latin mantichorās, from Ancient Greek μαρτιχόρας (martikhórās). This in turn is a transliteration of an Old Persian compound word consisting of martīya 'man' and xuar- stem, 'to eat', i.e., man-eater."@en ;
    beast:hasRootTerm "Martikhórās"@grc ;
    beast:isEtymologyOf beastiary:creature_manticore .

beastiary:etymology_medusa a beast:Etymology ;
    beast:hasMeaning "The name comes from the Ancient Greek verb medein (μήδω), meaning 'to rule over' or 'to protect'. As a proper noun, it translates literally to 'guardian' or 'protector'."@en ;
    beast:hasRootTerm "Medein"@grc ;
    beast:isEtymologyOf beastiary:creature_medusa .

beastiary:etymology_minotaur a beast:Etymology ;
    beast:hasMeaning "Compound of Minos (Μίνως) and tauros (ταῦρος) meaning bull. Literally Bull of Minos."@en ;
    beast:hasRootTerm "Minṓtauros"@grc ;
    beast:isEtymologyOf beastiary:creature_minotaur .

beastiary:etymology_ogre a beast:Etymology ;
    beast:hasMeaning "The word come from old french originatelly derived from the etruscan Orcu, the good of the underworld punisher of broken oath in etruscan mythology."@en ;
    beast:hasRootTerm "Orcus"@ett,
        "Orcus"@fr ;
    beast:isEtymologyOf beastiary:creature_ogre .

beastiary:etymology_onager a beast:Etymology ;
    beast:hasMeaning "From Ancient Greek onagros (ὄναγρος), compound of onos ('donkey') and agrios ('wild'), literally 'wild donkey'. Passed into Latin as onager. The term designated the Asiatic wild ass (Equus hemionus) in ancient natural history, appearing in Aristotle's Historia Animalium and Pliny's Naturalis Historia."@en ;
    beast:hasRootTerm "Onagros"@grc ;
    beast:isEtymologyOf beastiary:creature_onager .

beastiary:etymology_onocentaur a beast:Etymology ;
    beast:hasMeaning "From Ancient Greek onokentauros (ὀνοκένταυρος), a compound of onos ('donkey') and kentauros ('centaur'), literally meaning 'donkey-centaur'. The term appears in the Septuagint as a translation of Hebrew im (איִם), a term for a desert creature of uncertain identity, and later in Physiologus where it acquired allegorical Christian meaning representing hypocrisy and the divided self."@en ;
    beast:hasRootTerm "Onokentauros"@grc ;
    beast:isEtymologyOf beastiary:creature_onocentaur .

beastiary:etymology_pegasus a beast:Etymology ;
    beast:hasMeaning "Hesiod connects Pegasus's name to the springs of the Ocean where he was born from Medusa's blood."@en ;
    beast:hasRootTerm "Pḗgasos"@grc ;
    beast:isEtymologyOf beastiary:creature_pegasus .

beastiary:etymology_phoenix a beast:Etymology ;
    beast:hasMeaning "The word phoenix traces back to the Ancient Greek word phoinix (φοῖνιξ), which originally referred to a mythological firebird."@en ;
    beast:hasRootTerm "Phoinix"@grc ;
    beast:isEtymologyOf beastiary:creature_phoenix .

beastiary:etymology_polycephalus a beast:Etymology ;
    beast:hasMeaning "Polycephaly is the condition of having more than one head. The term is derived from the Greek stems poly (Greek: πολύ) meaning 'many' and kephalē (Greek: κεφαλή) meaning 'head'."@en ;
    beast:hasRootTerm "poly + kephalē"@grc ;
    beast:isEtymologyOf beastiary:creature_polycephalus_sheep .

beastiary:etymology_polymelic a beast:Etymology ;
    beast:hasMeaning "Polymelic comes from the Greek prefix poly- (meaning 'many' or 'much') and melos (meaning 'limb' or 'member')."@en ;
    beast:hasRootTerm "poly + melos"@grc ;
    beast:isEtymologyOf beastiary:creature_polymelic_cat .

beastiary:etymology_satyr a beast:Etymology ;
    beast:hasMeaning "The word derives from the ancient greek sathe (σαθη), which refers to the male member and highlights the tendency of satyrs to always be prone to lust."@en ;
    beast:hasRootTerm "Sátyros"@grc ;
    beast:isEtymologyOf beastiary:creature_satyr .

beastiary:etymology_scorpion a beast:Etymology ;
    beast:hasMeaning "The word \"'scorpion' originates from the Latin term 'scorpionem', which is derived from the Greek word 'skorpios'. This Greek term is related to the Proto-Indo-European root 'sker-', meaning to cut or to shear."@en ;
    beast:hasRootTerm "Scorpionem"@la ;
    beast:isEtymologyOf beastiary:creature_scorpion .

beastiary:etymology_siren a beast:Etymology ;
    beast:hasMeaning "Siren derives from the ancient greek Seirēn, which indicated female mythological creatures endowed with enchanting and often dangerous powers for sailors."@en ;
    beast:hasRootTerm "Seirḗn"@grc ;
    beast:isEtymologyOf beastiary:creature_siren .

beastiary:etymology_snake a beast:Etymology ;
    beast:hasMeaning "The word traces back to the Old English snaca, from Proto-Germanic 'snakon' and from Proto-Indo-European root 'sneg-', to crawl, creeping thing. In Modern English, gradually replacing serpent in popular use."@en ;
    beast:hasRootTerm "Snake"@enm ;
    beast:isEtymologyOf beastiary:creature_snake .

beastiary:etymology_sphinx a beast:Etymology ;
    beast:hasMeaning "\"The word originates from the Ancient Greek sphínx, which the Greeks likely derived from their own verb sphíngō, meaning to squeeze or to bind tight\"."@en ;
    beast:hasRootTerm "Sphínx"@grc ;
    beast:isEtymologyOf beastiary:creature_sphinx .

beastiary:etymology_troll a beast:Etymology ;
    beast:hasMeaning "In Old Norse the noun troll (or trǫll) used to mean 'fiend', as in Middle High German, 'demon', 'werewolf'. It also comes from the Old Norse verb 'trylla' which means to enchant, to turn into a troll and the Middle High German verb trüllen, 'to flutter'."@en ;
    beast:hasRootTerm "Troll"@gmh,
        "Troll"@non ;
    beast:isEtymologyOf beastiary:creature_troll .

beastiary:etymology_unicorn a beast:Etymology ;
    beast:hasMeaning "The word come from ancient greek meanig 'one horn' passing to latin to unicornis, from uni- (single) and cornu-(horn)."@en ;
    beast:hasRootTerm "monokerōs"@grc ;
    beast:isEtymologyOf beastiary:creature_unicorn .

beastiary:function_instigator a beast:NarrativeFunction ;
    rdfs:label "Instigator"@en ;
    beast:hasMeaning "The creature's own action precipitates a conflict or catastrophe, setting events in motion through its own transgression."@en ;
    beast:relatedTo beastiary:function_antagonist .

beastiary:function_punisher a beast:NarrativeFunction ;
    rdfs:label "Punisher"@en ;
    beast:hasMeaning "The creature enacts punishment or retribution, serving as the instrument of justice or contrapasso."@en .

beastiary:function_transformation a beast:NarrativeFunction ;
    rdfs:label "Transformation"@en ;
    beast:hasMeaning "The creature embodies or undergoes metamorphosis, the change of form that is itself the narrative event."@en .

beastiary:habitat_africa a beast:GeographicPlace ;
    rdfs:label "Africa"@en ;
    rdfs:comment "The African continent invoked in classical and medieval sources as the remote homeland of exotic and monstrous creatures. In the ancient and medieval imagination, Africa was a space of geographic otherness."@en ;
    beast:habitatCategory beast:Terrestrial .

beastiary:habitat_arabia a beast:GeographicPlace ;
    rdfs:label "Arabia"@en ;
    rdfs:comment "The arid lands of the Arabian peninsula, a remote eastern region of deserts and aromatic groves traditionally held to be the dwelling of the phoenix, which there builds its spice-laden nest of frankincense and myrrh."@en ;
    beast:habitatCategory beast:Terrestrial .

beastiary:habitat_cave a beast:RealWorldPlace ;
    rdfs:label "Cave"@en ;
    rdfs:comment "A natural rocky hollow or cavern."@en ;
    beast:habitatCategory beast:Terrestrial .

beastiary:habitat_chamber_of_secrets a beast:ImaginaryPlace ;
    rdfs:label "Chamber of Secrets"@en ;
    rdfs:comment "A vast underground chamber hidden beneath Hogwarts School of Witchcraft and Wizardry, built by Salazar Slytherin in the 10th century to conceal his basilisk."@en ;
    beast:hasOriginContext beastiary:source_harry_potter_book_2 .

beastiary:habitat_cloud_kingdom a beast:ImaginaryPlace ;
    rdfs:label "Cloud Kingdom"@en ;
    rdfs:comment "The Cloud Kingdom is the mystical kingdom floating high above the earth among the clouds location where the movie takes place."@en ;
    beast:habitatCategory beast:Aerial ;
    beast:hasOriginContext beastiary:source_barbie .

beastiary:habitat_dry_places a beast:RealWorldPlace ;
    rdfs:label "Dry places"@en ;
    rdfs:comment "Arid dry environment with scarce vegetation."@en ;
    beast:habitatCategory beast:Terrestrial .

beastiary:habitat_duloc_swamp a beast:ImaginaryPlace ;
    rdfs:label "Swamp"@en ;
    rdfs:comment "The magical swamp is surrounded by dense trees and mossy water, home of Shrek."@en ;
    beast:habitatCategory beast:Terrestrial ;
    beast:hasOriginContext beastiary:source_shrek .

beastiary:habitat_edge_of_world a beast:ImaginaryPlace ;
    rdfs:label "Edge of the World"@en ;
    rdfs:comment "The far western limit of the cosmos in Hesiod's Theogony, beyond glorious Ocean toward Night and near the Hesperides, where the Gorgons dwell at the boundary of the known world."@en ;
    beast:hasOriginContext beastiary:source_teogonia .

beastiary:habitat_forbidden_forest a beast:ImaginaryPlace ;
    rdfs:label "Forbidden Forest"@en ;
    rdfs:comment "The Forbidden Forest, also known as the Dark Forest, was a forest that bordered the edges of the grounds of Hogwarts School of Witchcraft and Wizardry."@en ;
    beast:hasOriginContext beastiary:source_harry_potter_book_1 .

beastiary:habitat_great_riddle_gate a beast:ImaginaryPlace ;
    rdfs:label "Great Riddle Gate"@en ;
    rdfs:comment "The Great Riddle Gate is the first of three gates leading to the Southern Oracle in Fantastica, formed by two facing sphinxes whose gaze freezes the unworthy in place, condemning them to solve all the world's riddles or perish."@en ;
    beast:hasOriginContext beastiary:source_unendliche_geschichte .

beastiary:habitat_heaven_of_jupyter a beast:ImaginaryPlace ;
    rdfs:label "Heaven of Jupiter"@en ;
    rdfs:comment "The sixth celestial sphere of Dante's Paradise, the heaven of just rulers, where the souls of the righteous compose the figure of the Eagle of divine justice."@en ;
    beast:hasOriginContext beastiary:source_dante_paradiso .

beastiary:habitat_india a beast:GeographicPlace ;
    rdfs:label "India"@en ;
    beast:habitatCategory beast:Terrestrial .

beastiary:habitat_labyrinth a beast:ImaginaryPlace ;
    rdfs:label "Labyrinth"@en ;
    rdfs:comment "The mythological maze built by Daedalus in Crete to contain the Minotaur commissioned by King Minos."@en .

beastiary:habitat_middle_earth a beast:ImaginaryPlace ;
    rdfs:label "Middle Earth"@en ;
    rdfs:comment "Middle-earth is fictional continent in J.R.R. Tolkien’s fantasy world, as our actual Earth in a mythical, pre-historic past."@en ;
    beast:habitatCategory beast:Terrestrial ;
    beast:hasOriginContext beastiary:source_lotr .

beastiary:habitat_neverland a beast:ImaginaryPlace ;
    rdfs:label "Neverland"@en ;
    rdfs:comment "Neverland is a fictional, magical island where children never grow up, inhabited by fairies (like Tinker Bell), mermaids, the Lost Boys (Peter Pan), pirates, and Native Americans."@en ;
    beast:habitatCategory beast:Terrestrial ;
    beast:hasOriginContext beastiary:source_peter_pan .

beastiary:habitat_north_pole a beast:GeographicPlace ;
    rdfs:label "North Pole"@en ;
    rdfs:comment "The North Pole, is the the northernmost point on Earth, located at the exact intersection of the planet's axis and its surface, known by its very cold temperatures all year round."@en ;
    beast:habitatCategory beast:Terrestrial .

beastiary:habitat_ocean a beast:RealWorldPlace ;
    rdfs:label "Ocean"@en ;
    rdfs:comment "The vast salt sea."@en ;
    beast:habitatCategory beast:Aquatic .

beastiary:habitat_olympus a beast:ImaginaryPlace ;
    rdfs:label "Olympus"@en ;
    rdfs:comment "Mount Olympus in greek mythology is the place were the gods live."@en ;
    beast:habitatCategory beast:Aerial ;
    beast:hasOriginContext beastiary:source_teogonia .

beastiary:habitat_ravenna a beast:GeographicPlace ;
    rdfs:label "Ravenna"@en ;
    rdfs:comment "The city of Ravenna in northern Italy."@en ;
    beast:habitatCategory beast:Terrestrial .

beastiary:habitat_riphean_mountains a beast:ImaginaryPlace ;
    rdfs:label "Riphean Mountains"@en ;
    rdfs:comment "The Riphean Mountains, a remote and semi-legendary range placed at the far north of the world, beyond the frozen seas; in Ariosto's Orlando Furioso the rare native haunt from which the hippogriff comes."@en ;
    beast:hasOriginContext beastiary:source_orlando_furioso .

beastiary:habitat_river a beast:RealWorldPlace ;
    rdfs:label "River"@en ;
    rdfs:comment "A flowing freshwater watercourse."@en ;
    beast:habitatCategory beast:Aquatic .

beastiary:habitat_underworld a beast:ImaginaryPlace ;
    rdfs:label "Underworld (Hades)"@en ;
    rdfs:comment "The subterranean realm of the dead in Greek mythology, ruled by Hades, whose gates are guarded by Cerberus to prevent the dead from leaving."@en ;
    beast:hasOriginContext beastiary:source_greek_mythology .

