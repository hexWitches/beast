beastiary:creature_phoenix a beast:Creature,
        beast:ImaginaryBeing ;
    rdfs:label "Phoenix"@en ;
    rdfs:comment "The phoenix is the supreme cyclical symbol: its death-and-rebirth from ashes is the very image of the Eternal Return, where death is reintegrated as a stage of incessant renewal."@en ;
    beast:belongsToImaginaryStructure beast:SyntheticStructure ;
    beast:embodiesImaginarySymbol beast:CyclicalSymbol ;
    beast:hasAbility beastiary:ability_immortality,
        beastiary:ability_self_renewal ;
    beast:hasDiet beast:Elemental ;
    beast:hasDistinctiveTrait "Phoenix is known for being immortal - it regenerates from its own ashes or from the father's body depending on the source."^^xsd:string ;
    beast:hasEtymology beastiary:etymology_phoenix ;
    beast:hasHabitat beastiary:habitat_forests ;
    beast:hasOriginContext beastiary:source_greek_mythology ;
    beast:hasPart beastiary:part_red_and_gold_feathers ;
    beast:hasPartDerivedFrom beastiary:creature_eagle ;
    beast:isGovernedBy beast:NocturnalRegime .

beastiary:source_greek_mythology a beast:Tradition .

