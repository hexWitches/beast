beastiary:creature_human_dog a beast:HybridCreature ;
    rdfs:label "Half human"@en,
        "half dog"@en ;
    beast:hasHeadOf beastiary:creature_human ;
    beast:hasLowerBodyOf beastiary:creature_dog ;
    beast:hasOriginContext beastiary:source_monstres_prodiges ;
    beast:hasTailOf beastiary:creature_dog ;
    beast:hasUpperBodyOf beastiary:creature_human .

beastiary:creature_polymelic_cat a beast:RealAnimal ;
    rdfs:label "Polymelic cat"@en ;
    beast:hasAlternativeName "Six-footed cat"^^xsd:string ;
    beast:hasEtymology beastiary:etymology_polymelic ;
    beast:hasModificationOf beastiary:part_multiple_limbs ;
    beast:hasOriginContext beastiary:source_monstrorum_historia_aldrovandi ;
    beast:isOfSpecies beastiary:creature_cat .

beastiary:etymology_acephalus a beast:Etymology ;
    beast:hasMeaning "Acephalus originates from the Late Latin acephalus. It is rooted in the Ancient Greek aképhalos, which breaks down into the prefix a- (without or not) and kephalē (head)."@en ;
    beast:hasRootTerm "aképhalos"@grc ;
    beast:isEtymologyOf beastiary:creature_acephalus .

beastiary:etymology_ant a beast:Etymology ;
    beast:hasMeaning "From Ancient Greek myrmex (μύρμηξ), meaning 'ant'. The term passed into Latin as formica, though the Greek myrmex was retained in learned and naturalistic contexts."@en ;
    beast:hasRootTerm "Myrmex"@grc ;
    beast:isEtymologyOf beastiary:creature_ant .

beastiary:etymology_antlion a beast:Etymology ;
    beast:hasMeaning "Compound of myrmex (ant) and leon (lion). Derived from a mistranslation of the Hebrew lajisch (lion) in Job 4:11 of the Septuagint, possibly influenced by the classical term myrmex used by Strabo and Aelian for an obscure Arabian lion-like animal."@en ;
    beast:hasRootTerm "Myrmekoleon"@grc ;
    beast:isEtymologyOf beastiary:creature_antlion .

beastiary:etymology_basilisk a beast:Etymology ;
    beast:hasMeaning "Diminutive of basileus (king), literally little king. Named for the crown-like crest on its head resembling a diadem, reflecting its status as king of serpents."@en ;
    beast:hasRootTerm "Basilískos"@grc ;
    beast:isEtymologyOf beastiary:creature_basilisk .

beastiary:etymology_bull a beast:Etymology ;
    beast:hasMeaning "From old Norse 'boli bull', male of the domestic bovine, perhaps also from an old English 'bula', both from Proto-Germanic 'bullon-'. Some sources attribute its etymology to a Germanic verbal stem meaning 'to roar', which survives in some German dialect. The other possibility [Watkins] is that the Germanic word is from Proto-Indo-European root 'bhel-', 'to blow, swell'."@en ;
    beast:hasRootTerm "Bule"@ang,
        "Bule"@non ;
    beast:isEtymologyOf beastiary:creature_bull .

beastiary:etymology_centaur a beast:Etymology ;
    beast:hasMeaning "From Ancient Greek kentauros (Κένταυρος), of disputed etymology. The most accepted derivation compounds ken- (possibly related to kentein, 'to prick' or 'to spur') and tauros ('bull'), suggesting 'bull-piercer' or 'bull-slayer', possibly referencing early Thessalian horsemen who hunted bulls. Alternative proposals derive it from a pre-Greek substrate language. First attested in Homer's Iliad and Hesiod's Theogony."@en ;
    beast:hasRootTerm "Kentauros"@grc ;
    beast:isEtymologyOf beastiary:creature_centaur .

beastiary:etymology_chimera a beast:Etymology ;
    beast:hasMeaning "From Ancient Greek Khímaira (Χίμαιρα), literally 'she-goat', derived from khímaros (male goat), linked to kheîma (winter), as goats were used to mark the passing of a year. The monster is first attested in Homer's Iliad (VIII century BCE), where it is described as lion in front, serpent behind, and goat in the middle. The name's broader meaning of 'wild impossible fantasy' developed in early modern European languages through Latin Chimaera and Old French Chimere."@en ;
    beast:hasRootTerm "Chimaera"@grc ;
    beast:isEtymologyOf beastiary:creature_chimera .

beastiary:etymology_cow a beast:Etymology ;
    beast:hasMeaning "The word derives from the Proto-Indo-European root 'gwou-', which indicates the female of a bovine animal."@en ;
    beast:hasRootTerm "Gwou"@ine ;
    beast:isEtymologyOf beastiary:creature_cow .

beastiary:etymology_dragon a beast:Etymology ;
    beast:hasMeaning "The word dragon entered the English language in the early 13th century from Old French 'dragon', which, in turn, comes from Latin 'draco', meaning 'huge serpent', from Ancient Greek: δράκων, drákōn, 'serpent'. The Greek and Latin term referred to any great serpent, not necessarily mythological."@en ;
    beast:hasRootTerm "Drákōn"@grc ;
    beast:isEtymologyOf beastiary:creature_dragon .

beastiary:etymology_eagle a beast:Etymology ;
    beast:hasMeaning "\"The word comes from the Old French egle, from Old Provençal aigla, from Latin aquila. It refers to a very large diurnal raptorial bird\"."@en ;
    beast:hasRootTerm "Aquila"@la ;
    beast:isEtymologyOf beastiary:creature_eagle .

beastiary:etymology_elf a beast:Etymology ;
    beast:hasMeaning "The Germanic word presumably originally meant 'white one', perhaps as a euphemism."@en ;
    beast:hasRootTerm "ælf"@ang ;
    beast:isEtymologyOf beastiary:creature_elf .

beastiary:etymology_fairy a beast:Etymology ;
    beast:hasMeaning "The Fates were the three mythological goddesses who spun, measured, and cut the thread of human life."@en ;
    beast:hasRootTerm "Fatum"@la ;
    beast:isEtymologyOf beastiary:creature_fairy .

beastiary:etymology_fish a beast:Etymology ;
    beast:hasMeaning "The word comes from Proto-Germanic 'fiskaz' which indicates a vertebrate which has grills and fins adapting it for living in the water."@en ;
    beast:hasRootTerm "Fish"@gem ;
    beast:isEtymologyOf beastiary:creature_fish .

beastiary:etymology_giant a beast:Etymology ;
    beast:hasMeaning "The word Giant comes from the ancient greek Gígas (γίγας) which was used to describe divine and savages human beings."@en ;
    beast:hasRootTerm "Gígas"@grc ;
    beast:isEtymologyOf beastiary:creature_giant .

beastiary:etymology_goat a beast:Etymology ;
    beast:hasMeaning "The word is inherited from Middle English goot, got, gat, from Old English gāt, from Proto-West Germanic 'gait', from Proto-Germanic 'gaits'."@en ;
    beast:hasRootTerm "Gaits"@enm ;
    beast:isEtymologyOf beastiary:creature_goat .

beastiary:etymology_hermaphrodite a beast:Etymology ;
    beast:hasMeaning "The word that refers to a character belonging to greek mythology, the child of Ermes (Ἑρμῆς) and Aphrodite (Aphrodítē). Represented in greek mythology as a female figure with male genitals, they are historically used to describe androgynous and effeminacy."@en ;
    beast:hasRootTerm "Hermaphroditos"@grc ;
    beast:isEtymologyOf beastiary:creature_hermaphrodite .

beastiary:etymology_hippogriff a beast:Etymology ;
    beast:hasMeaning "The word derives from the Ancient Greek híppos (horse) and the Italian grifo, which stems from the Late Latin gryphus and the Ancient Greek grýps (γρύψ), meaning griffin."@en ;
    beast:hasRootTerm "Hippos + grifo"@grc,
        "Hippos + grifo"@la ;
    beast:isEtymologyOf beastiary:creature_hippogriff .

beastiary:etymology_horse a beast:Etymology ;
    beast:hasMeaning "The word derives from the Proto-Germanic 'harss-', of unknown origin. By some, connected to Proto-Indo-European root 'kers-' to run, source of Latin currere, to run."@en ;
    beast:hasRootTerm "Harss"@gem ;
    beast:isEtymologyOf beastiary:creature_horse .

beastiary:etymology_lion a beast:Etymology ;
    beast:hasMeaning "The word originated from the latin word 'leo' which means leopard. The word traces back to the ancient greek 'leon' which also meant leopard and has evolved over time to describe the lion, animal belonging to the family of felines."@en ;
    beast:hasRootTerm "Leo"@grc,
        "Leo"@la ;
    beast:isEtymologyOf beastiary:creature_lion .

beastiary:etymology_mandrake a beast:Etymology ;
    beast:hasMeaning "The word mandrake derives from the Ancient Greek mandragόras (μανδραγόρας), which traces back to an ancient, non-Indo-European language."@en ;
    beast:hasRootTerm "Mandragóras"@grc ;
    beast:isEtymologyOf beastiary:creature_mandrake .

beastiary:etymology_manticore a beast:Etymology ;
    beast:hasMeaning "\"The English-language term manticore comes via Latin mantichorās, from Ancient Greek μαρτιχόρας (martikhórās). This in turn is a transliteration of an Old Persian compound word consisting of martīya 'man' and xuar- stem, 'to eat', i.e., man-eater."@en ;
    beast:hasRootTerm "Martikhórās"@grc ;
    beast:isEtymologyOf beastiary:creature_manticore .

beastiary:etymology_medusa a beast:Etymology ;
    beast:hasMeaning "The name comes from the Ancient Greek verb medein (μήδω), meaning 'to rule over' or 'to protect'. As a proper noun, it translates literally to 'guardian' or 'protector'."@en ;
    beast:hasRootTerm "Medein"@grc ;
    beast:isEtymologyOf beastiary:creature_medusa .

beastiary:etymology_minotaur a beast:Etymology ;
    beast:hasMeaning "Compound of Minos (Μίνως) and tauros (ταῦρος) meaning bull. Literally Bull of Minos."@en ;
    beast:hasRootTerm "Minṓtauros"@grc ;
    beast:isEtymologyOf beastiary:creature_minotaur .

beastiary:etymology_ogre a beast:Etymology ;
    beast:hasMeaning "The word come from old french originatelly derived from the etruscan Orcu, the good of the underworld punisher of broken oath in etruscan mythology."@en ;
    beast:hasRootTerm "Orcus"@ett,
        "Orcus"@fr ;
    beast:isEtymologyOf beastiary:creature_ogre .

beastiary:etymology_onager a beast:Etymology ;
    beast:hasMeaning "From Ancient Greek onagros (ὄναγρος), compound of onos ('donkey') and agrios ('wild'), literally 'wild donkey'. Passed into Latin as onager. The term designated the Asiatic wild ass (Equus hemionus) in ancient natural history, appearing in Aristotle's Historia Animalium and Pliny's Naturalis Historia."@en ;
    beast:hasRootTerm "Onagros"@grc ;
    beast:isEtymologyOf beastiary:creature_onager .

beastiary:etymology_onocentaur a beast:Etymology ;
    beast:hasMeaning "From Ancient Greek onokentauros (ὀνοκένταυρος), a compound of onos ('donkey') and kentauros ('centaur'), literally meaning 'donkey-centaur'. The term appears in the Septuagint as a translation of Hebrew im (איִם), a term for a desert creature of uncertain identity, and later in Physiologus where it acquired allegorical Christian meaning representing hypocrisy and the divided self."@en ;
    beast:hasRootTerm "Onokentauros"@grc ;
    beast:isEtymologyOf beastiary:creature_onocentaur .

beastiary:etymology_pegasus a beast:Etymology ;
    beast:hasMeaning "Hesiod connects Pegasus's name to the springs of the Ocean where he was born from Medusa's blood."@en ;
    beast:hasRootTerm "Pḗgasos"@grc ;
    beast:isEtymologyOf beastiary:creature_pegasus .

beastiary:etymology_phoenix a beast:Etymology ;
    beast:hasMeaning "The word phoenix traces back to the Ancient Greek word phoinix (φοῖνιξ), which originally referred to a mythological firebird."@en ;
    beast:hasRootTerm "Phoinix"@grc ;
    beast:isEtymologyOf beastiary:creature_phoenix .

beastiary:etymology_polycephalus a beast:Etymology ;
    beast:hasMeaning "Polycephaly is the condition of having more than one head. The term is derived from the Greek stems poly (Greek: πολύ) meaning 'many' and kephalē (Greek: κεφαλή) meaning 'head'."@en ;
    beast:hasRootTerm "poly + kephalē"@grc ;
    beast:isEtymologyOf beastiary:creature_polycephalus_sheep .

beastiary:etymology_polymelic a beast:Etymology ;
    beast:hasMeaning "Polymelic comes from the Greek prefix poly- (meaning 'many' or 'much') and melos (meaning 'limb' or 'member')."@en ;
    beast:hasRootTerm "poly + melos"@grc ;
    beast:isEtymologyOf beastiary:creature_polymelic .

beastiary:etymology_satyr a beast:Etymology ;
    beast:hasMeaning "The word derives from the ancient greek sathe (σαθη), which refers to the male member and highlights the tendency of satyrs to always be prone to lust."@en ;
    beast:hasRootTerm "Sátyros"@grc ;
    beast:isEtymologyOf beastiary:creature_satyr .

beastiary:etymology_scorpion a beast:Etymology ;
    beast:hasMeaning "The word \"'scorpion' originates from the Latin term 'scorpionem', which is derived from the Greek word 'skorpios'. This Greek term is related to the Proto-Indo-European root 'sker-', meaning to cut or to shear."@en ;
    beast:hasRootTerm "Scorpionem"@la ;
    beast:isEtymologyOf beastiary:creature_scorpion .

beastiary:etymology_siren a beast:Etymology ;
    beast:hasMeaning "Siren derives from the ancient greek Seirēn, which indicated female mythological creatures endowed with enchanting and often dangerous powers for sailors."@en ;
    beast:hasRootTerm "Seirḗn"@grc ;
    beast:isEtymologyOf beastiary:creature_siren .

beastiary:etymology_snake a beast:Etymology ;
    beast:hasMeaning "The word traces back to the Old English snaca, from Proto-Germanic 'snakon' and from Proto-Indo-European root 'sneg-', to crawl, creeping thing. In Modern English, gradually replacing serpent in popular use."@en ;
    beast:hasRootTerm "Snake"@enm ;
    beast:isEtymologyOf beastiary:creature_snake .

beastiary:etymology_sphinx a beast:Etymology ;
    beast:hasMeaning "\"The word originates from the Ancient Greek sphínx, which the Greeks likely derived from their own verb sphíngō, meaning to squeeze or to bind tight\"."@en ;
    beast:hasRootTerm "Sphínx"@grc ;
    beast:isEtymologyOf beastiary:creature_sphinx .

beastiary:etymology_troll a beast:Etymology ;
    beast:hasMeaning "In Old Norse the noun troll (or trǫll) used to mean 'fiend', as in Middle High German, 'demon', 'werewolf'. It also comes from the Old Norse verb 'trylla' which means to enchant, to turn into a troll and the Middle High German verb trüllen, 'to flutter'."@en ;
    beast:hasRootTerm "Troll"@gmh,
        "Troll"@non ;
    beast:isEtymologyOf beastiary:creature_troll .

beastiary:etymology_unicorn a beast:Etymology ;
    beast:hasMeaning "The word come from ancient greek meanig 'one horn' passing to latin to unicornis, from uni- (single) and cornu-(horn)."@en ;
    beast:hasRootTerm "monokerōs"@grc ;
    beast:isEtymologyOf beastiary:creature_unicorn .

beastiary:function_instigator a beast:NarrativeFunction ;
    beast:hasMeaning "The creature's own action precipitates a conflict or catastrophe, setting events in motion through its own transgression."@en ;
    beast:relatedTo beastiary:function_antagonist .

beastiary:function_punisher a beast:NarrativeFunction ;
    beast:hasMeaning "The creature enacts punishment or retribution, serving as the instrument of justice or contrapasso."@en .

beastiary:function_transformation a beast:NarrativeFunction ;
    beast:hasMeaning "The creature embodies or undergoes metamorphosis, the change of form that is itself the narrative event."@en .

beastiary:habitat_africa a beast:RealWorldPlace ;
    rdfs:label "Africa"@en ;
    rdfs:comment "The African continent invoked in classical and medieval sources as the remote homeland of exotic and monstrous creatures. In the ancient and medieval imagination, Africa was a space of geographic otherness."@en ;
    beast:habitatCategory beast:habitat_terrestrial .

beastiary:habitat_dry_places a beast:RealWorldPlace ;
    rdfs:label "Dry places"@en ;
    rdfs:comment "Arid dry environment with scarce vegetation."@en ;
    beast:habitatCategory beast:habitat_terrestrial .

beastiary:habitat_labyrinth a beast:ImaginaryPlace ;
    rdfs:label "Labyrinth"@en ;
    rdfs:comment "The mythological maze built by Daedalus in Crete to contain the Minotaur commissioned by King Minos."@en .

beastiary:habitat_ravenna a beast:RealWorldPlace ;
    rdfs:label "Ravenna"@en ;
    rdfs:comment "The city of Ravenna in northern Italy."@en ;
    beast:habitatCategory beast:habitat_terrestrial .

beastiary:int_basilisk_plinio a beast:Interpretation ;
    beast:appearsIn beastiary:source_naturalis_historia ;
    beast:hasTextualReference beastiary:citation_plinio_8 ;
    beast:ofCreature beastiary:creature_basilisk .

beastiary:int_basilisk_rowling_harry a beast:Interpretation ;
    beast:additionalAbility beastiary:ability_petrifying_gaze ;
    beast:alternativeHabitat beast:habitat_chamber_of_secrets ;
    beast:appearsIn beastiary:source_harry_potter_book_2 ;
    beast:embodiesArchetype beastiary:archetype_guardian_threshold ;
    beast:hasNarrativeFunction beastiary:function_guardian ;
    beast:ofCreature beastiary:creature_basilisk .

beastiary:int_chimera_fullmetal_alchemist a beast:Interpretation ;
    beast:additionalPart beastiary:part_lizard_lower_body,
        beastiary:part_lizard_tail ;
    beast:appearsIn beastiary:source_fullmetal_alchemist ;
    beast:embodiesArchetype beastiary:archetype_scientific_transgression,
        beastiary:archetype_shameful_offspring ;
    beast:hasDistinctiveTrait "The chimera is produced through human transmutation"^^xsd:string,
        "a forbidden alchemical act. The product is a new"^^xsd:string,
        "combined creature which inherits features and attributes from both of its original base organisms."^^xsd:string ;
    beast:hasNarrativeFunction beastiary:function_guardian ;
    beast:ofCreature beastiary:creature_chimera ;
    beast:removedAbility beastiary:ability_fire_breathing ;
    beast:removedPart beastiary:part_goat_lower_body,
        beastiary:part_snake_tail .

beastiary:int_chimera_moreau a beast:Interpretation ;
    rdfs:comment "Moreau's Chimera converts the threatening hybrid into an object of desire: winged and human above, bestial below, she fuses the ascensional pull of flight with a nyctomorphic undertow of obscurity and seduction, where fire and fang no longer signal attack but the dark, submerged allure of the abyss itself."@en ;
    beast:additionalAbility beastiary:ability_fly ;
    beast:additionalPart beastiary:part_horse_lower_body,
        beastiary:part_human_upper_body,
        beastiary:part_wings ;
    beast:appearsIn beastiary:source_chimera_moreau ;
    beast:belongsToImaginaryStructure beast:SchizomorphicStructure ;
    beast:embodiesArchetype beastiary:archetype_seduction,
        beastiary:archetype_sublime ;
    beast:embodiesImaginarySymbol beast:AscensionalSymbol,
        beast:NyctomorphicSymbol ;
    beast:hasPersonalName "The Chimera"^^xsd:string ;
    beast:isGovernedBy beast:DiurnalRegime ;
    beast:ofCreature beastiary:creature_chimera ;
    beast:removedAbility beastiary:ability_fire_breathing ;
    beast:removedPart beastiary:part_goat_lower_body,
        beastiary:part_lion_head,
        beastiary:part_lion_upper_body,
        beastiary:part_snake_tail .

beastiary:int_chimera_statue a beast:Interpretation ;
    beast:appearsIn beastiary:source_chimera_d_arezzo_statue ;
