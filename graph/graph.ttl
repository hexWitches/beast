    beast:hasHabitat beastiary:habitat_mountains ;
    beast:hasHeadOf beastiary:creature_lion ;
    beast:hasLowerBodyOf beastiary:creature_goat ;
    beast:hasOriginContext beastiary:source_greek_mythology ;
    beast:hasPart beastiary:part_goat_head,
        beastiary:part_snake_head ;
    beast:hasTailOf beastiary:creature_snake ;
    beast:hasUpperBodyOf beastiary:creature_lion ;
    beast:isGovernedBy beast:DiurnalRegime .

beastiary:creature_giant a beast:Creature,
        beast:ImaginaryBeing ;
    rdfs:label "Giant"@en ;
    rdfs:comment "Giants, in different interpretation, are symbols of the primordial chaos that needs to be reordered in order to bring balance to the universe. They stick to the nyctomorphic symbolism by representing the dark times of humanity. While in Attack on Titan this caos manifest as a terrifying voracitiy, where giands devour human bodies, in classical interpretation and art it is represented by the trauma of the fall and cosmic cataclysm."@en ;
    beast:belongsToImaginaryStructure beast:SchizomorphicStructure ;
    beast:embodiesImaginarySymbol beast:NyctomorphicSymbol ;
    beast:hasAbility beastiary:ability_strenght ;
    beast:hasBodyOf beastiary:creature_human ;
    beast:hasDiet beast:Omnivorous ;
    beast:hasEtymology beastiary:etymology_giant ;
    beast:hasHabitat beastiary:habitat_terrestrial ;
    beast:hasOriginContext beastiary:source_greek_mythology ;
    beast:isGovernedBy beast:DiurnalRegime .

