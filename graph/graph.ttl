beastiary:creature_minotaur a beast:Creature,
        beast:HybridCreature ;
    rdfs:label "Minotaur"@en ;
    rdfs:comment "The Minotaur is fundamentally a teriomorphic symbol: its bull head embodies violent force, instinct, and uncontrolled movement, while its consumption of Athenian youths exemplifies the schema of the devouring jaws. The Minotaur carries also a catamorphic dimension through its inhabiting of the labyrinth, an enclosed descending structure symbolizing the fall into darkness, confusion and the unconscious."@en ;
    beast:belongsToImaginaryStructure beast:SchizomorphicStructure ;
    beast:embodiesImaginarySymbol beast:CatamorphicSymbol,
        beast:TeriomorphicSymbol ;
    beast:hasAbility beastiary:ability_strenght ;
