beastiary:ability_immortality a beast:Ability ;
    rdfs:label "Immortality"@en ;
    rdfs:comment "Deathlessness expresses the ascensional refusal of mortality, the upward transcendence that escapes the degradation of time."@en,
        "The creature does not die of natural causes and may be immune to conventional means of harm."@en ;
    beast:belongsToImaginaryStructure beast:SchizomorphicStructure ;
    beast:embodiesImaginarySymbol beast:AscensionalSymbol ;
    beast:isGovernedBy beast:DiurnalRegime .

beastiary:ability_trumpet_voice rdfs:label "Trumpet Voice"@en ;
    rdfs:comment "The physical capacity to emit an exceptionally loud, resonant, and piercing vocalization resembling a brass instrument, used to signal danger, terrify enemies, or assert dominance over a vast territory."@en .

beastiary:archetype_abandoned_child a beast:Archetype ;
    rdfs:label "Abandoned Child"@en ;
    beast:hasMeaning "The exposed or forsaken infant, left to fate yet often marked for a special destiny."@en ;
    beast:relatedTo beastiary:archetype_shameful_offspring .

beastiary:archetype_cosmic a beast:Archetype ;
    rdfs:label "Cosmic"@en ;
    beast:hasMeaning "The universal principle or force operating on a cosmic scale, beyond the human."@en .

beastiary:archetype_divided_self a beast:Archetype ;
    rdfs:label "Divided Self"@en ;
    beast:hasMeaning "A figure torn between animal impulse and human consciousness, embodying the internal conflict between instinct and reason."@en .

beastiary:archetype_divine_punishment a beast:Archetype ;
    rdfs:label "Divine punishment"@en ;
    beast:hasMeaning "Retribution inflicted by the gods for transgression, the sacred sanction against hubris."@en .

beastiary:archetype_metamorphosis a beast:Archetype ;
    rdfs:label "Metamorphosis"@en ;
    beast:hasMeaning "The principle of transformation and change of form as such."@en .

beastiary:archetype_semi_divine a beast:Archetype ;
    rdfs:label "Semi-Divine"@en ;
    beast:hasMeaning "Represents immortal beings, of noble character and superior skills."@en .

beastiary:archetype_sublime a beast:Archetype ;
    rdfs:label "Sublime"@en ;
    beast:hasMeaning "The fusion of terror and beauty into an overwhelming aesthetic."@en .

beastiary:creature_acephalus a beast:RealAnimal ;
    rdfs:label "Acephalus"@en ;
    beast:hasAbsenceOf beastiary:part_head ;
    beast:hasEtymology beastiary:etymology_acephalus ;
    beast:hasOriginContext beastiary:source_monstres_prodiges ;
    beast:isOfSpecies beastiary:creature_human .

beastiary:creature_onager a beast:RealAnimal ;
