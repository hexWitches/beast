@prefix beast: <https://w3id.org/beast/ontology#> .
@prefix beastiary: <https://w3id.org/beast/graph/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix wd: <http://www.wikidata.org/entity/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

beastiary:ability_extinct rdfs:label "Extinct"@en ;
    rdfs:comment "The condition of having died out entirely, with no living members of the kind remaining; the creature is known only through past attestation rather than present existence."@en .

beastiary:ability_self_renewal a beast:Ability ;
    rdfs:label "Self-renewal"@en ;
    rdfs:comment "Self-renewal is the cyclical symbol itself: death reintegrated as a necessary phase of an incessant movement in which every ending is the prelude to rebirth."@en,
        "The capacity to regenerate, rejuvenate, or be reborn, often cyclically."@en ;
    beast:belongsToImaginaryStructure beast:SyntheticStructure ;
    beast:embodiesImaginarySymbol beast:CyclicalSymbol ;
    beast:isGovernedBy beast:NocturnalRegime .

beastiary:ability_strength rdfs:label "Strength"@en ;
    rdfs:comment "Exceptional physical power, allowing the creature to overpower prey or enemies through brute force."@en .

beastiary:archetype_chritsmas_elf a beast:Archetype ;
    beast:hasMeaning "Lives with Santa Claus at the North Pole and acts as his helper. Christmas elves are usually depicted as green- or red-clad, with large, pointy ears and wearing pointy hats."@en .

beastiary:archetype_strenght a beast:Archetype ;
    beast:hasMeaning "Heroic physical power and might."@en ;
    beast:relatedTo beastiary:archetype_protection .

beastiary:citation_rowling_8 a beast:Citation ;
    beast:extractedFrom beastiary:source_fantastic_beasts ;
    beast:isTextualReferenceOf beastiary:int_basilisk_rowling_fantastic .

beastiary:citation_tolkien_2 a beast:Citation ;
    beast:extractedFrom beastiary:source_lotr ;
    beast:isTextualReferenceOf beastiary:int_troll_tolkien .

beastiary:diet_autotrophic rdfs:label "Autotrophic"@en ;
    rdfs:comment "Self-nourishing through sunlight and nutrients drawn from the soil rather than by consuming other organisms; the mode proper to plant-creatures such as the mandrake."@en .

beastiary:diet_crabs_eater rdfs:label "Crabs eater"@en ;
    rdfs:comment "A diet consisting of crabs and similar shellfish; the creature feeds on crustaceans."@en .

beastiary:diet_elephant_blood rdfs:label "Elephant blood"@en ;
    rdfs:comment "A specialized carnivorous diet of elephant blood, sought by the dragon of Pliny's tradition to cool its own heat; the creature lies in wait to drain the elephant."@en ;
    beast:dietCategory beast:Carnivorous .

beastiary:diet_man_eater rdfs:label "Man eater"@en ;
    rdfs:comment "A carnivorous diet directed especially at human flesh; the creature preys on people by preference, beyond ordinary predation on animals."@en ;
    beast:dietCategory beast:Carnivorous .

beastiary:diet_none rdfs:label "Starvation"@en ;
    rdfs:comment "A creature physiologically incapable of sustaining itself, unable to digest any food due to its contradictory hybrid nature."@en .

beastiary:diet_wind rdfs:label "Wind"@en ;
    rdfs:comment "A creature sustaining itself entirely by consuming air or wind, rather than solid food or water."@en ;
    beast:dietCategory beast:Elemental .

beastiary:etymology_amelic a beast:Etymology ;
    beast:hasMeaning "The term amelic comes from the Greek prefix a- (without) and mélos (limb), combined with the suffix -ic."@en ;
    beast:hasRootTerm "a + mélos"@grc ;
    beast:isEtymologyOf beastiary:creature_amelic .

beastiary:genesis_anomaly_paré_1 a beast:Genesis ;
    beast:hasGenesisDescription "Paré includes the creature among his examples of monsters created by the imagination. According to his description"@en,
        "the hairy girl was born because her mother looked for too long at a painting."@en ;
    beast:isGenesisOf beastiary:int_anomaly_paré_1 .

beastiary:genesis_anomaly_paré_3 a beast:Genesis ;
    beast:hasGenesisDescription "Paré includes the creature among his examples of monsters created by the absence of seed."@en ;
    beast:isGenesisOf beastiary:int_anomaly_paré_3 .

beastiary:genesis_anomaly_paré_4 a beast:Genesis ;
    beast:hasGenesisDescription "Paré includes the creature among his examples of monsters createy by an excessive quantity of seed."@en ;
    beast:isGenesisOf beastiary:int_anomaly_paré_4 .

beastiary:genesis_basilisk_lucano a beast:Genesis ;
    beast:hasGenesisDescription "Sprung from the blood of Medusa's severed head as Perseus carried it in flight over Libya"@en,
        "one among the many venomous serpents born from those drops."@en ;
    beast:involvesParent beastiary:creature_medusa ;
    beast:isGenesisOf beastiary:int_basilisk_lucano .

beastiary:genesis_basilisk_theophilus a beast:Genesis ;
    beast:hasGenesisDescription "Hatched from a yolkless egg laid by an old cock"@en,
        "incubated by a toad in place of the natural mother."@en ;
    beast:isGenesisOf beastiary:int_basilisk_theophilus .

beastiary:genesis_centaur_ovid a beast:Genesis ;
    beast:hasGenesisDescription "Descended from the union of Ixion with Nephele"@en,
        "a cloud shaped by Zeus in the likeness of Hera to deceive Ixion."@en ;
    beast:involvesParent beastiary:myth_ixion,
        beastiary:myth_nephele ;
    beast:isGenesisOf beastiary:int_centaur_ovid .

beastiary:genesis_chimera_esiodo a beast:Genesis ;
    beast:hasGenesisDescription "Offspring of Echidna and Typhon"@en,
        "one of the monstrous brood born to the two primordial serpent-giants."@en ;
    beast:hasSibling beastiary:creature_sphinx ;
    beast:involvesParent beastiary:myth_echidna,
        beastiary:myth_typhon ;
    beast:isGenesisOf beastiary:int_chimera_esiodo .

beastiary:genesis_chimera_fullmetal a beast:Genesis ;
    beast:hasGenesisDescription "Produced through human transmutation"@en,
        "a forbidden alchemical act combining two base organisms into a new composite creature."@en ;
    beast:hasSibling beastiary:creature_sphinx ;
    beast:isGenesisOf beastiary:int_chimera_fullmetal_alchemist .

beastiary:genesis_giant_teogonia a beast:Genesis ;
    beast:hasGenesisDescription "Sprang from Gaia (Earth) after she was fertilised by the blood of Uranus's castration."@en ;
    beast:involvesParent beastiary:myth_gaia,
        beastiary:myth_uranus ;
    beast:isGenesisOf beastiary:int_giant_teogonia .

beastiary:genesis_hermaphrodite_ovidius a beast:Genesis ;
    beast:hasGenesisDescription "Child of Hermes and Aphrodite"@en,
        "originally a male youth of great beauty. Fused into a single dual-sexed body with the nymph Salmacis after she embraced him in her pool and prayed never to be parted from him."@en ;
    beast:involvesParent beastiary:myth_aphrodite,
        beastiary:myth_hermes ;
    beast:isGenesisOf beastiary:int_hermaphrodite_ovidius .

beastiary:genesis_medusa_esiodo a beast:Genesis ;
    beast:hasGenesisDescription "Daughter of the ancient sea deities Phorcys and Ceto"@en,
        "one of the three Gorgon sisters."@en ;
    beast:involvesParent beastiary:myth_ceto,
        beastiary:myth_phorcys ;
    beast:isGenesisOf beastiary:int_medusa_esiodo .

beastiary:genesis_medusa_ovid a beast:Genesis ;
    beast:hasGenesisDescription "Originally a beautiful mortal maiden"@en,
        "transformed into a monstrous Gorgon as punishment by Athena after being violated by Poseidon within Athena's temple."@en ;
    beast:isGenesisOf beastiary:int_medusa_ovid .

beastiary:genesis_minotaur_ovidius a beast:Genesis ;
    beast:hasGenesisDescription "Born of Queen Pasiphae's union with the Cretan Bull"@en,
        "an offspring bearing the head of a bull upon a man's body."@en ;
    beast:involvesParent beastiary:creature_bull,
        beastiary:myth_pasiphae ;
    beast:isGenesisOf beastiary:int_minotaur_ovidius .

beastiary:genesis_mostro_paré_1 a beast:Genesis ;
    beast:hasGenesisDescription "Paré includes the creature among his examples of monsters created by God's rage. He recounts the story of Pope Julius II"@en,
        "arguing that the Pope provoked divine anger by waging war against Louis XII."@en ;
    beast:isGenesisOf beastiary:int_mostro_paré_1 .

beastiary:genesis_mostro_paré_3 a beast:Genesis ;
    beast:hasGenesisDescription "Paré includes the creature among his examples of monsters created by 'commistion des semences'"@en,
        "the mixing of seed. This creatures is generated by a human and a dog."@en ;
    beast:isGenesisOf beastiary:int_mostro_paré_3 .

beastiary:genesis_pegaso_esiodo a beast:Genesis ;
    beast:hasGenesisDescription "Sprang"@en,
        "from the neck of Medusa at the moment of her beheading by Perseus."@en,
        "together with his brother Chrysaor"@en ;
    beast:involvesParent beastiary:creature_medusa ;
    beast:isGenesisOf beastiary:int_pegaso_esiodo .

beastiary:genesis_phoenix_claudio a beast:Genesis ;
    beast:hasGenesisDescription "The Phoenix is not born of parents but self-immolates upon a pyre of aromatic wood at the end of its life cycle to be reborn from its own ashes."@en ;
    beast:involvesParent beastiary:creature_phoenix ;
    beast:isGenesisOf beastiary:int_phoenix_claudio .

beastiary:genesis_siren_ovidius a beast:Genesis ;
    beast:hasGenesisDescription "Daughters of the river god Achelous and originally companions of Persephone. They were transformed into part-bird creatures at their own request"@en,
        "so that they might search the world by both land and sea for the abducted Persephone."@en ;
    beast:involvesParent beastiary:myth_achelous ;
    beast:isGenesisOf beastiary:int_siren_ovidius .

beastiary:genesis_sphinx_apollodoro a beast:Genesis ;
    beast:hasGenesisDescription "Daughter of Echidna and Typhon"@en,
        "sent to Thebes as an instrument of divine punishment."@en ;
    beast:hasSibling beastiary:creature_chimera ;
    beast:involvesParent beastiary:myth_echidna,
        beastiary:myth_typhon ;
    beast:isGenesisOf beastiary:int_sphinx_apollodoro .

beastiary:habitat_arabia a beast:RealWorldPlace ;
    rdfs:label "Arabia"@en ;
    rdfs:comment "The arid lands of the Arabian peninsula, a remote eastern region of deserts and aromatic groves traditionally held to be the dwelling of the phoenix, which there builds its spice-laden nest of frankincense and myrrh."@en ;
    beast:habitatCategory beast:habitat_terrestrial .

beastiary:habitat_cave a beast:RealWorldPlace ;
    rdfs:label "Cave"@en ;
    rdfs:comment "A natural rocky hollow or cavern."@en ;
    beast:habitatCategory beast:habitat_terrestrial .

beastiary:habitat_chamber_of_secrets a beast:ImaginaryPlace ;
    rdfs:label "Chamber of Secrets"@en ;
    rdfs:comment "A vast underground chamber hidden beneath Hogwarts School of Witchcraft and Wizardry, built by Salazar Slytherin in the 10th century to conceal his basilisk."@en ;
    beast:hasOriginContext beastiary:source_harry_potter_book_2 .

beastiary:habitat_cloud_kingdom a beast:ImaginaryPlace ;
    rdfs:label "Cloud Kingdom"@en ;
    rdfs:comment "The Cloud Kingdom is the mystical kingdom floating high above the earth among the clouds location where the movie takes place."@en ;
    beast:habitatCategory beast:habitat_aerial ;
    beast:hasOriginContext beastiary:source_barbie .

beastiary:habitat_desert a beast:RealWorldPlace ;
    rdfs:label "Desert"@en ;
    rdfs:comment "An arid expanse of sand and barren ground."@en ;
    beast:habitatCategory beast:habitat_terrestrial .

beastiary:habitat_duloc_swamp a beast:ImaginaryPlace ;
    rdfs:label "Swamp"@en ;
    rdfs:comment "The magical swamp is surrounded by dense trees and mossy water, home of Shrek."@en ;
    beast:habitatCategory beast:habitat_terrestrial ;
    beast:hasOriginContext beastiary:source_shrek .

beastiary:habitat_edge_of_world a beast:ImaginaryPlace ;
    rdfs:label "Edge of the World"@en ;
    rdfs:comment "The far western limit of the cosmos in Hesiod's Theogony, beyond glorious Ocean toward Night and near the Hesperides, where the Gorgons dwell at the boundary of the known world."@en ;
    beast:hasOriginContext beastiary:source_teogonia .

beastiary:habitat_fantastica a beast:ImaginaryPlace ;
    rdfs:label "Fantastica"@en ;
    rdfs:comment "Fantastica is the limitless realm of imagination in 'The Neverending Story', ruled by the Childlike Empress, home to all imagined creatures, and sustained by human dreams - threatened by the Nothing when people cease to believe."@en ;
    beast:hasOriginContext beastiary:source_unendliche_geschichte .

beastiary:habitat_great_riddle_gate a beast:ImaginaryPlace ;
    rdfs:label "Great Riddle Gate"@en ;
    rdfs:comment "The Great Riddle Gate is the first of three gates leading to the Southern Oracle in Fantastica, formed by two facing sphinxes whose gaze freezes the unworthy in place, condemning them to solve all the world's riddles or perish."@en ;
    beast:hasOriginContext beastiary:source_unendliche_geschichte .

beastiary:habitat_heaven_of_jupyter a beast:ImaginaryPlace ;
    rdfs:label "Heaven of Jupiter"@en ;
    rdfs:comment "The sixth celestial sphere of Dante's Paradise, the heaven of just rulers, where the souls of the righteous compose the figure of the Eagle of divine justice."@en ;
    beast:hasOriginContext beastiary:source_dante_paradiso .

beastiary:habitat_hell a beast:ImaginaryPlace ;
    rdfs:label "Hell"@en ;
    rdfs:comment "The infernal underworld of Dante's Inferno, realm of the damned."@en ;
    beast:hasOriginContext beastiary:source_dante_inferno .

beastiary:habitat_lonely_mountain a beast:ImaginaryPlace ;
    rdfs:label "Lonely Mountain (Erebor)"@en ;
    rdfs:comment "The solitary mountain of Erebor in Tolkien's legendarium, whose excavated halls house the dwarves' kingdom and, after its seizure, the dragon Smaug and his hoard."@en ;
    beast:hasOriginContext beastiary:source_the_hobbit .

beastiary:habitat_middle_earth a beast:ImaginaryPlace ;
    rdfs:label "Middle Earth"@en ;
    rdfs:comment "Middle-earth is fictional continent in J.R.R. Tolkien’s fantasy world, as our actual Earth in a mythical, pre-historic past."@en ;
    beast:habitatCategory beast:habitat_terrestrial ;
    beast:hasOriginContext beastiary:source_lotr .

beastiary:habitat_mount_phicium a beast:RealWorldPlace ;
    rdfs:label "Mount Phicium (Thebes)"@en ;
    rdfs:comment "The mountain near Thebes."@en ;
    beast:habitatCategory beast:habitat_terrestrial .

beastiary:habitat_neverland a beast:ImaginaryPlace ;
    rdfs:label "Neverland"@en ;
    rdfs:comment "Neverland is a fictional, magical island where children never grow up, inhabited by fairies (like Tinker Bell), mermaids, the Lost Boys (Peter Pan), pirates, and Native Americans."@en ;
    beast:habitatCategory beast:habitat_terrestrial ;
    beast:hasOriginContext beastiary:source_peter_pan .

beastiary:habitat_north_pole a beast:RealWorldPlace ;
    rdfs:label "North Pole"@en ;
    rdfs:comment "The North Pole, is the the northernmost point on Earth, located at the exact intersection of the planet's axis and its surface, known by its very cold temperatures all year round."@en ;
    beast:habitatCategory beast:habitat_terrestrial ;
    beast:hasOriginContext beastiary:source_st_Nicholas .

beastiary:habitat_ocean a beast:RealWorldPlace ;
    rdfs:label "Ocean"@en ;
    rdfs:comment "The vast salt sea."@en ;
    beast:habitatCategory beast:habitat_acquatic .

beastiary:habitat_olympus a beast:ImaginaryPlace ;
    rdfs:label "Olympus"@en ;
    rdfs:comment "Mount Olympus in greek mythology is the place were the gods live."@en ;
    beast:habitatCategory beast:habitat_aerial ;
    beast:hasOriginContext beastiary:source_teogonia .

beastiary:habitat_riphean_mountains a beast:ImaginaryPlace ;
    rdfs:label "Riphean Mountains"@en ;
    rdfs:comment "The Riphean Mountains, a remote and semi-legendary range placed at the far north of the world, beyond the frozen seas; in Ariosto's Orlando Furioso the rare native haunt from which the hippogriff comes."@en ;
    beast:hasOriginContext beastiary:source_orlando_furioso .

beastiary:habitat_river a beast:RealWorldPlace ;
    rdfs:label "River"@en ;
    rdfs:comment "A flowing freshwater watercourse."@en ;
    beast:habitatCategory beast:habitat_acquatic .

beastiary:habitat_subterranean a beast:RealWorldPlace ;
    rdfs:label "Subterranean"@en ;
    rdfs:comment "The underground realm of caves, tunnels, and buried depths, beneath the surface of the earth."@en ;
    beast:habitatCategory beast:habitat_terrestrial .

beastiary:int_unicorn_isidor a beast:Interpretation ;
    rdfs:comment "Isidore writes that the unicorn is so strong no hunter can catch it, however when the virgin girl approaches, the beast forgets its ferocity, lays its head in her lap, and falls asleep and it can be captured following a intimacy scene."@en ;
    beast:belongsToImaginaryStructure beast:MysticalStructure ;
    beast:embodiesImaginarySymbol beast:IntimacySymbol ;
    beast:isGovernedBy beast:NocturnalRegime .

beastiary:person_brueghel_jeune a schema:Person ;
    rdfs:comment "1564 – 1638"@en ;
    foaf:familyName "Brueghel"^^xsd:string ;
    foaf:givenName "Pieter"^^xsd:string ;
    schema:birthDate "1564"^^xsd:gYear ;
    schema:deathDate "1638"^^xsd:gYear ;
    schema:nationality "Dutch"^^xsd:string ;
    schema:sameAs <http://viaf.org/viaf/http://viaf.org/viaf/106974142>,
        wd:Q255828 .

beastiary:person_isayama a schema:Person ;
    rdfs:comment "1986 – present"@en ;
    foaf:familyName "Isayama"^^xsd:string ;
    foaf:givenName "Hajime"^^xsd:string ;
    schema:birthDate "1986"^^xsd:gYear ;
    schema:nationality "Japanese"^^xsd:string ;
    schema:sameAs <http://viaf.org/viaf/http://viaf.org/viaf/171550535>,
        wd:Q3782468 .

beastiary:person_ovredal a schema:Person ;
    rdfs:comment "1973 - present"@en ;
    foaf:familyName "Øvredal"^^xsd:string ;
    foaf:givenName "André"^^xsd:string ;
    schema:birthDate "1973"^^xsd:gYear ;
    schema:nationality "Norwegian"^^xsd:string ;
    schema:sameAs <http://viaf.org/viaf/http://viaf.org/viaf/288292099>,
        wd:Q2848912 .

beastiary:ability_archery rdfs:label "Archery"@en ;
    rdfs:comment "Exceptional skill with a bow and arrow."@en .

beastiary:ability_blindness a beast:Ability ;
    rdfs:label "Blindness"@en ;
    rdfs:comment "The condition of impaired or absent sight, whether innate, induced, or afflicting the creature; the inability to see, sometimes overcome by remedies or compensated by other senses."@en,
        "The loss of vision, blindness, and the physical mutilation of the eyes are terrifying nyctomorphic symbols, representing the ultimate triumph of the void."@en ;
    beast:belongsToImaginaryStructure beast:SchizomorphicStructure ;
    beast:embodiesImaginarySymbol beast:NyctomorphicSymbol ;
    beast:isGovernedBy beast:DiurnalRegime .

beastiary:ability_compassion rdfs:label "Compassion"@en ;
    rdfs:comment "The capacity for mercy and restraint toward the vulnerable; the creature spares those it has overcome, releases captives, and refrains from harming the weak."@en .

beastiary:ability_courage a beast:Ability ;
    rdfs:label "Courage"@en ;
    rdfs:comment "A behavioral disposition toward fearlessness and boldness in the face of danger, often attributed symbolically rather than as a physical trait."@en,
        "Courage belongs to the ascensional register of virile, heroic archetypes (the warrior, celestial royalty); it is the upward, transcendent virtue that confronts and rises above fear and the threat of time."@en ;
    beast:belongsToImaginaryStructure beast:SchizomorphicStructure ;
    beast:embodiesImaginarySymbol beast:AscensionalSymbol ;
    beast:isGovernedBy beast:DiurnalRegime .

beastiary:ability_dance a beast:Ability ;
    rdfs:label "Dance"@en ;
    rdfs:comment "Rhythmic movement attributed to the creature, often in mythological or allegorical contexts."@en,
        "Rhythmic, repetitive movement embodies the cyclical 'rhythmic constants that govern natural phenomena,' the patterned return that reconciles the imagination with passing time."@en ;
    beast:belongsToImaginaryStructure beast:SyntheticStructure ;
    beast:embodiesImaginarySymbol beast:CyclicalSymbol ;
    beast:isGovernedBy beast:NocturnalRegime .

beastiary:ability_deadly_scream a beast:Ability ;
    rdfs:label "Deadly scream"@en ;
    rdfs:comment "A vocalization so powerful it causes death or severe harm to those who hear it."@en,
        "The lethal cry is formless sonic terror erupting from the unknown, enacting the nyctomorphic voracity of night that dissolves the listener into the abyss."@en ;
    beast:belongsToImaginaryStructure beast:SchizomorphicStructure ;
    beast:embodiesImaginarySymbol beast:NyctomorphicSymbol ;
    beast:isGovernedBy beast:DiurnalRegime .

beastiary:ability_healing_tears a beast:Ability ;
    rdfs:comment "Healing turns wound into refuge and harm into shelter, aligning the intimacy symbol's movement from the fear of being swallowed to the comfort of being contained."@en ;
    beast:belongsToImaginaryStructure beast:MysticalStructure ;
    beast:embodiesImaginarySymbol beast:IntimacySymbol ;
    beast:isGovernedBy beast:NocturnalRegime .

beastiary:ability_hypnotic_gaze a beast:Ability ;
    rdfs:comment "The entrancing gaze draws its victim down into shadow, sleep, and loss of self, enacting the nyctomorphic engulfment by darkness."@en ;
    beast:belongsToImaginaryStructure beast:SchizomorphicStructure ;
    beast:embodiesImaginarySymbol beast:NyctomorphicSymbol ;
    beast:isGovernedBy beast:DiurnalRegime .

beastiary:ability_killing_gaze a beast:Ability ;
    rdfs:label "Killing gaze"@en ;
    rdfs:comment "A lethal power transmitted invisibly through the eyes, without weapon or bite, belongs to the nyctomorphic register: death arrives as formless, unseeable agency, the abyss looking back rather than a jaw striking."@en,
        "The ability to cause instant death through direct eye contact, distinct from petrification."@en ;
    beast:belongsToImaginaryStructure beast:SchizomorphicStructure ;
    beast:embodiesImaginarySymbol beast:NyctomorphicSymbol ;
    beast:isGovernedBy beast:DiurnalRegime .

beastiary:ability_lethal_breath rdfs:label "Lethal breath"@en ;
    rdfs:comment "Exhalation capable of killing living beings, scorching vegetation, and breaking stones."@en .

beastiary:ability_lethal_hiss rdfs:label "Lethal hiss"@en ;
    rdfs:comment "A hissing sound capable of causing death or severe harm."@en .

beastiary:ability_lethal_odor rdfs:label "Lethal odor"@en ;
    rdfs:comment "A smell so toxic it kills serpents and other creatures in proximity."@en .

beastiary:ability_play_the_flute rdfs:label "Play the flute"@en ;
    rdfs:comment "The ability to play a musical instrument, attributed symbolically or as a marker of the creature's connection to music and nature."@en .

beastiary:ability_purify_water rdfs:label "Water purification"@en ;
    rdfs:comment "The ability to cleanse or sanctify bodies of water through presence or touch."@en .

beastiary:ability_resolution rdfs:label "Resolution"@en ;
    rdfs:comment "Firmness of will and steadfast determination; the creature's resolute, unyielding disposition, located by the bestiaries in the head as the seat of its resolve."@en .

beastiary:ability_self_destructive a beast:Ability ;
    rdfs:label "Self-destruction"@en ;
    rdfs:comment "A creature undone by its own internally contradictory nature enacts the catamorphic fall turned inward: degradation and death as the direct consequence of the body's own impossible composition."@en,
        "The creature is driven to destroy itself due to its internally contradictory nature, whether physiological, psychological, or ontological."@en ;
    beast:belongsToImaginaryStructure beast:SchizomorphicStructure ;
    beast:embodiesImaginarySymbol beast:CatamorphicSymbol ;
    beast:isGovernedBy beast:DiurnalRegime .

beastiary:ability_shapeshifting a beast:Ability ;
    rdfs:comment "Shapeshifting enacts the inversive logic of transformation and doubling, by which a single being turns into its other."@en ;
    beast:belongsToImaginaryStructure beast:MysticalStructure ;
    beast:embodiesImaginarySymbol beast:InversionSymbol ;
    beast:isGovernedBy beast:NocturnalRegime .

beastiary:ability_skin_shedding a beast:Ability ;
    rdfs:label "Skin Shedding"@en ;
    rdfs:comment "Periodically shedding skin symbolizes cyclical regeneration, renewal through repetition, and the eternal return, transforming apparent decay into the promise of rebirth."@en,
        "The periodic sloughing of the outer skin to renew the body, by which the creature casts off its old self and regains its youth, as the snake squeezes through a narrow crack to shed its skin."@en ;
    beast:belongsToImaginaryStructure beast:SyntheticStructure ;
    beast:embodiesImaginarySymbol beast:CyclicalSymbol ;
    beast:isGovernedBy beast:NocturnalRegime .

beastiary:ability_speak_black_speech rdfs:label "Speak Black Speech"@en ;
    rdfs:comment "The capacity to speak the dark tongue of evil or infernal beings; articulate speech in a malign or forbidden language."@en .

beastiary:ability_sunlight_petrification rdfs:label "Sunlight Petrification"@en ;
    rdfs:comment "The power, or vulnerability, by which exposure to sunlight turns a creature to stone; petrifaction induced by daylight."@en .

beastiary:ability_swim rdfs:label "Swimming"@en ;
    rdfs:comment "The ability to move efficiently through water."@en .

beastiary:ability_swim_in_air rdfs:label "Swim in the air"@en ;
    rdfs:comment "The capacity to move through the air as though swimming through water, flying in constant, fluid motion without the aid of wings."@en .

beastiary:ability_wine_drinking rdfs:label "Wine Drinking"@en ;
    rdfs:comment "An exceptional or culturally distinctive relationship with wine consumption, often associated with loss of rational control, festivity, or ritual behavior."@en .

beastiary:archetype_androgynous a beast:Archetype ;
    beast:hasMeaning "The androgynous is a symbol of unity and completeness, representing the integration and armonization of the polarities of the human being."@en .

beastiary:archetype_anti_fairy_tale a beast:Archetype ;
    beast:hasMeaning "Here the character subverts the traditional figure of the evil and goes over a personal and interior journey where it becomes the story hero."@en .

beastiary:archetype_belief a beast:Archetype ;
    beast:hasMeaning "The embodiment of belief without belief, her magic fades, that things exist only so long as we believe in them."@en .

beastiary:archetype_constancy a beast:Archetype ;
    beast:hasMeaning "Steadfast faithfulness and devotion, unwavering even unto death."@en .

beastiary:archetype_darkness a beast:Archetype ;
    beast:hasMeaning "They are often linked to shadows, darkness, and the chthonic aspects of the world, such as death, magic, and the hidden forces of nature."@en .

beastiary:archetype_exotic_marvel a beast:Archetype ;
    beast:hasMeaning "Represents the classic archetype of geographic alterità, other countries seen as spaces full of weird creatures to document and organize."@en .

beastiary:archetype_fertility a beast:Archetype ;
    beast:hasMeaning "The generative principle of abundance, reproduction, and the renewal of life."@en .

beastiary:archetype_godmother a beast:Archetype ;
    beast:hasMeaning "The benevolent supernatural protector who guides and aids the protagonist."@en .

beastiary:archetype_guardian_threshold a beast:Archetype ;
    beast:hasMeaning "A powerful figure stationed at the boundary between worlds or states of being, controlling access to forbidden or sacred spaces."@en ;
    beast:relatedTo beastiary:archetype_guardian_hell .

beastiary:archetype_hypocrisy a beast:Archetype ;
    beast:hasMeaning "The figure whose outward appearance or speech professes virtue while concealing or enacting baseness and vice, embodying the moral duplicity of one who says truth but does villainy."@en ;
    beast:relatedTo beastiary:archetype_divided_self .

beastiary:archetype_justice a beast:Archetype ;
    beast:hasMeaning "The principle of right order and equitable judgment."@en .

beastiary:archetype_love a beast:Archetype ;
    beast:hasMeaning "The embodiment of devoted, transcendent love."@en .

beastiary:archetype_natural_marvel a beast:Archetype ;
    beast:hasMeaning "The wonder of the natural world rationalized as a marvel rather than a monster."@en .

beastiary:archetype_parasite a beast:Archetype ;
    beast:hasMeaning "An organism whose life depends on the exploitation of another being, causing damage to it."@en .

beastiary:archetype_poetic_inspiration a beast:Archetype ;
    beast:hasMeaning "Represents the poetic inspiration that the muses give to have the spontaneous artistic and intellectual brilliance."@en .

beastiary:archetype_power a beast:Archetype ;
    beast:hasMeaning "Worldly sovereignty and dynastic might, the power of rule and dominion."@en .

beastiary:archetype_pride a beast:Archetype ;
    beast:hasMeaning "Overweening self-exaltation, the vice of superbia. archetype_prima_materia The alchemical first matter, the base substance of transformation."@en .

beastiary:archetype_prima_materia a beast:Archetype ;
    beast:hasMeaning "The role of shielding and safeguarding from harm."@en ;
    beast:relatedTo beastiary:archetype_cosmic .

beastiary:archetype_resilience a beast:Archetype ;
    beast:hasMeaning "The figure of endurance that withstands and recovers from oppression or adversity."@en ;
    beast:relatedTo beastiary:archetype_defiance .

beastiary:archetype_scientific_transgression a beast:Archetype ;
    beast:hasMeaning "The creature born of forbidden knowledge and technical hubris, produced by the violation of natural boundaries through human artifice rather than divine or monstrous agency."@en ;
    beast:relatedTo beastiary:archetype_shameful_offspring .

beastiary:archetype_spirit a beast:Archetype ;
    beast:hasMeaning "The numinous animating presence, a being of pure spirit or nature."@en .

beastiary:archetype_uncanny a beast:Archetype ;
    beast:hasMeaning "The unsettling familiarity-in-strangeness that provokes dread."@en ;
    beast:relatedTo beastiary:archetype_sublime .

beastiary:archetype_vice a beast:Archetype ;
    beast:hasMeaning "The embodiment of a moral failing or sinful disposition - a creature that personifies a specific human vice such as pride, lust, or wrath, serving as an allegorical warning against that failing."@en .

