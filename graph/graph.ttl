beastiary:archetype_emasculation a beast:Archetype ;
    rdfs:label "Emasculation"@en ;
    beast:hasMeaning "Privation of the vital force, sovereignty, or active identity. It represents the transition from a place of autonomy and force to a state of submission, fragmentation, or sterile softness."@en .

