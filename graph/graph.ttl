    beast:hasTailOf beastiary:creature_onager ;
    beast:hasUpperBodyOf beastiary:creature_human .

beastiary:diet_man_eater rdfs:label "Man eater"@en ;
    rdfs:comment "A carnivorous diet directed especially at human flesh; the creature preys on people by preference, beyond ordinary predation on animals."@en ;
    beast:dietCategory beast:Carnivorous .

beastiary:function_agent a beast:NarrativeFunction ;
    rdfs:label "Agent"@en ;
    beast:hasMeaning "The creature acts as the instrument of another's will, carrying out a god's or character's purpose."@en ;
    beast:relatedTo beastiary:function_weapon .

beastiary:function_protector a beast:NarrativeFunction ;
    rdfs:label "Protector"@en ;
    beast:hasMeaning "The creature shields and safeguards a person or place from harm, actively defending its charge against threats"@en .

